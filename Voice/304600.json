{
    "id": 304600,
    "collectionNo": 300,
    "name": "弗栗多",
    "voices": {
        "0_B010": {
            "name": "攻击 1",
            "text": {
                "0_B010": "唔？　痛吗？"
            }
        },
        "0_B020": {
            "name": "攻击 2",
            "text": {
                "0_B020": "看招看招！"
            }
        },
        "0_B030": {
            "name": "攻击 3",
            "text": {
                "0_B030": "啃噬吧。"
            }
        },
        "0_B040": {
            "name": "额外攻击 1",
            "text": {
                "0_B040": "——封闭吧。"
            }
        },
        "0_B050": {
            "name": "宝具 1",
            "text": {
                "0_B050": "吾乃弗栗多，覆盖此世天地的存在。",
                "0_B051": "集结吧，阿修罗啊，吾血肉化作的魔之大军啊！",
                "0_B052": "此乃分隔之理。彻底遮蔽万象！",
                "0_B053": "魔啊，阻塞尽天地！"
            }
        },
        "0_B080": {
            "name": "技能 1",
            "text": {
                "0_B080": "看我阻塞了你。"
            }
        },
        "0_B090": {
            "name": "スキル 2",
            "text": {
                "0_B090": ""
            },
            "raw_text": {
                "0_B090": ""
            }
        },
        "0_B100": {
            "name": "开始 1",
            "text": {
                "0_B100": "看上去挺好吃的嘛。"
            }
        },
        "0_B110": {
            "name": "开始 2",
            "text": {
                "0_B110": "来，让我尝尝，让我尝尝……"
            }
        },
        "0_B120": {
            "name": "胜利 1",
            "text": {
                "0_B120": "唉……无聊。"
            }
        },
        "0_B130": {
            "name": "胜利 2",
            "text": {
                "0_B130": "是不是吃的太快了？"
            }
        },
        "0_B140": {
            "name": "ダメージ 2",
            "text": {
                "0_B140": ""
            },
            "raw_text": {
                "0_B140": ""
            }
        },
        "0_B150": {
            "name": "受击 1",
            "text": {
                "0_B150": "这样就对了……！"
            }
        },
        "0_B160": {
            "name": "无法战斗 1",
            "text": {
                "0_B160": "不要，我的乐趣，还没……"
            }
        },
        "0_B170": {
            "name": "无法战斗 2",
            "text": {
                "0_B170": "这倒是稍微有些麻烦呢……"
            }
        },
        "0_B180": {
            "name": "指令卡 1",
            "text": {
                "0_B180": "我可不会动真格。"
            }
        },
        "0_B190": {
            "name": "指令卡 2",
            "text": {
                "0_B190": "哦？"
            }
        },
        "0_B200": {
            "name": "指令卡 3",
            "text": {
                "0_B200": "真没办法。"
            }
        },
        "0_B210": {
            "name": "宝具卡 1",
            "text": {
                "0_B210": "真的可以吗？"
            }
        },
        "0_B220": {
            "name": "宝具卡 2",
            "text": {
                "0_B220": "这就是我这个魔。"
            }
        },
        "0_B410": {
            "name": "攻击 4",
            "text": {
                "0_B410": "要不要吐点什么出来呢。"
            }
        },
        "0_B420": {
            "name": "攻击 5",
            "text": {
                "0_B420": "惨叫还不够。"
            }
        },
        "0_B430": {
            "name": "攻击 6",
            "text": {
                "0_B430": "试着拷问吧。"
            }
        },
        "0_B440": {
            "name": "额外攻击 2",
            "text": {
                "0_B440": "呵呵，是我的东西。"
            }
        },
        "0_B480": {
            "name": "技能 3",
            "text": {
                "0_B480": "呵欠……唔喵唔喵。"
            }
        },
        "0_B490": {
            "name": "技能 4",
            "text": {
                "0_B490": "希望我嗷呜地吼一声吗？"
            }
        },
        "0_B500": {
            "name": "开始 3",
            "text": {
                "0_B500": "没什么食欲呢。"
            }
        },
        "0_B800": {
            "name": "宝具 2",
            "text": {
                "0_B800": "天啊，为变幻之鳞封闭的天啊。",
                "0_B801": "地啊，为暴食之颚吞噬的地啊。",
                "0_B802": "连哀叹都能阻塞的是巨大之蛇。",
                "0_B803": "魔啊，阻塞尽天地！"
            }
        },
        "0_B810": {
            "name": "宝具 3",
            "text": {
                "0_B810": "算了，随便陪你玩玩吧。",
                "0_B811": "唔～，这样就够了吗？　已经够了吗？",
                "0_B812": "……怎么，这么就完了呀。",
                "0_B813": "无聊无聊无聊～。"
            }
        },
        "0_B840": {
            "name": "额外攻击 3",
            "text": {
                "0_B840": "阻碍，终结。"
            }
        },
        "0_G010": {
            "name": "升级 1",
            "text": {
                "0_G010": "你是否搞错了该给吾吃的东西？"
            }
        },
        "0_G020": {
            "name": "灵基再临 2",
            "text": {
                "0_G020": "在意长相的只有人类吧。",
                "0_G021": "无论是神还是魔，肉眼可见的形象不过是暂时的。",
                "0_G022": "别悲喜无常的。"
            }
        },
        "0_G030": {
            "name": "灵基再临 1",
            "text": {
                "0_G030": "唔，这就是灵基再临……有种蜕皮的心情呢。",
                "0_G031": "总之，感觉不赖。"
            }
        },
        "0_G040": {
            "name": "灵基再临 3",
            "text": {
                "0_G040": "真拿你没办法。反正肚子也吃饱了，稍微变个更适合战斗的形态吧。",
                "0_G041": "……特别待遇哦？"
            }
        },
        "0_G050": {
            "name": "灵基再临 4",
            "text": {
                "0_G050": "哎呀呀，竟然把被称为邪龙的吾培养到这种程度……",
                "0_G051": "你想要自我毁灭吗，御主？",
                "0_G052": "……不，吾明白。你只是相信着而已吧。",
                "0_G053": "虽然不清楚你相信什么，相信谁……",
                "0_G054": "可以确定的，只有当这份信任落空之时，人会被魔吞噬殆尽吧。",
                "0_G055": "为了不后悔，你就好好垂死挣扎吧。咿嘻嘻！"
            }
        },
        "0_G110": {
            "name": "升级 2",
            "text": {
                "0_G110": "啊唔啊唔……不过，要让吾吃的话，吾还是吃得下去的……"
            }
        },
        "0_H010": {
            "name": "生日",
            "text": {
                "0_H010": "生日啊……想必是很快就会死去的生物才会有的风俗习惯吧。",
                "0_H011": "对于死后还会复活的吾这样的魔来说，真不知有什么好高兴的。"
            }
        },
        "0_H020": {
            "name": "活动举行中",
            "text": {
                "0_H020": "这吵吵闹闹的，就是所谓的祭典吗？",
                "0_H021": "唔，吾也想做一些有趣的事了。"
            }
        },
        "0_H030": {
            "name": "对话 1",
            "text": {
                "0_H030": "你窝在这种洞里干嘛？",
                "0_H031": "快带吾去有趣的地方。"
            }
        },
        "0_H040": {
            "name": "对话 2",
            "text": {
                "0_H040": "如果群体的头领死去，通常会有替代者成为头领吧。",
                "0_H041": "但如果不是这样，而是你的死意味着全部的终结……",
                "0_H042": "唔，不得不说这里的群体相当扭曲呢。"
            }
        },
        "0_H050": {
            "name": "对话 3",
            "text": {
                "0_H050": "吾并没有发誓对你效忠。",
                "0_H051": "只是想愉快地观察你的将来而已。",
                "0_H052": "可别误会了哦？"
            }
        },
        "0_H060": {
            "name": "喜欢的东西",
            "text": {
                "0_H060": "其实呀，吾很喜欢歌唱跳舞那类……人类愉快的表演。",
                "0_H061": "这里也有擅长这种事的人吧？",
                "0_H062": "很好，把他们带来。"
            }
        },
        "0_H070": {
            "name": "讨厌的东西 1",
            "text": {
                "0_H070": "讨厌的东西",
                "0_H071": "唔……吾不喝酒。",
                "0_H072": "一喝那个就容易犯困。"
            }
        },
        "0_H080": {
            "name": "关于圣杯",
            "text": {
                "0_H080": "圣杯啊。反正只要能填饱肚子的东西，吾都喜欢哦？"
            }
        },
        "0_H090": {
            "name": "牵绊Lv.1",
            "text": {
                "0_H090": "吾在这里的问题可以暂时不论。",
                "0_H091": "但是，为什么吾非要为你工作不可啊？"
            }
        },
        "0_H100": {
            "name": "牵绊Lv.2",
            "text": {
                "0_H100": "是蛇还是龙，就算问吾这种问题吾也不知道。",
                "0_H101": "那些都只是人类擅自使用的词语。"
            }
        },
        "0_H110": {
            "name": "牵绊Lv.3",
            "text": {
                "0_H110": "你或许已经发现了，这是因陀罗的伐折罗。",
                "0_H111": "你知道那家伙是怎么把这玩意儿打进我嘴里的吗？"
            }
        },
        "0_H120": {
            "name": "牵绊Lv.4",
            "text": {
                "0_H120": "唔。我开始觉得……",
                "0_H121": "要不是让吾无谓地工作，在一旁观察你们的生活或许也不赖呢。"
            }
        },
        "0_H130": {
            "name": "牵绊Lv.5",
            "text": {
                "0_H130": "咿嘻嘻。",
                "0_H131": "不惜使役吾这种存在的你那种执着……吾非常中意哦。",
                "0_H132": "就让吾在特等坐席好好欣赏吧。",
                "0_H133": "无可救药的情况下，吾倒也可以助你一臂之力……",
                "0_H134": "但汝，可别浪费了吾的力量哦，御主？"
            }
        },
        "0_H170": {
            "name": "对话 4",
            "text": {
                "0_H170": "被因陀罗夺走了铠甲的人啊。",
                "0_H171": "那家伙就是这种会耍诡计的神明，吾也非常清楚哦～。",
                "0_H172": "什么，你不恨他？",
                "0_H173": "咿嘻嘻，那还真是……"
            }
        },
        "0_H180": {
            "name": "对话 5",
            "text": {
                "0_H180": "怎么，连因陀罗之子也在这里呀。",
                "0_H181": "这还真是……该怎么说呢，令人期待呢。"
            }
        },
        "0_H190": {
            "name": "对话 6",
            "text": {
                "0_H190": "亦神亦魔的西方之蛇啊……",
                "0_H191": "唔，倒是让吾产生了一些亲近感。",
                "0_H192": "不过，吾可不会把人类变成石头，或者刻意将他们融化并吃掉哦。"
            }
        },
        "0_H200": {
            "name": "对话 7",
            "text": {
                "0_H200": "那些人好像对自己的歌声很有自信呢。",
                "0_H201": "有机会的话务必要听听。"
            }
        },
        "0_H210": {
            "name": "对话 8",
            "text": {
                "0_H210": "唔唔……那些家伙似乎一副「我只要愿意随时都可以骑龙」的表情呢。",
                "0_H211": "吾喜欢把人类当玩具耍，但不爽被当成玩具耍。",
                "0_H212": "别让那些人靠近我。"
            }
        },
        "0_H220": {
            "name": "会話 9",
            "text": {
                "0_H220": "真是的，因陀罗那家伙。亏他好不容易来到迦勒底，却整天只知道喝酒摆架子，真是太无趣了。看来这时候，还得由咱来加把劲，给他准备一个能让他动真格的事件才行呢。该准备什么样的试炼好呢。真是令人期待啊。嘻嘻嘻。",
                "0_H221": "",
                "0_H222": "",
                "0_H223": "",
                "0_H224": ""
            },
            "raw_text": {
                "0_H220": "まったくインドラめ。せっかくカルデアに来たというのに、酒を飲んでふんぞり返っておるだけで、実につまらん姿じゃ。ここは一つ、またワイが頑張って、奴が本気になれるような事件を用意してやらねばなるまいな。どんな試練にしようかのう。楽しみじゃの。ひひひ。",
                "0_H221": "",
                "0_H222": "",
                "0_H223": "",
                "0_H224": ""
            }
        },
        "0_H3070": {
            "name": "讨厌的东西 2",
            "text": {
                "0_H3070": "讨厌讨厌，吾可不想浑身都是泡泡！",
                "0_H3071": "……慢着，可别误会了哦？",
                "0_H3072": "吾只是讨厌用和人类一样的方式洗澡而已……",
                "0_H3073": "吾……吾才不臭呢！　吾每天都有用水冲洗啦！"
            }
        },
        "0_I010": {
            "name": "荣光的圣诞老人之路\n～被封印的圣诞礼物～ 1",
            "text": {
                "0_I010": "我是弗栗多借给万相这一存在的那部分的残渣……",
                "0_I011": "只是由邪龙的一部分构建而成的假想程序般的存在。",
                "0_I012": "至于这种很快就会消失的东西为什么会出现在这里……"
            }
        },
        "0_I020": {
            "name": "荣光的圣诞老人之路\n～被封印的圣诞礼物～ 2",
            "text": {
                "0_I020": "欢迎光临。请问想要什么呢？",
                "0_I021": "比如这个，如果巧妙运用的话，说不定能让那个痴呆神……"
            }
        },
        "0_I030": {
            "name": "荣光的圣诞老人之路\n～被封印的圣诞礼物～ 3",
            "text": {
                "0_I030": "能看到您那心满意足的表情，最喜欢人类笑容的因陀罗大人一定会非常高兴吧咿嘻嘻嘻！",
                "0_I031": "……抱歉，事到如今，连我都忍不住被自己这种肉麻的台词逗笑了。"
            }
        },
        "0_I040": {
            "name": "荣光的圣诞老人之路\n～被封印的圣诞礼物～ 4",
            "text": {
                "0_I040": "隔壁那位神明给的宝物一定豪华到这里的东西根本无法与之相提并论吧。",
                "0_I041": "比如说一百个圣杯，或者十兆量子之类的。"
            }
        },
        "0_I050": {
            "name": "荣光的圣诞老人之路\n～被封印的圣诞礼物～ 5",
            "text": {
                "0_I050": "多谢惠顾。"
            }
        },
        "0_I060": {
            "name": "荣光的圣诞老人之路\n～被封印的圣诞礼物～ 6",
            "text": {
                "0_I060": "这个形象并没有什么特殊的意义。",
                "0_I061": "只是觉得如果以清纯女性的形象出现，会更容易骗过因陀罗而已。"
            }
        },
        "0_I070": {
            "name": "荣光的圣诞老人之路\n～被封印的圣诞礼物～ 7",
            "text": {
                "0_I070": "看来这段时间也快要结束了。",
                "0_I071": "你们应该已经记住因陀罗的敌人不只有弗栗多了吧。",
                "0_I072": "就算我消失了，弗栗多今后也会继续与因陀罗战斗下去吧。"
            }
        },
        "0_I080": {
            "name": "荣光的圣诞老人之路\n～被封印的圣诞礼物～ 8",
            "text": {
                "0_I080": "呵欠……唔唔。",
                "0_I081": "实在是困得睁不开眼了。",
                "0_I082": "就算没到春天，只要想起来还是会起来的，",
                "0_I083": "所以就趁现在搜集道具努力锻炼吧。",
                "0_I084": "那么，吾先去睡了。"
            }
        },
        "0_I9050": {
            "name": "荣光的圣诞老人之路\n～被封印的圣诞礼物～ 5",
            "text": {
                "0_I9050": "那是什么？ 要怎么使用？"
            }
        },
        "0_S010": {
            "name": "召唤",
            "text": {
                "0_S010": "吾乃弗栗多。",
                "0_S011": "真是的，人类到底希望吾这样的蛇干什么……",
                "0_S012": "吾乃是为自身欲望而行动的魔。别以为能驯服吾哦？"
            }
        }
    },
    "ChrVoice_ids": [
        "304600",
        "109832840",
        "109832850"
    ]
}