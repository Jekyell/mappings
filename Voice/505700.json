{
    "id": 505700,
    "name": "",
    "voices": {
        "0_M010": {
            "name": "Fate/strange Fakeコラボイベント 6",
            "text": {
                "0_M010": "做得很好。给你奖励哦。",
                "0_M011": ""
            }
        },
        "0_M020": {
            "name": "Fate/strange Fakeコラボイベント 7",
            "text": {
                "0_M020": "这是我的珍藏。要对弗朗索瓦保密哦。",
                "0_M021": ""
            }
        },
        "0_M030": {
            "name": "Fate/strange Fakeコラボイベント 8",
            "text": {
                "0_M030": "以为到此为止了吗？真遗憾。是下一个任务。",
                "0_M031": ""
            }
        },
        "0_M040": {
            "name": "Fate/strange Fakeコラボイベント 9",
            "text": {
                "0_M040": "哎呀呀？总觉得情况有点奇怪，去确认一下吧。"
            }
        },
        "0_M060": {
            "name": "Fate/strange Fakeコラボイベント 11",
            "text": {
                "0_M060": "增加了这么多希波吕忒酱，你是打算把迦勒底变成亚马逊之国吗，你这坏家伙。",
                "0_M061": ""
            }
        },
        "0_N010": {
            "name": "Fate/strange Fakeコラボイベント 1",
            "text": {
                "0_N010": "情人节快乐！来吧来吧，你会把巧克力送给谁呢？又在觊觎谁的回礼呢？嗯？不是吗？好啦好啦，难得有机会，要带走我的巧克力吗？虽然是现实中的哦。",
                "0_N011": "",
                "0_N012": "",
                "0_N013": "",
                "0_N014": "",
                "0_N015": ""
            }
        },
        "0_N020": {
            "name": "Fate/strange Fakeコラボイベント 2",
            "text": {
                "0_N020": "呐呐，我有个请求想请你听听。我不会说想要你的灵魂之类的话，所以试着挑战一下吧？挑战一下我倾注了心血的任务。好吗？",
                "0_N021": "",
                "0_N022": ""
            }
        },
        "0_N030": {
            "name": "Fate/strange Fakeコラボイベント 3",
            "text": {
                "0_N030": "呐呐，弗朗索瓦和我，你更喜欢哪一个？啊，抱歉抱歉，我问法不对。你更讨厌哪一个？如果只能让其中一个灰飞烟灭的话，你会选哪一个？",
                "0_N031": "",
                "0_N032": "",
                "0_N033": ""
            }
        },
        "0_N040": {
            "name": "Fate/strange Fakeコラボイベント 4",
            "text": {
                "0_N040": "快乐的任务，愉快的任务。通关之后就有惊喜，我会给你一份特别的奖励哦。",
                "0_N041": "",
                "0_N042": ""
            }
        },
        "0_N050": {
            "name": "Fate/strange Fakeコラボイベント 5",
            "text": {
                "0_N050": "信息公告。不想看的话无视也可以。错过重要的事情，之后看着你悔恨哭泣的样子，那也挺有趣的。",
                "0_N051": "",
                "0_N052": ""
            }
        }
    },
