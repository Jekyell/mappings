{
    "id": 9947830,
    "name": "Enemy 9947830",
    "voices": {
        "0_B010": {
            "name": "0_B010",
            "text": {
                "0_B010": "粉碎吧！"
            },
            "raw_text": {
                "0_B010": "くだけろ。"
            }
        },
        "0_B020": {
            "name": "0_B020",
            "text": {
                "0_B020": "彻底碾碎你。"
            },
            "raw_text": {
                "0_B020": "ひねり潰す。"
            }
        },
        "0_B030": {
            "name": "0_B030",
            "text": {
                "0_B030": "别小看我了！"
            },
            "raw_text": {
                "0_B030": "なめんじゃねえぞ。"
            }
        },
        "0_B040": {
            "name": "0_B040",
            "text": {
                "0_B040": "在那躺着吧，永远地。"
            },
            "raw_text": {
                "0_B040": "そこで寝太郎永遠にな。"
            }
        },
        "0_B050": {
            "name": "0_B050",
            "text": {
                "0_B050": "此乃——"
            },
            "raw_text": {
                "0_B050": "これこそは。"
            }
        },
        "0_B051": {
            "name": "0_B051",
            "text": {
                "0_B051": "毁灭我父之邪剑。"
            },
            "raw_text": {
                "0_B051": "我が父を滅ぼし邪剣。"
            }
        },
        "0_B052": {
            "name": "0_B052",
            "text": {
                "0_B052": "灿然辉耀之王剑（Clarent Blood Arthur）！"
            },
            "raw_text": {
                "0_B052": "クラレンとブラッドアッサー！"
            }
        },
        "0_B080": {
            "name": "0_B080",
            "text": {
                "0_B080": "最棒了。"
            },
            "raw_text": {
                "0_B080": "最高だな。"
            }
        },
        "0_B090": {
            "name": "0_B090",
            "text": {
                "0_B090": "轻而易举。"
            },
            "raw_text": {
                "0_B090": "ざっしょがねえな。"
            }
        },
        "0_B100": {
            "name": "0_B100",
            "text": {
                "0_B100": "就当穿这身衣服的我比平时强三倍吧。嘛，虽然我平时就强三倍就是了。"
            },
            "raw_text": {
                "0_B100": "この服の俺は普段の三倍強いと思いな。まあ普段から三倍強いんだが。"
            }
        },
        "0_B110": {
            "name": "0_B110",
            "text": {
                "0_B110": "好，一个不留全部揍飞！"
            },
            "raw_text": {
                "0_B110": "よーし一匹残らずぶっ飛ばす。"
            }
        },
        "0_B120": {
            "name": "0_B120",
            "text": {
                "0_B120": "赢啦赢啦，凯旋归来！"
            },
            "raw_text": {
                "0_B120": "勝った勝った凱旋だ！"
            }
        },
        "0_B130": {
            "name": "0_B130",
            "text": {
                "0_B130": "好啦，晚餐吃鸡，Master请客哦。"
            },
            "raw_text": {
                "0_B130": "よーしディナーはチキンマスターのおごりな。"
            }
        },
        "0_B140": {
            "name": "0_B140",
            "text": {
                "0_B140": "切。"
            },
            "raw_text": {
                "0_B140": "ちぇ。"
            }
        },
        "0_B150": {
            "name": "0_B150",
            "text": {
                "0_B150": "可恶。"
            },
            "raw_text": {
                "0_B150": "畜生。"
            }
        },
        "0_B160": {
            "name": "0_B160",
            "text": {
                "0_B160": "好。"
            },
            "raw_text": {
                "0_B160": "はい。"
            }
        },
        "0_B170": {
            "name": "0_B170",
            "text": {
                "0_B170": "好。"
            },
            "raw_text": {
                "0_B170": "はい。"
            }
        },
        "0_B180": {
            "name": "0_B180",
            "text": {
                "0_B180": "好嘞。"
            },
            "raw_text": {
                "0_B180": "うっし。"
            }
        },
        "0_B190": {
            "name": "0_B190",
            "text": {
                "0_B190": "哈啊！"
            },
            "raw_text": {
                "0_B190": "シャア！"
            }
        },
        "0_B200": {
            "name": "0_B200",
            "text": {
                "0_B200": "了解。"
            },
            "raw_text": {
                "0_B200": "了解だ。"
            }
        },
        "0_B210": {
            "name": "0_B210",
            "text": {
                "0_B210": "在我的剑下毁灭吧，畜生们。"
            },
            "raw_text": {
                "0_B210": "我が剣にて滅べよ畜生ども。"
            }
        },
        "0_B220": {
            "name": "0_B220",
            "text": {
                "0_B220": "要我手下留情吗？嗯？"
            },
            "raw_text": {
                "0_B220": "手加減してやろうか。え？"
            }
        },
        "0_B410": {
            "name": "0_B410",
            "text": {
                "0_B410": "看招！"
            },
            "raw_text": {
                "0_B410": "そらよ！"
            }
        },
        "0_B440": {
            "name": "0_B440",
            "text": {
                "0_B440": "砍掉脑袋的话，就会老实点了吗？"
            },
            "raw_text": {
                "0_B440": "首が切れば大人しくなるか。"
            }
        },
        "0_B800": {
            "name": "0_B800",
            "text": {
                "0_B800": "我并非王，而是行于其后之人。"
            },
            "raw_text": {
                "0_B800": "我は王にあらずその後ろを歩むもの。"
            }
        },
        "0_B801": {
            "name": "0_B801",
            "text": {
                "0_B801": "为了那位王的安宁，我将驱逐所有的敌人。"
            },
            "raw_text": {
                "0_B801": "かの王の安らぎのためにあらゆる敵を駆逐する。"
            }
        },
        "0_B802": {
            "name": "0_B802",
            "text": {
                "0_B802": "灿然辉耀之王剑（Clarent Blood Arthur）！"
            },
            "raw_text": {
                "0_B802": "クラレントブラッドアーサー！"
            }
        }
    }
}