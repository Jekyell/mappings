{
    "id": 306300,
    "collectionNo": 473,
    "name": "グレイ・リリィ",
    "voices": {
        "0_B010": {
            "name": "アタック 1",
            "text": {
                "0_B010": "我会贯穿的！那就用这招吧！"
            },
            "raw_text": {
                "0_B010": "貫きます。だったらこれだな！"
            }
        },
        "0_B020": {
            "name": "アタック 2",
            "text": {
                "0_B020": "我一定会斩断它！"
            },
            "raw_text": {
                "0_B020": "奪ってみせる。"
            }
        },
        "0_B030": {
            "name": "アタック 3",
            "text": {
                "0_B030": "额、那个……亚德先生！"
            },
            "raw_text": {
                "0_B030": "え、えっと、マジで？大友さん！"
            }
        },
        "0_B040": {
            "name": "エクストラアタック 1",
            "text": {
                "0_B040": "绝不原谅。一口气解决掉吧！",
                "0_B041": ""
            },
            "raw_text": {
                "0_B040": "許しません。一気に決めるぜー。",
                "0_B041": ""
            }
        },
        "0_B050": {
            "name": "宝具 1",
            "text": {
                "0_B050": "古老的神秘啊，消逝殆尽吧。天之谜题啊，悉数归于虚无吧。第二阶段，限定解除。圣装、拔锚、闪耀于终焉之枪、神话。",
                "0_B051": "",
                "0_B052": "",
                "0_B053": "",
                "0_B054": ""
            },
            "raw_text": {
                "0_B050": "古き神秘よ、死にたいよ、天木なぞよ、ことごとく無に帰れ。第二段階、応用限定解除。戦争、末病、ランガミニアだ。ミトス。",
                "0_B051": "",
                "0_B052": "",
                "0_B053": "",
                "0_B054": ""
            }
        },
        "0_B080": {
            "name": "スキル 1",
            "text": {
                "0_B080": "魔力充能。出发吧。"
            },
            "raw_text": {
                "0_B080": "魔力充電。いこうか。"
            }
        },
        "0_B090": {
            "name": "スキル 2",
            "text": {
                "0_B090": "借我力量。真没办法啊。"
            },
            "raw_text": {
                "0_B090": "力を貸して。仕方ねえな。"
            }
        },
        "0_B100": {
            "name": "開始 1",
            "text": {
                "0_B100": "啊，好的。……我们要出发了。这边也要上了哦！"
            },
            "raw_text": {
                "0_B100": "あ、はい、グレイ、行きます。こっちも行くぜー。"
            }
        },
        "0_B110": {
            "name": "開始 2",
            "text": {
                "0_B110": "为了不让御主和师父丢脸。"
            },
            "raw_text": {
                "0_B110": "マスターにも師匠にも恥ずかしくないように。"
            }
        },
        "0_B120": {
            "name": "勝利 1",
            "text": {
                "0_B120": "总算设法解决了。嘻嘻嘻，好好感谢我吧。"
            },
            "raw_text": {
                "0_B120": "なんとかなりました。にひひひ、たっぷり感謝しろよ。"
            }
        },
        "0_B130": {
            "name": "勝利 2",
            "text": {
                "0_B130": "这多亏了御主的战术。也有我的功劳吧？"
            },
            "raw_text": {
                "0_B130": "マスターの戦術のおかげです。俺のおかげもあるだろ。"
            }
        },
        "0_B140": {
            "name": "ダメージ 2",
            "text": {
                "0_B140": "这点程度……"
            },
            "raw_text": {
                "0_B140": "これぐらい。"
            }
        },
        "0_B150": {
            "name": "ダメージ 1",
            "text": {
                "0_B150": "撑住啊，格蕾！"
            },
            "raw_text": {
                "0_B150": "これもう耐えろグレイ！"
            }
        },
        "0_B160": {
            "name": "戦闘不能 1",
            "text": {
                "0_B160": "御主、师父，我要撤退了。接下来就交给你啦！"
            },
            "raw_text": {
                "0_B160": "マスター、師匠、撤退します。あとは任せた！"
            }
        },
        "0_B170": {
            "name": "戦闘不能 2",
            "text": {
                "0_B170": "再继续下去的话……对不起。"
            },
            "raw_text": {
                "0_B170": "これ以上はごめんなさい。"
            }
        },
        "0_B180": {
            "name": "コマンドカード 1",
            "text": {
                "0_B180": "是这个吧。"
            },
            "raw_text": {
                "0_B180": "これですね。"
            }
        },
        "0_B190": {
            "name": "コマンドカード 2",
            "text": {
                "0_B190": "我明白了。"
            },
            "raw_text": {
                "0_B190": "わかりました。"
            }
        },
        "0_B200": {
            "name": "コマンドカード 3",
            "text": {
                "0_B200": "请交给我吧。"
            },
            "raw_text": {
                "0_B200": "任せてください。"
            }
        },
        "0_B2010": {
            "name": "アタック 10",
            "text": {
                "0_B2010": "要射击了！扫射个够之后，看招！"
            },
            "raw_text": {
                "0_B2010": "撃ちます!たっぷりばらまいてから、こうだ!"
            }
        },
        "0_B2020": {
            "name": "アタック 11",
            "text": {
                "0_B2020": "射击、射击，然后斩击。"
            },
            "raw_text": {
                "0_B2020": "うってうって、切る。"
            }
        },
        "0_B2030": {
            "name": "アタック 12",
            "text": {
                "0_B2030": "能承受灼烧吗？办不到吧。"
            },
            "raw_text": {
                "0_B2030": "焼けられますか？無理だよな。"
            }
        },
        "0_B210": {
            "name": "宝具カード 1",
            "text": {
                "0_B210": "解开吧，吞噬吧。"
            },
            "raw_text": {
                "0_B210": "暗くて浮かれて。"
            }
        },
        "0_B220": {
            "name": "宝具カード 2",
            "text": {
                "0_B220": "渴望吧，堕落吧。"
            },
            "raw_text": {
                "0_B220": "望んで堕落させて。"
            }
        },
        "0_B230": {
            "name": "宝具カード 3",
            "text": {
                "0_B230": "渴望、堕落。"
            },
            "raw_text": {
                "0_B230": "グレイ、デイブ。"
            }
        },
        "0_B2410": {
            "name": "アタック 13",
            "text": {
                "0_B2410": "以最高速度上吧。"
            },
            "raw_text": {
                "0_B2410": "トップスピードで行こう。"
            }
        },
        "0_B2420": {
            "name": "アタック 14",
            "text": {
                "0_B2420": "如同暴风雨般。"
            },
            "raw_text": {
                "0_B2420": "嵐のように。"
            }
        },
        "0_B2430": {
            "name": "アタック 15",
            "text": {
                "0_B2430": "螺旋，生效！"
            },
            "raw_text": {
                "0_B2430": "うずまき、効果！"
            }
        },
        "0_B250": {
            "name": "宝具カード 4",
            "text": {
                "0_B250": "渴望、堕落。"
            },
            "raw_text": {
                "0_B250": "クレイヴ、ディプレイヴ。"
            }
        },
        "0_B410": {
            "name": "アタック 4",
            "text": {
                "0_B410": "会有点痛哦。"
            },
            "raw_text": {
                "0_B410": "ちょっと痛いですよ。"
            }
        },
        "0_B420": {
            "name": "アタック 5",
            "text": {
                "0_B420": "第一阶段，限定解除！"
            },
            "raw_text": {
                "0_B420": "第一段階、限定解除だ！"
            }
        },
        "0_B430": {
            "name": "アタック 6",
            "text": {
                "0_B430": "死神之镰！果然很顺手呢！"
            },
            "raw_text": {
                "0_B430": "グリムリーパー！やっぱり馴染むね！"
            }
        },
        "0_B440": {
            "name": "エクストラアタック 2",
            "text": {
                "0_B440": "我真的生气了。这下可不得了啊！",
                "0_B441": ""
            },
            "raw_text": {
                "0_B440": "もう怒りました。こいつはやばいぜ。",
                "0_B441": ""
            }
        },
        "0_B480": {
            "name": "スキル 3",
            "text": {
                "0_B480": "做准备了。"
            },
            "raw_text": {
                "0_B480": "準備をします。"
            }
        },
        "0_B490": {
            "name": "スキル 4",
            "text": {
                "0_B490": "那么，开始吧。"
            },
            "raw_text": {
                "0_B490": "さあ、始めましょう。"
            }
        },
        "0_B500": {
            "name": "開始 3",
            "text": {
                "0_B500": "那么，我们走吧。准备OK啦！"
            },
            "raw_text": {
                "0_B500": "さあ、行きましょう。準備オッケーだぜ。"
            }
        },
        "0_B510": {
            "name": "開始 4",
            "text": {
                "0_B510": "我会保护好御主的！亚德！怎么能这样！？"
            },
            "raw_text": {
                "0_B510": "マスターを守り抜きます。わかりましたか？あった！そんな話あねえか！"
            }
        },
        "0_B520": {
            "name": "勝利 3",
            "text": {
                "0_B520": "发挥出力量了。偶尔也自信一点嘛。"
            },
            "raw_text": {
                "0_B520": "力が発揮できました。たまには自信持っていいんだぜ。"
            }
        },
        "0_B540": {
            "name": "ダメージ 4",
            "text": {
                "0_B540": "我不会输的。"
            },
            "raw_text": {
                "0_B540": "負けません。"
            }
        },
        "0_B550": {
            "name": "ダメージ 3",
            "text": {
                "0_B550": "对不起。真是的……"
            },
            "raw_text": {
                "0_B550": "ごめんなさい。もう。"
            }
        },
        "0_B800": {
            "name": "宝具 2",
            "text": {
                "0_B800": "幼小的幻想啊，苏醒吧。遥远的梦想啊，化为基石吧。第二阶段，限定解除。圣装、拔锚、闪耀于终焉之枪、神话。",
                "0_B801": "",
                "0_B802": "",
                "0_B803": "",
                "0_B804": ""
            },
            "raw_text": {
                "0_B800": "幼き幻想よ、蘇れ。春けき夢よ、礎となれ。第二段階、応用限定解除。清掃、発病、ランガミニアの、メタス。",
                "0_B801": "",
                "0_B802": "",
                "0_B803": "",
                "0_B804": ""
            }
        },
        "0_B810": {
            "name": "宝具 3",
            "text": {
                "0_B810": "疑似人格停止。魔力收集率突破规定值。复合灵装“逻辑反应·复刻版”功能解放。圣装、拔锚、闪耀于终焉之枪、神话。",
                "0_B811": "",
                "0_B812": "",
                "0_B813": "",
                "0_B814": ""
            },
            "raw_text": {
                "0_B810": "擬似人格停止。魔力の収集率、規定値を突破。複合霊装、ロゴスリアクトレプリカの機能を解放。聖装、末病、ロングミニアド、メタス。",
                "0_B811": "",
                "0_B812": "",
                "0_B813": "",
                "0_B814": ""
            }
        },
        "0_B840": {
            "name": "エクストラアタック 3",
            "text": {
                "0_B840": "切碎、击溃！"
            },
            "raw_text": {
                "0_B840": "切り刻み、突き崩す！"
            }
        },
        "0_B910": {
            "name": "アタック 7",
            "text": {
                "0_B910": "将其斩裂。"
            },
            "raw_text": {
                "0_B910": "切り裂きます。"
            }
        },
        "0_B920": {
            "name": "アタック 8",
            "text": {
                "0_B920": "是战戟。要大干一场啦！"
            },
            "raw_text": {
                "0_B920": "ハルバードです。やっちまうかー！"
            }
        },
        "0_B930": {
            "name": "アタック 9",
            "text": {
                "0_B930": "竭尽全力。"
            },
            "raw_text": {
                "0_B930": "力の限りに。"
            }
        },
        "0_G010": {
            "name": "レベルアップ 1",
            "text": {
                "0_G010": "等级提升了。不管经历多少次都很高兴呢。",
                "0_G011": ""
            },
            "raw_text": {
                "0_G010": "レベルアップです。何度やっても嬉しいですね。",
                "0_G011": ""
            }
        },
        "0_G020": {
            "name": "霊基再臨 2",
            "text": {
                "0_G020": "是第二次灵基再临。能像这样和您聊天，总觉得很高兴。——你这家伙能说这么多话，也就对那个君主、莱妮丝、奥尔加玛丽，还有凛和埃尔戈了吧？请、请不要插嘴！还有……",
                "0_G021": "",
                "0_G022": "",
                "0_G023": ""
            },
            "raw_text": {
                "0_G020": "礼儀再輪二度目です。こうしてお話するの、なんだか嬉しいです。お前がこんなに話すの、あのロードとライネスとオルガマリーと、あとリンとエルゴぐらいじゃないか。ちょ、ちょっと口を挟まないでください。あと。",
                "0_G021": "",
                "0_G022": "",
                "0_G023": ""
            }
        },
        "0_G030": {
            "name": "霊基再臨 1",
            "text": {
                "0_G030": "是灵基再临。没有换衣服稍微有点遗憾呢。那个，比起我，大概莱妮丝小姐会觉得更遗憾吧……我可不想再被强行变身了啊！",
                "0_G031": "",
                "0_G032": "",
                "0_G033": ""
            },
            "raw_text": {
                "0_G030": "礼儀再輪です。着替えがないのは少しだけ残念ですね。その、多分雪よりライネスさんの方が残念がりそうなんですけれど。これ以上変身させられるのはごめんだぜい。",
                "0_G031": "",
                "0_G032": "",
                "0_G033": ""
            }
        },
        "0_G040": {
            "name": "霊基再臨 3",
            "text": {
                "0_G040": "灵基再临。转眼间就是第三次了。我、我可以收下这么多吗？——能拿的就拿着。对吧，御主？",
                "0_G041": "",
                "0_G042": ""
            },
            "raw_text": {
                "0_G040": "礼儀再輪。あっという間に三度目です。こ、こんなに頂いていいんですか？もらえるもんはもらっとき。な、マスター。",
                "0_G041": "",
                "0_G042": ""
            }
        },
        "0_G050": {
            "name": "霊基再臨 4",
            "text": {
                "0_G050": "非常感谢您。这灵基的到达点，我确实看到了。虽然不知道还能在一起多久，但亚德、师父、莱妮丝、奥尔加小姐，都会一直站在您这一边。请让我陪您走到最后。",
                "0_G051": "",
                "0_G052": "",
                "0_G053": ""
            },
            "raw_text": {
                "0_G050": "本当にありがとうございます。この霊気の到達地点、確かに見えました。あと、どれくらい一緒にいられるかわからないけれど、雪音も師匠もライネスもオルガさんも、ずっとあなたの味方です。最後まで一緒にいさせてください。",
                "0_G051": "",
                "0_G052": "",
                "0_G053": ""
            }
        },
        "0_G110": {
            "name": "レベルアップ 2",
            "text": {
                "0_G110": "哇，力量涌上来了。我想这样就能为御主和师父提供支援了。",
                "0_G111": "",
                "0_G112": ""
            },
            "raw_text": {
                "0_G110": "うわっ力が湧いてきました。マスターと師匠のバックアップできると思います。",
                "0_G111": "",
                "0_G112": ""
            }
        },
        "0_G120": {
            "name": "レベルアップ 3",
            "text": {
                "0_G120": "嗯，美味！啊，等、等一下，不要抢先吃火种啊！",
                "0_G121": ""
            },
            "raw_text": {
                "0_G120": "うん、デリシャス。あ、あっと。先に種火を食べないで。",
                "0_G121": ""
            }
        },
        "0_H010": {
            "name": "誕生日",
            "text": {
                "0_H010": "我是从迦勒底的大家那里听说的。今天是御主的生日。愿这星尘的光芒，能一直指引您的旅途。……嘿，嘻嘻嘻，嘛，至少今天就老老实实地对你说声恭喜吧。",
                "0_H011": "",
                "0_H012": "",
                "0_H013": ""
            },
            "raw_text": {
                "0_H010": "カルデアの皆さんから聞きました。今日がマスターの誕生日だって。どうかせつと、この星草の輝きが、あなたの旅路の導きになれていますように。ねえ、ひひひ、ま、今日ぐらいは素直にめでたいって言ってやるか。",
                "0_H011": "",
                "0_H012": "",
                "0_H013": ""
            }
        },
        "0_H020": {
            "name": "イベント開催中",
            "text": {
                "0_H020": "啊，外面好像又发生什么事了。得赶紧准备才行。我去拜托一下师父。",
                "0_H021": "",
                "0_H022": ""
            },
            "raw_text": {
                "0_H020": "あ、また何か外で起きてるみたいですよ。急いで準備しないと。師匠にもお願いしてきます。",
                "0_H021": "",
                "0_H022": ""
            }
        },
        "0_H030": {
            "name": "会話 1",
            "text": {
                "0_H030": "差不多到出击的时间了呢。请随时叫我。",
                "0_H031": ""
            },
            "raw_text": {
                "0_H030": "そろそろ出撃の時間のようですね。いつでも声をかけてください。",
                "0_H031": ""
            }
        },
        "0_H040": {
            "name": "会話 2",
            "text": {
                "0_H040": "虽然以前也说过，但对我来说您是御主，而师父就只有那一个人。谢谢您能容许这一点。",
                "0_H041": ""
            },
            "raw_text": {
                "0_H040": "前も話しましたけれど、雪音にとってあなたはマスターで、師匠はたった一人のあの人です。そういうのを許してくれてありがとうございます。",
                "0_H041": ""
            }
        },
        "0_H050": {
            "name": "会話 3",
            "text": {
                "0_H050": "虽然我以前说过“既然是御主和从者，请不用客气尽管命令我”，但御主完全不会那样做呢。不过，大家一定都很高兴您是这样的人。——嘛，需要帮忙的时候就直说啊！",
                "0_H051": "",
                "0_H052": ""
            },
            "raw_text": {
                "0_H050": "前にマスターとサーヴァントだから遠慮なく命令してくださいと言いましたけれど、マスターは全然そうはならないですね。でも、あなたがそういう人なことをきっとみんな喜んでいると思います。まあ、助けが必要な時は言うんだぜ。",
                "0_H051": "",
                "0_H052": ""
            }
        },
        "0_H060": {
            "name": "好きなこと",
            "text": {
                "0_H060": "我很喜欢师父、莱妮丝小姐和大家都在的那个空间。最近阿斯克勒庇俄斯先生会和特里姆玛乌小姐一起帮忙端茶倒水，偶尔还会悄悄向我展示新的杂耍呢。",
                "0_H061": ""
            },
            "raw_text": {
                "0_H060": "師匠とライネスさんとみんながいてくれてる空間がとても好きです。最近はトリムマウさんと一緒にアスカロポスさんが球児をしてくれて、時々ちらっと新しいジャグリングとかも見せてくれるんです。",
                "0_H061": ""
            }
        },
        "0_H070": {
            "name": "嫌いなこと",
            "text": {
                "0_H070": "那个，呃，虽然现在才说这个有点晚，但我很怕幽灵。您可能会想，一个守墓人在说什么傻话呢，但唯独这件事，似乎就算灵基改变了也一样。",
                "0_H071": "",
                "0_H072": "",
                "0_H073": ""
            },
            "raw_text": {
                "0_H070": "その、えっと、今更なんですが、幽霊は苦手です。墓守が何を言ってるのかと思われるでしょうが、こればっかりは、霊気が変わっても一緒みたいです。",
                "0_H071": "",
                "0_H072": "",
                "0_H073": ""
            }
        },
        "0_H080": {
            "name": "聖杯について",
            "text": {
                "0_H080": "圣杯。这是无数次在我身边被提及的词汇。对于如今成为从者的我来说，这或许是理所当然的，但我总觉得，这是无法避开的宿命吧。",
                "0_H081": "",
                "0_H082": ""
            },
            "raw_text": {
                "0_H080": "聖杯。何度も、雪の周囲で囁かれる言葉です。サーヴァントになった今なら当然かもしれませんが、避けては通れないのだろうと、そんな風に思います。",
                "0_H081": "",
                "0_H082": ""
            }
        },
        "0_H090": {
            "name": "絆Lv.1",
            "text": {
                "0_H090": "啊，是的。我是这个灵基的格蕾。还是有些不太适应呢。我自己也觉得有些不可思议，不过正在一点点练习。",
                "0_H091": "",
                "0_H092": ""
            },
            "raw_text": {
                "0_H090": "あ、はい。暖簾れいきのグレーです。まだなかなか馴染まないですよね。説もなんだか不思議な気がするんですが、ちょっとずつ練習してます。",
                "0_H091": "",
                "0_H092": ""
            }
        },
        "0_H170": {
            "name": "会話 4",
            "text": {
                "0_H170": "师父又在学习了呢。明明事到如今再学习魔术，作为从者也没什么用处。那件事我就随他去了，不过剪头发的事请务必交给我。",
                "0_H171": "",
                "0_H172": ""
            },
            "raw_text": {
                "0_H170": "師匠はまた勉強してるんですね。今さら魔術の学習をしても、サーヴァントとしては役立たないでしょうに。それは許してあげますから、髪は切つに任せてください。",
                "0_H171": "",
                "0_H172": ""
            }
        },
        "0_H180": {
            "name": "会話 5",
            "text": {
                "0_H180": "只要有师父和莱妮丝小姐在，光是这样，我就会感到安心。无论那里是时钟塔、迦勒底，还是其他什么地方，我都会觉得，那是容许我存在的地方。",
                "0_H181": ""
            },
            "raw_text": {
                "0_H180": "師匠とライネスさんがいれば、それだけで、セツはホッとします。そこが時計塔であれ、カルデアであれ、もっと別の場所であれ、自分がいていい場所だって、そう思えるんです。",
                "0_H181": ""
            }
        },
        "0_H190": {
            "name": "会話 6",
            "text": {
                "0_H190": "我一直很憧憬阿斯特赖亚小姐的凛然姿态。作为她凭依容器的露维亚小姐也是如此，无论何时都在全身心地面对正确的生活方式。我有这种感觉。",
                "0_H191": "",
                "0_H192": "",
                "0_H193": ""
            },
            "raw_text": {
                "0_H190": "アストライアさんの凛々しさにはいつも憧れます。あの方が拠り所にしたルビアさんもそうですけれど、正しい生き方にいつだって全身で向き合ってる。そういう気がするんです。",
                "0_H191": "",
                "0_H192": "",
                "0_H193": ""
            }
        },
        "0_H200": {
            "name": "会話 7",
            "text": {
                "0_H200": "啊、那个，Faker小姐，一直以来师父都承蒙您照顾了。那个，如果可以的话，还请尽量不要和他吵架。",
                "0_H201": ""
            },
            "raw_text": {
                "0_H200": "あ、あ、あの、フェイカさん、いつも師匠がお世話になってます。その、できたらあまり喧嘩にならないようにお願いします。",
                "0_H201": ""
            }
        },
        "0_H210": {
            "name": "会話 8",
            "text": {
                "0_H210": "堤丰·艾菲梅洛斯小姐来到迦勒底的时候虽然吓了我一跳，但她反而比我还融入这里呢。她的妹妹也现身了，两人总是开开心心的，让我有点羡慕呢。",
                "0_H211": "",
                "0_H212": "",
                "0_H213": ""
            },
            "raw_text": {
                "0_H210": "リフォンエフェメロスさんがカルデアに来られた時はびっくりしましたけれど、むしろ雪より馴染んでるくらいですよね。妹さんも現れていつも楽しそうで、ちょっとだけ羨ましいです。",
                "0_H211": "",
                "0_H212": "",
                "0_H213": ""
            }
        },
        "0_H220": {
            "name": "会話 9",
            "text": {
                "0_H220": "是的，我总是向图书馆之王借新书。有时也会和征服王先生一起在树荫下悠闲地阅读。不过，总觉得那个王一直在盯着我们观察啊。",
                "0_H221": "",
                "0_H222": ""
            },
            "raw_text": {
                "0_H220": "はい、図書館の王にはいつも新しい本をお借りしています。時々制服王さんも一緒に日陰でゆっくり読ませてもらってるんです。どうもあの王様にはジロジロ観察されてる気もするんだよな。",
                "0_H221": "",
                "0_H222": ""
            }
        },
        "0_H230": {
            "name": "会話 10",
            "text": {
                "0_H230": "有时，有时，厄里倪厄斯女士会露面。一看到我和阿比盖尔小姐，她就会非常温柔地微笑着消失。这让我的心里感到有那么一点点难过。",
                "0_H231": "",
                "0_H232": ""
            },
            "raw_text": {
                "0_H230": "時々、時々、エリニュスさんが顔を見せるんです。セツやアビゲイルさんを見ると、とても優しく笑って消えていって。ほんの少しだけ切なくなります。",
                "0_H231": "",
                "0_H232": ""
            }
        },
        "0_H240": {
            "name": "会話 11",
            "text": {
                "0_H240": "是的，这张脸和身体是模仿阿尔托莉雅大人的。原本的我对此感到很痛苦，虽然和师匠以及莱妮丝小姐在一起时这种感觉淡化了，但在这个灵基下，总觉得能够接受了。这一定多亏了德墨忒尔女士吧。事到如今，反正那家伙也不会介意的吧。",
                "0_H241": "",
                "0_H242": "",
                "0_H243": "",
                "0_H244": ""
            },
            "raw_text": {
                "0_H240": "はい、この顔や体はアルトリアさんを模したものです。もともとの説はそれが辛くて、師匠やライネスさんと一緒にいると薄れていたのですけれど、この霊気だとなんだか受け入れてしまっています。きっとデメテルさんのおかげですね。今更向こうも気にしてたりしないだろうからな。",
                "0_H241": "",
                "0_H242": "",
                "0_H243": "",
                "0_H244": ""
            }
        },
        "0_H250": {
            "name": "会話 12",
            "text": {
                "0_H250": "那两位征服王经常缠着我讲故事。因为师匠在迦勒底不怎么提起自己那个世界的事，所以我也一直有所克制，但一看到他们展露笑容，我就忍不住……",
                "0_H251": "",
                "0_H252": ""
            },
            "raw_text": {
                "0_H250": "制服王のお二人にはしょっちゅう話をせがまれてます。師匠はあまり自分の世界の話をカルデアでしないものですから、説も控えているのですけれど、あの方々の笑顔を向けられるとつい。",
                "0_H251": "",
                "0_H252": ""
            }
        },
        "0_H260": {
            "name": "会話 13",
            "text": {
                "0_H260": "看到伊什塔尔小姐，就会让我想起和凛小姐一起环游世界的时候。和师匠、埃尔戈，有时还有司翁小姐他们一起。啊，不行。因为这是另一个世界的事情。嘿嘿嘻嘻，我看到那张脸，身上也直发痒啊。",
                "0_H261": "",
                "0_H262": "",
                "0_H263": ""
            },
            "raw_text": {
                "0_H260": "イシュタルさんを見ると、リンさんと世界中を駆け回った時を思い出します。師匠とエルゴと、時々シオンさんたちも一緒に。あ、いけません。これは雪の世界のことですので。ねえひひひ、俺もあの顔見てると体がむず痒くなっちまうな。",
                "0_H261": "",
                "0_H262": "",
                "0_H263": ""
            }
        },
        "0_H270": {
            "name": "会話 14",
            "text": {
                "0_H270": "阿斯卡拉福斯先生总是展现出完美的管家风范呢。无论何时都准备周全。不过偶尔也会有冒失的一面，我看着觉得挺开心的。",
                "0_H271": "",
                "0_H272": ""
            },
            "raw_text": {
                "0_H270": "アスカラボスさんはいつも完璧な羊ぶりですよね。どんな時でも用意周到で。でも時々おっちょこちょいだったりするところが、せつは見てて楽しいです。",
                "0_H271": "",
                "0_H272": ""
            }
        },
        "0_H280": {
            "name": "会話 15",
            "text": {
                "0_H280": "奥尔加玛丽小姐当上了迦勒底所长……不，我很开心。非常开心。是啊，因为我一直都知道，那个人是完全能做到这种事的。",
                "0_H281": "",
                "0_H282": "",
                "0_H283": ""
            },
            "raw_text": {
                "0_H280": "オルガマリーさんがカルデア所長に。いえ、嬉しいです。とっても嬉しいです。ええ、あの人はそれだけのことができるってずっと知っていたんですから。",
                "0_H281": "",
                "0_H282": "",
                "0_H283": ""
            }
        },
        "0_H290": {
            "name": "会話 16",
            "text": {
                "0_H290": "看到村正先生，就会让我想起以前赌场的事。虽然几乎没有好好说过话，仅仅是交谈了一两句而已。",
                "0_H291": ""
            },
            "raw_text": {
                "0_H290": "村正さんを見ると昔のカジノのことを思い出します。ちゃんと話したことはほとんどなくて、ほんの一言二言交わしたそれだけなんですが。",
                "0_H291": ""
            }
        },
        "0_H300": {
            "name": "会話 17",
            "text": {
                "0_H300": "我虽然是选择了枪的可能性，但并没有忘记选择圣剑的未来。所以，有时和那位圣剑使说话，总觉得受到了鼓舞。",
                "0_H301": ""
            },
            "raw_text": {
                "0_H300": "雪は槍を選んだ可能性ですけれど、聖剣を選んだ未来を忘れたわけじゃありません。だから聖剣使いのあの人と時々話すのは、なんだか励みになります。",
                "0_H301": ""
            }
        },
        "0_S020": {
            "name": "仮加入",
            "text": {
                "0_S020": "重新自我介绍一下，我是格蕾。虽然又是从零开始，但只要有师父和御主在，我就不会害怕。",
                "0_S021": ""
            },
            "raw_text": {
                "0_S020": "改めまして、グレイです。また一からの出発ですけれど、師匠やマスターがいるなら怖くありません。",
                "0_S021": ""
            }
        }
    },
    "ChrVoice_ids": [
        "306300"
    ]
}