{
    "id": 9947710,
    "name": "Enemy 9947710",
    "voices": {
        "0_B010": {
            "name": "0_B010",
            "text": {
                "0_B010": "那首歌中毫无希望。"
            },
            "raw_text": {
                "0_B010": "その歌に希望はない。"
            }
        },
        "0_B020": {
            "name": "0_B020",
            "text": {
                "0_B020": "故事无法延续。"
            },
            "raw_text": {
                "0_B020": "物語は続かず。"
            }
        },
        "0_B030": {
            "name": "0_B030",
            "text": {
                "0_B030": "呐喊绝无法传达。"
            },
            "raw_text": {
                "0_B030": "叫びが届くことはない。"
            }
        },
        "0_B040": {
            "name": "0_B040",
            "text": {
                "0_B040": "尔等之命，不会被载入历史。"
            },
            "raw_text": {
                "0_B040": "貴様らの命は歴史には記されん。"
            }
        },
        "0_B050": {
            "name": "0_B050",
            "text": {
                "0_B050": "率领叛逆界域。"
            },
            "raw_text": {
                "0_B050": "インヴェルシオリベルタティスを裏切る。"
            }
        },
        "0_B051": {
            "name": "0_B051",
            "text": {
                "0_B051": "在时间的尽头，人类将从暴君与愚民中解放。"
            },
            "raw_text": {
                "0_B051": "時の果てにて人類は暴君からも愚民からも解放される。"
            }
        },
        "0_B052": {
            "name": "0_B052",
            "text": {
                "0_B052": "燃尽的世界啊，如今只管化作焦炭吧。"
            },
            "raw_text": {
                "0_B052": "焼けた世界よ今はただ炭となりて。"
            }
        },
        "0_B053": {
            "name": "0_B053",
            "text": {
                "0_B053": "编纂历史吧。"
            },
            "raw_text": {
                "0_B053": "歴史を綴れ。"
            }
        },
        "0_B080": {
            "name": "0_B080",
            "text": {
                "0_B080": "无需多言。"
            },
            "raw_text": {
                "0_B080": "語るに及ばず。"
            }
        },
        "0_B090": {
            "name": "0_B090",
            "text": {
                "0_B090": "这是通往神明之路的指引。"
            },
            "raw_text": {
                "0_B090": "神に至る道しるべだ。"
            }
        },
        "0_B140": {
            "name": "0_B140",
            "text": {
                "0_B140": "唔……"
            },
            "raw_text": {
                "0_B140": "くうん。"
            }
        },
        "0_B150": {
            "name": "0_B150",
            "text": {
                "0_B150": "连这具躯体也要彻底粉碎吗。"
            },
            "raw_text": {
                "0_B150": "この身をも砕き尽くすか。"
            }
        },
        "0_B2010": {
            "name": "0_B2010",
            "text": {
                "0_B2010": "在此献上祝福。"
            },
            "raw_text": {
                "0_B2010": "祝福をここに。"
            }
        },
        "0_B2020": {
            "name": "0_B2020",
            "text": {
                "0_B2020": "其步伐毫无理由。"
            },
            "raw_text": {
                "0_B2020": "その歩みに理由はなく。"
            }
        },
        "0_B2030": {
            "name": "0_B2030",
            "text": {
                "0_B2030": "流淌的鲜血毫无意义。"
            },
            "raw_text": {
                "0_B2030": "流れる血に意味はなく。"
            }
        },
        "0_B2410": {
            "name": "0_B2410",
            "text": {
                "0_B2410": "生死流转。"
            },
            "raw_text": {
                "0_B2410": "生と死はるてんする。"
            }
        },
        "0_B2420": {
            "name": "0_B2420",
            "text": {
                "0_B2420": "刀刃终将蒙锈。"
            },
            "raw_text": {
                "0_B2420": "刃は錆を抱く。"
            }
        },
        "0_B310": {
            "name": "0_B310",
            "text": {
                "0_B310": "这并非互相残杀。仅仅是彼此历史的相互闭锁。"
            },
            "raw_text": {
                "0_B310": "これは殺し合いではない。単なる互いの歴史の閉ざし合いだ。"
            }
        },
        "0_B410": {
            "name": "0_B410",
            "text": {
                "0_B410": "大地无言。"
            },
            "raw_text": {
                "0_B410": "大地は語らず。"
            }
        },
        "0_B420": {
            "name": "0_B420",
            "text": {
                "0_B420": "唯有前行。"
            },
            "raw_text": {
                "0_B420": "ただ歩むのみ。"
            }
        },
        "0_B430": {
            "name": "0_B430",
            "text": {
                "0_B430": "在此献上悲叹。"
            },
            "raw_text": {
                "0_B430": "嘆きをここに。"
            }
        },
        "0_B440": {
            "name": "0_B440",
            "text": {
                "0_B440": "那灵魂不会被任何人传颂。"
            },
            "raw_text": {
                "0_B440": "その魂は誰にも語られることはない。"
            }
        },
        "0_B490": {
            "name": "0_B490",
            "text": {
                "0_B490": "还不够……还触及不到。"
            },
            "raw_text": {
                "0_B490": "まだだまだ届かぬ。"
            }
        },
        "0_B540": {
            "name": "0_B540",
            "text": {
                "0_B540": "嗯。"
            },
            "raw_text": {
                "0_B540": "うん。"
            }
        },
        "0_B550": {
            "name": "0_B550",
            "text": {
                "0_B550": "无谓的挣扎。"
            },
            "raw_text": {
                "0_B550": "無駄なあがきを。"
            }
        },
        "0_B800": {
            "name": "0_B800",
            "text": {
                "0_B800": "伟业、愚行、奇迹、悲剧，一切都融入过去而消逝。"
            },
            "raw_text": {
                "0_B800": "偉業、愚行、奇跡、悲劇、すべては過去へと溶け消えた。"
            }
        },
        "0_B801": {
            "name": "0_B801",
            "text": {
                "0_B801": "英雄与凡人的边界被合于书中。"
            },
            "raw_text": {
                "0_B801": "英雄とただ人の境界は書に閉ざされ。"
            }
        },
        "0_B802": {
            "name": "0_B802",
            "text": {
                "0_B802": "须知，这终将被无数的传颂者所铭记。"
            },
            "raw_text": {
                "0_B802": "やがて幾万もの語り部に刻まれると知れ。"
            }
        },
        "0_B803": {
            "name": "0_B803",
            "text": {
                "0_B803": "伟业、愚行、奇迹、悲剧。"
            },
            "raw_text": {
                "0_B803": "偉業愚行奇跡悲劇。"
            }
        },
        "0_B804": {
            "name": "0_B804",
            "text": {
                "0_B804": "一切都融入过去而消逝。"
            },
            "raw_text": {
                "0_B804": "全ては過去へと溶け消えた。"
            }
        },
        "0_B880": {
            "name": "0_B880",
            "text": {
                "0_B880": "仍未盈满。"
            },
            "raw_text": {
                "0_B880": "いまだ満ちることはない。"
            }
        },
        "0_B890": {
            "name": "0_B890",
            "text": {
                "0_B890": "暴君吗……那也不错。"
            },
            "raw_text": {
                "0_B890": "坊君かそれも良い。"
            }
        },
        "0_B910": {
            "name": "0_B910",
            "text": {
                "0_B910": "救赎不会降临于死者。"
            },
            "raw_text": {
                "0_B910": "死者に救いは訪れず。"
            }
        },
        "0_B920": {
            "name": "0_B920",
            "text": {
                "0_B920": "风嘲弄着一切。"
            },
            "raw_text": {
                "0_B920": "風はすべてをあざ笑う。"
            }
        },
        "0_B930": {
            "name": "0_B930",
            "text": {
                "0_B930": "在此献上福音。"
            },
            "raw_text": {
                "0_B930": "福音をここに。"
            }
        }
    }
}