                "0_B160": "对，对不起……"
            }
        },
        "0_B170": {
            "name": "戦闘不能 2",
            "text": {
                "0_B170": "先折返一次。"
            }
        },
        "0_B180": {
            "name": "コマンドカード 1",
            "text": {
                "0_B180": "什么？"
            }
        },
        "0_B190": {
            "name": "コマンドカード 2",
            "text": {
                "0_B190": "哎？"
            }
        },
        "0_B200": {
            "name": "コマンドカード 3",
            "text": {
                "0_B200": "啊！"
            }
        },
        "0_B2010": {
            "name": "アタック 10",
            "text": {
                "0_B2010": "【小野篁】嘿呀！"
            }
        },
        "0_B2020": {
            "name": "アタック 11",
            "text": {
                "0_B2020": "嘿咻。"
            }
        },
        "0_B2030": {
            "name": "アタック 12",
            "text": {
                "0_B2030": "嘿呼，嘿呼。"
            }
        },
        "0_B210": {
            "name": "宝具カード 1",
            "text": {
                "0_B210": "是！　宝具吧！"
            }
        },
        "0_B220": {
            "name": "宝具カード 2",
            "text": {
                "0_B220": "好的。"
            }
        },
        "0_B230": {
            "name": "宝具カード 3",
            "text": {
                "0_B230": "我，我来做！"
            }
        },
        "0_B2410": {
            "name": "アタック 13",
            "text": {
                "0_B2410": "秋风吹起……"
            }
        },
        "0_B2420": {
            "name": "アタック 14",
            "text": {
                "0_B2420": "【小野篁】针山！"
            }
        },
        "0_B2430": {
            "name": "アタック 15",
            "text": {
                "0_B2430": "【小野篁】串刺！"
            }
        },
        "0_B2440": {
            "name": "エクストラアタック 4",
            "text": {
                "0_B2440": "【小野篁】阎魔王，劳您亲自前来，感激不尽。"
            }
        },
        "0_B250": {
            "name": "宝具カード 4",
            "text": {
                "0_B250": "我会试试！"
            }
        },
        "0_B410": {
            "name": "アタック 4",
            "text": {
                "0_B410": "这样吗？"
            }
        },
        "0_B420": {
            "name": "アタック 5",
            "text": {
                "0_B420": "顺滑地～。"
            }
        },
        "0_B430": {
            "name": "アタック 6",
            "text": {
                "0_B430": "通过啦。"
            }
        },
        "0_B440": {
            "name": "エクストラアタック 2",
            "text": {
                "0_B440": "【小野小町】父亲大人，那个…… 【小野篁】召唤·阎魔的一瞪！"
            }
        },
        "0_B480": {
            "name": "スキル 3",
            "text": {
                "0_B480": "思君方入梦……"
            }
        },
        "0_B490": {
            "name": "スキル 4",
            "text": {
                "0_B490": "浦间无海草　我已无心与君好……"
            }
        },
        "0_B500": {
            "name": "開始 3",
            "text": {
                "0_B500": "呜哇……"
            }
        },
        "0_B510": {
            "name": "開始 4",
            "text": {
                "0_B510": "要，要动手吗？　真的吗？"
            }
        },
        "0_B520": {
            "name": "勝利 3",
            "text": {
                "0_B520": "赢了吗，真的吗？"
            }
        },
        "0_B530": {
            "name": "勝利 4",
            "text": {
                "0_B530": "……我们应该，没见过吧。"
            }
        },
        "0_B540": {
            "name": "ダメージ 4",
            "text": {
                "0_B540": "哇哇哇！"
            }
        },
        "0_B550": {
            "name": "ダメージ 3",
            "text": {
                "0_B550": "哈～！"
            }
        },
        "0_B560": {
            "name": "戦闘不能 3",
            "text": {
                "0_B560": "呜哇～"
            }
        },
        "0_B570": {
            "name": "戦闘不能 4",
            "text": {
                "0_B570": "不行啦，不行！"
            }
        },
        "0_B800": {
            "name": "宝具 2",
            "text": {
                "0_B800": "……无论是我，还是你。",
                "0_B801": "会如这樱花般，",
                "0_B802": "终有一天虚缈地凋零。",
                "0_B803": "——『小町传说·佳人薄命』",
                "0_B804": "再见了……"
            }
        },
        "0_B810": {
            "name": "宝具 3",
            "text": {
                "0_B810": "……我明白。",
                "0_B811": "会如这樱花般，",
                "0_B812": "终有一天虚缈地凋零。",
                "0_B813": "——『小町传说·佳人薄命』",
                "0_B814": "呜呼，父亲大人……"
            }
        },
        "0_B840": {
            "name": "エクストラアタック 3",
            "text": {
                "0_B840": "【小野篁】恶业所感，阎魔王！"
            }
        },
        "0_B880": {
            "name": "スキル 5",
            "text": {
                "0_B880": "我最喜欢……少女漫画了！"
            }
        },
        "0_B890": {
            "name": "スキル 6",
            "text": {
                "0_B890": "真好，真好……"
            }
        },
        "0_B910": {
            "name": "アタック 7",
            "text": {
                "0_B910": "唔……？　噢噢～。"
            }
        },
        "0_B920": {
            "name": "アタック 8",
            "text": {
                "0_B920": "唔……？　啊啊～。"
            }
        },
        "0_B930": {
            "name": "アタック 9",
            "text": {
                "0_B930": "【小野篁】血池地狱！"
            }
        },
        "0_G010": {
            "name": "レベルアップ 1",
            "text": {
                "0_G010": "啊，谢谢。"
            }
        },
        "0_G110": {
            "name": "レベルアップ 2",
            "text": {
                "0_G110": "哇。"
            }
        },
        "0_G120": {
            "name": "レベルアップ 3",
            "text": {
                "0_G120": "非常感谢。"
            }
        },
        "0_H010": {
            "name": "誕生日",
            "text": {
                "0_H010": "【小野小町】那个……",
                "0_H011": "【小野小町】呃，嗯……",
                "0_H012": "【小野小町】——祝，祝您生日快乐！",
                "0_H013": "【小野小町】啊～好紧张。",
                "0_H014": "【小野小町】不，没什么，生日快乐！",
                "0_H015": "【小野篁】深呼吸，小町。",
                "0_H016": "【小野小町】吸～呼～。",
                "0_H017": "【小野小町】请允许与父亲大人一同向您献上祝福，御主大人！"
            }
        },
        "0_H020": {
            "name": "イベント開催中",
            "text": {
                "0_H020": "咦，祭典吗？",
                "0_H021": "活动……",
                "0_H022": "这是……什么意思呢……？"
            }
        },
        "0_H030": {
            "name": "会話 1",
            "text": {
                "0_H030": "要外出吗？",
                "0_H031": "需要我，陪同吗……？"
            }
        },
        "0_H040": {
            "name": "会話 2",
            "text": {
                "0_H040": "虽然我不太擅长战斗……",
                "0_H041": "但，但我会努力的。",
                "0_H042": "啊哈哈……"
            }
        },
        "0_H050": {
            "name": "会話 3",
            "text": {
                "0_H050": "御主大人喜欢什么样的故事呢？",
                "0_H051": "啊，不是故事也可以……",
                "0_H052": "诗歌，或是随笔都可以！"
            }
        },
        "0_H060": {
            "name": "好きなこと",
            "text": {
                "0_H060": "曾经的我最喜欢恋爱的诗歌。",
                "0_H061": "只有这一点直到现在我也记得很清楚。"
            }
        },
        "0_H070": {
            "name": "嫌いなこと",
            "text": {
                "0_H070": "讨厌的东西吗？",
                "0_H071": "让我想想……",
                "0_H072": "有倒是没有……",
                "0_H073": "啊哈哈。"
            }
        },
        "0_H080": {
            "name": "聖杯について",
            "text": {
                "0_H080": "圣杯……",
                "0_H081": "是能实现愿望的，东西吗？",
                "0_H082": "……啊～，唔～。",
                "0_H083": "别人的愿望暂且不论，自己的话，有些难以想象呢……",
                "0_H084": "这是为什么呢……？"
            }
        },
        "0_H090": {
            "name": "絆Lv.1",
            "text": {
                "0_H090": "那个……再次和您打个招呼，请多关照。",
                "0_H091": "我是小野小町。",
                "0_H092": "啊哈哈……"
            }
        },
        "0_H100": {
            "name": "絆Lv.2",
            "text": {
                "0_H100": "呃，那个……",
                "0_H101": "您有什么……喜欢的读物吗？",
                "0_H102": "什么都可以哦。",
                "0_H103": "现代有很多读物，真好。",
                "0_H104": "感觉无论有多少时间都不够用……"
            }
        },
        "0_H110": {
            "name": "絆Lv.3",
            "text": {
                "0_H110": "我的话，那个……",
                "0_H111": "很喜欢那种叫少女漫画的东西。",
                "0_H112": "里面充满了少女们朦胧的感情……",
                "0_H113": "啊～……好喜欢……"
            }
        },
        "0_H120": {
            "name": "絆Lv.4",
            "text": {
                "0_H120": "在我那个时代，更喜欢把感情寄托于诗歌之中。",
                "0_H121": "没想到现代也会采用这种表现形式啊……",
                "0_H122": "啊呜～……真美好！"
            }
        },
        "0_H130": {
            "name": "絆Lv.5",
            "text": {
                "0_H130": "今天我也会去图书馆！",
                "0_H131": "御主要不要一起去？",
                "0_H132": "很有意思哦！",
                "0_H133": "啊，不过在图书馆内要保持安静吧……",
                "0_H134": "感想交流还是留到其他地方去做吧！"
            }
        },
        "0_H170": {
            "name": "会話 4",
            "text": {
                "0_H170": "紫式部大人、清少纳言大人！",
                "0_H171": "太客气了，我怎么能算前辈呢……",
                "0_H172": "啊哈哈。"
            }
        },
        "0_H180": {
            "name": "会話 5",
            "text": {
                "0_H180": "那几位也是带着父亲大人一起现界的吗？",
                "0_H181": "唔嗯唔嗯……"
            }
        },
        "0_H190": {
            "name": "会話 6",
            "text": {
                "0_H190": "【小野篁】哦哦，红阎魔阁下。阎魔大人一直挂念着您呢。",
                "0_H191": "【小野小町】啊哇哇，父亲大人给您添麻烦了……"
            }
        },
        "0_H200": {
            "name": "会話 7",
            "text": {
                "0_H200": "【小野小町】怎么了，父亲大人？",
                "0_H201": "【小野篁】那位叫阿拉什的男人，莫非是……唔……",
                "0_H202": "【小野小町】怎么了？"
            }
        },
        "0_H210": {
            "name": "会話 8",
            "text": {
                "0_H210": "【小野篁】唔？　鞍马的……",
                "0_H211": "【小野篁】是大天狗阁下吗！　这还真是！",
                "0_H212": "【小野小町】哎，啊，父亲大人那么激动……？"
            }
        },
        "0_H220": {
            "name": "会話 9",
            "text": {
                "0_H220": "世界三大美女……",
                "0_H221": "哦，这又怎么了……",
                "0_H222": "……哎，我吗？　三大美女之一？",
                "0_H223": "哎～？",
                "0_H224": "啊哈哈，不可能啦。"
            }
        },
        "0_H300": {
            "name": "会話 10",
            "text": {
                "0_H300": "哇啊，怎，怎么了。",
                "0_H301": "玄奘三藏大人？　唐朝的高僧？",
                "0_H302": "咦，像观音菩萨……",
                "0_H303": "等一下，是说我吗！？",
                "0_H304": "没有没有，不可能的啦！"
            }
        },
        "0_I210": {
            "name": "小野小町古今抄 ～雪消月のキラキラ蓮華～ 8",
            "text": {
                "0_I210": "在这里好像可以把巧克力送出去哦。",
                "0_I211": "请加油哦！"
            }
        },
        "0_I220": {
            "name": "小野小町古今抄 ～雪消月のキラキラ蓮華～ 9",
            "text": {
                "0_I220": "决定好要送给谁了吗？",
                "0_I221": "啊啊……",
                "0_I222": "明明置身事外，却也会心跳加速呢……"
            }
        },
        "0_I230": {
            "name": "小野小町古今抄 ～雪消月のキラキラ蓮華～ 10",
            "text": {
                "0_I230": "情人节。",
                "0_I231": "应季的事件，是少女漫画中的看点之一。",
                "0_I232": "换作过去，说不定已经成季语了……",
                "0_I233": "哎？　在现代或许已经算季语了？",
                "0_I234": "是这样吗？"
            }
        },
        "0_I310": {
            "name": "小野小町古今抄 ～雪消月のキラキラ蓮華～ 11",
            "text": {
                "0_I310": "那个……",
                "0_I311": "您是打算把真爱巧克力……",
                "0_I312": "送给意中之人……",
                "0_I313": "不，没有，没什么！",
                "0_I314": "这是私事吧，不会说的吧。"
            }
        },
        "0_I320": {
            "name": "小野小町古今抄 ～雪消月のキラキラ蓮華～ 12",
            "text": {
                "0_I320": "全，全部完成了……吗！",
                "0_I321": "这这，这是何等惊人的……",
                "0_I322": "恋之强者啊……"
            }
        },
        "0_I420": {
            "name": "小野小町古今抄 ～雪消月のキラキラ蓮華～ 13",
            "text": {
                "0_I420": "据说在这里好像可以……收取巧克力。",
                "0_I421": "您做好心理准备了吗？"
            }
        },
        "0_I430": {
            "name": "小野小町古今抄 ～雪消月のキラキラ蓮華～ 14",
            "text": {
                "0_I430": "该从谁那里收取巧克力……",
                "0_I431": "您已经决定了吗？",
                "0_I432": "难道说，您还在犹豫……",
                "0_I433": "应该没有吧？"
            }
        },
        "0_I440": {
            "name": "小野小町古今抄 ～雪消月のキラキラ蓮華～ 15",
            "text": {
                "0_I440": "父亲大人如是说，",
                "0_I441": "「应该先从情书开始」……",
                "0_I442": "他似乎对巧克力没什么兴趣。",
                "0_I443": "您呢？"
            }
        },
        "0_I510": {
            "name": "小野小町古今抄 ～雪消月のキラキラ蓮華～ 16",
            "text": {
                "0_I510": "……唔，咦？",
                "0_I511": "我还以为情人节时期已经过去了……",
                "0_I512": "哎。",
                "0_I513": "难，难道说您……",
                "0_I514": "还有忘记收取的……！？",
                "0_I515": "啊哇哇哇，如果是的话，赶快！　赶快啊！"
            }
        },
        "0_I520": {
            "name": "小野小町古今抄 ～雪消月のキラキラ蓮華～ 17",
            "text": {
                "0_I520": "全部完成了……",
                "0_I521": "真是恭喜您了。",
                "0_I522": "那个，您该不会……",
                "0_I523": "拥有与恋爱相关的加护吧？",
                "0_I524": "不是吗？"
            }
        },
        "0_N010": {
            "name": "小野小町古今抄 ～雪消月のキラキラ蓮華～ 1",
            "text": {
                "0_N010": "呃，欢迎光临！",
                "0_N011": "我是小野小町。",
                "0_N012": "您可以在这里确认现在的进度哦。"
            }
        },
        "0_N020": {
            "name": "小野小町古今抄 ～雪消月のキラキラ蓮華～ 2",
            "text": {
                "0_N020": "……唔，啊，嗯。",
                "0_N021": "欢迎光临！",
                "0_N022": "是来确认进度的吧。请看吧。"
            }
        },
        "0_N030": {
            "name": "小野小町古今抄 ～雪消月のキラキラ蓮華～ 3",
            "text": {
                "0_N030": "嗯嗯，真是耐人寻味呢……",
                "0_N031": "无论是６０年代的少女漫画……",
                "0_N032": "还是７０年代、８０年代、９０年代、００年代的少女漫画，肯定都有各自不同的倾向……",
                "0_N033": "却也同时存在共通的表现……",
                "0_N034": "啊，对不起，是来确认进度的吧？",
                "0_N035": "请看吧！"
            }
        },
        "0_N040": {
            "name": "小野小町古今抄 ～雪消月のキラキラ蓮華～ 4",
            "text": {
                "0_N040": "父亲大人？",
                "0_N041": "您在吗？",
                "0_N042": "……咦，不在？",
                "0_N043": "其实是装作不在，实际在吧。"
            }
        },
        "0_N050": {
            "name": "小野小町古今抄 ～雪消月のキラキラ蓮華～ 5",
            "text": {
                "0_N050": "帮助信息……",
                "0_N051": "您确认过了？　吗？",
                "0_N052": "里面好像写了重要的事，",
                "0_N053": "请随时记得查看哦。"
            }
        },
        "0_N060": {
            "name": "小野小町古今抄 ～雪消月のキラキラ蓮華～ 6",
            "text": {
                "0_N060": "哈欠……",
                "0_N061": "呃，啊，咦？",
                "0_N062": "已经关店了啊……",
                "0_N063": "啊，嗯。您完全可以在这里休息哦～。"
            }
        },
        "0_N070": {
            "name": "小野小町古今抄 ～雪消月のキラキラ蓮華～ 7",
            "text": {
                "0_N070": "怎么了？",
                "0_N071": "啊，难道说，您想要看小町珍藏的少女漫画？",
                "0_N072": "请便请便。",
                "0_N073": "有很多哦！"
            }
        },
        "0_S010": {
            "name": "召喚",
            "text": {
                "0_S010": "——呃，初次见面。",
                "0_S011": "我是小野小町。",
                "0_S012": "我和您应该是初次见面吧……",
                "0_S013": "是这样吗……？"
            }
        },
        "1_B010": {
            "name": "アタック 1",
            "text": {
                "1_B010": "哎……呀！　接住！",
                "1_B2810": ""
            }
        },
        "1_B020": {
            "name": "アタック 2",
            "text": {
                "1_B020": "怎么样！　接住！",
                "1_B2820": ""
            }
        },
        "1_B030": {
            "name": "アタック 3",
            "text": {
                "1_B030": "哼！"
            }
        },
        "1_B040": {
            "name": "エクストラアタック 1",
            "text": {
                "1_B040": "【小野小町】他不在身旁 好似暗夜无月…… 【小野篁】假象展开·地狱草子！"
            }
        },
        "1_B050": {
            "name": "宝具 1",
            "text": {
                "1_B050": "──花开",
                "1_B051": "──花又落",
                "1_B052": "──红颜终蹉跎",
                "1_B053": "──长雨绵绵惹思索",
                "1_B054": "再见了……"
            }
        },
        "1_B080": {
            "name": "スキル 1",
            "text": {
                "1_B080": "这是父亲大人的教诲。"
            }
        },
        "1_B090": {
            "name": "スキル 2",
            "text": {
                "1_B090": "学习是很重要的。"
            }
        },
        "1_B100": {
            "name": "開始 1",
            "text": {
                "1_B100": "——明白了。你，是我们的敌人吧。"
            }
        },
        "1_B110": {
            "name": "開始 2",
            "text": {
                "1_B110": "打算，阻挡我们吧。"
            }
        },
        "1_B120": {
            "name": "勝利 1",
            "text": {
                "1_B120": "……结束了呢。"
            }
        },
        "1_B130": {
            "name": "勝利 2",
            "text": {
                "1_B130": "辛苦了。"
            }
        },
        "1_B140": {
            "name": "ダメージ 2",
            "text": {
                "1_B140": "唔……！"
            }
        },
        "1_B150": {
            "name": "ダメージ 1",
            "text": {
                "1_B150": "啊——！"
            }
        },
        "1_B160": {
            "name": "戦闘不能 1",
            "text": {
                "1_B160": "对不起……"
            }
        },
        "1_B170": {
            "name": "戦闘不能 2",
            "text": {
                "1_B170": "御主……！"
            }
        },
        "1_B180": {
            "name": "コマンドカード 1",
            "text": {
                "1_B180": "嗯。"
            }
        },
        "1_B190": {
            "name": "コマンドカード 2",
            "text": {
                "1_B190": "说得对。"
            }
        },
        "1_B200": {
            "name": "コマンドカード 3",
            "text": {
                "1_B200": "好……"
            }
        },
        "1_B2010": {
            "name": "アタック 10",
            "text": {
                "1_B2010": "【小野小町】拜托了！ 【小野篁】血池！"
            }
        },
        "1_B2020": {
            "name": "アタック 11",
            "text": {
                "1_B2020": "抓紧时间。"
            }
        },
        "1_B2030": {
            "name": "アタック 12",
            "text": {
                "1_B2030": "呵呵"
            }
        },
        "1_B210": {
            "name": "宝具カード 1",
            "text": {
                "1_B210": "是宝具吧。"
            }
        },
        "1_B220": {
            "name": "宝具カード 2",
            "text": {
                "1_B220": "明白了。"
            }
        },
        "1_B230": {
            "name": "宝具カード 3",
            "text": {
                "1_B230": "动手吧。"
            }
        },
        "1_B2410": {
            "name": "アタック 13",
            "text": {
                "1_B2410": "秋风吹起……"
            }
        },
        "1_B2420": {
            "name": "アタック 14",
            "text": {
                "1_B2420": "【小野小町】父亲大人！ 【小野篁】针山！"
            }
        },
        "1_B2430": {
            "name": "アタック 15",
            "text": {
                "1_B2430": "【小野小町】请吧。 【小野篁】喝！"
            }
        },
        "1_B2440": {
            "name": "エクストラアタック 4",
            "text": {
                "1_B2440": "【小野篁】阎魔王，劳您亲自前来，感激不尽。"
            }
        },
        "1_B250": {
            "name": "宝具カード 4",
            "text": {
                "1_B250": "真名解放……"
            }
        },
        "1_B410": {
            "name": "アタック 4",
            "text": {
                "1_B410": "失礼了。"
            }
        },
        "1_B420": {
            "name": "アタック 5",
            "text": {
                "1_B420": "叮铃叮铃。"
            }
        },
        "1_B430": {
            "name": "アタック 6",
            "text": {
                "1_B430": "不好意思了。"
            }
        },
        "1_B440": {
            "name": "エクストラアタック 2",
            "text": {
                "1_B440": "【小野小町】他不在身旁 好似暗夜无月…… 【小野篁】召唤·阎魔的一瞪！"
            }
        },
        "1_B480": {
            "name": "スキル 3",
            "text": {
                "1_B480": "思君方入梦……"
            }
        },
        "1_B490": {
            "name": "スキル 4",
            "text": {
                "1_B490": "浦间无海草　我已无心与君好……"
            }
        },
        "1_B500": {
            "name": "開始 3",
            "text": {
                "1_B500": "没办法了……"
            }
        },
        "1_B510": {
            "name": "開始 4",
            "text": {
                "1_B510": "动手吧。"
            }
        },
        "1_B520": {
            "name": "勝利 3",
            "text": {
                "1_B520": "胜利了呢，各位。"
            }
        },
        "1_B530": {
            "name": "勝利 4",
            "text": {
                "1_B530": "啊啊，那是，谁呢……"
            }
        },
        "1_B540": {
            "name": "ダメージ 4",
            "text": {
                "1_B540": "哇……！"
            }
        },
        "1_B550": {
            "name": "ダメージ 3",
            "text": {
                "1_B550": "唔……！"
            }
        },
        "1_B560": {
            "name": "戦闘不能 3",
            "text": {
                "1_B560": "竟然半途……"
            }
        },
        "1_B570": {
            "name": "戦闘不能 4",
            "text": {
                "1_B570": "我……还没……！"
            }
        },
        "1_B800": {
            "name": "宝具 2",
            "text": {
                "1_B800": "……无论是我，还是你。",
                "1_B801": "会如这樱花般，",
                "1_B802": "终有一天虚缈地凋零。",
                "1_B803": "——『小町传说·佳人薄命』",
                "1_B804": "再见了……"
            }
        },
        "1_B810": {
            "name": "宝具 3",
            "text": {
                "1_B810": "……我明白。",
                "1_B811": "会如这樱花般，",
                "1_B812": "终有一天虚缈地凋零。",
                "1_B813": "——『小町传说·佳人薄命』",
                "1_B814": "呜呼，父亲大人……"
            }
        },
        "1_B840": {
            "name": "エクストラアタック 3",
            "text": {
                "1_B840": "【小野篁】恶业所感，阎魔王！"
            }
        },
        "1_B880": {
            "name": "スキル 5",
            "text": {
                "1_B880": "嗯嗯……啊啊～，真好！"
            }
        },
        "1_B890": {
            "name": "スキル 6",
            "text": {
                "1_B890": "呜呼，真好……"
            }
        },
        "1_B910": {
            "name": "アタック 7",
            "text": {
                "1_B910": "啊啊……太美妙了。"
            }
        },
        "1_B920": {
            "name": "アタック 8",
            "text": {
                "1_B920": "嗯……太棒了！"
            }
        },
        "1_B930": {
            "name": "アタック 9",
            "text": {
                "1_B930": "【小野小町】父亲大人。 【小野篁】血池！"
            }
        },
        "1_G010": {
            "name": "レベルアップ 1",
            "text": {
                "1_G010": "……非常感谢。"
            }
        },
        "1_G020": {
            "name": "霊基再臨 2",
            "text": {
                "1_G020": "我能感受到，某种存在正在提升……",
                "1_G021": "某种存在……"
            }
        },
        "1_G030": {
            "name": "霊基再臨 1",
            "text": {
                "1_G030": "我是小野小町。",
                "1_G031": "——嗯，我是小野小町，不是其他人。",
                "1_G032": "当外形改变之后，",
                "1_G033": "心态也会发生，一些改变吗……"
            }
        },
        "1_G110": {
            "name": "レベルアップ 2",
            "text": {
                "1_G110": "呵呵。"
            }
        },
        "1_G120": {
            "name": "レベルアップ 3",
            "text": {
                "1_G120": "这样啊。"
            }
        },
        "1_H010": {
            "name": "誕生日",
            "text": {
                "1_H010": "【小野小町】祝你生日快乐。",
                "1_H011": "【小野小町】……其实，我本想为您吟唱一首诗歌，",
                "1_H012": "【小野小町】但对不起。",
                "1_H013": "【小野小町】那个，一不小心太投入了……",
                "1_H014": "【小野小町】结果画完了一整本分镜稿……",
                "1_H015": "【小野小町】啊，嗯。分镜稿。",
                "1_H016": "【小野小町】一整本以生日为题材的少女漫画分镜。",
                "1_H017": "【小野篁】……御主，不好意思，能请您收下吗？",
                "1_H018": "【小野小町】父，父亲大人……"
            }
        },
        "1_H020": {
            "name": "イベント開催中",
            "text": {
                "1_H020": "活动……",
                "1_H021": "是活动吧。您有何打算呢？"
            }
        },
        "1_H030": {
            "name": "会話 1",
            "text": {
                "1_H030": "要出门吗？",
                "1_H031": "嗯。那由我陪同。"
            }
        },
        "1_H040": {
            "name": "会話 2",
            "text": {
                "1_H040": "【小野小町】这个灵基比以前更善战了。",
                "1_H041": "【小野小町】对吧，父亲大人。",
                "1_H042": "【小野篁】……无需担心。有我在。"
            }
        },
        "1_H050": {
            "name": "会話 3",
            "text": {
                "1_H050": "御主？",
                "1_H051": "呵呵。"
            }
        },
        "1_H060": {
            "name": "好きなこと",
            "text": {
                "1_H060": "当然！",
                "1_H061": "我非常喜欢少女漫画。",
                "1_H062": "我觉得这算是现代的一种情诗。",
                "1_H063": "虽然我也很喜欢情歌，",
                "1_H064": "但还是当属少女漫画……"
            }
        },
        "1_H070": {
            "name": "嫌いなこと",
            "text": {
                "1_H070": "讨厌的东西是……",
                "1_H071": "我不太想提呢。"
            }
        },
        "1_H080": {
            "name": "聖杯について",
            "text": {
                "1_H080": "能够实现愿望之物，圣杯。",
                "1_H081": "要小心猴爪协议呢……"
            }
        },
        "1_H10090": {
            "name": "絆Lv.1",
            "text": {
                "1_H10090": "再次和您打个招呼，我是小野小町。",
                "1_H10091": "——没错，是货真价实您召唤的那个小町。",
                "1_H10092": "呵呵。"
            }
        },
        "1_H10100": {
            "name": "絆Lv.2",
            "text": {
                "1_H10100": "小野小町。",
                "1_H10101": "小野小町。",
                "1_H10102": "小野，小町……",
                "1_H10103": "……虽然我明白自己是这位女子，但生前的记忆却仿佛笼罩在迷雾中。",
                "1_H10104": "成为传说还真是不好办呢。"
            }
        },
        "1_H10110": {
            "name": "絆Lv.3",
            "text": {
                "1_H10110": "【小野小町】我的灵基……",
                "1_H10111": "【小野小町】虽然记忆仍然模糊不清，但有一件事是可以肯定的。",
                "1_H10112": "【小野小町】对吧，父亲大人。",
                "1_H10113": "【小野篁】……说得对。",
                "1_H10114": "【小野小町】嗯。",
                "1_H10115": "【小野小町】唯有父亲大人，永远是父亲大人。",
                "1_H10116": "【小野小町】我绝不会忘记。"
            }
        },
        "1_H10120": {
            "name": "絆Lv.4",
            "text": {
                "1_H10120": "御主大人。",
                "1_H10121": "能否借一步说句悄悄话。",
                "1_H10122": "现在父亲大人似乎不在……请听我说。",
                "1_H10123": "其实……",
                "1_H10124": "虽然我一直称他为父亲大人……",
                "1_H10125": "但我其实记不清是否真是如此了。",
                "1_H10126": "我究竟是那个人的女儿，还是孙女。",
                "1_H10127": "就算问他，他也不愿意告诉我……"
            }
        },
        "1_H10130": {
            "name": "絆Lv.5",
            "text": {
                "1_H10130": "……御主大人？",
                "1_H10131": "什么事？",
                "1_H10132": "啊……",
                "1_H10133": "……",
                "1_H10134": "『即便没有记忆，此刻心中的情感应该也是真实的』——这样吗。",
                "1_H10135": "……御主大人真是位温柔的人呢。",
                "1_H10136": "呵呵。非常感谢。"
            }
        },
        "1_H230": {
            "name": "会話 4",
            "text": {
                "1_H230": "清少纳言大人，紫式部大人。",
                "1_H231": "日安。",
                "1_H232": "二位近来可好？"
            }
        },
        "1_H250": {
            "name": "会話 5",
            "text": {
                "1_H250": "【小野小町】红阎魔大人。",
                "1_H251": "【小野小町】父亲大人一直承蒙您的关照……",
                "1_H252": "【小野篁】小町。",
                "1_H253": "【小野小町】什么？",
                "1_H254": "【小野小町】……没有，给您添麻烦吧？"
            }
        },
        "1_H260": {
            "name": "会話 6",
            "text": {
                "1_H260": "父亲大人失礼了，阿拉什大人。",
                "1_H261": "每当见到您，父亲大人似乎就会想起某个人……"
            }
        },
        "1_H270": {
            "name": "会話 7",
            "text": {
                "1_H270": "鬼一大人，怎么了？",
                "1_H271": "父亲大人吗？",
                "1_H272": "呵呵，没关系。他已经安静下来了。"
            }
        },
        "1_H280": {
            "name": "会話 8",
            "text": {
                "1_H280": "世界三大美女……",
                "1_H281": "这样吗。",
                "1_H282": "是这样的吗……"
            }
        },
        "2_B010": {
            "name": "アタック 1",
            "text": {
                "2_B010": "啊啊……"
            }
        },
        "2_B020": {
            "name": "アタック 2",
            "text": {
                "2_B020": "邪心……"
            }
        },
        "2_B030": {
            "name": "アタック 3",
            "text": {
                "2_B030": "嗯……"
            }
        },
        "2_B040": {
            "name": "エクストラアタック 1",
            "text": {
                "2_B040": "歌为心……心为歌……"
            }
        },
        "2_B050": {
            "name": "宝具 1",
            "text": {
                "2_B050": "──花开",
                "2_B051": "──花又落",
                "2_B052": "──红颜终蹉跎",
                "2_B053": "──长雨绵绵惹思索",
                "2_B054": "为你，带来拯救。"
            }
        },
        "2_B080": {
            "name": "スキル 1",
            "text": {
                "2_B080": "父亲大人……"
            }
        },
        "2_B090": {
            "name": "スキル 2",
            "text": {
                "2_B090": "【小野篁】唔……"
            }
        },
        "2_B100": {
            "name": "開始 1",
            "text": {
                "2_B100": "……好。"
            }
        },
        "2_B110": {
            "name": "開始 2",
            "text": {
