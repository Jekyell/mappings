        "2_H010": {
            "name": "誕生日",
            "text": {
                "2_H010": "诞生的日子？",
                "2_H011": "这样啊。",
                "2_H012": "……",
                "2_H013": "父亲大人似乎在远处说，应该送上祝福。",
                "2_H014": "说得对。",
                "2_H015": "……祝你生日快乐。",
                "2_H016": "为你的诞生，带来拯救。"
            }
        },
        "2_H020": {
            "name": "イベント開催中",
            "text": {
                "2_H020": "发生什么……",
                "2_H021": "事了吗？"
            }
        },
        "2_H030": {
            "name": "会話 1",
            "text": {
                "2_H030": "呵呵呵……"
            }
        },
        "2_H040": {
            "name": "会話 2",
            "text": {
                "2_H040": "什么事？"
            }
        },
        "2_H050": {
            "name": "会話 3",
            "text": {
                "2_H050": "你在努力吧。",
                "2_H051": "值得赞赏。"
            }
        },
        "2_H060": {
            "name": "好きなこと",
            "text": {
                "2_H060": "南无大慈大悲观世音菩萨……"
            }
        },
        "2_H070": {
            "name": "嫌いなこと",
            "text": {
                "2_H070": "无论什么时代，都有无法被拯救的存在。",
                "2_H071": "令人悲伤。"
            }
        },
        "2_H080": {
            "name": "聖杯について",
            "text": {
                "2_H080": "圣杯……",
                "2_H081": "啊，如意宝珠。",
                "2_H082": "想要吗？"
            }
        },
        "2_H20090": {
            "name": "絆Lv.1",
            "text": {
                "2_H20090": "呵呵……"
            }
        },
        "2_H20100": {
            "name": "絆Lv.2",
            "text": {
                "2_H20100": "什么事……？",
                "2_H20101": "有什么，变化吗？"
            }
        },
        "2_H20110": {
            "name": "絆Lv.3",
            "text": {
                "2_H20110": "是的。",
                "2_H20111": "所谓的灵基，发生了变化。",
                "2_H20112": "虽然只是细枝末节……"
            }
        },
        "2_H20120": {
            "name": "絆Lv.4",
            "text": {
                "2_H20120": "南无大慈大悲观世音菩萨……",
                "2_H20121": "为众生，带来拯救，带来慈悲。",
                "2_H20122": "唵·阿噜力迦·娑婆诃。",
                "2_H20123": "对你亦然。"
            }
        },
        "2_H20130": {
            "name": "絆Lv.5",
            "text": {
                "2_H20130": "这个形象的话……",
                "2_H20131": "呜呼，说得对。",
                "2_H20132": "听不见，父亲大人的声音了……",
                "2_H20133": "……会感到寂寞，是因为此身尚不成熟呢。"
            }
        },
        "2_H290": {
            "name": "会話 4",
            "text": {
                "2_H290": "哎呀，那位是……",
                "2_H291": "这样啊，这样啊。",
                "2_H292": "大陆的玄奘三藏……",
                "2_H293": "呵呵……"
            }
        }
