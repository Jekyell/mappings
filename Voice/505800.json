            "text": {
                "0_B110": "咦？　哎？　什么？"
            }
        },
        "0_B120": {
            "name": "勝利 1",
            "text": {
                "0_B120": "咦？　结束了吗？"
            }
        },
        "0_B130": {
            "name": "勝利 2",
            "text": {
                "0_B130": "太棒了，结束了！"
            }
        },
        "0_B140": {
            "name": "ダメージ 2",
            "text": {
                "0_B140": "好痛！"
            }
        },
        "0_B150": {
