{
    "id": 205500,
    "collectionNo": 205500,
    "name": "ウルズ",
    "voices": {
        "0_B010": {
            "name": "アタック 1(真名判明後)",
            "text": {
                "0_B010": "哈。"
            },
            "raw_text": {
                "0_B010": "はっ。"
            }
        },
        "0_B020": {
            "name": "アタック 2(真名判明後)",
            "text": {
                "0_B020": "嘿。"
            },
            "raw_text": {
                "0_B020": "せっ。"
            }
        },
        "0_B030": {
            "name": "アタック 3(真名判明後)",
            "text": {
                "0_B030": "真是的。"
            },
            "raw_text": {
                "0_B030": "まったく。"
            }
        },
        "0_B040": {
            "name": "エクストラアタック 1(真名判明後)",
            "text": {
                "0_B040": "纺织世界，编织人类。"
            },
            "raw_text": {
                "0_B040": "世界を紡ぎ人を編む。"
            }
        },
        "0_B050": {
            "name": "宝具 1(真名判明後)",
            "text": {
                "0_B050": "过去并非不可动摇，而是由我的权能所支配之物。",
                "0_B051": "你已败北，坠落于地。",
                "0_B052": "——兀儿德·斯拉兹尔·霍恩。",
                "0_B053": "这正是你命中注定的命运。"
            },
            "raw_text": {
                "0_B050": "過去は不動にあらず、我が剣能によって支配するもの。汝は敗北し、地に堕ちた。ウルザルスラズルフォルン。それこそが汝の運命であったのです。",
                "0_B051": "",
                "0_B052": "",
                "0_B053": ""
            }
        },
        "0_B080": {
            "name": "スキル 1(真名判明後)",
            "text": {
                "0_B080": "不知您是否享用了呢？"
            },
            "raw_text": {
                "0_B080": "召し上がったかしら。"
            }
        },
        "0_B090": {
            "name": "スキル 2(真名判明後)",
            "text": {
                "0_B090": "汝之过去已然注定。"
            },
            "raw_text": {
                "0_B090": "汝の過去が決まりました。"
            }
        },
        "0_B100": {
            "name": "開始 1(真名判明後)",
            "text": {
                "0_B100": "看来你很想刻下败北的过去呢。很好。"
            },
            "raw_text": {
                "0_B100": "敗北の過去を刻みたかったのね。よろしい。"
            }
        },
        "0_B110": {
            "name": "開始 2(真名判明後)",
            "text": {
                "0_B110": "就交给女神我吧。我会稍微享受一下的。"
            },
            "raw_text": {
                "0_B110": "女神様に任せなさい。ちょっと楽しかったわ。"
            }
        },
        "0_B120": {
            "name": "勝利 1(真名判明後)",
            "text": {
                "0_B120": "我们胜利了。不，是已经胜利了？这可不行呢，时间轴有些模糊了。"
            },
            "raw_text": {
                "0_B120": "勝利しました。あいえ、勝利しています？いけないわね、時間軸が曖昧だった。"
            }
        },
        "0_B130": {
            "name": "勝利 2(真名判明後)",
            "text": {
                "0_B130": "是为了战败才战斗的吗？你们真是愚蠢之人。不，是曾经愚蠢。"
            },
            "raw_text": {
                "0_B130": "負けるために戦ったのかしら。汝らは愚か者です。ないえ、でした。"
            }
        },
        "0_B140": {
            "name": "ダメージ 2(真名判明後)",
            "text": {
                "0_B140": "没用的。"
            },
            "raw_text": {
                "0_B140": "無駄。"
            }
        },
        "0_B150": {
            "name": "ダメージ 1(真名判明後)",
            "text": {
                "0_B150": "这是……"
            },
            "raw_text": {
                "0_B150": "これは。"
            }
        },
        "0_B160": {
            "name": "戦闘不能 1(真名判明後)",
            "text": {
                "0_B160": "时间无法倒流。无法倒流了啊……"
            },
            "raw_text": {
                "0_B160": "時間が戻らない。戻らないの。"
            }
        },
        "0_B170": {
            "name": "戦闘不能 2(真名判明後)",
            "text": {
                "0_B170": "这也是早已注定的事。对吧？"
            },
            "raw_text": {
                "0_B170": "これも決まっていたこと。ね。"
            }
        },
        "0_B180": {
            "name": "コマンドカード 1(真名判明後)",
            "text": {
                "0_B180": "嗯。"
            },
            "raw_text": {
                "0_B180": "ええ。"
            }
        },
        "0_B190": {
            "name": "コマンドカード 2(真名判明後)",
            "text": {
                "0_B190": "哎呀呀。"
            },
            "raw_text": {
                "0_B190": "あらまあ。"
            }
        },
        "0_B200": {
            "name": "コマンドカード 3(真名判明後)",
            "text": {
                "0_B200": "是。"
            },
            "raw_text": {
                "0_B200": "はい。"
            }
        },
        "0_B2010": {
            "name": "アタック 10(真名判明後)",
            "text": {
                "0_B2010": "贯穿了。"
            },
            "raw_text": {
                "0_B2010": "貫抜きました。"
            }
        },
        "0_B2020": {
            "name": "アタック 11(真名判明後)",
            "text": {
                "0_B2020": "莉莉安光束。"
            },
            "raw_text": {
                "0_B2020": "リリアンビーム。"
            }
        },
        "0_B2030": {
            "name": "アタック 12(真名判明後)",
            "text": {
                "0_B2030": "宛如波涛。"
            },
            "raw_text": {
                "0_B2030": "波涛のように。"
            }
        },
        "0_B210": {
            "name": "宝具カード 1(真名判明後)",
            "text": {
                "0_B210": "看来你消耗了许多呢。"
            },
            "raw_text": {
                "0_B210": "多くを使ったのですね。"
            }
        },
        "0_B220": {
            "name": "宝具カード 2(真名判明後)",
            "text": {
                "0_B220": "编织……啊，不，我要使用了。"
            },
            "raw_text": {
                "0_B220": "オーム、ああいいえ、使いますね。"
            }
        },
        "0_B230": {
            "name": "宝具カード 3(真名判明後)",
            "text": {
                "0_B230": "要结束了呢。"
            },
            "raw_text": {
                "0_B230": "終わらせますね。"
            }
        },
        "0_B2410": {
            "name": "アタック 13(真名判明後)",
            "text": {
                "0_B2410": "我把您击飞了。"
            },
            "raw_text": {
                "0_B2410": "殴り飛ばしましたわ。"
            }
        },
        "0_B2420": {
            "name": "アタック 14(真名判明後)",
            "text": {
                "0_B2420": "退下。"
            },
            "raw_text": {
                "0_B2420": "控えよ。"
            }
        },
        "0_B2430": {
            "name": "アタック 15(真名判明後)",
            "text": {
                "0_B2430": "此乃命运。"
            },
            "raw_text": {
                "0_B2430": "運命でした。"
            }
        },
        "0_B2810": {
            "name": "アタック 16(真名判明後)",
            "text": {
                "0_B2810": "解体。"
            },
            "raw_text": {
                "0_B2810": "解体。"
            }
        },
        "0_B2820": {
            "name": "アタック 17(真名判明後)",
            "text": {
                "0_B2820": "分离作业。"
            },
            "raw_text": {
                "0_B2820": "分離作業。"
            }
        },
        "0_B2830": {
            "name": "アタック 18(真名判明後)",
            "text": {
                "0_B2830": "此乃可悲之事。"
            },
            "raw_text": {
                "0_B2830": "悲しきことです。"
            }
        },
        "0_B3010": {
            "name": "アタック 19(真名判明後)",
            "text": {
                "0_B3010": "原来是在那里。"
            },
            "raw_text": {
                "0_B3010": "そこでした。"
            }
        },
        "0_B410": {
            "name": "アタック 4(真名判明後)",
            "text": {
                "0_B410": "穿透吧。"
            },
            "raw_text": {
                "0_B410": "うがたれよ。"
            }
        },
        "0_B420": {
            "name": "アタック 5(真名判明後)",
            "text": {
                "0_B420": "愚者之雨。"
            },
            "raw_text": {
                "0_B420": "愚者の雨。"
            }
        },
        "0_B430": {
            "name": "アタック 6(真名判明後)",
            "text": {
                "0_B430": "轮转起来了呢。"
            },
            "raw_text": {
                "0_B430": "回りましたね。"
            }
        },
        "0_B440": {
            "name": "エクストラアタック 2(真名判明後)",
            "text": {
                "0_B440": "解明时间，眷爱大地。"
            },
            "raw_text": {
                "0_B440": "時をひもとき地を愛す。"
            }
        },
        "0_B480": {
            "name": "スキル 3(真名判明後)",
            "text": {
                "0_B480": "真是滑稽呢。"
            },
            "raw_text": {
                "0_B480": "おかしかったわ。"
            }
        },
        "0_B490": {
            "name": "スキル 4(真名判明後)",
            "text": {
                "0_B490": "你这人，倒挺有趣的呢。"
            },
            "raw_text": {
                "0_B490": "面白かったわね、あなた。"
            }
        },
        "0_B500": {
            "name": "開始 3(真名判明後)",
            "text": {
                "0_B500": "原来是战争啊。挥霍生命与财产，就那么令人快乐吗？"
            },
            "raw_text": {
                "0_B500": "戦争だったのね。生命と財産を浪費して楽しいものなの？"
            }
        },
        "0_B510": {
            "name": "開始 4(真名判明後)",
            "text": {
                "0_B510": "动手杀了呢。这也是无可奈何的事吧。"
            },
            "raw_text": {
                "0_B510": "殺したわ。仕方なかったわね。"
            }
        },
        "0_B540": {
            "name": "ダメージ 4(真名判明後)",
            "text": {
                "0_B540": "唔。"
            },
            "raw_text": {
                "0_B540": "くっ。"
            }
        },
        "0_B550": {
            "name": "ダメージ 3(真名判明後)",
            "text": {
                "0_B550": "住手吧。"
            },
            "raw_text": {
                "0_B550": "やめなさい。"
            }
        },
        "0_B560": {
            "name": "戦闘不能 3",
            "text": {
                "0_B560": "必须改变……这个过去……"
            },
            "raw_text": {
                "0_B560": "この過去を変えないと。"
            }
        },
        "0_B800": {
            "name": "宝具 2(真名判明後)",
            "text": {
                "0_B800": "终焉已然开始。丝线断裂，过去动摇。",
                "0_B801": "时间啊，倒流吧。你曾是如此美丽。",
                "0_B802": "——兀儿德·斯拉兹尔·霍恩。",
                "0_B803": "肃然接受这命运吧。"
            },
            "raw_text": {
                "0_B800": "終焉を開始しました。糸はほつれ、過去は揺らぐ。時を巻き戻れ。汝はかつて美しかった。ウルザルスラツルフォルン。この運命を粛々と受け入れよ。",
                "0_B801": "",
                "0_B802": "",
                "0_B803": ""
            }
        },
        "0_B910": {
            "name": "アタック 7(真名判明後)",
            "text": {
                "0_B910": "飞石。"
            },
            "raw_text": {
                "0_B910": "歴代。"
            }
        },
        "0_B920": {
            "name": "アタック 8(真名判明後)",
            "text": {
                "0_B920": "倾泻而下了哦。"
            },
            "raw_text": {
                "0_B920": "降り注ぎましたよ。"
            }
        },
        "0_B930": {
            "name": "アタック 9(真名判明後)",
            "text": {
                "0_B930": "这是温柔的雨。"
            },
            "raw_text": {
                "0_B930": "優しい雨です。"
            }
        },
        "0_G010": {
            "name": "レベルアップ 1(真名判明後)",
            "text": {
                "0_G010": "冷气得到了强化。虽然还远不及全盛时期就是了。",
                "0_G011": ""
            },
            "raw_text": {
                "0_G010": "冷気が強化されました。まだまだ全盛期に渡りませんが。",
                "0_G011": ""
            }
        },
        "0_G020": {
            "name": "霊基再臨 2(真名判明後)",
            "text": {
                "0_G020": "羽化即将完成了。也就是说，马上就要过渡到下一个灵基了哦。",
                "0_G021": ""
            },
            "raw_text": {
                "0_G020": "羽化は間もなくでした。つまり、もうすぐ次の霊気に移るということですよ。",
                "0_G021": ""
            }
        },
        "0_G030": {
            "name": "霊基再臨 1(真名判明後)",
            "text": {
                "0_G030": "配合现代的文化水平，我试着改变了灵基。适合我吗？失礼了。应该说很适合我吧？呵呵。看到你那副表情，答案就已经心知肚明了。毕竟这可是最前沿的流行款式呢。诶？有点不对？诶？诶——",
                "0_G031": "",
                "0_G032": "",
                "0_G033": "",
                "0_G034": "",
                "0_G035": "",
                "0_G036": ""
            },
            "raw_text": {
                "0_G030": "現代の文化レベルに合わせて、礼器を変化させてみました。似合いましたか？失礼。似合っているでしょう？ええへ。その顔を見たなら、答えは分かっています。なにしろ、最先端の流行ですからね。え？ちょっと違う。え？えー。",
                "0_G031": "",
                "0_G032": "",
                "0_G033": "",
                "0_G034": "",
                "0_G035": "",
                "0_G036": ""
            }
        },
        "0_G110": {
            "name": "レベルアップ 2(真名判明後)",
            "text": {
                "0_G110": "味道相当不错呢。嗯。",
                "0_G111": ""
            },
            "raw_text": {
                "0_G110": "味はなかなかいいですね。ふむ。",
                "0_G111": ""
            }
        },
        "0_H010": {
            "name": "誕生日(真名判明後)",
            "text": {
                "0_H010": "哎呀，又积累了一层过去呢。也就是说，祝你生日快乐。要好好珍惜积累起来的过去哦。不过，要是想篡改它的话，随时可以跟我说。",
                "0_H011": "",
                "0_H012": "",
                "0_H013": ""
            },
            "raw_text": {
                "0_H010": "あら、また一つ過去を積み上げたのね。つまり、お誕生日おめでとうということですけど。積み上げた過去を大切になさい。でも、改ざんしたいならいつでも声をかけてね。",
                "0_H011": "",
                "0_H012": "",
                "0_H013": ""
            }
        },
        "0_H020": {
            "name": "イベント開催中(真名判明後)",
            "text": {
                "0_H020": "听说活动正在举办中哦。啊，不对，现在好像一直都是这样呢。",
                "0_H021": ""
            },
            "raw_text": {
                "0_H020": "イベント開催中だったそうよ。あいえ、今ずっとそうみたいよ。",
                "0_H021": ""
            }
        },
        "0_H030": {
            "name": "会話 1(真名判明後)",
            "text": {
                "0_H030": "再不出击的话，可是会降下神罚的哦。"
            },
            "raw_text": {
                "0_H030": "出撃しないと神罰です。"
            }
        },
        "0_H040": {
            "name": "会話 2(真名判明後)",
            "text": {
                "0_H040": "既然我是女神，就会赋予汝信徒的地位。毕竟作为神，还是有敬仰我的人类在比较好。",
                "0_H041": ""
            },
            "raw_text": {
                "0_H040": "私が女神である以上、汝には信奉者の地位が与えられます。神としては、私を敬う人間がいた方が良いので。",
                "0_H041": ""
            }
        },
        "0_H050": {
            "name": "会話 3(真名判明後)",
            "text": {
                "0_H050": "虽然本应是魔力供给关系，但汝的魔力似乎有些不足呢。请增加到大约一个城市的分量吧。",
                "0_H051": ""
            },
            "raw_text": {
                "0_H050": "魔力供与関係のはずですが、汝はどうも魔力が足りないですね。一都市分くらい増やしてください。",
                "0_H051": ""
            }
        },
        "0_H060": {
            "name": "好きなこと(真名判明後)",
            "text": {
                "0_H060": "喜欢的事物吗？盛装打扮是比什么都美妙的事情哦。",
                "0_H061": ""
            },
            "raw_text": {
                "0_H060": "好きなことですか着飾ることは何よりも素晴らしいものですよ。",
                "0_H061": ""
            }
        },
        "0_H070": {
            "name": "嫌いなこと(真名判明後)",
            "text": {
                "0_H070": "讨厌的事物吗？我以前很讨厌懊悔过去的人类呢。",
                "0_H071": ""
            },
            "raw_text": {
                "0_H070": "嫌いなものですか。過去を悔やむ人間は嫌いでしたよ。",
                "0_H071": ""
            }
        },
        "0_H080": {
            "name": "聖杯について(真名判明後)",
            "text": {
                "0_H080": "圣杯吗？作为魔力资源来说，感觉还远远不够呢。如果能给我一百个左右的话，那就太感谢了。",
                "0_H081": "",
                "0_H082": ""
            },
            "raw_text": {
                "0_H080": "聖杯ですか。魔力リソースとしてはまだまだという感じですね。百ほど頂ければありがたいですが。",
                "0_H081": "",
                "0_H082": ""
            }
        },
        "0_H090": {
            "name": "絆Lv.1",
            "text": {
                "0_H090": "有什么事吗？"
            },
            "raw_text": {
                "0_H090": "なんでしょう。"
            }
        },
        "0_H100": {
            "name": "絆Lv.2",
            "text": {
                "0_H100": "怎么了吗？",
                "0_H101": ""
            },
            "raw_text": {
                "0_H100": "どうしましたか。",
                "0_H101": ""
            }
        },
        "0_H10090": {
            "name": "絆Lv.1(真名判明後)",
            "text": {
                "0_H10090": "御主，刚才找我有什么事吗？"
            },
            "raw_text": {
                "0_H10090": "マスター、何か用でしたか。"
            }
        },
        "0_H10100": {
            "name": "絆Lv.2(真名判明後)",
            "text": {
                "0_H10100": "我可是女神。多少崇拜我一下吧。虽说我是由“自称”具现化而成的类型，但只要有信徒的话，我也会干劲满满的。",
                "0_H10101": "",
                "0_H10102": ""
            },
            "raw_text": {
                "0_H10100": "女神です。少しは崇拝しなさい。私は自称が具現化したタイプとはいえ、信じる者がいれば愛愛が出るので。",
                "0_H10101": "",
                "0_H10102": ""
            }
        },
        "0_H10110": {
            "name": "絆Lv.3(真名判明後)",
            "text": {
                "0_H10110": "真是值得赞许的态度。以你的标准来说做得相当不错呢。诶？在说什么？接下来不是御主要向我献上侍奉吗？不是？那我要去篡改过去咯。",
                "0_H10111": "",
                "0_H10112": "",
                "0_H10113": "",
                "0_H10114": "",
                "0_H10115": ""
            },
            "raw_text": {
                "0_H10110": "いい心がけでした。汝にしてはなかなかやりますね。え？何の話？今からマスターが私に奉仕してくださるのでしょう？違う？過去を改ざんしますね。",
                "0_H10111": "",
                "0_H10112": "",
                "0_H10113": "",
                "0_H10114": "",
                "0_H10115": ""
            }
        },
        "0_H10120": {
            "name": "絆Lv.4(真名判明後)",
            "text": {
                "0_H10120": "好了，被你这样夸奖，我刚才都有些害羞了呢。你会夸我的对吧？很好。但是，你得再多学点华丽的辞藻。粗糙的夸奖方式，作为女神可不怎么欣赏哦。",
                "0_H10121": "",
                "0_H10122": "",
                "0_H10123": "",
                "0_H10124": ""
            },
            "raw_text": {
                "0_H10120": "さあ、そんなに褒められると照れくさかったですよ。褒めますよね。よろしい。ですが、もう少しビジュレイクを覚えなさい。雑な褒め方は女神的に感心しませんから。",
                "0_H10121": "",
                "0_H10122": "",
                "0_H10123": "",
                "0_H10124": ""
            }
        },
        "0_H10130": {
            "name": "絆Lv.5(真名判明後)",
            "text": {
                "0_H10130": "用我的力量，来帮你修改过去吧。你打算怎么做？是吗，不行吗？不，我早就料到你会这么说了，所以没关系。因为你无论何时，都选择了不留遗憾的生存方式。这一点作为人类来说，我很中意。",
                "0_H10131": "",
                "0_H10132": "",
                "0_H10133": "",
                "0_H10134": "",
                "0_H10135": ""
            },
            "raw_text": {
                "0_H10130": "私の力で、あなたの過去を変更してあげますよ。どうします？そうですか。ダメですか。いいえ。あなたならそう言っただろうな、とは考えていたので、問題はありません。だってあなたは、いつだって後悔しない生き方を選んだのですから。そういうところは、人として好ましいです。",
                "0_H10131": "",
                "0_H10132": "",
                "0_H10133": "",
                "0_H10134": "",
                "0_H10135": ""
            }
        },
        "0_H110": {
            "name": "絆Lv.3",
            "text": {
                "0_H110": "好啦好啦，找兀儿德有什么事吗？是要读什么书吗？不，要我读给你听吗？我可是很擅长读绘本给别人听的哦。",
                "0_H111": "",
                "0_H112": ""
            },
            "raw_text": {
                "0_H110": "はいはい、時子さんに何か用でしたか。本でも読みましたか。いえ、読みますか。絵本の読み聞かせとか、得意ですよ。",
                "0_H111": "",
                "0_H112": ""
            }
        },
        "0_H11600": {
            "name": "絆Lv.4\n(真名判明後+郷愁永巡刻盤 パスト・カルデアクリア以降)",
            "text": {
                "0_H11600": "我失败了。这一点我承认。但是，如果你以为我很弱，那就大错特错了。我可是女神。而且，是掌管时间的女神。或者说，在某种意义上我就是时间本身。也就是说，用你们国家的童话来打比方，让你迎来“浦岛太郎式的结局”也是轻而易举的事。感到恐惧颤抖了吗？",
                "0_H11601": "",
                "0_H11602": "",
                "0_H11603": "",
                "0_H11604": "",
                "0_H11605": "",
                "0_H11606": "",
                "0_H11607": ""
            },
            "raw_text": {
                "0_H11600": "私は敗北しました。それは認めます。しかし。私が弱いと思ったら大間違いですよ。女神ですので。しかも。時間を司る女神ですよ。というより、ある意味では時間そのものです。つまり。あなたの国の童話で言うところの。浦島太郎エンドにするのも簡単ということです。恐れ慄きましたか？",
                "0_H11601": "",
                "0_H11602": "",
                "0_H11603": "",
                "0_H11604": "",
                "0_H11605": "",
                "0_H11606": "",
                "0_H11607": ""
            }
        },
        "0_H11800": {
            "name": "絆Lv.5\n(真名判明後+郷愁永巡刻盤 パスト・カルデアクリア以降)",
            "text": {
                "0_H11800": "为什么我没能及得上你呢。虽然每当有机会我都会思考，但无论如何也想不通。究竟是为什么呢。是因为过去足够强大？是因为想要守护当下？还是因为相信未来会无比美好？在明白这一点之前，我打算一直与你同行。是的。",
                "0_H11801": "",
                "0_H11802": "",
                "0_H11803": "",
                "0_H11804": "",
                "0_H11805": ""
            },
            "raw_text": {
                "0_H11800": "なぜ私はあなたに及ばなかったのか。折に触れては考えていたのですが。どうしても分からなかった。なぜでしょうね。過去が強かったから。今を守りたかったから。未来が素晴らしいと信じていたから。それが分かる日まで。私はあなたと共にいるつもりですよ。ええ。",
                "0_H11801": "",
                "0_H11802": "",
                "0_H11803": "",
                "0_H11804": "",
                "0_H11805": ""
            }
        },
        "0_H120": {
            "name": "絆Lv.4",
            "text": {
                "0_H120": "“终末的弓兵”。呵呵，我觉得自己刚才那样挺帅气的呢。诶，啊，你什么时候在那里的？呜，这、那个，但是，真的很帅气对吧？对吧？",
                "0_H121": "",
                "0_H122": "",
                "0_H123": "",
                "0_H124": "",
                "0_H125": ""
            },
            "raw_text": {
                "0_H120": "終末のアーチャー。うふふ、我ながらかっこよかったですね。え、あ、いつからそこに？う、こ、えっと、その、でもかっこいいんですよね？ね？",
                "0_H121": "",
                "0_H122": "",
                "0_H123": "",
                "0_H124": "",
                "0_H125": ""
            }
        },
        "0_H130": {
            "name": "絆Lv.5",
            "text": {
                "0_H130": "明明连我的名字都不知道，却还与我加深羁绊的您。如果知道了我的真面目，说不定会感到失望吧。这稍微有点让人害怕呢。产生这种心情还是有生以来第一次。毕竟我可是女神啊。啊，说漏嘴了。",
                "0_H131": "",
                "0_H132": "",
                "0_H133": "",
                "0_H134": "",
                "0_H135": ""
            },
            "raw_text": {
                "0_H130": "私の名前もわからないのに、絆を深めてくださったあなた。私の正体を知れば、もしかすると落胆してしまうかもしれません。それはちょっと怖いですね。こんな気持ちになるのは生まれて初めてです。なにしろ女神なので。あ、いっちゃった。",
                "0_H131": "",
                "0_H132": "",
                "0_H133": "",
                "0_H134": "",
                "0_H135": ""
            }
        },
        "0_H170": {
            "name": "会話 4(真名判明後)",
            "text": {
                "0_H170": "那边的少女，稍微等一下。名字是？这样啊，叫莉莉丝啊。因为这是你未曾记录的记忆，所以你可能没什么实感。你似乎，踏入了我的领域呢。虽然应该不会有第二次了，但可别再有下次了。下一次，你可就要背负起大罪了哦。",
                "0_H171": "",
                "0_H172": "",
                "0_H173": "",
                "0_H174": "",
                "0_H175": ""
            },
            "raw_text": {
                "0_H170": "そこな少女、少し待ちなさい。名前は？そう、メルトリリスっていうのね。あなたには登録されていない記憶だからピンと来ないでしょうけど。あなたはどうも、私の領域に踏み込んだようね。二度はないでしょうけど、次はしないことね。今度は滞在を背負う羽目になるわよ。",
                "0_H171": "",
                "0_H172": "",
                "0_H173": "",
                "0_H174": "",
                "0_H175": ""
            }
        },
        "0_H180": {
            "name": "会話 5(真名判明後)",
            "text": {
                "0_H180": "那边的Caster，你……原来如此，那种方法也是可行的呢。不过，总觉得像是把麻烦事推给了你一样。明明是我们九界的大神，真是的。况且，关于女武神的事也是……啊，已经走了呢。",
                "0_H181": "",
                "0_H182": "",
                "0_H183": "",
                "0_H184": "",
                "0_H185": ""
            },
            "raw_text": {
                "0_H180": "そこのキャスター、あなたは。なるほど、そういう方法もありということですね。しかし、面倒ごとをあなたに押し付けたような。我らが九つの領域の対心でありながら、全くも。だいたい、ワルキューレの件にしても。いなくなりましたね。",
                "0_H181": "",
                "0_H182": "",
                "0_H183": "",
                "0_H184": "",
                "0_H185": ""
            }
        },
        "0_S010": {
            "name": "召喚(真名判明後)",
            "text": {
                "0_S010": "看来我回应了你的召唤呢。那么，为我引路吧。名字？你不知道吗？也是呢，你们确实还不知道。我的名字是兀尔德。命运三女神——诺恩之一。我是司掌过去之人。你们的过去并非命中注定，正如未来是一张白纸，过去同样也是白纸。那么，请吧。",
                "0_S011": "",
                "0_S012": "",
                "0_S013": "",
                "0_S014": "",
                "0_S015": "",
                "0_S016": ""
            },
            "raw_text": {
                "0_S010": "召喚に応じてしまったわね。では案内しなさい。名前？知らなかった？そうでしたね。汝らは知らなかったのでした。私の名はウルツ。運命の三女神。ノルニルの一柱。私は過去を司るもの。汝らの過去は決まったものではなく、未来が白紙なのと同様に、過去も白紙であるのです。では。",
                "0_S011": "",
                "0_S012": "",
                "0_S013": "",
                "0_S014": "",
                "0_S015": "",
                "0_S016": ""
            }
        },
        "0_S110": {
            "name": "召喚\n(真名判明後+郷愁永巡刻盤 パスト・カルデアクリア以降)",
            "text": {
                "0_S110": "我回应你的召唤了。来，你应该知道我的名字吧？不过，这样是不是有些失礼了呢。真是没办法。我的名字是兀儿德。虽然败给了你们，但那也可以说是胜利呢。为什么？这很简单吧？因为你们已经被我夺去了心神，甚至都将我召唤出来了。对吧？",
                "0_S111": "",
                "0_S112": "",
                "0_S113": "",
                "0_S114": "",
                "0_S115": "",
                "0_S116": "",
                "0_S117": "",
                "0_S118": ""
            },
            "raw_text": {
                "0_S110": "召喚に応じてあげたわ。そら、名前は知っているでしょう？でも、失礼だったかしら。仕方ありませんね。我が名はウルツ。汝らに敗北しましたが、それは勝利であったとも言えるのです。なぜ？簡単でしょう？私を召喚するほどに、心奪われたのですから。ね？",
                "0_S111": "",
                "0_S112": "",
                "0_S113": "",
                "0_S114": "",
                "0_S115": "",
                "0_S116": "",
                "0_S117": "",
                "0_S118": ""
            }
        },
        "2_B010": {
            "name": "アタック 1(真名判明後)",
            "text": {
                "2_B010": "真难看。"
            },
            "raw_text": {
                "2_B010": "ブザマ。"
            }
        },
        "2_B020": {
            "name": "アタック 2(真名判明後)",
            "text": {
                "2_B020": "闪耀。"
            },
            "raw_text": {
                "2_B020": "グロー。"
            }
        },
        "2_B030": {
            "name": "アタック 3(真名判明後)",
            "text": {
                "2_B030": "放肆。"
            },
            "raw_text": {
                "2_B030": "不遜。"
            }
        },
        "2_B040": {
            "name": "エクストラアタック 1(真名判明後)",
            "text": {
                "2_B040": "斯莱普尼尔。"
            },
            "raw_text": {
                "2_B040": "スレイプニル。"
            }
        },
        "2_B050": {
            "name": "宝具 1(真名判明後)",
            "text": {
                "2_B050": "流逝的沙，滴落的水，",
                "2_B051": "坠落的一切皆会剥离、歪曲、扭曲。",
                "2_B052": "兀儿德·拉斯尔·霍恩",
                "2_B053": "——指引向应当归往的正确时间。"
            },
            "raw_text": {
                "2_B050": "こぼれる砂滴る水落ちるものすべては乖離歪みねじ曲がるウルザルスラズルフォルン向かうべきは正しき時。",
                "2_B051": "",
                "2_B052": "",
                "2_B053": ""
            }
        },
        "2_B080": {
            "name": "スキル 1(真名判明後)",
            "text": {
                "2_B080": "敬畏我吧。"
            },
            "raw_text": {
                "2_B080": "敬え。"
            }
        },
        "2_B090": {
            "name": "スキル 2(真名判明後)",
            "text": {
                "2_B090": "平伏吧。"
            },
            "raw_text": {
                "2_B090": "平伏せよ。"
            }
        },
        "2_B100": {
            "name": "開始 1(真名判明後)",
            "text": {
                "2_B100": "珍惜那条命吧。因为你们已经失去了它。"
            },
            "raw_text": {
                "2_B100": "その命を惜しみなさい。なくしてしまったのだから。"
            }
        },
        "2_B110": {
            "name": "開始 2(真名判明後)",
            "text": {
                "2_B110": "你们已经死了。那个过去是无法改变的。"
            },
            "raw_text": {
                "2_B110": "汝らは死んだ。その過去は変えられない。"
            }
        },
        "2_B120": {
            "name": "勝利 1(真名判明後)",
            "text": {
                "2_B120": "如何，御主？挥舞女神之力的感觉怎么样？"
            },
            "raw_text": {
                "2_B120": "どうだマスター女神の力を振るう気持ちは。"
            }
        },
        "2_B130": {
            "name": "勝利 2(真名判明後)",
            "text": {
                "2_B130": "所谓胜利，终将成为过去——也就是说，那是属于我的东西呢。"
            },
            "raw_text": {
                "2_B130": "勝利とは常に過去のものつまり私のものというわけだな。"
            }
        },
        "2_B140": {
            "name": "ダメージ 2(真名判明後)",
            "text": {
                "2_B140": "唔！"
            },
            "raw_text": {
                "2_B140": "ブレ。"
            }
        },
        "2_B150": {
            "name": "ダメージ 1(真名判明後)",
            "text": {
                "2_B150": "不可饶恕。"
            },
            "raw_text": {
                "2_B150": "許さぬ。"
            }
        },
        "2_B160": {
            "name": "戦闘不能 1(真名判明後)",
            "text": {
                "2_B160": "这段过去……无法承认。"
            },
            "raw_text": {
                "2_B160": "この過去は認められない。"
            }
        },
        "2_B170": {
            "name": "戦闘不能 2(真名判明後)",
            "text": {
                "2_B170": "抱歉。是我错了。"
            },
            "raw_text": {
                "2_B170": "すまぬ。私が間違っていた。"
            }
        },
        "2_B180": {
            "name": "コマンドカード 1(真名判明後)",
            "text": {
                "2_B180": "原来如此。"
            },
            "raw_text": {
                "2_B180": "なるほど。"
            }
        },
        "2_B190": {
            "name": "コマンドカード 2(真名判明後)",
            "text": {
                "2_B190": "好吧。"
            },
            "raw_text": {
                "2_B190": "いいだろう。"
            }
        },
        "2_B200": {
            "name": "コマンドカード 3(真名判明後)",
            "text": {
                "2_B200": "嗯。"
            },
            "raw_text": {
                "2_B200": "うむ。"
            }
        },
        "2_B2010": {
            "name": "アタック 10(真名判明後)",
            "text": {
                "2_B2010": "死了呢。"
            },
            "raw_text": {
                "2_B2010": "死んだな。"
            }
        },
        "2_B2020": {
            "name": "アタック 11(真名判明後)",
            "text": {
                "2_B2020": "已是极限。"
            },
            "raw_text": {
                "2_B2020": "極言だ。"
            }
        },
        "2_B2030": {
            "name": "アタック 12(真名判明後)",
            "text": {
                "2_B2030": "古老的枯骨啊。"
            },
            "raw_text": {
                "2_B2030": "古き骨よ。"
            }
        },
        "2_B210": {
            "name": "宝具カード(真名判明後)",
            "text": {
                "2_B210": "让一切回溯吧。"
            },
            "raw_text": {
                "2_B210": "すべてを巻き戻そう。"
            }
        },
        "2_B2410": {
            "name": "アタック 13(真名判明後)",
            "text": {
                "2_B2410": "雨。"
            },
            "raw_text": {
                "2_B2410": "雨。"
            }
        },
        "2_B2420": {
            "name": "アタック 14(真名判明後)",
            "text": {
                "2_B2420": "收束。"
            },
            "raw_text": {
                "2_B2420": "収束。"
            }
        },
        "2_B2430": {
            "name": "アタック 15(真名判明後)",
            "text": {
                "2_B2430": "贯穿了。"
            },
            "raw_text": {
                "2_B2430": "貫いたぞ。"
            }
        },
        "2_B2810": {
            "name": "アタック 16(真名判明後)",
            "text": {
                "2_B2810": "毫无意义。"
            },
            "raw_text": {
                "2_B2810": "無意味。"
            }
        },
        "2_B2820": {
            "name": "アタック 17(真名判明後)",
            "text": {
                "2_B2820": "败北了呢。"
            },
            "raw_text": {
                "2_B2820": "敗北したな。"
            }
        },
        "2_B2830": {
            "name": "アタック 18(真名判明後)",
            "text": {
                "2_B2830": "无从防备。"
            },
            "raw_text": {
                "2_B2830": "防の余地なし。"
            }
        },
        "2_B3010": {
            "name": "アタック 19(真名判明後)",
            "text": {
                "2_B3010": "逆卷吧。"
            },
            "raw_text": {
                "2_B3010": "逆巻け。"
            }
        },
        "2_B410": {
            "name": "アタック 4(真名判明後)",
            "text": {
                "2_B410": "大地已然崩裂。"
            },
            "raw_text": {
                "2_B410": "地は崩れた。"
            }
        },
        "2_B420": {
            "name": "アタック 5(真名判明後)",
            "text": {
                "2_B420": "碎裂便好。"
            },
            "raw_text": {
                "2_B420": "砕けてよし。"
            }
        },
        "2_B430": {
            "name": "アタック 6(真名判明後)",
            "text": {
                "2_B430": "挣扎吧。"
            },
            "raw_text": {
                "2_B430": "あっ返せよ。"
            }
        },
        "2_B440": {
            "name": "エクストラアタック 2(真名判明後)",
            "text": {
                "2_B440": "尽数蹂躏吧。"
            },
            "raw_text": {
                "2_B440": "ことごとく蹂躙せよ。"
            }
        },
        "2_B480": {
            "name": "スキル 3(真名判明後)",
            "text": {
                "2_B480": "好困啊。"
            },
            "raw_text": {
                "2_B480": "眠いな。"
            }
        },
        "2_B490": {
            "name": "スキル 4(真名判明後)",
            "text": {
                "2_B490": "汝的命运已定。"
            },
            "raw_text": {
                "2_B490": "汝の運命は定まった。"
            }
        },
        "2_B500": {
            "name": "開始 3(真名判明後)",
            "text": {
                "2_B500": "正因为无法抗拒，命运才被称为命运。"
            },
            "raw_text": {
                "2_B500": "運命は抗えぬからこその運命である。"
            }
        },
        "2_B540": {
            "name": "ダメージ 4(真名判明後)",
            "text": {
                "2_B540": "啧！"
            },
            "raw_text": {
                "2_B540": "チ。"
            }
        },
        "2_B550": {
            "name": "ダメージ 3(真名判明後)",
            "text": {
                "2_B550": "啊啊啊啊啊啊啊啊啊啊啊啊啊啊啊啊啊啊啊啊啊"
            },
            "raw_text": {
                "2_B550": "ううううううううううううううううううううう"
            }
        },
        "2_B800": {
            "name": "宝具 2(真名判明後)",
            "text": {
                "2_B800": "不准前进，亦不准停步。",
                "2_B801": "汝等，接受篡改过去的惩罚吧。",
                "2_B802": "兀儿德·斯拉兹尔·霍恩",
                "2_B803": "——不过，篡改过去的其实是我就是了。"
            },
            "raw_text": {
                "2_B800": "進むことは許さぬ立ち止まることも許さぬ汝ら過去を改ざんした罰を受けよウルザルスラズルフォルンまあ改ざんしたのは私なのだが。",
                "2_B801": "",
                "2_B802": "",
                "2_B803": ""
            }
        },
        "2_B840": {
            "name": "エクストラアタック 3(真名判明後)",
            "text": {
                "2_B840": "为何反抗，为何不认，为何执迷不悟。"
            },
            "raw_text": {
                "2_B840": "なぜ逆らうなぜ認めぬなぜ懲りぬ。"
            }
        },
        "2_B910": {
            "name": "アタック 7(真名判明後)",
            "text": {
                "2_B910": "践踏殆尽。"
            },
            "raw_text": {
                "2_B910": "踏みにじった。"
            }
        },
        "2_B920": {
            "name": "アタック 8(真名判明後)",
            "text": {
                "2_B920": "注意降雨。"
            },
            "raw_text": {
                "2_B920": "こう注意。"
            }
        },
        "2_B930": {
            "name": "アタック 9(真名判明後)",
            "text": {
                "2_B930": "会是一场好雨吧。"
            },
            "raw_text": {
                "2_B930": "良き雨であろう。"
            }
        },
        "2_G010": {
            "name": "レベルアップ 1(真名判明後)",
            "text": {
                "2_G010": "灵基的提升。嗯，还不够呢。"
            },
            "raw_text": {
                "2_G010": "冷気の向上。うん、まだ足りんな。"
            }
        },
        "2_G040": {
            "name": "霊基再臨 1(真名判明後)",
            "text": {
                "2_G040": "因此，这就是最终形态了。很符合司掌过去的女神的姿态吧。不过还请注意。在这个灵基的状态下，我的大部分性质都偏向了神明那一侧。思考和逻辑自然也会变成那样。不过，如果是你的话，应该也能很好地驾驭这样的我吧。……喂，可别往奇怪的方向理解哦。",
                "2_G041": "",
                "2_G042": "",
                "2_G043": "",
                "2_G044": "",
                "2_G045": "",
                "2_G046": ""
            },
            "raw_text": {
                "2_G040": "というわけで最終形態だ。過去を司る女神として相応しい姿だろう。だが気をつけてほしい。この霊気の場合、かなりの部分が神側に寄っているからな。思考も論理も自然とそういうものになる。もっとも、汝ならばこの私も上手く乗りこなせるだろうさ。え、変な意味に取るなよ。",
                "2_G041": "",
                "2_G042": "",
                "2_G043": "",
                "2_G044": "",
                "2_G045": "",
                "2_G046": ""
            }
        },
        "2_G050": {
            "name": "霊基再臨 2(真名判明後)",
            "text": {
                "2_G050": "你似乎误以为已经抵达终局了呢，御主。要展现出作为女神的真正力量，还需要大约一千个圣杯。真是遗憾啊。也就是说，在全部奉献完之前，既不允许你离开我身边，也不允许你死去。好啦，没问题的。只要我兀儿德继续干涉过去，汝就永远是安泰的。别说什么可怕可怕的，作为女神我可是很受打击的哦。总之，今后也请多指教啦，御主。",
                "2_G051": "",
                "2_G052": "",
                "2_G053": "",
                "2_G054": "",
                "2_G055": "",
                "2_G056": "",
                "2_G057": "",
                "2_G058": ""
            },
            "raw_text": {
                "2_G050": "終局に到着した、と勘違いしているようだなマスター。女神としての真の力を見せるには、あと一千個くらいの聖杯が必要だ。残念だったな。つまり、それを捧げ終わるまでは、その身を離すことも、死ぬことも許されないわけだ。なあに、問題ないさ。このウルスが過去をいじくり続ける限り、汝は常に安泰なのだから。怖いと言うな怖いと。女神的にはショックだぞ。ともかく、今後ともよろしくね、マスター。",
                "2_G051": "",
                "2_G052": "",
                "2_G053": "",
                "2_G054": "",
                "2_G055": "",
                "2_G056": "",
                "2_G057": "",
                "2_G058": ""
            }
        },
        "2_G110": {
            "name": "レベルアップ 2(真名判明後)",
            "text": {
                "2_G110": "这样也行吧。不过，我也想要圣杯哦。"
            },
            "raw_text": {
                "2_G110": "まあいいだろう。だが聖杯も欲しいぞ。"
            }
        },
        "2_H010": {
            "name": "誕生日(真名判明後)",
            "text": {
                "2_H010": "生日吗。这在你的过去之中，也是尤为重要的一天吧。你对自己诞生的日子感到喜悦吗？那就好。但如果这让你感到痛苦，无论过去日历上的哪一天，我都可以为你篡改生日。只要在那一天庆祝就行了。",
                "2_H011": "",
                "2_H012": "",
                "2_H013": "",
                "2_H014": "",
                "2_H015": ""
            },
            "raw_text": {
                "2_H010": "誕生日か。汝の過去の中でも特に重要な日であろうな。汝は自身が生まれた日を喜びと感じているか。それならいい。だがもし苦しいようであれば、私は過去の日付のいつであろうと汝の誕生日を改ざんしてやろう。その日を祝えばそれでいいのだ。",
                "2_H011": "",
                "2_H012": "",
                "2_H013": "",
                "2_H014": "",
                "2_H015": ""
            }
        },
        "2_H020": {
            "name": "イベント開催中(真名判明後)",
            "text": {
                "2_H020": "听说现在正是祭祀女神的庆典期间。不是“跑起来”，而是什么来着？对了对了，是“转起来”。嗯，好好转吧。",
                "2_H021": "",
                "2_H022": "",
                "2_H023": ""
            },
            "raw_text": {
                "2_H020": "女神を祀る祝い事の最中だと聞く。走れではなく、なんだったかな。そうだそうだ、回せだ。うむ、よく回すがいい。",
                "2_H021": "",
                "2_H022": "",
                "2_H023": ""
            }
        },
        "2_H030": {
            "name": "会話 1(真名判明後)",
            "text": {
                "2_H030": "你在做什么。站起来，出发了。",
                "2_H031": ""
            },
            "raw_text": {
                "2_H030": "何をしている。たて行くのだ。",
                "2_H031": ""
            }
        },
        "2_H040": {
            "name": "会話 2(真名判明後)",
            "text": {
                "2_H040": "身为女神的我，以及忍耐着这一点的你。这才是正确的君臣关系呢。",
                "2_H041": ""
            },
            "raw_text": {
                "2_H040": "女神である私それを辛抱する汝正しい主従であるな。",
                "2_H041": ""
            }
        },
        "2_H050": {
            "name": "会話 3(真名判明後)",
            "text": {
                "2_H050": "与御主的关系？就是被侍奉者与侍奉者的关系吧。",
                "2_H051": ""
            },
            "raw_text": {
                "2_H050": "マスターとの関係？奉仕されるものとするものだな。",
                "2_H051": ""
            }
        },
        "2_H060": {
            "name": "好きなこと(真名判明後)",
            "text": {
                "2_H060": "喜欢的事物？女神怎么能把喜好挂在嘴边。什么啊，正因为是女神，有喜恶才是理所当然的吗？嗯……比如化石之类的。",
                "2_H061": "",
                "2_H062": "",
                "2_H063": ""
            },
            "raw_text": {
                "2_H060": "好きなこと？女神が好き嫌いを言ってどうする。なんや、女神だからこそ好き嫌いはあって当然か。うん。化石とか。",
                "2_H061": "",
                "2_H062": "",
                "2_H063": ""
            }
        },
        "2_H070": {
            "name": "嫌いなこと(真名判明後)",
            "text": {
                "2_H070": "讨厌的事物？如果说是对未来的展望，感觉会被诗蔻蒂生气呢。那个……我不喜欢容易变质的食物。",
                "2_H071": "",
                "2_H072": "",
                "2_H073": "",
                "2_H074": ""
            },
            "raw_text": {
                "2_H070": "嫌いなこと未来への展望というとスクルドに怒られそうだな。えっとえっとの足が速い食べ物は好まぬ。",
                "2_H071": "",
                "2_H072": "",
                "2_H073": "",
                "2_H074": ""
            }
        },
        "2_H080": {
            "name": "聖杯について(真名判明後)",
            "text": {
                "2_H080": "关于圣杯？为了恢复作为女神的力量，非常想要，想要很多。",
                "2_H081": "",
                "2_H082": ""
            },
            "raw_text": {
                "2_H080": "聖杯女神としての力を蘇らせるために大変欲しいたくさん欲しい。",
                "2_H081": "",
                "2_H082": ""
            }
        },
        "2_H20090": {
            "name": "絆Lv.1(真名判明後)",
            "text": {
                "2_H20090": "明明让我变强了却不让我战，这态度倒是不错。",
                "2_H20091": ""
            },
            "raw_text": {
                "2_H20090": "強くしてなお戦いには挑ませぬとは良い心がけです。",
                "2_H20091": ""
            }
        },
        "2_H20100": {
            "name": "絆Lv.2(真名判明後)",
            "text": {
                "2_H20100": "献上供品吧。至于该献上什么，那应该是你该考虑的事。",
                "2_H20101": "",
                "2_H20102": ""
            },
            "raw_text": {
                "2_H20100": "供物を捧げよ。何を捧げればいいか。それは汝が考えるべきことである。",
                "2_H20101": "",
                "2_H20102": ""
            }
        },
        "2_H20110": {
            "name": "絆Lv.3(真名判明後)",
            "text": {
                "2_H20110": "哼。问我默默盯着你在做什么？愚蠢。凭借我们培养至今的羁绊，我的思考你应该能看透吧。完全看不懂？给我看懂。",
                "2_H20111": "",
                "2_H20112": "",
                "2_H20113": "",
                "2_H20114": "",
                "2_H20115": ""
            },
            "raw_text": {
                "2_H20110": "ふん。無言で睨んで何をしているのかだと。グレッツ。培った絆をもってすれば私の思考くらい見通せるだろう。全然わからない？わかれ。",
                "2_H20111": "",
                "2_H20112": "",
                "2_H20113": "",
                "2_H20114": "",
                "2_H20115": ""
            }
        },
        "2_H20120": {
            "name": "絆Lv.4(真名判明後)",
            "text": {
                "2_H20120": "刚才的态度，可不是对待女神该有的态度呢。不过，既然已经一起走到这里了，你的喜好我还是能看透的。女神最棒？嗯，确实如此。没错吧。好，那就好。",
                "2_H20121": "",
                "2_H20122": "",
                "2_H20123": "",
                "2_H20124": "",
                "2_H20125": "",
                "2_H20126": ""
            },
            "raw_text": {
                "2_H20120": "先の態度は女神へなかったな。んだが、ここまで共にやってきたのだ。汝の趣向くらいは見通してやろう。女神最高？うむ、まさにその通りであるぞ。あるよね。よし、ならばよし。",
                "2_H20121": "",
                "2_H20122": "",
                "2_H20123": "",
                "2_H20124": "",
                "2_H20125": "",
                "2_H20126": ""
            }
        },
        "2_H20130": {
            "name": "絆Lv.5(真名判明後)",
            "text": {
                "2_H20130": "真是的，直到最后都是个不可爱的御主。不过，就原谅你吧。既然身为女神，就必须宽容。那么，给你最后的试练吧。猜猜看我现在在想什么。猜不中可不原谅你。……答对了。虽然早就觉得你是个有前途的人类，没想到竟然能走到这一步。嗯？你为什么在流汗？",
                "2_H20131": "",
                "2_H20132": "",
                "2_H20133": "",
                "2_H20134": "",
                "2_H20135": "",
                "2_H20136": "",
                "2_H20137": ""
            },
            "raw_text": {
                "2_H20130": "まったく、最後の最後まで可愛げのないマスターである。だが許そう。女神たるもの、寛容でなくてはな。では、最後の試練を与えよう。私が何を考えているか当ててみよ。当てないと許さない。正解だ。見どころのある人間だと思っていたが、ここまでに至ったか。む、なぜ汗をかいている？",
                "2_H20131": "",
                "2_H20132": "",
                "2_H20133": "",
                "2_H20134": "",
                "2_H20135": "",
                "2_H20136": "",
                "2_H20137": ""
            }
        },
        "2_H210": {
            "name": "会話 4(真名判明後)",
            "text": {
                "2_H210": "啊，那是金星女神吗。原来如此，确实看起来很贪婪。既然想要的是宝石，那不就不是金星女神，而是应该改名叫红宝石星的神明吗？",
                "2_H211": "",
                "2_H212": "",
                "2_H213": "",
                "2_H214": ""
            },
            "raw_text": {
                "2_H210": "あああれは金星の女神かなるほどいかにも強欲そうだ欲しいのは宝石では金星の女神ではないのではルビー星の神様とかに改名するべきでは。",
                "2_H211": "",
                "2_H212": "",
                "2_H213": "",
                "2_H214": ""
            }
        },
        "2_H21600": {
            "name": "絆Lv.4\n(真名判明後+郷愁永巡刻盤 パスト・カルデアクリア以降)",
            "text": {
                "2_H21600": "展现出这个姿态却还是落败了。不，那时候的我只是还没有拿出真本事而已。真的，是真的，超级真。就算当时真的拿出了真本事，我也会把它变成‘没有拿出真本事’的过去。",
                "2_H21601": "",
                "2_H21602": "",
                "2_H21603": ""
            },
            "raw_text": {
                "2_H21600": "この姿を晒してなお敗北とは。いや、あの時の私はまだ本気を出していなかっただけだがな。本当だ本当、すごく本当だ。仮に本気を出していたとしても、出していない過去にする。",
                "2_H21601": "",
                "2_H21602": "",
                "2_H21603": ""
            }
        },
        "2_H21800": {
            "name": "絆Lv.5\n(真名判明後+郷愁永巡刻盤 パスト・カルデアクリア以降)",
            "text": {
                "2_H21800": "所谓过去，总是带有污点的。而只要活着，那就是无法拭去的伤痕。神明也是如此吗。毕竟神明也是因为拥有过去才成为神明的。抱歉，说了些无聊的话。忘了吧。神明是不该示弱的。只是，希望你能稍微陪在我身边。",
                "2_H21801": "",
                "2_H21802": "",
                "2_H21803": "",
                "2_H21804": "",
                "2_H21805": "",
                "2_H21806": ""
            },
            "raw_text": {
                "2_H21800": "過去というものは常に汚れがあるもの。そしてそれは生きている限り拭い去れぬ傷である。それは神も同じか。神とて過去があるからこその神なのだから。すまない、つまらないことを言ったな。忘れろ。神が弱音を吐いてはならないのだから。ただ、少し傍にいてほしい。",
                "2_H21801": "",
                "2_H21802": "",
                "2_H21803": "",
                "2_H21804": "",
                "2_H21805": "",
                "2_H21806": ""
            }
        },
        "2_H220": {
            "name": "会話 5(真名判明後)",
            "text": {
                "2_H220": "奔放的爱之神吗。不过那位女神，怎么看都给人一种走纯爱路线的感觉，是我的错觉吗？本人倒是自称是让全人类堕落的可怕神明。这样啊，这就是所谓的地域独特性吗。",
                "2_H221": "",
                "2_H222": "",
                "2_H223": ""
            },
            "raw_text": {
                "2_H220": "奔放な愛の神か。しかし女神愛で見た感じ、どう見ても純愛路線真っすぐな感じがするのだが、気のせいか？本人は全人類を堕落させる恐るべき神だと自称している。そうか、地域の独自性というものか。",
                "2_H221": "",
                "2_H222": "",
                "2_H223": ""
            }
        },
        "2_H230": {
            "name": "会話 6(真名判明後)",
            "text": {
                "2_H230": "阿兹特克的最高神吗。既是善神又是战神。原来如此。所以才对职业摔角那么了解啊。也就是说，她把职业摔角当成了战神的仪式吗。不过，可不能轻易接近她啊。感觉命运之线会被一口气烧光。而且从性格上来说也有点可怕。",
                "2_H231": "",
                "2_H232": "",
                "2_H233": "",
                "2_H234": "",
                "2_H235": "",
                "2_H236": ""
            },
            "raw_text": {
                "2_H230": "アステカの最高神か。前進でありつつも先人。なるほど。だからプロレスにも詳しいと。つまり、プロレスを先人による儀式と定めているわけか。しかし、迂闊には近寄り難いな。運命の糸がまとめて燃えそうで。キャラ的にも少し怖いというか。",
                "2_H231": "",
                "2_H232": "",
                "2_H233": "",
                "2_H234": "",
                "2_H235": "",
                "2_H236": ""
            }
        },
        "2_H240": {
            "name": "会話 7(真名判明後)",
            "text": {
                "2_H240": "那就是阿兹特克的命运之神吗。真是搞不懂他的底细——不对，是真意。明知道打不中，为什么还要钟情于打不中的武器呢？明明要是换作枪械以外的武器，就拥有必中的本领。我吗？我可是司掌过去的女神啊。切断未命中的过去，只将命中的过去定为正确的命运。嗯。那尊神明也是命运之神吧。为什么会打不中呢？难道有什么重大的秘密吗？",
                "2_H241": "",
                "2_H242": "",
                "2_H243": "",
                "2_H244": "",
                "2_H245": "",
                "2_H246": "",
                "2_H247": "",
                "2_H248": ""
            },
            "raw_text": {
                "2_H240": "あれがアステカの運命神。えたいが、あいや真意がわからない。当たらないと知った上で、なぜ当たらない武器を好むのか。銃以外であれば必中の技量だというのに。私か？私は過去を司る女神だぞ。外れた過去を切断し、当てた過去のみを正しき運命とする。うんよ。あの神も運命神だったな。なぜ外れるのだ。何か重大な秘密が？",
                "2_H241": "",
