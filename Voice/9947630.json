{
    "id": 9947630,
    "name": "Enemy 9947630",
    "voices": {
        "0_B010": {
            "name": "0_B010",
            "text": {
                "0_B010": "赐予光芒。"
            },
            "raw_text": {
                "0_B010": "光を。"
            }
        },
        "0_B020": {
            "name": "0_B020",
            "text": {
                "0_B020": "波涛啊。"
            },
            "raw_text": {
                "0_B020": "波よ。"
            }
        },
        "0_B030": {
            "name": "0_B030",
            "text": {
                "0_B030": "大地啊。"
            },
            "raw_text": {
                "0_B030": "大地よ。"
            }
        },
        "0_B040": {
            "name": "0_B040",
            "text": {
                "0_B040": "奉献一切吧。"
            },
            "raw_text": {
                "0_B040": "すべてを捧げましょう。"
            }
        },
        "0_B080": {
            "name": "0_B080",
            "text": {
                "0_B080": "回到我的怀抱中吧。"
            },
            "raw_text": {
                "0_B080": "戻りなさい私の中へ。"
            }
        },
        "0_B090": {
            "name": "0_B090",
            "text": {
                "0_B090": "粉碎凋零吧。"
            },
            "raw_text": {
                "0_B090": "砕け散りなさい。"
            }
        },
        "0_B140": {
            "name": "0_B140",
            "text": {
                "0_B140": "啊啊。"
            },
            "raw_text": {
                "0_B140": "ああ。"
            }
        },
        "0_B150": {
            "name": "0_B150",
            "text": {
                "0_B150": "仅此程度吗。"
            },
            "raw_text": {
                "0_B150": "この程度。"
            }
        },
        "0_B160": {
            "name": "0_B160",
            "text": {
                "0_B160": "培育系统功能停止。传导机构……"
            },
            "raw_text": {
                "0_B160": "プラント機能停止。伝達機構。"
            }
        },
        "0_B300": {
            "name": "0_B300",
            "text": {
                "0_B300": "悲哀的是死亡，悲哀的是终结。"
            },
            "raw_text": {
                "0_B300": "悲しきは死、悲しきは終わり。"
            }
        },
        "0_B410": {
            "name": "0_B410",
            "text": {
                "0_B410": "天空啊。"
            },
            "raw_text": {
                "0_B410": "そらよ。"
            }
        },
        "0_B440": {
            "name": "0_B440",
            "text": {
                "0_B440": "爱着万物吧。"
            },
            "raw_text": {
                "0_B440": "すべてを愛しましょう。"
            }
        }
    }
}