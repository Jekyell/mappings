{
    "id": 800190,
    "collectionNo": 0,
    "name": "マシュ・キリエライト",
    "voices": {
        "17_B010": {
            "name": "アタック 1",
            "text": {
                "17_B010": "我正在进行未来观测！"
            }
        },
        "17_B020": {
            "name": "アタック 2",
            "text": {
                "17_B020": "目标，绝不会失手！"
            }
        },
        "17_B030": {
            "name": "アタック 3",
            "text": {
                "17_B030": "盾，消散！"
            }
        },
        "17_B040": {
            "name": "エクストラアタック",
            "text": {
                "17_B040": "全力，一直线！"
            }
        },
        "17_B080": {
            "name": "スキル 1",
            "text": {
                "17_B080": "领域装甲，展开！"
            }
        },
        "17_B090": {
            "name": "スキル 2",
            "text": {
                "17_B090": "生命距离弹，简易测定！"
            }
        },
        "17_B100": {
            "name": "開始 1",
            "text": {
                "17_B100": "心情冷静，思维清晰…… 好！　圣骑士盾兵，出击！"
            }
        },
        "17_B110": {
            "name": "開始 2",
            "text": {
                "17_B110": "灵基阶段，抵达最终色彩。 别以为你能贯穿这面盾！"
            }
        },
        "17_B120": {
            "name": "勝利 1",
            "text": {
                "17_B120": "周围的敌对、危险反应，全部消除。 呼——我们胜利了，御主！"
            }
        },
        "17_B130": {
            "name": "勝利 2",
            "text": {
                "17_B130": "这面盾是迦勒底之旅的成果，是我战斗意志的结晶。 可不能被轻易击破！"
            }
        },
        "17_B140": {
            "name": "ダメージ 2",
            "text": {
                "17_B140": "不算什么！"
            }
        },
        "17_B150": {
            "name": "ダメージ 1",
            "text": {
                "17_B150": "盾，展开！"
            }
        },
        "17_B160": {
            "name": "戦闘不能 1",
            "text": {
                "17_B160": "我一定会回来的！ 我的心还没有屈服……！"
            }
        },
        "17_B170": {
            "name": "戦闘不能 2",
            "text": {
                "17_B170": "暂时撤退！ 敌方战力的分析就麻烦您了！"
            }
        },
        "17_B180": {
            "name": "コマンドカード 1",
            "text": {
                "17_B180": "是！"
            }
        },
        "17_B190": {
            "name": "コマンドカード 2",
            "text": {
                "17_B190": "好～！"
            }
        },
        "17_B200": {
            "name": "コマンドカード 3",
            "text": {
                "17_B200": "非常准确呢！"
            }
        },
        "17_B2010": {
            "name": "アタック 10",
            "text": {
                "17_B2010": "哈—！"
            }
        },
        "17_B2020": {
            "name": "アタック 11",
            "text": {
                "17_B2020": "光辉的银之臂！"
            }
        },
        "17_B2030": {
            "name": "アタック 12",
            "text": {
                "17_B2030": "锋利，豪迈！"
            }
        },
        "17_B210": {
            "name": "宝具カード",
            "text": {
                "17_B210": "请交给我吧，御主！"
            }
        },
        "17_B220": {
            "name": "宝具カード",
            "text": {
                "17_B220": "请好好看着，所长！"
            }
        },
        "17_B230": {
            "name": "宝具カード",
            "text": {
                "17_B230": "圣剑，拔刀！"
            }
        },
        "17_B2410": {
            "name": "アタック 13",
            "text": {
                "17_B2410": "上！　下！"
            }
        },
        "17_B2420": {
            "name": "アタック 14",
            "text": {
                "17_B2420": "呼！呀—！"
            }
        },
        "17_B2430": {
            "name": "アタック 15",
            "text": {
                "17_B2430": "挥挥，挥！"
            }
        },
        "17_B250": {
            "name": "宝具カード",
            "text": {
                "17_B250": "即便，这不是正确的答案。"
            }
        },
        "17_B2810": {
            "name": "アタック 16",
            "text": {
                "17_B2810": "掀起，风暴！"
            }
        },
        "17_B2820": {
            "name": "アタック 17",
            "text": {
                "17_B2820": "休想逃跑！"
            }
        },
        "17_B2830": {
            "name": "アタック 18",
            "text": {
                "17_B2830": "坠落！"
            }
        },
        "17_B410": {
            "name": "アタック 4",
            "text": {
                "17_B410": "一、二！"
            }
        },
        "17_B420": {
            "name": "アタック 5",
            "text": {
                "17_B420": "这样，如何！"
            }
        },
        "17_B430": {
            "name": "アタック 6",
            "text": {
                "17_B430": "封印，控制！"
            }
        },
        "17_B440": {
            "name": "エクストラアタック",
            "text": {
                "17_B440": "强大、沉重、无所畏惧！"
            }
        },
        "17_B480": {
            "name": "スキル 3",
            "text": {
                "17_B480": "配合时机！"
            }
        },
        "17_B490": {
            "name": "スキル 4",
            "text": {
                "17_B490": "赌上盾兵之名！"
            }
        },
        "17_B500": {
            "name": "開始 3",
            "text": {
                "17_B500": "我会为了我想要的东西……！ 请指示，御主！"
            }
        },
        "17_B050": {
            "name": "宝具",
            "text": {
                "17_B050": "真名，刻铭。",
                "17_B051": "那是连接了诸多世界，诸多梦想的吾等之誓。",
                "17_B052": "证明吧！　构筑希望的人理之盾！",
                "17_B053": "这是连接众多世界、",
                "17_B054": "众多梦想的吾等之誓。",
                "17_B055": "证明吧，",
                "17_B056": "『构筑希望的人理之盾』！"
            }
        },
        "17_B800": {
            "name": "宝具",
            "text": {
                "17_B800": "纵然傲慢，也要高声宣告。",
                "17_B801": "为了有朝一日能偿还失去的东西！",
                "17_B802": "引导之星啊，化为力量吧！"
            }
        },
        "17_B810": {
            "name": "宝具",
            "text": {
                "17_B810": "反悖论构造体，形成！",
                "17_B811": "刻寿测量针，设定。记录计数，由悖论转变为真理！",
                "17_B812": "阶层安全锁。",
                "17_B813": "准备发射！",
                "17_B814": "印证希望的人理之剑！",
                "17_B815": "成就标尺，设定。",
                "17_B816": "记录计数器，从悖论转向真说。"
            }
        },
        "17_B820": {
            "name": "宝具",
            "text": {
                "17_B820": "领域装甲，解除。",
                "17_B821": "将灵基形态换装为炮身形态，生命距离弹，装填！",
                "17_B822": "——不会失手！",
                "17_B823": "我们，要前往未来！"
            }
        },
        "17_B840": {
            "name": "エクストラアタック",
            "text": {
                "17_B840": "基列莱特～……",
                "17_B841": "究极，阻截——！"
            }
        },
        "17_B880": {
            "name": "スキル 5",
            "text": {
                "17_B880": "没关系……放心吧。"
            }
        },
        "17_B890": {
            "name": "スキル 6",
            "text": {
                "17_B890": "我获得勇气了！"
            }
        },
        "17_B910": {
            "name": "アタック 7",
            "text": {
                "17_B910": "盾，失衡！"
            }
        },
        "17_B920": {
            "name": "アタック 8",
            "text": {
                "17_B920": "从正面，重击！"
            }
        },
        "17_B930": {
            "name": "アタック 9",
            "text": {
                "17_B930": "预备！"
            }
        },
        "17_G010": {
            "name": "レベルアップ",
            "text": {
                "17_G010": "请交给我吧！",
                "17_G011": "我会承受住所有的攻击！"
            }
        },
        "17_G110": {
            "name": "レベルアップ",
            "text": {
                "17_G110": "等级提升了！",
                "17_G111": "不只是防御，攻击也请交给我吧！"
            }
        },
        "17_G120": {
            "name": "レベルアップ",
            "text": {
                "17_G120": "盾牌坚硬而灵活，炮击沉重而坚定。",
                "17_G121": "虽然学会的东西变多是很不容易的，但我会努力的。"
            }
        },
        "17_H010": {
            "name": "誕生日",
            "text": {
                "17_H010": "祝您生日快乐。",
                "17_H011": "这是一件非常值得庆祝的事，是否该设立一个举国欢庆的节日呢？"
            }
        },
        "17_H020": {
            "name": "イベント開催中",
            "text": {
                "17_H020": "确认特殊事象发生。前辈，赶紧走吧！",
                "17_H021": "让我们干劲十足地赢得稀有道具吧！"
            }
        },
        "17_H030": {
            "name": "会話 1",
            "text": {
                "17_H030": "出击准备就绪！ 请交给圣骑士吧！"
            }
        },
        "17_H040": {
            "name": "会話 2",
            "text": {
                "17_H040": "我迄今为止和前辈完成了许多作战。",
                "17_H041": "今后无论遇到什么样的作战，我都无所畏惧了。"
            }
        },
        "17_H050": {
            "name": "会話 3",
            "text": {
                "17_H050": "达·芬奇亲说，你们间的眼神交流已经很完美了。",
                "17_H051": "虽，虽然不太明白理由，但会有点不好意思呢。"
            }
        },
        "17_H060": {
            "name": "好きなこと",
            "text": {
                "17_H060": "喜欢的东西没有改变。",
                "17_H061": "天空的色彩和大地的气味。",
                "17_H062": "还有梦想明天。"
            }
        },
        "17_H3070": {
            "name": "嫌いなこと",
            "text": {
                "17_H3070": "讨厌的东西……",
                "17_H3071": "以前我并不清楚，但现在我能明确地说出来。",
                "17_H3072": "而且我也明白了即便讨厌，也未必需要敌对。",
                "17_H3073": "……是的。她大概又要讨厌我了吧。"
            }
        },
        "17_H9000": {
            "name": "霊衣について",
            "text": {
                "17_H9000": "圣骑士……",
                "17_H9001": "这个称号对我来说过于崇高，但我会努力不辜负这个名字的。",
                "17_H9002": "虽然灵基提升后会加重对御主的负担，但今后也请多关照。"
            }
        }
    },
    "ChrVoice_ids": [
        "800190"
    ]
}