{
    "id": 405600,
    "name": "ヒッポリュテ",
    "voices": {
        "0_B010": {
            "name": "アタック 1",
            "text": {
                "0_B010": "要上了。"
            },
            "raw_text": {
                "0_B010": "行くぞ。"
            }
        },
        "0_B020": {
            "name": "アタック 2",
            "text": {
                "0_B020": "可没空让你东张西望。"
            },
            "raw_text": {
                "0_B020": "よそ見をする暇などないぞ。"
            }
        },
        "0_B030": {
            "name": "アタック 3",
            "text": {
                "0_B030": "别来碍事。"
            },
            "raw_text": {
                "0_B030": "邪魔をするな。"
            }
        },
        "0_B040": {
            "name": "エクストラアタック 1",
            "text": {
                "0_B040": "别以为能阻挡我们的进军。"
            },
            "raw_text": {
                "0_B040": "我らが進軍止められると思うな。"
            }
        },
        "0_B050": {
            "name": "宝具 1",
            "text": {
                "0_B050": "集结吧，军势。吾等跨越荒野与黑夜的境界，以先祖与月之女神之名，粉碎一切不实。——『战神之军带（Sybringia Adatrepon）』，『月下之圣域（Edin-Ues）』！",
                "0_B051": "",
                "0_B052": "",
                "0_B053": ""
            },
            "raw_text": {
                "0_B050": "あれよ軍隊、我らは荒夜と翌夜の境界を踏み越え、先人と月女神の名のもとに、すべての不実を打ち砕く。シュブリンギア・アダトレポン、エディンユエス。",
                "0_B051": "",
                "0_B052": "",
                "0_B053": ""
            }
        },
        "0_B080": {
            "name": "スキル 1",
            "text": {
                "0_B080": "来吧，卡里奥。"
            },
            "raw_text": {
                "0_B080": "来い、カリオ。"
            }
        },
        "0_B090": {
            "name": "スキル 2",
            "text": {
                "0_B090": "共同进发吧。"
            },
            "raw_text": {
                "0_B090": "共に行こう。"
            }
        },
        "0_B100": {
            "name": "開始 1",
            "text": {
                "0_B100": "我名希波吕忒。乃亚马逊之女王，亦是统军之将。"
            },
            "raw_text": {
                "0_B100": "我が名はヒッポリュテ。アマゾネスの女王にして戦将である。"
            }
        },
        "0_B110": {
            "name": "開始 2",
            "text": {
                "0_B110": "此番我将作为月女神的巫女参战。"
            },
            "raw_text": {
                "0_B110": "この度は月女神の巫女として参陣させてもらう。"
            }
        },
        "0_B120": {
            "name": "勝利 1",
            "text": {
                "0_B120": "下次，希望能以一对一的决斗再次相见。"
            },
            "raw_text": {
                "0_B120": "次は一騎打ちにてまみえたいものだ。"
            }
        },
        "0_B130": {
            "name": "勝利 2",
            "text": {
                "0_B130": "精彩的武勇。若你来到我的领地，定当盛情款待。"
            },
            "raw_text": {
                "0_B130": "見事なる武勇我が土地に来たときは歓待しよう。"
            }
        },
        "0_B140": {
            "name": "ダメージ 2",
            "text": {
                "0_B140": "唔。"
            },
            "raw_text": {
                "0_B140": "うん。"
            }
        },
        "0_B150": {
            "name": "ダメージ 1",
            "text": {
                "0_B150": "拥有如此强大的力量，为何……"
            },
            "raw_text": {
                "0_B150": "ここまでの力を持ちながらなぜ。"
            }
        },
        "0_B160": {
            "name": "戦闘不能 1",
            "text": {
                "0_B160": "愿我的败北，能成为让他人生存下去的食粮。"
            },
            "raw_text": {
                "0_B160": "我が敗北が誰かを生かす糧にならんこと。"
            }
        },
        "0_B170": {
            "name": "戦闘不能 2",
            "text": {
                "0_B170": "妹妹们……之后就拜托了。"
            },
            "raw_text": {
                "0_B170": "妹たちを後は任せる。"
            }
        },
        "0_B180": {
            "name": "コマンドカード 1",
            "text": {
                "0_B180": "有趣的手段。"
            },
            "raw_text": {
                "0_B180": "面白い手だ。"
            }
        },
        "0_B190": {
            "name": "コマンドカード 2",
            "text": {
                "0_B190": "谨遵御主之命。"
            },
            "raw_text": {
                "0_B190": "マスターに従おう。"
            }
        },
        "0_B200": {
            "name": "コマンドカード 3",
            "text": {
                "0_B200": "原来如此，明白了。"
            },
            "raw_text": {
                "0_B200": "なるほど理解した。"
            }
        },
        "0_B2010": {
            "name": "アタック 10",
            "text": {
                "0_B2010": "接招！"
            },
            "raw_text": {
                "0_B2010": "くらえ！"
            }
        },
        "0_B2020": {
            "name": "アタック 11",
            "text": {
                "0_B2020": "就用这一击！"
            },
            "raw_text": {
                "0_B2020": "この一撃で！"
            }
        },
        "0_B210": {
            "name": "宝具カード 1",
            "text": {
                "0_B210": "吾等之怒火，就在此刻释放。"
            },
            "raw_text": {
                "0_B210": "我らが怒り今こそ解き放たん。"
            }
        },
        "0_B220": {
            "name": "宝具カード 2",
            "text": {
                "0_B220": "就从这里，颠覆一切。"
            },
            "raw_text": {
                "0_B220": "ここから全てを覆す。"
            }
        },
        "0_B230": {
            "name": "宝具カード 3",
            "text": {
                "0_B230": "亚马逊的荣耀，就在此展现！"
            },
            "raw_text": {
                "0_B230": "アマゾネスの誇りここに示さん！"
            }
        },
        "0_B410": {
            "name": "アタック 4",
            "text": {
                "0_B410": "将其斩碎。"
            },
            "raw_text": {
                "0_B410": "切り砕く。"
            }
        },
        "0_B420": {
            "name": "アタック 5",
            "text": {
                "0_B420": "就这种程度吗。"
            },
            "raw_text": {
                "0_B420": "そんなものか。"
            }
        },
        "0_B430": {
            "name": "アタック 6",
            "text": {
                "0_B430": "上吧，加里安！"
            },
            "raw_text": {
                "0_B430": "行くぞ、ガリオン！"
            }
        },
        "0_B440": {
            "name": "エクストラアタック 2",
            "text": {
                "0_B440": "此刻便让你见识亚马逊人的力量！"
            },
            "raw_text": {
                "0_B440": "今こそ見せようアマゾネスの力を！"
            }
        },
        "0_B480": {
            "name": "スキル 3",
            "text": {
                "0_B480": "月女神啊，请见证我的斗争。"
            },
            "raw_text": {
                "0_B480": "月女神よ、我が闘争をご覧あれ。"
            }
        },
        "0_B490": {
            "name": "スキル 4",
            "text": {
                "0_B490": "愿我父战神阿瑞斯的加护降临于此！"
            },
            "raw_text": {
                "0_B490": "我が父先人アレスの加護をここに！"
            }
        },
        "0_B520": {
            "name": "勝利 3",
            "text": {
                "0_B520": "这是一场精彩的战斗。向敌我双方致以谢意。"
            },
            "raw_text": {
                "0_B520": "良き戦いであった敵味方双方に感謝を。"
            }
        },
        "0_B530": {
            "name": "勝利 4",
            "text": {
                "0_B530": "愿将这份胜利的荣光，献给月之女神。"
            },
            "raw_text": {
                "0_B530": "この勝利の外光を月神のもとに。"
            }
        },
        "0_B540": {
            "name": "ダメージ 4",
            "text": {
                "0_B540": "唔，挺能干的嘛。"
            },
            "raw_text": {
                "0_B540": "うっ、やるな。"
            }
        },
        "0_B550": {
            "name": "ダメージ 3",
            "text": {
                "0_B550": "还没完，我们依然会屹立不倒。"
            },
            "raw_text": {
                "0_B550": "まだだ、まだ我らは立ち続ける。"
            }
        },
        "0_B560": {
            "name": "戦闘不能 3",
            "text": {
                "0_B560": "还没完……我还什么都没能传达给……"
            },
            "raw_text": {
                "0_B560": "まだだまだ私は何も伝え切れては。"
            }
        },
        "0_B800": {
            "name": "宝具 2",
            "text": {
                "0_B800": "流淌于吾身的先祖之血，此刻献于女神，化作盈满月光的利刃。追随吾之先驱吧，并肩作战的战士们啊！",
                "0_B801": "",
                "0_B802": ""
            },
            "raw_text": {
                "0_B800": "我が身に流れる先人の血今こそ女神に捧げ月光刃に満たさん我が先駆けに続け共に歩みし戦士たちよ。",
                "0_B801": "",
                "0_B802": ""
            }
        },
        "0_B880": {
            "name": "スキル 5",
            "text": {
                "0_B880": "调整宝具状态。"
            },
            "raw_text": {
                "0_B880": "宝具を解調する。"
            }
        },
        "0_B910": {
            "name": "アタック 7",
            "text": {
                "0_B910": "领教一下吧！"
            },
            "raw_text": {
                "0_B910": "何も見よ。"
            }
        },
        "0_B920": {
            "name": "アタック 8",
            "text": {
                "0_B920": "还没完呢。"
            },
            "raw_text": {
                "0_B920": "まだまだ。"
            }
        },
        "0_B930": {
            "name": "アタック 9",
            "text": {
                "0_B930": "哈啊啊啊！"
            },
            "raw_text": {
                "0_B930": "はあああっ。"
            }
        },
        "0_G010": {
            "name": "レベルアップ 1",
            "text": {
                "0_G010": "这种名为“种火”的火焰，总觉得似乎与神灵有所关联。真的可以直接吸收掉吗？",
                "0_G011": "",
                "0_G012": ""
            },
            "raw_text": {
                "0_G010": "この種火とかいう炎、なんとなくだが神に連なるものではないのか。本当に取り込んでしまってよいのか。",
                "0_G011": "",
                "0_G012": ""
            }
        },
        "0_G020": {
            "name": "霊基再臨 2",
            "text": {
                "0_G020": "即便外表没有变化，我也能感觉到内在魔力的质得到了提升。迦勒底还真是了不起啊。",
                "0_G021": ""
            },
            "raw_text": {
                "0_G020": "姿は変わらずとも内なる魔力の質が引き上げられていくのが分かる。カルデアというのは大したものだな。",
                "0_G021": ""
            }
        },
        "0_G030": {
            "name": "霊基再臨 1",
            "text": {
                "0_G030": "啊，我的灵基直到最后都会保持这个样子。理由有很多，其中之一也是因为我很中意这副姿态。",
                "0_G031": ""
            },
            "raw_text": {
                "0_G030": "ああ、私の霊気なら最後までこのままださ。理由はいろいろとあるが、私がこの姿を気に入っているというのもある。",
                "0_G031": ""
            }
        },
        "0_G040": {
            "name": "霊基再臨 3",
            "text": {
                "0_G040": "我能感觉到灵基正在趋于完成。既然受到了如此隆重的款待，我也必须尽到相应的礼数。虽然不能将父亲托付给我的腰带交给你，但我会立下与之相称的战果给你看的。",
                "0_G041": "",
                "0_G042": ""
            },
            "raw_text": {
                "0_G040": "霊器が完成していくのが分かる。ここまで歓待されたからには、相応の礼を尽くさねばならないな。父から預かりし帯を渡すわけにはいかないが、それに見合う戦果は挙げてみせよう。",
                "0_G041": "",
                "0_G042": ""
            }
        },
        "0_G050": {
            "name": "霊基再臨 4",
            "text": {
                "0_G050": "没想到你竟然能将我这半神灵基的调和完成到如此地步。作为阿瑞斯之子的战士，作为亚马逊的女王，作为月女神阿尔忒弥斯的祭司，以及，作为名为希波吕忒的一名从者，我向你致谢。我起誓，将以此全部的力量与你共同战斗，御主。",
                "0_G051": "",
                "0_G052": "",
                "0_G053": ""
            },
            "raw_text": {
                "0_G050": "ここまで凡신たる我が霊気の調和を成し遂げてくれるとは。アレスの子である戦士として、アマゾネスの女王として、月女神アルテミスの巫女として、そして、ヒッポリュテという一機のサーヴァントとして、君に感謝する。この全ての力を持ちいて共に戦うと誓おう、マスター。",
                "0_G051": "",
                "0_G052": "",
                "0_G053": ""
            }
        },
        "0_G110": {
            "name": "レベルアップ 2",
            "text": {
                "0_G110": "这感觉不错。流淌在我体内的先祖阿瑞斯之血，仿佛正逐渐与全身融为一体。"
            },
            "raw_text": {
                "0_G110": "これは良い。我が身に流れる先人アレスの血が全身に馴染んでいくかのようだ。"
            }
        },
        "0_G120": {
            "name": "レベルアップ 3",
            "text": {
                "0_G120": "能力提升了。不坏。这种感觉就像是刚从一场大战中幸存下来一样。",
                "0_G121": "",
                "0_G122": ""
            },
            "raw_text": {
                "0_G120": "両力が上がった。悪くない。大きな戦を一つ生き延びた後のような感覚だ。",
                "0_G121": "",
                "0_G122": ""
            }
        },
        "0_H010": {
            "name": "誕生日",
            "text": {
                "0_H010": "是御主诞生的日子吗。在我们的部族，能够生存过一年即是值得尊敬的强大，而现在的你也同样适用。恭喜你。让我们一同庆祝你所度过的这些岁月吧。",
                "0_H011": "",
                "0_H012": ""
            },
            "raw_text": {
                "0_H010": "マスターの生誕した日か。我らの部族では一年を生き延びることができた強さを尊ぶものであったが、今の君にもそれは当てはまる。おめでとう。君の生きた日々を共に祝おうとしよう。",
                "0_H011": "",
                "0_H012": ""
            }
        },
        "0_H020": {
            "name": "イベント開催中",
            "text": {
                "0_H020": "看来祭典正在举办啊。能享受的时候就尽情享受吧。我也陪你一起。",
                "0_H021": "",
                "0_H022": ""
            },
            "raw_text": {
                "0_H020": "どうやら祭りが開催されているようだな。楽しめる時は思い切り楽しむといい。私も付き合う。",
                "0_H021": "",
                "0_H022": ""
            }
        },
        "0_H030": {
            "name": "会話 1",
            "text": {
                "0_H030": "那么，差不多该让你见识一下亚马逊的战斗方式了。御主，请指引我前往战场。",
                "0_H031": ""
            },
            "raw_text": {
                "0_H030": "さて、そろそろアマゾネスの戦い方を見せておこう。マスター、戦場へ導いてくれ。",
                "0_H031": ""
            }
        },
        "0_H040": {
            "name": "会話 2",
            "text": {
                "0_H040": "主从关系吗。我自然是服从御主之身，但若有何想法，我会如实相告。所以御主，当我以战士长或女王的身份行事时，你若有何想法，也请尽管直言。",
                "0_H041": "",
                "0_H042": ""
            },
            "raw_text": {
                "0_H040": "主従関係か。私はもちろんマスターに従う身だが、何か思うところがあれば正直に言う。だからマスターも、私が戦士長や女王として振る舞う際に、何か思うところがあれば遠慮なく言うといい。",
                "0_H041": "",
                "0_H042": ""
            }
        },
        "0_H050": {
            "name": "会話 3",
            "text": {
                "0_H050": "御主与从者的关系吗。虽然我理解魔术使魔这一立场，但我很讨厌将拥有意志的存在视作器物的家伙。不过，对于你，我并没有这种担心。",
                "0_H051": "",
                "0_H052": ""
            },
            "raw_text": {
                "0_H050": "マスターとサーヴァントの関係か。魔術的な使い魔という立場は理解しているが、意志ある存在を物扱いするような輩は苦手だ。ただ、君に対してはそのような心配はしていない。",
                "0_H051": "",
                "0_H052": ""
            }
        },
        "0_H060": {
            "name": "好きなこと",
            "text": {
                "0_H060": "喜欢的东西吗。是强者。即便那是应当击倒的敌人，我也会对其追求强大的志向致以敬意。而作为并肩作战的战士，我喜欢那种深知自身的软弱，在承认软弱的同时仍拥有向前迈进之勇气的人。",
                "0_H061": "",
                "0_H062": "",
                "0_H063": ""
            },
            "raw_text": {
                "0_H060": "好きなものか。強者だ。打ち倒すべき敵だとしても、強者たろうとする志には敬意を払う。共に歩む戦士としては、己の弱さを知り、それを認めながらもなお前に歩む勇気を持つ者が、私は好きだ。",
                "0_H061": "",
                "0_H062": "",
                "0_H063": ""
            }
        },
        "0_H070": {
            "name": "嫌いなこと",
            "text": {
                "0_H070": "我所厌恶的是傲慢之人。在战斗中无论使用何种卑鄙手段，若那是为了反抗强者，我尚能接受。但我绝不能容忍强者并非为了胜利，而是为了彰显优越感而刻意采取卑劣行径。",
                "0_H071": "",
                "0_H072": ""
            },
            "raw_text": {
                "0_H070": "私が厭うのは傲慢なものだ。戦においていかなる卑怯な手を使われようが、強さに抗うための手段なら飲み込める。だが、強者が勝利ではなく優越のためにあえて卑劣な手口を行うことは嫌悪する。",
                "0_H071": "",
                "0_H072": ""
            }
        },
        "0_H080": {
            "name": "聖杯について",
            "text": {
                "0_H080": "圣杯吗。作为个人的愿望已算实现了一半，但作为亚马逊女王的愿望，并非是能托付给圣杯之物。因为那是唯有我们将其永怀于心才有意义的东西。",
                "0_H081": "",
                "0_H082": "",
                "0_H083": ""
            },
            "raw_text": {
                "0_H080": "聖杯か。個人としての願いは半分叶っているようなものだが、アマゾネスの長としての願いは聖杯に頼るものではない。我らが己の内に抱き続けることこそに意味があるものだからな。",
                "0_H081": "",
                "0_H082": "",
                "0_H083": ""
            }
        },
        "0_H090": {
            "name": "絆Lv.1",
            "text": {
                "0_H090": "我会看清你究竟是怎样的御主。同时也希望你能看清，我究竟是怎样的从者。",
                "0_H091": ""
            },
            "raw_text": {
                "0_H090": "君がいかなるマスターなのか見極めさせてもらう。君も私がいかなるサーヴァントであるのかを見極めてほしい。",
                "0_H091": ""
            }
        },
        "0_H100": {
            "name": "絆Lv.2",
            "text": {
                "0_H100": "亚马逊这一部族的生存方式因统治的女王而异，但守护那些遭受无理暴虐之人也是其中之一。在我们那个时代，想必我不说你也明白。",
                "0_H101": "",
                "0_H102": "",
                "0_H103": ""
            },
            "raw_text": {
                "0_H100": "アマゾネスという部族のあり方は統治した女王ごとに異なるが、理不尽な暴虐に晒された者たちの守護もその一つだ。私たちの時代の場合は、言わずともわかるだろう。",
                "0_H101": "",
                "0_H102": "",
                "0_H103": ""
            }
        },
        "0_H110": {
            "name": "絆Lv.3",
            "text": {
                "0_H110": "你的强大并非源于武力或剑法权谋，而是在于你的存在本身。我会化作你的长枪、你的弓箭，并与爱马一同守护你。所以，随心所欲地去做你想做的事吧，御主。",
                "0_H111": "",
                "0_H112": "",
                "0_H113": ""
            },
            "raw_text": {
                "0_H110": "君の強さは武力や剣法術数ではない。そのあり方そのものなのだな。私は君の槍となり弓となり愛馬を伴い君を守る。だから君は君のやりたいようにすればいい、マスター。",
                "0_H111": "",
                "0_H112": "",
                "0_H113": ""
            }
        },
        "0_H120": {
            "name": "絆Lv.4",
            "text": {
                "0_H120": "你的为人处世深得我心。并非作为亚马逊的战士，而是作为支撑部族根基的一员，我甚至想邀请你前往我们的土地。放心，我不会把你掳走的。",
                "0_H121": "",
                "0_H122": ""
            },
            "raw_text": {
                "0_H120": "君のあり方はとても好ましいな。アマゾネスの戦士としてではない。部族の根幹を支える一員として、われわれの土地に招きたいぐらいだ。安心しろ、さらったりはしない。",
                "0_H121": "",
                "0_H122": ""
            }
        },
        "0_H130": {
            "name": "絆Lv.5 男性主人公選択時",
            "text": {
                "0_H130": "我以女王兼战士长之名宣告。你值得与亚马逊结下友谊。你是我应守护之人，亦是与我共赴战场的同胞。我向月女神及家父——那位战神先辈起誓。你的灵魂将永远与我们亚马逊的祝福同在。",
                "0_H131": "",
                "0_H132": "",
                "0_H133": "",
                "0_H134": ""
            },
            "raw_text": {
                "0_H130": "女王にして戦士長たる私が宣言しよう。君はアマゾネスと遊戯を結ぶに値する。私が守るべき人間であり、共に戦場を歩む同胞である。月女神と我が父である先人に誓おう。君の魂は常に我らアマゾネスの祝福と共にあると。",
                "0_H131": "",
                "0_H132": "",
                "0_H133": "",
                "0_H134": ""
            }
        },
        "0_H170": {
            "name": "会話 4",
            "text": {
                "0_H170": "赫拉克勒斯，果然在这里吗。希腊屈指可数的英杰，亦是杀死了我的男人。即便失去了理智，你似乎也毫无改变。我有无数想与你倾诉的话语，亦有无数与你交锋的理由，但现在，就让我们为了迦勒底并肩而行吧。",
                "0_H171": "",
                "0_H172": "",
                "0_H173": "",
                "0_H174": ""
            },
            "raw_text": {
                "0_H170": "ヘラクレス、やはりいたか。ギリシャ屈指の英傑にして、私を殺した男よ。正気を失っていようとも、お前は何も変わっていないな。語り合いたいことも刃を交える理由も山ほどあるが、今はただ、カルデアのために共に歩むとしよう。",
                "0_H171": "",
                "0_H172": "",
                "0_H173": "",
                "0_H174": ""
            }
        },
        "0_H180": {
            "name": "会話 5",
            "text": {
                "0_H180": "我的妹妹，彭忒西勒亚啊。任由愤怒支配也无妨。愤慨与狂奔，亦是月女神光辉的一角。若那是你力量的源泉，我便予以肯定。况且，对于阿喀琉斯和忒修斯，我也有着诸多积怨。",
                "0_H181": "",
                "0_H182": "",
                "0_H183": "",
                "0_H184": ""
            },
            "raw_text": {
                "0_H180": "我が妹、ペントシレイアよ。怒りに身を任せるのもよかろう。憤怒と凶本も、また月女神の輝きの一片。それがお前の強さの源であるのなら、私は肯定する。それに、アキレウスやテセウスには、私も思うところは大いにあるしな。",
                "0_H181": "",
                "0_H182": "",
                "0_H183": "",
                "0_H184": ""
            }
        },
        "0_H1800": {
            "name": "絆Lv.5 女性主人公選択時",
            "text": {
                "0_H1800": "我以女王兼圣将之名宣告。我认可你为亚马逊的一员。你是我应守护之人，亦是与我共赴战场的同胞。我向月女神及家父——那位战神先辈起誓。你的灵魂将永远与我们亚马逊的祝福同在。",
                "0_H1801": "",
                "0_H1802": "",
                "0_H1803": "",
                "0_H1804": ""
            },
            "raw_text": {
                "0_H1800": "女王にして聖将たる私が宣言しよう。君をアマゾネスの民として認める。私が守るべき人間であり、共に戦場を歩む腹からである。月女神と我が父である先人に誓おう。君の魂は常に我らアマゾネスの祝福と共にあると。",
                "0_H1801": "",
                "0_H1802": "",
                "0_H1803": "",
                "0_H1804": ""
            }
        },
        "0_H190": {
            "name": "会話 6",
            "text": {
                "0_H190": "哦，迦勒底的名马可真多啊。真想与它们驰骋一番。赤兔也是匹可爱的马呢。什么？你说你不是赤兔而是吕布？原来如此，名为吕布的马吗。看起来很是勇猛呢。",
                "0_H191": "",
                "0_H192": "",
                "0_H193": "",
                "0_H194": ""
            },
            "raw_text": {
                "0_H190": "おお、カルデアには名馬が多いな。遊戯を図りたいところだ。石渡というのも可愛らしい馬だな。何、私は石渡ではなく緑風。そうか、緑風という名の馬か。勇猛そうだな。",
                "0_H191": "",
                "0_H192": "",
                "0_H193": "",
                "0_H194": ""
            }
        },
        "0_H200": {
            "name": "会話 7",
            "text": {
                "0_H200": "没想到阿耳忒弥斯大人竟然降临了。甚至连那位平庸猎人的身姿也一并……实在令人钦佩。为了不让俄里翁阁下误入歧途，一旦发现他有任何不轨之举，我会立刻通过祈祷与矢文告知您的。",
                "0_H201": "",
                "0_H202": "",
                "0_H203": ""
            },
            "raw_text": {
                "0_H200": "よもやアルテミス様が降臨なさっているとは。凡庸たる狩人殿の遅くまで。敬服いたしました。オリオン殿が道を踏み外さぬよう、不手際を見かけた際には、すぐに祈祷と矢文にてお知らせしましょうぞ。",
                "0_H201": "",
                "0_H202": "",
                "0_H203": ""
            }
        },
        "0_H210": {
            "name": "会話 8",
            "text": {
                "0_H210": "亚马逊CEO。御主，我需要一个解释。为何我的妹妹戴着眼镜和领带，说话时还总是一副抱着终端设备的姿势？长相相同却是他人……原来如此，这就是所谓的“二重身”现象吗。",
                "0_H211": "",
                "0_H212": "",
                "0_H213": "",
                "0_H214": ""
            },
            "raw_text": {
                "0_H210": "アマゾネスドットコム。マスター、説明を求める。何ゆえ我が妹は眼鏡とネクタイをつけ、喋るときに常に器を抱えるような姿勢を取っているのだ。同じ顔だが別人。なるほど、これがドッペルゲンガーという現象か。",
                "0_H211": "",
                "0_H212": "",
                "0_H213": "",
                "0_H214": ""
            }
        },
        "0_H220": {
            "name": "会話 9",
            "text": {
                "0_H220": "阿塔兰忒，听说你也是尊崇月女神的同胞。改日希望能与你一同狩猎献给神殿的供品，切磋一下弓术。",
                "0_H221": "",
                "0_H222": ""
            },
            "raw_text": {
                "0_H220": "あたらて、君も月女神を天に掲げる同胞と聞いた。いずれ神殿に捧げる供物を共に狩り、弓の腕を競いたいものだ。",
                "0_H221": "",
                "0_H222": ""
            }
        },
        "0_H230": {
            "name": "会話 10",
            "text": {
                "0_H230": "金色的王吗。手持权杖与泥板的那位暂且不论，我与穿着铠甲时期的那家伙实在合不来。尤其是那种傲慢。虽然比起他舍弃一切后的那个姿态要好一些。",
                "0_H231": "",
                "0_H232": ""
            },
            "raw_text": {
                "0_H230": "金色の王か。杖と粘土板を扱う方はともかく、鎧をまとっている時期の奴とはそりが合わん。あの傲慢さが特にな。それを全て捨て去った時の姿よりはマシだが。",
                "0_H231": "",
                "0_H232": ""
            }
        },
        "0_H240": {
            "name": "会話 11",
            "text": {
                "0_H240": "啊，是吗。那就是凛提到过的，关于我的发型……不，没什么。是我自言自语。",
                "0_H241": "",
                "0_H242": ""
            },
            "raw_text": {
                "0_H240": "ああそう。あれがリンの言っていた私の髪型の。いや、なんでもない。こちらの話だ。",
                "0_H241": "",
                "0_H242": ""
            }
        },
        "0_H250": {
            "name": "会話 12",
            "text": {
                "0_H250": "狮心王理查。那个男人，还是一如既往地活得奔放得令人悲哀啊。不过，那或许也有成为他人救赎的时候吧。至少，与他的并肩作战是一段美好的回忆。",
                "0_H251": "",
                "0_H252": "",
                "0_H253": ""
            },
            "raw_text": {
                "0_H250": "獅子心王リチャード。相変わらず悲しいほどに奔放に生きているな、あの男は。だが、それが誰かの救いになる時もあるのだろう。少なくとも奴との共闘は良きものだった。",
                "0_H251": "",
                "0_H252": "",
                "0_H253": ""
            }
        },
        "0_I010": {
            "name": "Fate/strange Fakeコラボイベント 1",
            "text": {
                "0_I010": "你来了啊，御主。看来这里是进行物物交换的场所。既然我受命看管此地，且被信任不会携物私逃，那我唯有不负这份期待。",
                "0_I011": "",
                "0_I012": ""
            }
        },
        "0_I020": {
            "name": "Fate/strange Fakeコラボイベント 2",
            "text": {
                "0_I020": "在我们部族，女王也经常出面参与交易。因此，不仅需要让对方不敢轻视的武力，还需要能鉴别物品真伪的眼力。放心吧，御主。这里的每一件都是货真价实的宝物。",
                "0_I021": "",
                "0_I022": ""
            }
        },
        "0_I030": {
            "name": "Fate/strange Fakeコラボイベント 3",
            "text": {
                "0_I030": "这是珠玉般的极品。小心别弄掉了。",
                "0_I031": ""
            }
        },
        "0_I040": {
            "name": "Fate/strange Fakeコラボイベント 4",
            "text": {
                "0_I040": "哦，难道你还有经商的才能吗？不错的选择。",
                "0_I041": ""
            }
        },
        "0_I050": {
            "name": "Fate/strange Fakeコラボイベント 5",
            "text": {
                "0_I050": "虽然是难以驾驭的物件，但若是你与迦勒底的话，应该能运用自如吧。"
            }
        },
        "0_S020": {
            "name": "仮加入",
            "text": {
                "0_S020": "Rider，希波吕忒。即便相处时日尚短，我也已明了你是个善良之人。从今往后，还请让我见识你作为战士、作为御主的姿态。当然，我也誓将作为一名战士，守护你的安全。",
                "0_S021": "",
                "0_S022": "",
                "0_S023": ""
            },
            "raw_text": {
                "0_S020": "ライダー引っ張り出た。君が善良なものであることは、この短き間でも理解した。ここから先は、戦士として、マスターとしての在り方を見せてもらいたい。無論、私も一人の戦士として、君を守ると誓おう。",
                "0_S021": "",
                "0_S022": "",
                "0_S023": ""
            }
        }
    },
    "ChrVoice_ids": [
        "405600"
    ]
}