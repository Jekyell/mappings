        "0_H1600": {
            "name": "絆Lv.4 (第1部クリア以降)",
            "text": {
                "0_H1600": "",
                "0_H1601": ""
            },
            "raw_text": {
                "0_H1600": "",
                "0_H1601": ""
            }
