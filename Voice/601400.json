        "0_H010": {
            "name": "生日",
            "text": {
                "0_H010": "祝您生日快乐。 到了能喝酒的年龄了吗？"
            }
        },
        "0_H020": {
            "name": "活动举行中",
            "text": {
                "0_H020": "哎呀呀。好像出什么事了哟，呵呵呵。"
            }
        },
        "0_H030": {
            "name": "对话 1",
            "text": {
                "0_H030": "我说，该出发了吧？"
            }
        },
        "0_H040": {
            "name": "对话 2",
            "text": {
                "0_H040": "主人♪ ……希望我这么称呼您吗？"
            }
        },
        "0_H050": {
            "name": "对话 3",
            "text": {
                "0_H050": "尽情向我撒娇吧，呵呵呵。"
            }
        },
        "0_H060": {
            "name": "喜欢的东西",
            "text": {
                "0_H060": "我喜欢崇高的人。 无论是男性还是女性。"
            }
        },
        "0_H070": {
            "name": "讨厌的东西",
            "text": {
                "0_H070": "我讨厌拿着权力当挡箭牌的人。 因为发生过很多事。"
            }
        },
        "0_H080": {
            "name": "关于圣杯",
            "text": {
                "0_H080": "圣杯啊…… 如果许愿说想要永远的青春，是否显得有些老套呢？",
                "0_H081": "还是说有些绝望呢。"
            }
        },
        "0_H090": {
            "name": "牵绊Lv.1",
            "text": {
                "0_H090": "不·行·哟♪"
            }
        },
        "0_H100": {
            "name": "牵绊Lv.2",
            "text": {
                "0_H100": "好吧，小指程度还是可以的哦。"
            }
        },
        "0_H110": {
            "name": "牵绊Lv.3",
            "text": {
                "0_H110": "哎呀，有什么好惊讶的？ 我触碰你就显得那么奇怪吗？"
            }
        },
        "0_H120": {
            "name": "牵绊Lv.4",
            "text": {
                "0_H120": "对对，你的触摸方法越来越熟练了呢。"
            }
        },
        "0_H130": {
            "name": "牵绊Lv.5",
            "text": {
                "0_H130": "呵呵，结果——还是小指和小指的接触最舒服吧。"
            }
        },
        "0_H1400": {
            "name": "絆Lv.3 (第1部クリア以降)",
            "text": {
                "0_H1400": "嗯，嗯。……一定非常痛苦吧。",
                "0_H1401": "今天我会一直陪着你。"
            },
            "raw_text": {
                "0_H1400": "",
                "0_H1401": ""
            }
        },
        "0_H1600": {
            "name": "絆Lv.4 (第1部クリア以降)",
            "text": {
                "0_H1600": "让我们手指相扣吧。",
                "0_H1601": "虽然无法治愈你的痛苦，只愿能让你心情平复。"
            },
            "raw_text": {
                "0_H1600": "",
                "0_H1601": ""
            }
        },
        "0_H170": {
            "name": "会話 4",
            "text": {
                "0_H170": "那位打扮华丽的小姐……",
                "0_H171": "哎呀，莉莉丝。",
                "0_H172": "呵呵呵，虽然很漂亮，但看上去很寂寞呢。",
                "0_H173": "御主，一定要好好关注她哦。"
            },
            "raw_text": {
                "0_H170": "あの派手なお嬢さんは。まあリリス。きれいだけど寂しそうね。マスター、ちゃんと見てあげなきゃダメよ。",
                "0_H171": "",
                "0_H172": "",
                "0_H173": ""
            }
        },
        "0_H180": {
            "name": "会話 5",
            "text": {
                "0_H180": "哎呀，是印度的神明……也是爱之女神吗？",
                "0_H181": "那必须好好拜一下呢，呵呵呵。",
                "0_H182": "但会令人堕落或许有些可怕呢……",
                "0_H183": "哎，没关系？　肯定没事？",
                "0_H184": "既然御主都这么说了，那肯定没事吧！"
            },
            "raw_text": {
                "0_H180": "あら、インドの神様で愛の女神なの？じゃあ拝んでおかなきゃね。でも人を堕落させるのはちょっと怖いかも。え、大丈夫？絶対に？マスターがそう言うなら大丈夫ね。",
                "0_H181": "",
                "0_H182": "",
                "0_H183": "",
                "0_H184": ""
            }
        },
        "0_H1800": {
            "name": "絆Lv.5 (第1部クリア以降)",
            "text": {
                "0_H1800": "你一直非常努力吧。",
                "0_H1801": "嗯……是不是得到了大家的夸奖？",
                "0_H1802": "但我相信无论得到多少次夸奖都会很开心，所以我还是要说。",
                "0_H1803": "你真的非常努力哦。我最喜欢你了，御主。"
            },
            "raw_text": {
                "0_H1800": "",
                "0_H1801": "",
                "0_H1802": "",
                "0_H1803": ""
            }
        },
        "0_H190": {
            "name": "会話 6",
            "text": {
                "0_H190": "哎呀，夏洛特。",
                "0_H191": "今天需要我教你打听情报的诀窍吗？",
                "0_H192": "还是说……要学撩御主的方法？",
                "0_H193": "呵呵呵。"
            },
            "raw_text": {
                "0_H190": "あらシャーロット、今日は情報を聞き出すコツを教えましょうか。それともマスターの口説き方でも？ふふ。",
                "0_H191": "",
                "0_H192": "",
                "0_H193": ""
            }
        },
        "0_H2300": {
            "name": "会話 3 (第1部クリア以降)",
            "text": {
                "0_H2300": "和御主的关系？",
                "0_H2301": "当然是被撒娇的那方啦。",
                "0_H2302": "……虽然偶尔也想试着成为撒娇的那方……",
                "0_H2303": "哎嘿嘿……"
            },
            "raw_text": {
                "0_H2300": "マスターとの関係。もちろん甘やかす側よ。甘やかされる側に回ってみたいなってたまに思うけど。",
                "0_H2301": "",
                "0_H2302": "",
                "0_H2303": ""
            }
        },
