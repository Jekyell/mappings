        "0_H010": {
            "name": "生日",
            "text": {
                "0_H010": "祝您生日快乐。 到了能喝酒的年龄了吗？"
            }
        },
        "0_H020": {
            "name": "活动举行中",
            "text": {
                "0_H020": "哎呀呀。好像出什么事哟，呵呵呵。"
            }
        },
        "0_H030": {
            "name": "对话 1",
            "text": {
                "0_H030": "我说，该出发了吧？"
            }
        },
        "0_H040": {
            "name": "对话 2",
            "text": {
                "0_H040": "主人♪  ……希望我这么称呼您吗？"
            }
        },
        "0_H050": {
            "name": "对话 3",
            "text": {
                "0_H050": "尽情向我撒娇吧，呵呵呵。"
            }
        },
        "0_H060": {
            "name": "喜欢的东西",
            "text": {
                "0_H060": "我喜欢崇高的人。 无论是男性还是女性。"
            }
        },
        "0_H070": {
            "name": "讨厌的东西",
            "text": {
                "0_H070": "我讨厌拿着权力当挡箭牌的人。 因为发生过很多事。"
            }
        },
        "0_H080": {
            "name": "关于圣杯",
            "text": {
                "0_H080": "圣杯啊…… 如果许愿说想要永远的青春，是否显得有些老套呢？",
                "0_H081": "还是说有些绝望呢。"
            }
        },
        "0_H090": {
            "name": "牵绊Lv.1",
            "text": {
                "0_H090": "不·行·哟♪"
            }
        },
        "0_H100": {
            "name": "牵绊Lv.2",
            "text": {
                "0_H100": "好吧，小指程度还是可以的哦。"
            }
        },
        "0_H110": {
            "name": "牵绊Lv.3",
            "text": {
                "0_H110": "哎呀，有什么好惊讶的？  我触碰你就显得那么奇怪吗？"
            }
        },
        "0_H120": {
            "name": "牵绊Lv.4",
            "text": {
                "0_H120": "对对，你的触摸方法越来越熟练了呢。"
            }
        },
        "0_H130": {
            "name": "牵绊Lv.5",
            "text": {
                "0_H130": "呵呵，结果―― 还是小指和小指的接触最舒服吧。"
            }
        },
        "0_H1400": {
            "name": "絆Lv.3 (第1部クリア以降)",
            "text": {
                "0_H1400": "",
                "0_H1401": ""
            },
            "raw_text": {
                "0_H1400": "",
                "0_H1401": ""
