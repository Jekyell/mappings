        "0_G010": {
            "name": "升级",
            "text": {
                "0_G010": "好像变强了呢。"
            }
        },
        "0_G020": {
            "name": "灵基再临 2",
            "text": {
                "0_G020": "嗯，感觉真不错。"
            }
        },
        "0_G030": {
            "name": "灵基再临 1",
            "text": {
                "0_G030": "哎呀，讨厌…… 呵呵呵，不错呢！"
            }
        },
        "0_G040": {
            "name": "灵基再临 3",
            "text": {
                "0_G040": "太棒了！ 我漂亮吗？"
            }
        },
        "0_G050": {
            "name": "灵基再临 4",
            "text": {
                "0_G050": "――谢谢。现在的我才是真正的我哦。呵呵呵。"
            }
        },
        "0_G110": {
