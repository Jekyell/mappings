{
    "id": 705100,
    "collectionNo": 440,
    "name": "リリス",
    "voices": {
        "0_B010": {
            "name": "アタック 1",
            "text": {
                "0_B010": "哈——！"
            }
        },
        "0_B020": {
            "name": "アタック 2",
            "text": {
                "0_B020": "一劈为二！"
            }
        },
        "0_B030": {
            "name": "アタック 3",
            "text": {
                "0_B030": "好，那边～！"
            }
        },
        "0_B040": {
            "name": "エクストラアタック 1",
            "text": {
                "0_B040": "拒绝！　腐朽而死吧！"
            }
        },
        "0_B050": {
            "name": "宝具 1",
            "text": {
                "0_B050": "律法回归虚无，稳健化作纷争。",
                "0_B051": "平坦的大地隆起山岳，万物尽数溶解化混沌。",
                "0_B052": "虚妄乃黑暗的女儿。",
                "0_B053": "来吧，恶梦开始了。"
            }
        },
        "0_B080": {
            "name": "スキル 1",
            "text": {
                "0_B080": "莉莉图。"
            }
        },
        "0_B090": {
            "name": "スキル 2",
            "text": {
                "0_B090": "对伦家来说算强化！"
            }
        },
        "0_B100": {
            "name": "開始 1",
            "text": {
                "0_B100": "做好坠落的准备了吗？"
            }
        },
        "0_B110": {
            "name": "開始 2",
            "text": {
                "0_B110": "OK别介意Let's go迦·勒·底！ 那么，开杀吧。"
            }
        },
        "0_B120": {
            "name": "勝利 1",
            "text": {
                "0_B120": "伦家赢了。毕竟是黑暗的女儿嘛～。"
            }
        },
        "0_B130": {
            "name": "勝利 2",
            "text": {
                "0_B130": "不可能赢过风暴本身吧～？"
            }
        },
        "0_B140": {
            "name": "ダメージ 2",
            "text": {
                "0_B140": "碍事！"
            }
        },
        "0_B150": {
            "name": "ダメージ 1",
            "text": {
                "0_B150": "好痛啊啊啊啊！？"
            }
        },
        "0_B160": {
            "name": "戦闘不能 1",
            "text": {
                "0_B160": "人家也到此为止了吗……也就这样了吧……啊啊……"
            }
        },
        "0_B170": {
            "name": "戦闘不能 2",
            "text": {
                "0_B170": "御主……握住人家的手……这点总行吧……"
            }
        },
        "0_B180": {
            "name": "コマンドカード 1",
            "text": {
                "0_B180": "没问题～。"
            }
        },
        "0_B190": {
            "name": "コマンドカード 2",
            "text": {
                "0_B190": "知道啦～。"
            }
        },
        "0_B200": {
            "name": "コマンドカード 3",
            "text": {
                "0_B200": "才不要呢。"
            }
        },
        "0_B2010": {
            "name": "アタック 10",
            "text": {
                "0_B2010": "לפא תעבט（暗之环）！"
            }
        },
        "0_B2020": {
            "name": "アタック 11",
            "text": {
                "0_B2020": "הפוס（风暴）！"
            }
        },
        "0_B2030": {
            "name": "アタック 12",
            "text": {
                "0_B2030": "切得粉碎！"
            }
        },
        "0_B210": {
            "name": "宝具カード 1",
            "text": {
                "0_B210": "宝具啊，好好～。"
            }
        },
        "0_B220": {
            "name": "宝具カード 2",
            "text": {
                "0_B220": "要使用宝具？　会死的，可以吗？"
            }
        },
        "0_B230": {
            "name": "宝具カード 3",
            "text": {
                "0_B230": "刮起风暴吧，要召唤黑夜了。"
            }
        },
        "0_B2410": {
            "name": "アタック 13",
            "text": {
                "0_B2410": "在身上打个洞也无妨吗！？"
            }
        },
        "0_B2420": {
            "name": "アタック 14",
            "text": {
                "0_B2420": "不准碰伦家！"
            }
        },
        "0_B2430": {
            "name": "アタック 15",
            "text": {
                "0_B2430": "直接去死吧！"
            }
        },
        "0_B2440": {
            "name": "エクストラアタック 4",
            "text": {
                "0_B2440": "英雄去死吧，勇者去死吧！"
            }
        },
        "0_B250": {
            "name": "宝具カード 4",
            "text": {
                "0_B250": "让你见识一下伦家有多帅气吧～。"
            }
        },
        "0_B410": {
            "name": "アタック 4",
            "text": {
                "0_B410": "ךְתַחָ（斩断）！"
            }
        },
        "0_B420": {
            "name": "アタック 5",
            "text": {
                "0_B420": "חורה דוקיר （风之舞）！"
            }
        },
        "0_B430": {
            "name": "アタック 6",
            "text": {
                "0_B430": "לפא ףושיכ（暗之咒缚）！"
            }
        },
        "0_B440": {
            "name": "エクストラアタック 2",
            "text": {
                "0_B440": "如果胆敢妨碍伦家，就去死吧！"
            }
        },
        "0_B480": {
            "name": "スキル 3",
            "text": {
                "0_B480": "吞噬黑夜。"
            }
        },
        "0_B490": {
            "name": "スキル 4",
            "text": {
                "0_B490": "风暴会紧随而来。"
            }
        },
        "0_B500": {
            "name": "開始 3",
            "text": {
                "0_B500": "唔～，被杀掉就麻烦了，所以先把对方灭了吧。"
            }
        },
        "0_B510": {
            "name": "開始 4",
            "text": {
                "0_B510": "伦家能召唤风暴哦～？ 也能召唤黑夜。毕竟我们是朋友嘛！"
            }
        },
        "0_B520": {
            "name": "勝利 3",
            "text": {
                "0_B520": "暴尸荒野，被风雨的磨耗下消失。生命体还真是脆弱呢。"
            }
        },
        "0_B530": {
            "name": "勝利 4",
            "text": {
                "0_B530": "唔～？　还没放弃吗？ 那就追加一份地狱的订单吧～。"
            }
        },
        "0_B540": {
            "name": "ダメージ 4",
            "text": {
                "0_B540": "很痛的啦！"
            }
        },
        "0_B550": {
            "name": "ダメージ 3",
            "text": {
                "0_B550": "呜……你这家伙——！"
            }
        },
        "0_B560": {
            "name": "戦闘不能 3",
            "text": {
                "0_B560": "对不起……对不起……明明承诺过了……承诺过了……！"
            }
        },
        "0_B800": {
            "name": "宝具 2",
            "text": {
                "0_B800": "真理才是时间的女儿，那虚妄便是黑暗的女儿。",
                "0_B801": "滴答，滴答，倒转的时间如风暴一般。",
                "0_B802": "虚妄乃黑暗的女儿。",
                "0_B803": "……去死吧。"
            }
        },
        "0_B840": {
            "name": "エクストラアタック 3",
            "text": {
                "0_B840": "四分五裂大卸八块杀人事件！"
            }
        },
        "0_B880": {
            "name": "スキル 5",
            "text": {
                "0_B880": "……杀掉。"
            }
        },
        "0_B910": {
            "name": "アタック 7",
            "text": {
                "0_B910": "לצה ברח（影之剑）！"
            }
        },
        "0_B920": {
            "name": "アタック 8",
            "text": {
                "0_B920": "苹果，咚！"
            }
        },
        "0_B930": {
            "name": "アタック 9",
            "text": {
                "0_B930": "הריקד（突刺）！"
            }
        },
        "0_G010": {
            "name": "レベルアップ 1",
            "text": {
                "0_G010": "知道啦知道啦，强化强化。"
            }
        },
        "0_G020": {
            "name": "霊基再臨 2",
            "text": {
                "0_G020": "好，中转点突破！",
                "0_G021": "下一次伦家打算走更豪华，或者更厚重的路线，所以希望你能多准备点种火哦。"
            }
        },
        "0_G030": {
            "name": "霊基再臨 1",
            "text": {
                "0_G030": "好，总之能力强化。",
                "0_G031": "其实只是脱下兜帽把胸口敞开而已。",
                "0_G032": "你觉得这对翅膀能飞吗？",
                "0_G033": "其实能飞哦。",
                "0_G034": "不过与其说是飞，更像是滑翔啦。"
            }
        },
        "0_G110": {
            "name": "レベルアップ 2",
            "text": {
                "0_G110": "噢，变强了。",
                "0_G111": "真有你的，御主。"
            }
        },
        "0_G120": {
            "name": "レベルアップ 3",
            "text": {
                "0_G120": "唔唔唔……咽下。",
                "0_G121": "嗯～，仿佛又甜又辣，还有些酸的可口感呢。",
                "0_G122": "啊～，不过好像还有点青春的微苦感！"
            }
        },
        "0_H010": {
            "name": "誕生日",
            "text": {
                "0_H010": "生日快乐！",
                "0_H011": "嗯，伦家很高兴你能出生在这个世界上。",
                "0_H012": "虽然很遗憾无法同日诞生，但会在同日死去哦！"
            }
        },
        "0_H020": {
            "name": "イベント開催中",
            "text": {
                "0_H020": "活动举办中～。",
                "0_H021": "来，打起点精神啦。",
                "0_H022": "然后也给伦家点东西啦。"
            }
        },
        "0_H030": {
            "name": "会話 1",
            "text": {
                "0_H030": "快点快点，该出门啦～。"
            }
        },
        "0_H040": {
            "name": "会話 2",
            "text": {
                "0_H040": "主从……",
                "0_H041": "怎么怎么，御主你真的打算当主人？",
                "0_H042": "想让伦家屈服？",
                "0_H043": "……不是那种意思？",
                "0_H044": "什么嘛，真没劲。"
            }
        },
        "0_H050": {
            "name": "会話 3",
            "text": {
                "0_H050": "和御主的关系啊……",
                "0_H051": "唔～，保密。"
            }
        },
        "0_H060": {
            "name": "好きなこと",
            "text": {
                "0_H060": "喜欢的东西吗……",
                "0_H061": "唔～，风和夜，还有观察人类？",
                "0_H062": "哦，观察人类这种说法听起来怪不好意思呢。",
                "0_H063": "不过伦家其实很喜欢人类哦～。"
            }
        },
        "0_H070": {
            "name": "嫌いなこと",
            "text": {
                "0_H070": "讨厌的东西、讨厌的人类、讨厌的从者……",
                "0_H071": "唔～，好像没有？"
            }
        },
        "0_H080": {
            "name": "聖杯について",
            "text": {
                "0_H080": "希望圣杯实现的愿望？",
                "0_H081": "唔～，不需要。",
                "0_H082": "伦家没什么想要的。",
                "0_H083": "如果御主想要，就给你～。"
            }
        },
        "0_H090": {
            "name": "絆Lv.1",
            "text": {
                "0_H090": "噢，御主。",
                "0_H091": "找伦家有事吗～？"
            }
        },
        "0_H100": {
            "name": "絆Lv.2",
            "text": {
                "0_H100": "伦家虽然出身于美索不达米亚，但和那个金闪闪的王或是帅哥泥人偶没什么关系哦。",
                "0_H101": "啊，当然也没有离过婚。"
            }
        },
        "0_H1000": {
            "name": "絆Lv.1 (奏章Ⅳクリア以降)",
            "text": {
                "0_H1000": "啊，基列莱特不在吧？",
                "0_H1001": "那就行了。"
            }
        },
        "0_H110": {
            "name": "絆Lv.3",
            "text": {
                "0_H110": "伦家是风暴与黑夜的化身。",
                "0_H111": "怎么样，很帅吧。",
                "0_H112": "用现代的话说，就是风属性和暗属性哦。",
                "0_H113": "用风系超能力把敌人切断，然后用暗系超能力让敌人阴沉～！",
                "0_H114": "……暗系还是再思考一下吧……"
            }
        },
        "0_H120": {
            "name": "絆Lv.4",
            "text": {
                "0_H120": "啊，御主。",
                "0_H121": "虽然有些突然，但伦家爱你哦？",
                "0_H122": "不，只是伦家总觉得这话还是要说的。",
                "0_H123": "毕竟咱们对彼此也有了一定程度的了解……",
                "0_H124": "你应该早就心知肚明了吧？"
            }
        },
        "0_H1200": {
            "name": "絆Lv.2 (奏章Ⅳクリア以降)",
            "text": {
                "0_H1200": "太执着于玛修？",
                "0_H1201": "哈～，伦家才不执着呢～！"
            }
        },
        "0_H130": {
            "name": "絆Lv.5",
            "text": {
                "0_H130": "话说御主，伦家要告诉你一件重要的事哦。",
                "0_H131": "如果你死了，伦家也会死。",
                "0_H132": "哎？　御主一死从者也会消灭？",
                "0_H133": "不不，不是那个意思。",
                "0_H134": "如果御主被杀，伦家就会当场捏碎自己的灵核去死。",
                "0_H135": "所以放心吧，御主。",
                "0_H136": "你死的时候绝对不会孤单。伦家肯定第一个跟上。",
                "0_H137": "好吗～？"
            }
        },
        "0_H1400": {
            "name": "絆Lv.3 (奏章Ⅳクリア以降)",
            "text": {
                "0_H1400": "地狱的日子过得开心吗？",
                "0_H1401": "伦家虽然只剩在雾气深处若隐若现的记忆了，但唯独那种感情还记得。",
                "0_H1402": "真遗憾，还是没能实现呢。"
            }
        },
        "0_H1600": {
            "name": "絆Lv.4 (奏章Ⅳクリア以降)",
            "text": {
                "0_H1600": "为什么讨厌基列莱特？",
                "0_H1601": "不，在地狱时伦家应该有明确的理由才对。",
                "0_H1602": "现在的话……不好说。",
                "0_H1603": "也许伦家只是想珍惜曾经讨厌的这种感情吧。",
                "0_H1604": "毕竟青春期是很复杂的嘛。"
            }
        },
        "0_H170": {
            "name": "会話 4",
            "text": {
                "0_H170": "噢噢～，是不良呢，不良。",
                "0_H171": "那种摇滚感相当不错哦～。",
                "0_H172": "要不要一起搞点事？　组个队闹一场之类的？",
                "0_H173": "啊，你是圆桌骑士啊？",
                "0_H174": "……感觉会被规矩束缚呢。"
            }
        },
        "0_H180": {
            "name": "会話 5",
            "text": {
                "0_H180": "啊哈哈！　这是亚当啊！",
                "0_H181": "不，这样也不错啦！　反正跟伦家毫无关系！",
                "0_H182": "倒不如说万一被说成离过婚也很不光彩！",
                "0_H183": "啊，但事已至此何不在肩上扛个火箭发射器呢？",
                "0_H184": "肯定会很帅吧！"
            }
        },
        "0_H1800": {
            "name": "絆Lv.5 (奏章Ⅳクリア以降)",
            "text": {
                "0_H1800": "伦家对自己做过的事丝毫不后悔，今后也不会后悔。",
                "0_H1801": "就算一直被基列莱特讨厌也不要紧。",
                "0_H1802": "对基列莱特来说，这世上有这么一个人也无妨吧。",
                "0_H1803": "这就能让伦家心满意足了。",
                "0_H1804": "……御主还真温柔呢。"
            }
        },
        "0_H190": {
            "name": "会話 6",
            "text": {
                "0_H190": "哎，难道那是伦家不知道的伦家的侧面！？",
                "0_H191": "啊，不是啊。",
                "0_H192": "不过那脚好帅啊～。",
                "0_H193": "伦家是不是也该加上那样的机关比较好？",
                "0_H194": "在战斗中加上旋转之类的？"
            }
        },
        "0_H200": {
            "name": "会話 7",
            "text": {
                "0_H200": "哦，阿育王。",
                "0_H201": "不，虽然伦家的身体不记得了，但内心还是记得你的。",
                "0_H202": "……这种说法好像有些不对呢。",
                "0_H203": "不过很高兴看到你还那么精神哦。",
                "0_H204": "你还在转轮吗？",
                "0_H205": "……明明是自己说的话，却有点莫名其妙呢，啊哈哈哈哈！"
            }
        },
        "0_H210": {
            "name": "会話 8",
            "text": {
                "0_H210": "啊，是废柴帅哥军团领头的莫里亚蒂呢。",
                "0_H211": "你在那边的特异点是个律师哦。",
                "0_H212": "正义伙伴的身份和你意外相衬呢？",
                "0_H213": "……哈哈，非常嫌弃的表情呢～。"
            }
        },
        "0_H220": {
            "name": "会話 9",
            "text": {
                "0_H220": "是但丁·阿利吉耶里。",
                "0_H221": "我是莉莉丝，剩下应该……也没什么好说的了吧。",
                "0_H222": "感觉咱们致命地不合嘛。",
                "0_H223": "毕竟你喜欢的是贝阿特丽切，这方面基本可以肯定。",
                "0_H224": "换言之现在的关系，因为是关系亲密的御主和他的从者……",
                "0_H225": "所以算朋友的朋友……？",
                "0_H226": "关系真浅呢！"
            }
        },
        "0_H230": {
            "name": "会話 10",
            "text": {
                "0_H230": "啊～，Shiro（小白）也在～。",
                "0_H231": "哎，像狗的名字？",
                "0_H232": "那就叫Shirou（四郎）吧。",
                "0_H233": "你还是那么憎恨人类？　还是喜欢人类？",
                "0_H234": "……都对，也都不对？",
                "0_H235": "你经历的人生还真是复杂呢。",
                "0_H236": "要不要像伦家一样变成风？",
                "0_H237": "四郎应该会成为一阵不错的风哦。",
                "0_H238": "不行吗，这样啊～。"
            }
        },
        "0_H2300": {
            "name": "会話 3 (絆Lv.5以上+奏章Ⅳクリア以降)",
            "text": {
                "0_H2300": "伦家以前没说过吗？",
                "0_H2301": "伦家会为了你去死。",
                "0_H2302": "很愉快的关系吧～。"
            }
        },
        "0_H3060": {
            "name": "好きなこと (絆Lv.5以上+奏章Ⅳクリア以降)",
            "text": {
                "0_H3060": "伦家的爱会让你觉得麻烦吗？",
                "0_H3061": "不觉得麻烦，但也无法回应？",
                "0_H3062": "啊……不是这个意思啦，御主。",
                "0_H3063": "人呀，有时只要怀着那份感情就能心满意足了。",
                "0_H3064": "不管对方有什么想法。"
            }
        },
        "0_H3070": {
            "name": "嫌いなこと (絆Lv.5以上+奏章Ⅳクリア以降)",
            "text": {
                "0_H3070": "讨厌的东西？",
                "0_H3071": "……你明明知道。"
            }
        },
        "0_S010": {
            "name": "召喚",
            "text": {
                "0_S010": "呀嗬～，",
                "0_S011": "哎呀，没想到竟然连伦家都召唤出来了。",
                "0_S012": "迦勒底还真是个相当邪恶的组织呢。",
                "0_S013": "伦家是莉莉丝。",
                "0_S014": "是在美索不达米亚出现的……",
                "0_S015": "唔～类似精灵的存在吧。",
                "0_S016": "总之，今后请多关照喵～！"
            }
        },
        "0_S110": {
            "name": "召喚 (奏章Ⅳクリア以降)",
            "text": {
                "0_S110": "呀嗬，是伦家哦～！",
                "0_S111": "自从地狱以来好久不见啦！　还精神吗～？",
                "0_S112": "……开玩笑的。毕竟缔结了那么紧密的缘分，就算不愿意也会被拉过来吧～。",
                "0_S113": "行吧。那么……",
                "0_S114": "风暴与夜之化身，莉莉丝。应该不需要自我介绍了吧？",
                "0_S115": "那么，今后还请多指教。",
                "0_S116": "对了，伦家会和基列莱特保持距离的。",
                "0_S117": "那样比较好吧？",
                "0_S118": "也省得让御主太费心嘛。"
            }
        },
        "2_B010": {
            "name": "アタック 1",
            "text": {
                "2_B010": "成为俘虏。"
            }
        },
        "2_B020": {
            "name": "アタック 2",
            "text": {
                "2_B020": "攻陷。"
            }
        },
        "2_B030": {
            "name": "アタック 3",
            "text": {
                "2_B030": "真可悲。"
            }
        },
        "2_B040": {
            "name": "エクストラアタック 1",
            "text": {
                "2_B040": "夜之帷幕化作永恒。"
            }
        },
        "2_B050": {
            "name": "宝具 1",
            "text": {
                "2_B050": "憎恨你、憎恨你、憎恨你。",
                "2_B051": "将你扔进黑暗，然后压溃吧。",
                "2_B052": "然虚妄乃黑暗的女儿。",
                "2_B053": "所以温暖地去死吧。"
            }
        },
        "2_B080": {
            "name": "スキル 1",
            "text": {
                "2_B080": "提升输出。"
            }
        },
        "2_B090": {
            "name": "スキル 2",
            "text": {
                "2_B090": "呼唤风暴。"
            }
        },
        "2_B100": {
            "name": "開始 1",
            "text": {
                "2_B100": "那就开始吧。"
            }
        },
        "2_B110": {
            "name": "開始 2",
            "text": {
                "2_B110": "【莉莉丝】莉莉恩，准备好了吗？ 【莉莉恩1】嗯～。 【莉莉恩2】算是吧～。 【莉莉恩3】好嘞，来啦。 【莉莉丝】非常好。"
            }
        },
        "2_B120": {
            "name": "勝利 1",
            "text": {
                "2_B120": "赢得胜利了。 来吧，御主，肯定有什么奖励吧，比方说拥抱之类的。"
            }
        },
        "2_B130": {
            "name": "勝利 2",
            "text": {
                "2_B130": "怎么了，不过是死了而已吧。 下次去地狱战斗吧。"
            }
        },
        "2_B140": {
            "name": "ダメージ 2",
            "text": {
                "2_B140": "我拒绝。"
            }
        },
        "2_B150": {
            "name": "ダメージ 1",
            "text": {
                "2_B150": "呜……！咕……！"
            }
        },
        "2_B160": {
            "name": "戦闘不能 1",
            "text": {
                "2_B160": "御主……对不起……对不起……"
            }
        },
        "2_B170": {
            "name": "戦闘不能 2",
            "text": {
                "2_B170": "【莉莉恩】好困。 【莉莉丝】是吗……那就睡吧。"
            }
        },
        "2_B180": {
            "name": "コマンドカード 1",
            "text": {
                "2_B180": "好。"
            }
        },
        "2_B190": {
            "name": "コマンドカード 2",
            "text": {
                "2_B190": "可以哦。"
            }
        },
        "2_B200": {
            "name": "コマンドカード 3",
            "text": {
                "2_B200": "请吧。"
            }
        },
        "2_B2010": {
            "name": "アタック 10",
            "text": {
                "2_B2010": "【莉莉恩1】上吧～！ 【莉莉恩2】看招～！ 【莉莉恩3】杀掉～！"
            }
        },
        "2_B2020": {
            "name": "アタック 11",
            "text": {
                "2_B2020": "蹂躏吧。"
            }
        },
        "2_B2030": {
            "name": "アタック 12",
            "text": {
                "2_B2030": "【莉莉丝】消灭他们。 【莉莉恩】好痛！"
            }
        },
        "2_B210": {
            "name": "宝具カード 1",
            "text": {
                "2_B210": "切换为宝具。"
            }
        },
        "2_B2100": {
            "name": "開始 5",
            "text": {
                "2_B2100": "【莉莉丝】莉莉恩，准备好了吗？ 【莉莉恩1】好困。 【莉莉恩2】好乏。 【莉莉恩3】肚子饿了。 【莉莉丝】毫无干劲呢。"
            }
        },
        "2_B220": {
            "name": "宝具カード 2",
            "text": {
                "2_B220": "要用撒手锏了。"
            }
        },
        "2_B230": {
            "name": "宝具カード 3",
            "text": {
                "2_B230": "宝具吗……呵呵呵。"
            }
        },
        "2_B2410": {
            "name": "アタック 13",
            "text": {
                "2_B2410": "我喜欢邪恶的东西哦。"
            }
        },
        "2_B2420": {
            "name": "アタック 14",
            "text": {
                "2_B2420": "受伤了吗？"
            }
        },
        "2_B2430": {
            "name": "アタック 15",
            "text": {
                "2_B2430": "要坚持住哦。"
            }
        },
        "2_B2440": {
            "name": "エクストラアタック 4",
            "text": {
                "2_B2440": "坠入极小的地狱！"
            }
        },
        "2_B250": {
            "name": "宝具カード 4",
            "text": {
                "2_B250": "【莉莉丝】准备好了吗？ 【莉莉恩1】没问题！ 【莉莉恩2】完美！ 【莉莉恩3】大概吧！"
            }
        },
        "2_B410": {
            "name": "アタック 4",
            "text": {
                "2_B410": "La～♪"
            }
        },
        "2_B420": {
            "name": "アタック 5",
            "text": {
                "2_B420": "被智慧之蛇。"
            }
        },
        "2_B430": {
            "name": "アタック 6",
            "text": {
                "2_B430": "真拿你没办法呢。"
            }
        },
        "2_B440": {
            "name": "エクストラアタック 2",
            "text": {
                "2_B440": "坠入窥视魔的深渊。"
            }
        },
        "2_B480": {
            "name": "スキル 3",
            "text": {
                "2_B480": "招来黑暗。"
            }
        },
        "2_B490": {
            "name": "スキル 4",
            "text": {
                "2_B490": "让我们堕落吧。"
            }
        },
        "2_B500": {
            "name": "開始 3",
            "text": {
                "2_B500": "暗之女王、污秽之风、谷底之骸。 ……也就是说，轮到我出场了吧。"
            }
        },
        "2_B510": {
            "name": "開始 4",
            "text": {
                "2_B510": "注视吧，为了成为俘虏。 沉睡吧，为了走向死亡。"
            }
        },
        "2_B520": {
            "name": "勝利 3",
            "text": {
                "2_B520": "【莉莉恩1】赢啦～。 【莉莉恩2】成功啦。 【莉莉恩3】南无阿弥陀佛。 【莉莉丝】最后的莉莉恩，别用那种啦。"
            }
        },
        "2_B530": {
            "name": "勝利 4",
            "text": {
                "2_B530": "我说过吧，我死亡之时，就是你死亡之时哦，御主。"
            }
        },
        "2_B540": {
            "name": "ダメージ 4",
            "text": {
                "2_B540": "好痒啊。"
            }
        },
        "2_B550": {
            "name": "ダメージ 3",
            "text": {
                "2_B550": "必须撑住……呜！"
            }
        },
        "2_B560": {
            "name": "戦闘不能 3",
            "text": {
                "2_B560": "明明……承诺过了……"
            }
        },
        "2_B800": {
            "name": "宝具 2",
            "text": {
                "2_B800": "深爱的你，无比深爱。",
                "2_B801": "所以融入黑暗消失于狭缝中吧。",
                "2_B802": "虚妄乃黑暗的女儿。",
                "2_B803": "此乃永远的丧失。"
            }
        },
        "2_B810": {
            "name": "宝具 3",
            "text": {
                "2_B810": "这是写入黑暗的历史。",
                "2_B811": "无处可去，也无处可归。",
                "2_B812": "虚妄乃黑暗的女儿。",
                "2_B813": "再见了，普通的人。"
            }
        },
        "2_B840": {
            "name": "エクストラアタック 3",
            "text": {
                "2_B840": "融入黑暗之中吧。"
            }
        },
        "2_B880": {
            "name": "スキル 5",
            "text": {
                "2_B880": "莉莉恩在闹腾呢。"
            }
        },
        "2_B890": {
            "name": "スキル 6",
            "text": {
                "2_B890": "【莉莉恩】摔倒了～。 【莉莉丝】我现在正忙啊……"
            }
        },
        "2_B910": {
            "name": "アタック 7",
            "text": {
                "2_B910": "五爪凄惨。"
            }
        },
        "2_B920": {
            "name": "アタック 8",
            "text": {
                "2_B920": "振翅时要安静。"
            }
        },
        "2_B930": {
            "name": "アタック 9",
            "text": {
                "2_B930": "无情的极涡。"
            }
        },
        "2_G010": {
            "name": "レベルアップ 1",
            "text": {
                "2_G010": "我竟然变强了呢，连我都这么觉得。"
            }
        },
        "2_G040": {
            "name": "霊基再臨 1",
            "text": {
                "2_G040": "——总之，这就是我的最终形态。",
                "2_G041": "我可没打算封印哦。",
                "2_G042": "只不过，会很羞耻吧？",
                "2_G043": "这么大……这么大的翅膀！",
                "2_G044": "不过……青涩的我似乎比较喜欢大的。",
                "2_G045": "不管怎么说，这个状态的我可是很强的哦。",
                "2_G046": "要不要立刻试试锋利程度呢？　御主。"
            }
        },
        "2_G050": {
            "name": "霊基再臨 2",
            "text": {
                "2_G050": "沙漠、风与夜，那就是我诞生的地方。",
                "2_G051": "其他的记忆模糊不清，其他的感情也早已被抛弃。",
                "2_G052": "但我仍有身为恶灵的职责哦。",
                "2_G053": "把那种栖息在冷清孤寂之地的怪物拉到阳光下的人可是你哦。",
                "2_G054": "所以，你可要负起这份责任哦。今后也请多关照，御主。",
                "2_G055": "当然，到死为止。"
            }
        },
        "2_G110": {
            "name": "レベルアップ 2",
            "text": {
                "2_G110": "是啊，",
                "2_G111": "再尽情多加一些吧。"
            }
        },
        "2_G120": {
            "name": "レベルアップ 3",
            "text": {
                "2_G120": "【莉莉恩1】追加～。",
                "2_G121": "【莉莉恩2】追加追加～。",
                "2_G122": "【莉莉恩3】变得更大吧～。"
            }
        },
        "2_H010": {
            "name": "誕生日",
            "text": {
                "2_H010": "是吗，生日啊。",
                "2_H011": "就算我不祝贺你，其他人也会祝贺你吧。",
                "2_H012": "虽然有些寂寞，但我为之感到高兴。",
                "2_H013": "因为那是很美好的。"
            }
        },
        "2_H020": {
            "name": "イベント開催中",
            "text": {
                "2_H020": "有活动哦，活动。",
                "2_H021": "拼命奔走吧，和我一起。"
            }
        },
        "2_H030": {
            "name": "会話 1",
            "text": {
                "2_H030": "御主，该出击了哦。",
                "2_H031": "来吧，起床、洗脸、打起精神、灵子转移啦。"
            }
        },
        "2_H040": {
            "name": "会話 2",
            "text": {
                "2_H040": "主从关系……",
                "2_H041": "御主，有何命令？",
                "2_H042": "但如果是我没兴致的事，我基本会全力拒绝哦。"
            }
        },
        "2_H050": {
            "name": "会話 3",
            "text": {
                "2_H050": "和御主的关系啊。",
                "2_H051": "应该不是主从吧。",
                "2_H052": "也不是什么恋人或家人。",
                "2_H053": "却是能相互托付性命的人。",
                "2_H054": "让我想想……这种关系该怎么称呼呢。"
            }
        },
        "2_H060": {
            "name": "好きなこと",
            "text": {
                "2_H060": "喜欢的东西吗？",
                "2_H061": "我喜欢看着孩子。",
                "2_H062": "不过迦勒底的孩子能否被称作孩子这个问题，还有点不好说。",
                "2_H063": "孩子很好哦。我想让他们成长……"
            }
        },
        "2_H070": {
            "name": "嫌いなこと",
            "text": {
                "2_H070": "没有什么讨厌的东西哦。",
                "2_H071": "没错，完全没有。"
            }
        },
        "2_H080": {
            "name": "聖杯について",
            "text": {
                "2_H080": "我没有什么需要圣杯实现的愿望。",
                "2_H081": "所以我原本应该与圣杯战争无缘才对……",
                "2_H082": "不过在这种事态下也没办法啦。"
            }
        },
        "2_H20090": {
            "name": "絆Lv.1",
            "text": {
                "2_H20090": "只顾着强化，却不建立牵绊什么的。",
                "2_H20091": "这可不行哦。"
            }
        },
        "2_H20100": {
            "name": "絆Lv.2",
            "text": {
                "2_H20100": "还差得远呢。",
                "2_H20101": "我想要涂满卡仕达酱的苹果派。",
                "2_H20102": "还有无糖咖啡。",
                "2_H20103": "嗯，当然是两人份。"
            }
        },
        "2_H20110": {
            "name": "絆Lv.3",
            "text": {
                "2_H20110": "是啊，到这一步已经算不错了。",
                "2_H20111": "因为我是比较严肃的存在。",
                "2_H20112": "……这一点和年轻青涩的「伦家」不同。",
                "2_H20113": "她不过是个恶灵，而我则是成为了与伟大之母截然相反之存在的莉莉丝。"
            }
        },
        "2_H20120": {
            "name": "絆Lv.4",
            "text": {
                "2_H20120": "啊……",
                "2_H20121": "感觉那个青涩的「伦家」可能快要说一些失去理智的话了。",
                "2_H20122": "把那些话忘了吧。",
                "2_H20123": "明白了吗，我趁现在先把话说在前头。",
                "2_H20124": "把～那～些～话～忘～了～吧～。"
            }
        },
        "2_H20130": {
            "name": "絆Lv.5",
            "text": {
                "2_H20130": "……真是的，我不是让你忘掉那些话嘛。",
                "2_H20131": "不过，既然说出了，也没办法。",
                "2_H20132": "我的想法并没有改变哦。",
                "2_H20133": "但之所以会对你那么说，纯粹是出于我的肤浅与独占欲。",
                "2_H20134": "现在我的想法也一样。",
                "2_H20135": "你死去时，我也会死。",
                "2_H20136": "这样才对等吧？"
            }
        },
        "2_H21600": {
            "name": "絆Lv.4 (奏章Ⅳクリア以降)",
            "text": {
                "2_H21600": "关于基列莱特吗？",
                "2_H21601": "呵呵呵。我现在是成熟的人，当然能接受哦。",
                "2_H21602": "不论她是什么、怎么样，对我来说都无关……",
                "2_H21603": "无关……",
                "2_H21604": "不，无关紧要不了。",
                "2_H21605": "如果基列莱特犯了什么过错，一定要告诉我。那一天我应该会过得非常愉快。",
                "2_H21606": "……绝对不告诉我？",
                "2_H21607": "哼……哼……",
                "2_H21608": "好吧，算了。"
            }
        },
        "2_H21800": {
            "name": "絆Lv.5 (奏章Ⅳクリア以降)",
            "text": {
                "2_H21800": "如果到了最终一战，基列莱特肯定会活下来。",
                "2_H21801": "但御主可能会死哦。",
                "2_H21802": "到那时，你就和我两个人一起变成某种幻影为她加油吧。",
                "2_H21803": "届时基列莱特估计会觉醒某种爱的力量解决一切。",
                "2_H21804": "怎么样？",
                "2_H21805": "……一脸不情愿呢。",
                "2_H21806": "讨厌以死为前提？",
                "2_H21807": "嘁。"
            }
        },
        "2_H250": {
            "name": "会話 4 男性主人公選択時",
            "text": {
                "2_H250": "母亲、丈夫、恋人……",
                "2_H251": "啊啊，原来如此。如果不用具体的名词去约束关系，就会极度不安啊。",
                "2_H252": "真可怜。",
                "2_H253": "啊，不。这纯粹是个人感想，没有诽谤污蔑的意思。"
            }
        },
        "2_H270": {
            "name": "会話 5",
            "text": {
                "2_H270": "大人物登场啦。竟然是提亚马特……",
                "2_H271": "啊，她好像对我怀着很高的警惕心呢。",
                "2_H272": "我确实也有死亡之母的一面。嗯，嗯。",
                "2_H273": "……不过，她是不是太溺爱人类了一点？",
                "2_H274": "哇，快哭了！　是我失礼了！　不，真的很抱歉啦！"
            }
        },
        "2_H280": {
            "name": "会話 6",
            "text": {
                "2_H280": "噢噢，多么直接的恶魔味。",
                "2_H281": "……不，但你也不是什么恶魔吧。",
                "2_H282": "明明喜欢破灭喜欢到不行，却在御主面前克制自己，真值得敬佩。",
                "2_H283": "啊，但死亡的顺序我可不会让给你哦。"
            }
        },
        "2_H3070": {
            "name": "嫌いなこと (絆Lv.5以上+奏章Ⅳクリア以降)",
            "text": {
                "2_H3070": "讨厌的东西是基列莱特。",
                "2_H3071": "啊，基列莱特就在那里啊。",
                "2_H3072": "呵呵呵，我知道。",
                "2_H3073": "呵呵呵。"
            }
        },
        "2_H5250": {
            "name": "会話 4 女性主人公選択時",
            "text": {
                "2_H5250": "母亲、妻子、恋人……",
                "2_H5251": "啊啊，原来如此。如果不用具体的名词去约束关系，就会极度不安啊。",
                "2_H5252": "真可怜。",
                "2_H5253": "啊，不。这纯粹是个人感想，没有诽谤污蔑的意思。"
            }
        }
    },
