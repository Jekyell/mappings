        "0_B500": {
            "name": "开始 3",
            "text": {
                "0_B500": "我是新选组三番队队长，斋藤一。能跑的话就快跑吧～。 ……不过，我是不会放跑你们的。"
            }
        },
        "0_B520": {
            "name": "胜利 3",
            "text": {
                "0_B520": "好，把活口都绑起来。 三番队！　收队回去啦。"
            }
        },
        "0_B540": {
            "name": "ダメージ 4",
            "text": {
                "0_B540": ""
            },
            "raw_text": {
                "0_B540": ""
            }
        },
        "0_B550": {
            "name": "受击 3",
            "text": {
                "0_B550": "不会吧，喂！？"
            }
        },
        "0_B560": {
            "name": "无法战斗 3",
            "text": {
                "0_B560": "……对不起了，大家。"
            }
        },
        "0_B800": {
            "name": "宝具 2",
            "text": {
                "0_B800": "受不了，既然这样……",
                "0_B801": "上吧上吧上吧上吧！",
                "0_B802": "——就此，了结！"
            }
        },
        "0_B810": {
            "name": "宝具 3",
            "text": {
                "0_B810": "无型故无形，",
                "0_B811": "流动故无限。",
                "0_B812": "——因此吾剑，无敌！"
            }
        },
        "0_B840": {
            "name": "额外攻击 3",
            "text": {
                "0_B840": "抱歉到此为止了，",
                "0_B841": "——去死吧。"
            }
        },
