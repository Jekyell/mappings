        "0_B210": {
            "name": "宝具卡 {0}",
            "text": {
                "0_B210": "就让你见识一下吧，无敌之剑。"
            }
        },
        "0_B220": {
            "name": "宝具卡 {0}",
            "text": {
                "0_B220": "唔，碍事，退后一点啦御主亲。"
            }
        },
        "0_B230": {
            "name": "宝具卡 {0}",
            "text": {
                "0_B230": "试着接下这剑吧。但接下就会死哦。"
            }
        },
