        },
        "0_B440": {
            "name": "额外攻击 2",
            "text": {
                "0_B440": "嘿嘿嘿嘿，",
                "0_B441": "……结束了！"
            }
        },
        "0_B480": {
            "name": "技能 3",
            "text": {
                "0_B480": "太得意忘形了吧。"
