        "0_B020": {
            "name": "攻击 2",
            "text": {
                "0_B020": "看招看招看招！"
            }
        },
        "0_B030": {
            "name": "攻击 3",
            "text": {
                "0_B030": "所谓的刀，应该这么用哦！"
            }
        },
        "0_B040": {
            "name": "额外攻击 1",
            "text": {
                "0_B040": "可别躲开哦～，",
                "0_B041": "……不过我是不会打偏的！"
            }
        },
        "0_B050": {
            "name": "宝具 1",
            "text": {
                "0_B050": "和流派或是别的什么没有关系啦。",
                "0_B051": "只是强者获胜而已。",
                "0_B052": "——就像我这样的！"
            }
        },
        "0_B080": {
            "name": "技能 1",
            "text": {
                "0_B080": "总之，轻松点上吧。"
            }
        },
        "0_B090": {
            "name": "技能 2",
            "text": {
                "0_B090": "那就杀了吧。"
            }
        },
        "0_B100": {
            "name": "开始 1",
            "text": {
                "0_B100": "不要紧不要紧，阿一我是无敌的啦……开玩笑的。"
            }
        },
        "0_B110": {
            "name": "开始 2",
            "text": {
                "0_B110": "好了，但愿对方都是群弱鸡。"
            }
        },
        "0_B120": {
            "name": "胜利 1",
            "text": {
                "0_B120": "我的宗旨就是不打会输的仗。 这就是所谓的无敌。"
            }
        },
        "0_B130": {
            "name": "胜利 2",
            "text": {
                "0_B130": "呼，这工作意外麻烦呢。 御主亲，没事吧？"
            }
        },
        "0_B140": {
            "name": "受击 2",
            "text": {
                "0_B140": "好痛！？"
            }
        },
        "0_B150": {
            "name": "受击 1",
            "text": {
                "0_B150": "惨了————！？"
            }
        },
        "0_B160": {
            "name": "无法战斗 1",
            "text": {
                "0_B160": "没想到我居然会输…… 竟然还敢自称什么无敌之剑。"
            }
        },
        "0_B170": {
            "name": "无法战斗 2",
            "text": {
                "0_B170": "不打会输的仗本是我的宗旨…… 还是迟钝了呢。"
            }
        },
        "0_B180": {
            "name": "指令卡 1",
            "text": {
                "0_B180": "这样啊。"
            }
        },
        "0_B190": {
            "name": "指令卡 2",
            "text": {
                "0_B190": "嗯。"
            }
        },
        "0_B200": {
            "name": "指令卡 3",
            "text": {
                "0_B200": "知道啦知道啦。"
            }
        },
        "0_B2010": {
