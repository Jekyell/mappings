        "0_B800": {
            "name": "宝具 2",
            "text": {
                "0_B800": "光啊。",
                "0_B801": "七个光轮啊。",
                "0_B802": "集结于此，照耀万物众生吧！",
                "0_B803": "——『法阿育·转轮圣王』！"
            }
        },
        "0_B810": {
            "name": "宝具 3",
            "text": {
                "0_B810": "namaḥ samanta-buddhānāṃ bhaḥ（归命遍在诸佛）……",
                "0_B811": "——『法阿育·转轮圣王』！"
            }
        },
        "0_B840": {
            "name": "エクストラアタック 3",
            "text": {
                "0_B840": "血染大地……吾之地狱……！"
            }
        },
        "0_B880": {
            "name": "スキル 5",
            "text": {
                "0_B880": "Ashoka Pillar！"
            }
        },
        "0_B890": {
            "name": "スキル 6",
            "text": {
                "0_B890": "转轮佛塔！"
            }
        },
        "0_B910": {
            "name": "アタック 7",
            "text": {
                "0_B910": "好！"
            }
        },
        "0_B920": {
            "name": "アタック 8",
            "text": {
                "0_B920": "嗯！"
            }
        },
        "0_B930": {
            "name": "アタック 9",
            "text": {
                "0_B930": "Abhicāra（降服）……"
            }
        },
        "0_G010": {
            "name": "レベルアップ 1",
            "text": {
                "0_G010": "嗯……"
            }
        },
        "0_G020": {
            "name": "霊基再臨 2",
            "text": {
                "0_G020": "以残影之身的英灵之躯而言，实在受之有愧。"
            }
        },
        "0_G030": {
            "name": "霊基再臨 1",
            "text": {
                "0_G030": "这正是我暴虐的形貌。",
                "0_G031": "在皈依佛法之前，",
                "0_G032": "甚至曾被称作地狱的吾之样貌。",
                "0_G033": "……如今，愿成为你的力量。"
            }
        },
        "0_G040": {
            "name": "霊基再臨 3",
            "text": {
                "0_G040": "──灵基再临，已至此境吗。",
                "0_G041": "我阿育王心悦诚服。",
                "0_G042": "这形象正是昔日被众人称为转轮圣王的形象。",
                "0_G043": "既是如此，定不辱期待，定会见证，",
                "0_G044": "见证你所前行的道路。"
            }
        },
        "0_G050": {
            "name": "霊基再臨 4",
            "text": {
                "0_G050": "安心休息吧。",
                "0_G051": "无需恐惧，有我在。",
                "0_G052": "我虽无法如觉者般彻悟，",
                "0_G053": "但能守护你们——"
            }
        },
        "0_G110": {
            "name": "レベルアップ 2",
            "text": {
                "0_G110": "是吗……"
            }
        },
        "0_G120": {
            "name": "レベルアップ 3",
            "text": {
                "0_G120": "定不辱期待。"
            }
        },
        "0_H010": {
            "name": "誕生日",
            "text": {
                "0_H010": "降生之日……",
                "0_H011": "原来如此，是这样吗。",
                "0_H012": "在当代，不只觉者，个人的诞生亦会被庆祝吗。",
                "0_H013": "既是如此，理当设宴才行。",
                "0_H014": "请稍等片刻。",
                "0_H015": "让我们举办一场盛大的宴席吧。"
            }
        },
        "0_H020": {
            "name": "イベント開催中",
            "text": {
                "0_H020": "活动……",
                "0_H021": "还有这样的事吗。",
                "0_H022": "那便一同出征吧，御主，请准备好。"
            }
        },
        "0_H030": {
            "name": "会話 1",
            "text": {
                "0_H030": "前进吧。",
                "0_H031": "即便心怀迷惘，也当继续前进。"
            }
        },
        "0_H040": {
            "name": "会話 2",
            "text": {
                "0_H040": "御主。",
                "0_H041": "此身既为从者，自当与你同行。",
                "0_H042": "哪怕前往奈落底部。"
            }
        },
        "0_H050": {
            "name": "会話 3",
            "text": {
                "0_H050": "若心怀迷惘，我愿倾听。",
                "0_H051": "御主。"
            }
        },
        "0_H060": {
            "name": "好きなこと",
            "text": {
                "0_H060": "佛法……",
                "0_H061": "Dharma，理应尊崇。"
            }
        },
        "0_H070": {
            "name": "嫌いなこと",
            "text": {
                "0_H070": "我否定暴力。",
                "0_H071": "那是曾经的我、是罪孽、是理应舍弃的存在。",
                "0_H072": "……但是，这灵基却不得不使用暴力。",
                "0_H073": "佛祖为我指引了一条苦难之路。"
            }
        },
        "0_H080": {
            "name": "聖杯について",
            "text": {
                "0_H080": "圣杯……",
                "0_H081": "唔。我觉得那更像魔境。"
            }
        },
        "0_H090": {
            "name": "絆Lv.1",
            "text": {
                "0_H090": "我乃阿育。",
                "0_H091": "既是统一印度之王，亦是佛法的守护者。",
                "0_H092": "转轮圣王？",
                "0_H093": "……虽有被如此称呼，但我决意不这么自称。"
            }
        },
        "0_H100": {
            "name": "絆Lv.2",
            "text": {
                "0_H100": "少年与狮子？",
                "0_H101": "啊，那是……",
                "0_H102": "可以说是我宝具的化身。",
                "0_H103": "虽非我本身，但大可将他们视作这灵基的一部分。"
            }
        },
        "0_H110": {
            "name": "絆Lv.3",
            "text": {
                "0_H110": "我曾是一位暴虐之王。",
                "0_H111": "杀戮即是我，我即是地狱。",
                "0_H112": "然而某一日，我邂逅了。",
                "0_H113": "邂逅了我的命运……",
                "0_H114": "值得尊崇的教诲——",
                "0_H115": "以及理应追求的崇高理想。"
            }
        },
        "0_H120": {
            "name": "絆Lv.4",
            "text": {
                "0_H120": "我尊崇佛法，厌恶争斗。",
                "0_H121": "即便身死之后……",
                "0_H122": "成了水中之月般的从者之身，此志亦未改变。",
                "0_H123": "只因吾乃佛法的守护者，阿育王。"
            }
        },
        "0_H130": {
            "name": "絆Lv.5",
            "text": {
                "0_H130": "我的灵基被塑造成了战斗的灵基。",
                "0_H131": "这是显而易见的事实。",
                "0_H132": "倘若战斗不可避免，我愿欣然接受。",
                "0_H133": "这亦是佛祖的引导。",
                "0_H134": "我将与你并肩作战。",
                "0_H135": "如今，作为泛人类史的守护者。"
            }
        },
        "0_H170": {
            "name": "会話 4",
            "text": {
                "0_H170": "嗯，嗯……"
            }
        },
        "0_H180": {
            "name": "会話 5",
            "text": {
                "0_H180": "oṃ ālolik svāhā（自淤泥而生之人啊）……"
            }
        },
        "0_H190": {
            "name": "会話 6",
            "text": {
                "0_H190": "噢噢，那是魔性之物吗。",
                "0_H191": "……嗯，明白了。",
                "0_H192": "看来我有必要与他们好好谈谈。"
            }
        },
        "0_H200": {
            "name": "会話 7",
            "text": {
                "0_H200": "行于月下之人啊。",
                "0_H201": "愿你的引导有光明相伴。"
            }
        },
        "0_S010": {
            "name": "召喚",
            "text": {
                "0_S010": "枪兵，现界。",
                "0_S011": "真名阿育王。",
                "0_S012": "————你确定是我的御主吗？"
            }
        }
    },
