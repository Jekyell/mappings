{
    "id": 901900,
    "collectionNo": 438,
    "name": "メタトロン・ジャンヌ",
    "voices": {
        "0_B010": {
            "name": "アタック 1",
            "text": {
                "0_B010": "给出裁定。"
            }
        },
        "0_B020": {
            "name": "アタック 2",
            "text": {
                "0_B020": "依照律法。"
            }
        },
        "0_B030": {
            "name": "アタック 3",
            "text": {
                "0_B030": "开始执行。"
            }
        },
        "0_B040": {
            "name": "エクストラアタック 1",
            "text": {
                "0_B040": "炎之柱，彼焰在此。"
            }
        },
        "0_B050": {
            "name": "宝具 1",
            "text": {
                "0_B050": "圣哉，圣哉，圣哉！",
                "0_B051": "回荡于大地的乃是主之言，",
                "0_B052": "我作为主之代理人，向所有一切降下神罚！",
                "0_B053": "所司者，全知全能也！"
            }
        },
        "0_B080": {
            "name": "スキル 1",
            "text": {
                "0_B080": "开始审议。"
            }
        },
        "0_B090": {
            "name": "スキル 2",
            "text": {
                "0_B090": "下达判决。"
            }
        },
        "0_B100": {
            "name": "開始 1",
            "text": {
                "0_B100": "那就出击吧。各位，祝各位武运昌隆。"
            }
        },
        "0_B110": {
            "name": "開始 2",
            "text": {
                "0_B110": "我们走吧，必须纠正秩序才行。"
            }
        },
        "0_B120": {
            "name": "勝利 1",
            "text": {
                "0_B120": "胜利了。 这理所当然，毕竟与主同在。"
            }
        },
        "0_B130": {
            "name": "勝利 2",
            "text": {
                "0_B130": "我可是无敌的哦。 否则怎能自称侍主者嘛。"
            }
        },
        "0_B140": {
            "name": "ダメージ 2",
            "text": {
                "0_B140": "没用。"
            }
        },
        "0_B150": {
            "name": "ダメージ 1",
            "text": {
                "0_B150": "啊、呜、呜……！"
            }
        },
        "0_B160": {
            "name": "戦闘不能 1",
            "text": {
                "0_B160": "啊啊……主啊……请允许我……到最后……"
            }
        },
        "0_B170": {
            "name": "戦闘不能 2",
            "text": {
                "0_B170": "她就……拜托您了……"
            }
        },
        "0_B180": {
            "name": "コマンドカード 1",
            "text": {
                "0_B180": "好。"
            }
        },
        "0_B190": {
            "name": "コマンドカード 2",
            "text": {
                "0_B190": "明白了吗？"
            }
        },
        "0_B200": {
            "name": "コマンドカード 3",
            "text": {
                "0_B200": "知道了。"
            }
        },
        "0_B2010": {
            "name": "アタック 10",
            "text": {
                "0_B2010": "倾泻而下。"
            }
        },
        "0_B2020": {
            "name": "アタック 11",
            "text": {
                "0_B2020": "展现奇迹。"
            }
        },
        "0_B2030": {
            "name": "アタック 12",
            "text": {
                "0_B2030": "沉溺吧。"
            }
        },
        "0_B210": {
            "name": "宝具カード 1",
            "text": {
                "0_B210": "要使用宝具了。"
            }
        },
        "0_B220": {
            "name": "宝具カード 2",
            "text": {
                "0_B220": "快退下，要发动宝具了。"
            }
        },
        "0_B230": {
            "name": "宝具カード 3",
            "text": {
                "0_B230": "将其消灭吧。"
            }
        },
        "0_B2410": {
            "name": "アタック 13",
            "text": {
                "0_B2410": "毁坏吧。"
            }
        },
        "0_B2420": {
            "name": "アタック 14",
            "text": {
                "0_B2420": "冻结吧。"
            }
        },
        "0_B2430": {
            "name": "アタック 15",
            "text": {
                "0_B2430": "坠落吧。"
            }
        },
        "0_B250": {
            "name": "宝具カード 4",
            "text": {
                "0_B250": "愿祈祷同在。"
            }
        },
        "0_B2810": {
            "name": "アタック 16",
            "text": {
                "0_B2810": "毁灭吧。"
            }
        },
        "0_B2820": {
            "name": "アタック 17",
            "text": {
                "0_B2820": "燃烧吧。"
            }
        },
        "0_B2830": {
            "name": "アタック 18",
            "text": {
                "0_B2830": "被贯穿吧。"
            }
        },
        "0_B3010": {
            "name": "アタック 19",
            "text": {
                "0_B3010": "前往彩虹之桥。"
            }
        },
        "0_B410": {
            "name": "アタック 4",
            "text": {
                "0_B410": "为荒野降水。"
            }
        },
        "0_B420": {
            "name": "アタック 5",
            "text": {
                "0_B420": "奏响神圣的旋律。"
            }
        },
        "0_B430": {
            "name": "アタック 6",
            "text": {
                "0_B430": "该冻结了。"
            }
        },
        "0_B440": {
            "name": "エクストラアタック 2",
            "text": {
                "0_B440": "宝石、羽翼、闪耀之眼。"
            }
        },
        "0_B480": {
            "name": "スキル 3",
            "text": {
                "0_B480": "肃静。"
            }
        },
        "0_B490": {
            "name": "スキル 4",
            "text": {
                "0_B490": "闪耀吧。"
            }
        },
        "0_B500": {
            "name": "開始 3",
            "text": {
                "0_B500": "太粗劣了。我要击溃那种狂妄。"
            }
        },
        "0_B510": {
            "name": "開始 4",
            "text": {
                "0_B510": "嗯——愿那灵魂获得救赎。"
            }
        },
        "0_B540": {
            "name": "ダメージ 4",
            "text": {
                "0_B540": "不会胆怯。"
            }
        },
        "0_B550": {
            "name": "ダメージ 3",
            "text": {
                "0_B550": "这是……呜！？"
            }
        },
        "0_B800": {
            "name": "宝具 2",
            "text": {
                "0_B800": "善者高歌恶者哀叹。",
                "0_B801": "光明充盈黑暗毁灭。",
                "0_B802": "光辉即为主之奇迹、恩宠、荣冠！",
                "0_B803": "所司者，全知全能也！"
            }
        },
        "0_B880": {
            "name": "スキル 5",
            "text": {
                "0_B880": "精疲力竭了。"
            }
        },
        "0_B890": {
            "name": "スキル 6",
            "text": {
                "0_B890": "开始小睡。"
            }
        },
        "0_B910": {
            "name": "アタック 7",
            "text": {
                "0_B910": "此乃天罚。"
            }
        },
        "0_B920": {
            "name": "アタック 8",
            "text": {
                "0_B920": "赐予恩宠。"
            }
        },
        "0_B930": {
            "name": "アタック 9",
            "text": {
                "0_B930": "炽烈地。"
            }
        },
        "0_G010": {
            "name": "レベルアップ 1",
            "text": {
                "0_G010": "等级提升了呢。"
            }
        },
        "0_G110": {
            "name": "レベルアップ 2",
            "text": {
                "0_G110": "这份觉悟非常好，那就再多来点吧。"
            }
        },
        "0_H010": {
            "name": "誕生日",
            "text": {
                "0_H010": "生日吗？",
                "0_H011": "祝你生日快乐。",
                "0_H012": "愿你的前途光辉灿烂。"
            }
        },
        "0_H020": {
            "name": "イベント開催中",
            "text": {
                "0_H020": "好像正在举办活动。",
                "0_H021": "那就麻利地工作起来吧。",
                "0_H022": "如果有我的素材，请务必拿到手。"
            }
        },
        "0_H030": {
            "name": "会話 1",
            "text": {
                "0_H030": "来吧，御主。",
                "0_H031": "开始出击吧，上！"
            }
        },
        "0_H040": {
            "name": "会話 2",
            "text": {
                "0_H040": "主从？",
                "0_H041": "我的确是侍奉主的存在。",
                "0_H042": "但并非侍奉御主。",
                "0_H043": "是这样哦。"
            }
        },
        "0_H050": {
            "name": "会話 3",
            "text": {
                "0_H050": "与御主的关系……",
                "0_H051": "我认为非常良好。",
                "0_H052": "毕竟签订了稳固的契约，支援也很出色。"
            }
        },
        "0_H060": {
            "name": "好きなこと",
            "text": {
                "0_H060": "喜欢的东西吗？",
                "0_H061": "没有。在主之下万物平等。"
            }
        },
        "0_H070": {
            "name": "嫌いなこと",
            "text": {
                "0_H070": "讨厌的东西啊。",
                "0_H071": "是的，我讨厌混沌或邪恶的存在。",
                "0_H072": "不过请放心。",
                "0_H073": "虽然迦勒底里确实有很多与我相性不佳的人，但我是不会和他们吵架的！"
            }
        },
        "0_H080": {
            "name": "聖杯について",
            "text": {
                "0_H080": "圣杯理应回归主的身边。这才是合理的形式吧？"
            }
        },
        "0_H090": {
            "name": "絆Lv.1",
            "text": {
                "0_H090": "你就是御主吗。",
                "0_H091": "请多关照。"
            }
        },
        "0_H100": {
            "name": "絆Lv.2",
            "text": {
                "0_H100": "梅塔特隆……",
                "0_H101": "不，准确地说应该是梅塔特隆·贞德。这个名称更合适。",
                "0_H102": "此身乃是极为清廉的少女之身。",
                "0_H103": "具备足以觐见主的谦虚。",
                "0_H104": "……啊，这里的主并不是指御主……"
            }
        },
        "0_H110": {
            "name": "絆Lv.3",
            "text": {
                "0_H110": "梅塔特隆是天使之名啦。",
                "0_H111": "拥有各式各样的别名，其中还有侍主者，或是监视者之类的说法。"
            }
        },
        "0_H120": {
            "name": "絆Lv.4",
            "text": {
                "0_H120": "嗯，这个世界中的天使既存在又不存在。",
                "0_H121": "梅塔特隆司掌的只有纯粹的力量。",
                "0_H122": "因此，才需要用贞德作为凭依之躯。"
            }
        },
        "0_H130": {
            "name": "絆Lv.5",
            "text": {
                "0_H130": "综上所述，介绍到此结束。",
                "0_H131": "那么御主，今后也请多关照。",
                "0_H132": "只要你还是善人，我便会追随你！"
            }
        },
        "0_H170": {
            "name": "会話 4",
            "text": {
                "0_H170": "什么，这里还有现役的圣职者吗？",
                "0_H171": "那我也作为相关人士去打个招呼吧。",
                "0_H172": "也可以降临，或是在梦中现身。",
                "0_H173": "当然，我也想在梦中询问其拥有什么样的信仰呢。"
            }
        },
        "0_H180": {
            "name": "会話 5",
            "text": {
                "0_H180": "圣女玛尔达吗……",
                "0_H181": "原来如此，那种信仰与拳确实值得学习。",
                "0_H182": "不过俗话说笔强于拳，所以我应该更强一些，大概吧。"
            }
        },
        "0_H190": {
            "name": "会話 6",
            "text": {
                "0_H190": "天草四郎。",
                "0_H191": "那种殉教精神相当可贵。",
                "0_H192": "虽然执着于圣杯的坏毛病稍微有些不合适，但既然是为了世界和平，那就没问题了。很了不起。",
                "0_H193": "作为奖励，授予你梅塔特隆奖吧。"
            }
        },
        "0_S010": {
            "name": "召喚",
            "text": {
                "0_S010": "呵欠……啊啊，好困……",
                "0_S011": "唔？　唔唔？",
                "0_S012": "怎么了？　有人叫我？",
                "0_S013": "……咳咳。失礼了。",
                "0_S014": "梅塔特隆·贞德。应召唤前来。",
                "0_S015": "职阶为裁定者。",
                "0_S016": "让我们并肩战斗，为世间带来秩序吧！",
                "0_S017": "或许迟早还会遇到我哦～。"
            }
        },
        "1_B010": {
            "name": "アタック 1",
            "text": {
                "1_B010": "看招～。"
            }
        },
        "1_B020": {
            "name": "アタック 2",
            "text": {
                "1_B020": "嘿咻。"
            }
        },
        "1_B030": {
            "name": "アタック 3",
            "text": {
                "1_B030": "速战速决～。"
            }
        },
        "1_B040": {
            "name": "エクストラアタック 1",
            "text": {
                "1_B040": "这个叫呃……彼焰什么来着。"
            }
        },
        "1_B050": {
            "name": "宝具 1",
            "text": {
                "1_B050": "麻烦麻烦，实在太麻烦了。",
                "1_B051": "啊，不过如果能靠这招全灭的话或许还算轻松？",
                "1_B052": "所司者，全知全能也。",
                "1_B053": "再见啦……"
            }
        },
        "1_B080": {
            "name": "スキル 1",
            "text": {
                "1_B080": "好麻烦。"
            }
        },
        "1_B090": {
            "name": "スキル 2",
            "text": {
                "1_B090": "好乏。"
            }
        },
        "1_B100": {
            "name": "開始 1",
            "text": {
                "1_B100": "要开始了哦～…… 要开始了啊，好麻烦……"
            }
        },
        "1_B110": {
            "name": "開始 2",
            "text": {
                "1_B110": "哎，反正最后肯定是我赢，直接结束不好吗～？"
            }
        },
        "1_B120": {
            "name": "勝利 1",
            "text": {
                "1_B120": "啊～赢了。好麻烦啊……"
            }
        },
        "1_B130": {
            "name": "勝利 2",
            "text": {
                "1_B130": "输也麻烦，赢也麻烦，总无法如愿呢。"
            }
        },
        "1_B140": {
            "name": "ダメージ 2",
            "text": {
                "1_B140": "真是的～。"
            }
        },
        "1_B150": {
            "name": "ダメージ 1",
            "text": {
                "1_B150": "好痛啊啊啊啊！"
            }
        },
        "1_B160": {
            "name": "戦闘不能 1",
            "text": {
                "1_B160": "对不起……输掉了……对不起……"
            }
        },
        "1_B170": {
            "name": "戦闘不能 2",
            "text": {
                "1_B170": "到此为止了吗～……再见了，御主，会变得寂寞呢。"
            }
        },
        "1_B180": {
            "name": "コマンドカード 1",
            "text": {
                "1_B180": "哎～。"
            }
        },
        "1_B190": {
            "name": "コマンドカード 2",
            "text": {
                "1_B190": "讨厌啦～"
            }
        },
        "1_B200": {
            "name": "コマンドカード 3",
            "text": {
                "1_B200": "唔唔……"
            }
        },
        "1_B2010": {
            "name": "アタック 10",
            "text": {
                "1_B2010": "好闲啊～。"
            }
        },
        "1_B2020": {
            "name": "アタック 11",
            "text": {
                "1_B2020": "怠惰地。"
            }
        },
        "1_B2030": {
            "name": "アタック 12",
            "text": {
                "1_B2030": "水祸圣人。"
            }
        },
        "1_B210": {
            "name": "宝具カード 1",
            "text": {
                "1_B210": "要放宝具吗？　知道啦知道啦……"
            }
        },
        "1_B220": {
            "name": "宝具カード 2",
            "text": {
                "1_B220": "哎……能不能当没发生过？"
            }
        },
        "1_B230": {
            "name": "宝具カード 3",
            "text": {
                "1_B230": "知道啦知道啦～，我做就是了～。"
            }
        },
        "1_B2410": {
            "name": "アタック 13",
            "text": {
                "1_B2410": "大地狂奏。"
            }
        },
        "1_B2420": {
            "name": "アタック 14",
            "text": {
                "1_B2420": "静寂冻土。"
            }
        },
        "1_B2430": {
            "name": "アタック 15",
            "text": {
                "1_B2430": "圣下天罚。"
            }
        },
        "1_B2810": {
            "name": "アタック 16",
            "text": {
                "1_B2810": "光线地走。"
            }
        },
        "1_B2820": {
            "name": "アタック 17",
            "text": {
                "1_B2820": "火业礼赞。"
            }
        },
        "1_B2830": {
            "name": "アタック 18",
            "text": {
                "1_B2830": "骤雨罚望。"
            }
        },
        "1_B3010": {
            "name": "アタック 19",
            "text": {
                "1_B3010": "前往彩虹的彼方。"
            }
        },
        "1_B410": {
            "name": "アタック 4",
            "text": {
                "1_B410": "水～。"
            }
        },
        "1_B420": {
            "name": "アタック 5",
            "text": {
                "1_B420": "来一曲如何～？"
            }
        },
        "1_B430": {
            "name": "アタック 6",
            "text": {
                "1_B430": "困了。"
            }
        },
        "1_B440": {
            "name": "エクストラアタック 2",
            "text": {
                "1_B440": "炎之柱，刚烤好的哦～。"
            }
        },
        "1_B480": {
            "name": "スキル 3",
            "text": {
                "1_B480": "好难受。"
            }
        },
        "1_B490": {
            "name": "スキル 4",
            "text": {
                "1_B490": "提不起劲～。"
            }
        },
        "1_B500": {
            "name": "開始 3",
            "text": {
                "1_B500": "啊啊，好麻烦啊…… 但又不能输，那就赢一下吧～……"
            }
        },
        "1_B510": {
            "name": "開始 4",
            "text": {
                "1_B510": "莫名有点干劲，那就努力一下吧～！ ……但这股干劲一分钟就没了，接下来就交给你啦～……"
            }
        },
        "1_B520": {
            "name": "勝利 3",
            "text": {
                "1_B520": "冷静想想啊。怎么可能在力量上赢过大天使嘛。"
            }
        },
        "1_B540": {
            "name": "ダメージ 4",
            "text": {
                "1_B540": "无伤。"
            }
        },
        "1_B550": {
            "name": "ダメージ 3",
            "text": {
                "1_B550": "唔！呜！"
            }
        },
        "1_B560": {
            "name": "戦闘不能 3",
            "text": {
                "1_B560": "我好困，所以要睡觉，先睡了，晚安～……哈呼。"
            }
        },
        "1_B800": {
            "name": "宝具 2",
            "text": {
                "1_B800": "怠惰返还。",
                "1_B801": "行使我的奇迹，破坏所有一切。",
                "1_B802": "所司者，全知全能也！",
                "1_B803": "然后化为恩惠之雨。"
            }
        },
        "1_B880": {
            "name": "スキル 5",
            "text": {
                "1_B880": "睡了～。"
            }
        },
        "1_B890": {
            "name": "スキル 6",
            "text": {
                "1_B890": "晚安～。"
            }
        },
        "1_B910": {
            "name": "アタック 7",
            "text": {
                "1_B910": "光线！"
            }
        },
        "1_B920": {
            "name": "アタック 8",
            "text": {
                "1_B920": "脑瓜崩！"
            }
        },
        "1_B930": {
            "name": "アタック 9",
            "text": {
                "1_B930": "地裂～。"
            }
        },
        "1_G010": {
            "name": "レベルアップ 1",
            "text": {
                "1_G010": "哎，变强了吗？",
                "1_G011": "好麻烦……"
            }
        },
        "1_G020": {
            "name": "霊基再臨 2",
            "text": {
                "1_G020": "没有变化哦。",
                "1_G021": "改变未免太麻烦了。"
            }
        },
        "1_G030": {
            "name": "霊基再臨 1",
            "text": {
                "1_G030": "唔？",
                "1_G031": "啊～……",
                "1_G032": "这是被神秘力量付与了怠惰的梅塔特隆·贞德的形态～。",
                "1_G033": "你就把这个我当做始终处于眩晕状态就行了～。"
            }
        },
        "1_G110": {
            "name": "レベルアップ 2",
            "text": {
                "1_G110": "知道啦知道啦，姑且先说一句谢谢吧。"
            }
        },
        "1_H010": {
            "name": "誕生日",
            "text": {
                "1_H010": "啊，今天是你的生日啊。",
                "1_H011": "生日快乐，不过我没什么能送你的……",
                "1_H012": "啊，不介意的话要试着坐坐这把椅子吗？"
            }
        },
        "1_H020": {
            "name": "イベント開催中",
            "text": {
                "1_H020": "有活动了哦～。",
                "1_H021": "不过我还是决定……睡觉！",
                "1_H022": "接下来交给你啦～。"
            }
        },
        "1_H030": {
            "name": "会話 1",
            "text": {
                "1_H030": "说出门什么的～……",
                "1_H031": "太麻烦了，还是一起睡吧～。"
            }
        },
        "1_H040": {
            "name": "会話 2",
            "text": {
                "1_H040": "主从……",
                "1_H041": "梅贞可不想要那种麻烦的关系～。"
            }
        },
        "1_H050": {
            "name": "会話 3",
            "text": {
                "1_H050": "和御主的关系啊。",
                "1_H051": "只要把腿借我靠着就行了。",
                "1_H052": "我要睡了。呼呼大睡。"
            }
        },
        "1_H060": {
            "name": "好きなこと",
            "text": {
                "1_H060": "喜欢的东西？",
                "1_H061": "……不，事到如今再说也好麻烦啊……"
            }
        },
        "1_H070": {
            "name": "嫌いなこと",
            "text": {
                "1_H070": "讨厌的东西？",
                "1_H071": "当然是勤奋啊、劳动之类的。"
            }
        },
        "1_H080": {
            "name": "聖杯について",
            "text": {
                "1_H080": "圣杯？",
                "1_H081": "实现愿望也很麻烦。随你便吧～。",
                "1_H082": "……啊，不过别拿来让我工作哦～。"
            }
        },
        "1_H10090": {
            "name": "絆Lv.1",
            "text": {
                "1_H10090": "好困……"
            }
        },
        "1_H10100": {
            "name": "絆Lv.2",
            "text": {
                "1_H10100": "有事吗？",
                "1_H10101": "有事的话，一万年后再说～……"
            }
        },
        "1_H10110": {
            "name": "絆Lv.3",
            "text": {
                "1_H10110": "你问归根结底为什么会那么怠惰？",
                "1_H10111": "为什么呢。",
                "1_H10112": "呵呵呵，少女总有各式各样的原因啦。"
            }
        },
        "1_H10120": {
            "name": "絆Lv.4",
            "text": {
                "1_H10120": "想了解梅塔特隆的话，就去问最初的我吧。",
                "1_H10121": "我是怠惰，什么都不做，也不干涉任何事。",
                "1_H10122": "呵欠……好困……"
            }
        },
        "1_H10130": {
            "name": "絆Lv.5",
            "text": {
                "1_H10130": "虽然发生了很多事，但你果然是这种人呢。",
                "1_H10131": "好吧，算了。",
                "1_H10132": "既然如此，我就奉陪到底吧。",
                "1_H10133": "毕竟是怠惰，只能尽可能啦。",
                "1_H10134": "但我犯困时还是会睡，没问题吧？"
            }
        },
        "1_H11400": {
            "name": "絆Lv.3 (奏章Ⅳクリア以降)",
            "text": {
                "1_H11400": "哦，看到你有精神就好。",
                "1_H11401": "没错，是我哦～。",
                "1_H11402": "虽然受了很多创伤，",
                "1_H11403": "也付出了让人难言开心的牺牲。",
                "1_H11404": "……即便如此，我还是想说我很开心。",
                "1_H11405": "不行吗？"
            }
        },
        "1_H11600": {
            "name": "絆Lv.4 (奏章Ⅳクリア以降)",
            "text": {
                "1_H11600": "嘿嘿～。",
                "1_H11601": "睡吧～，怠惰度日吧～，就像在那间公寓时一样。",
                "1_H11602": "或者，要不要再打麻将？",
                "1_H11603": "把言峰绮礼他们叫来～。"
            }
        },
        "1_H11800": {
            "name": "絆Lv.5 (奏章Ⅳクリア以降)",
            "text": {
                "1_H11800": "啊啊……",
                "1_H11801": "果然会有点寂寞呢。",
                "1_H11802": "不过，我应该还能再陪你一阵子，所以你尽管依靠我吧。",
                "1_H11803": "也一起聊天吧。",
                "1_H11804": "和你在一起时，我会努力不偷懒的。"
            }
        },
        "1_H200": {
            "name": "会話 4",
            "text": {
                "1_H200": "天草四郎也来过啊。",
                "1_H201": "怎么样？　他还是那种想要圣杯的裁定者吗？",
                "1_H202": "是吗～……",
                "1_H203": "毕竟连另一个我都敢挑战嘛～。",
                "1_H204": "他肯定相当有耐心吧。"
            }
        },
        "1_H210": {
            "name": "会話 5",
            "text": {
                "1_H210": "阿育王。",
                "1_H211": "原来如此，你也在啊。嗯，也对。",
                "1_H212": "怎么样？　迦勒底开心吗？",
                "1_H213": "开心就好。",
                "1_H214": "不管怎么说，只要有阿育王在，我应该就可以偷懒了吧！",
                "1_H215": "不行？",
                "1_H216": "不行啊～……"
            }
        },
        "1_H220": {
            "name": "会話 6",
            "text": {
                "1_H220": "噢，但丁也在呢～。",
                "1_H221": "特异点的事……",
                "1_H222": "啊，不记得了啊。",
                "1_H223": "那为了以防万一，我还是先说一下吧。",
                "1_H224": "我和贝雅特丽齐没有任何关系，她也没被召唤。",
                "1_H225": "「你难道不是贝雅特丽齐？」",
                "1_H226": "不是贝雅特丽齐哦……",
                "1_H227": "「没有任何机会了？」",
                "1_H228": "没有哦……"
            }
        },
        "1_H230": {
            "name": "会話 7",
            "text": {
                "1_H230": "年轻的莫里亚蒂……",
                "1_H231": "曾在那个特异点里当律师吧。",
                "1_H232": "总是和但丁闹闹腾腾的。",
                "1_H233": "稍微有点怀念。",
                "1_H234": "……然后，那家伙长大后会变成欧洲的大罪犯吗～……",
                "1_H235": "人类还真是难以捉摸呢～。"
            }
        },
        "1_H240": {
            "name": "会話 8",
            "text": {
                "1_H240": "呜哇，莉莉丝也在。",
                "1_H241": "哎，难不成你也有记忆？",
                "1_H242": "……啊，你还是知道的啊～……",
                "1_H243": "那么闹腾了一通还能成为同伴，该说迦勒底包容，还是御主心胸宽广呢……",
                "1_H244": "总之，别过于仰仗御主的温情哦。"
            }
        },
        "2_B010": {
            "name": "アタック 1",
            "text": {
                "2_B010": "到此为止。"
            }
        },
        "2_B020": {
            "name": "アタック 2",
            "text": {
                "2_B020": "没规矩。"
            }
        },
        "2_B030": {
            "name": "アタック 3",
            "text": {
                "2_B030": "保持沉默。"
            }
        },
        "2_B040": {
            "name": "エクストラアタック 1",
            "text": {
                "2_B040": "彼焰在此。"
            }
        },
        "2_B050": {
            "name": "宝具 1",
            "text": {
                "2_B050": "汝等得不到慈悲，唯有毁灭。",
                "2_B051": "我正是汝等想象之天。",
                "2_B052": "所司者，全知全能也。",
                "2_B053": "愿你们迎来美好的末日。"
            }
        },
        "2_B080": {
            "name": "スキル 1",
            "text": {
                "2_B080": "唯以光。"
            }
        },
        "2_B090": {
            "name": "スキル 2",
            "text": {
                "2_B090": "唯以火。"
            }
        },
        "2_B100": {
            "name": "開始 1",
            "text": {
                "2_B100": "开始扫荡。"
            }
        },
        "2_B110": {
            "name": "開始 2",
            "text": {
                "2_B110": "清扫大地。"
            }
        },
        "2_B120": {
            "name": "勝利 1",
            "text": {
                "2_B120": "我们不被允许失败。那么，继续前进吧。"
            }
        },
        "2_B130": {
            "name": "勝利 2",
            "text": {
                "2_B130": "只要冠以大天使梅塔特隆之名，我便不能败北。"
            }
        },
        "2_B140": {
            "name": "ダメージ 2",
            "text": {
                "2_B140": "没有问题。"
            }
        },
        "2_B150": {
            "name": "ダメージ 1",
            "text": {
                "2_B150": "这就是……宝具……"
            }
        },
        "2_B160": {
            "name": "戦闘不能 1",
            "text": {
                "2_B160": "无法战斗。无法撤退。就此结束了吧。先告辞了。"
            }
        },
        "2_B170": {
            "name": "戦闘不能 2",
            "text": {
                "2_B170": "做的事毫无意义呢……"
            }
        },
        "2_B180": {
            "name": "コマンドカード 1",
            "text": {
                "2_B180": "明白了。"
            }
        },
        "2_B190": {
            "name": "コマンドカード 2",
            "text": {
                "2_B190": "我接受。"
            }
        },
        "2_B200": {
            "name": "コマンドカード 3",
            "text": {
                "2_B200": "知道了。"
            }
        },
        "2_B2010": {
            "name": "アタック 10",
            "text": {
                "2_B2010": "飞升。"
            }
        },
        "2_B2020": {
            "name": "アタック 11",
            "text": {
                "2_B2020": "该惩罚了。"
            }
        },
        "2_B2030": {
            "name": "アタック 12",
            "text": {
                "2_B2030": "烧尽。"
            }
        },
        "2_B210": {
            "name": "宝具カード 1",
            "text": {
                "2_B210": "万物皆有毁灭之时。"
            }
        },
        "2_B220": {
            "name": "宝具カード 2",
            "text": {
                "2_B220": "当知毁灭亦是慈悲。"
            }
        },
        "2_B230": {
            "name": "宝具カード 3",
            "text": {
                "2_B230": "只愿仍有救赎。"
            }
        },
        "2_B2410": {
            "name": "アタック 13",
            "text": {
                "2_B2410": "连骨头一并融化。"
            }
        },
        "2_B2420": {
            "name": "アタック 14",
            "text": {
                "2_B2420": "一切化作虚无。"
            }
        },
        "2_B2430": {
            "name": "アタック 15",
            "text": {
                "2_B2430": "跪下。"
            }
        },
        "2_B2810": {
            "name": "アタック 16",
            "text": {
                "2_B2810": "断绝。"
            }
        },
        "2_B2820": {
            "name": "アタック 17",
            "text": {
                "2_B2820": "滑倒了。"
            }
        },
        "2_B2830": {
            "name": "アタック 18",
            "text": {
                "2_B2830": "恐惧吧。"
            }
        },
        "2_B3010": {
            "name": "アタック 19",
            "text": {
                "2_B3010": "我动怒了。"
            }
        },
        "2_B410": {
            "name": "アタック 4",
            "text": {
                "2_B410": "1600度。"
            }
        },
        "2_B420": {
            "name": "アタック 5",
            "text": {
                "2_B420": "座天使。"
            }
        },
        "2_B430": {
            "name": "アタック 6",
            "text": {
                "2_B430": "炽天使。"
            }
        },
        "2_B440": {
            "name": "エクストラアタック 2",
            "text": {
                "2_B440": "一切只为秩序！"
            }
        },
        "2_B480": {
            "name": "スキル 3",
            "text": {
                "2_B480": "唯以人。"
            }
        },
        "2_B490": {
            "name": "スキル 4",
            "text": {
                "2_B490": "唯以星。"
            }
        },
        "2_B500": {
            "name": "開始 3",
            "text": {
                "2_B500": "无话可说，唯有破坏。"
            }
        },
        "2_B510": {
            "name": "開始 4",
            "text": {
                "2_B510": "现在是神罚之时，认命吧。"
            }
        },
        "2_B520": {
            "name": "勝利 3",
            "text": {
                "2_B520": "各位，没有受伤吧？ 还有御主，冲得太前了。虽然这份心意难能可贵。"
            }
        },
        "2_B540": {
            "name": "ダメージ 4",
            "text": {
                "2_B540": "为什么？"
            }
        },
        "2_B550": {
            "name": "ダメージ 3",
            "text": {
                "2_B550": "为何要做这种事？"
            }
        },
        "2_B800": {
            "name": "宝具 2",
            "text": {
                "2_B800": "10种恩宠、136万5千个祝福、",
                "2_B801": "72片羽翼、36万5千个闪耀之眼、",
                "2_B802": "全体攻击。"
            }
        },
        "2_B810": {
            "name": "宝具 3",
            "text": {
                "2_B810": "祝福、闪耀之眼、羽翼、宝石、恩宠、王冠。",
                "2_B811": "将一切不正义化作灰烬。",
                "2_B812": "所司者，全知全能也。",
                "2_B813": "回归古老而美好的时代。"
            }
        },
        "2_B880": {
            "name": "スキル 5",
            "text": {
                "2_B880": "有点困了。"
            }
        },
        "2_B890": {
            "name": "スキル 6",
            "text": {
                "2_B890": "先休息了。"
            }
        },
        "2_B910": {
            "name": "アタック 7",
            "text": {
                "2_B910": "引力子。"
            }
        },
        "2_B920": {
            "name": "アタック 8",
            "text": {
                "2_B920": "消灭。"
            }
        },
        "2_B930": {
            "name": "アタック 9",
            "text": {
                "2_B930": "好痛！？"
            }
        },
        "2_G010": {
            "name": "レベルアップ 1",
            "text": {
                "2_G010": "强化结束了吗？ 再变强一点吧。"
            }
        },
        "2_G040": {
            "name": "霊基再臨 1",
            "text": {
                "2_G040": "这就是我，梅塔特隆本身。",
                "2_G041": "之前你看到的形象，不过是尚未成熟的蛹。",
                "2_G042": "这才称得上完美。",
                "2_G043": "你真幸运呢，人类。"
            }
        },
        "2_G050": {
            "name": "霊基再臨 2",
            "text": {
                "2_G050": "在阳光之下，像这样躺着，懒洋洋的。",
                "2_G051": "人生的喜悦，其实有这些就够了。",
                "2_G052": "然而你很贪婪，所以总会想不停往更远的地方前进。",
                "2_G053": "不过……",
                "2_G054": "人生也需要这样的懒洋洋哦。",
                "2_G055": "愿你的人生拥有爱与温柔的休息。",
                "2_G056": "……要吃马卡龙吗？"
            }
        },
        "2_G110": {
            "name": "レベルアップ 2",
            "text": {
                "2_G110": "真想无限制地使用啊。"
            }
        },
        "2_H010": {
            "name": "誕生日",
            "text": {
                "2_H010": "您诞生的日子啊。",
                "2_H011": "……或许还是找怠惰的我来更合适。",
                "2_H012": "因为我无法只祝福您一个人。",
                "2_H013": "……即便如此也可以？",
                "2_H014": "那么，祝您生日快乐。",
                "2_H015": "向养育了您的一切送上感谢。"
            }
        },
        "2_H020": {
            "name": "イベント開催中",
            "text": {
                "2_H020": "好像是活动。 您会参加吧，理所当然。"
            }
        },
        "2_H030": {
            "name": "会話 1",
            "text": {
                "2_H030": "该出击了。",
                "2_H031": "请准备。"
            }
        },
        "2_H040": {
            "name": "会話 2",
            "text": {
                "2_H040": "主从关系啊。",
                "2_H041": "我是侍奉神明之身。就这样。"
            }
        },
        "2_H050": {
            "name": "会話 3",
            "text": {
                "2_H050": "和御主的关系啊。",
                "2_H051": "我觉得并没有什么特别的。"
            }
        },
        "2_H060": {
            "name": "好きなこと",
            "text": {
                "2_H060": "我没有喜欢的东西。"
            }
        },
        "2_H070": {
            "name": "嫌いなこと",
            "text": {
                "2_H070": "我没有讨厌的东西。"
            }
        },
        "2_H080": {
            "name": "聖杯について",
            "text": {
                "2_H080": "我没有希望圣杯实现的愿望。",
                "2_H081": "实现愿望的力量不属于任何人。"
            }
        },
        "2_H20090": {
            "name": "絆Lv.1",
            "text": {
                "2_H20090": "如果您没有要事。"
            }
        },
        "2_H20100": {
            "name": "絆Lv.2",
            "text": {
                "2_H20100": "我先失陪了。"
            }
        },
        "2_H20110": {
            "name": "絆Lv.3",
            "text": {
                "2_H20110": "完美性是不可动摇的孤立。",
                "2_H20111": "明白了吗？"
            }
        },
        "2_H20120": {
            "name": "絆Lv.4",
            "text": {
                "2_H20120": "没办法了。",
                "2_H20121": "那就谈谈吧。",
                "2_H20122": "但我无法保证您不会在与我的对话中感到不愉快。",
                "2_H20123": "如果您不介意的话。"
            }
        },
        "2_H20130": {
            "name": "絆Lv.5",
            "text": {
                "2_H20130": "原来如此。您也是试图靠近主的存在。",
                "2_H20131": "换言之，或许与义人以诺无异。",
                "2_H20132": "若真是如此，我自没有拒绝您的理由。",
                "2_H20133": "那就让我们慢慢谈吧。",
                "2_H20134": "时间还很充裕，对吧？"
            }
        },
        "2_H21600": {
            "name": "絆Lv.4 (奏章Ⅳクリア以降)",
            "text": {
                "2_H21600": "我已将记录铭刻在自己身上了。",
                "2_H21601": "请放心。那个特异点内的战斗是我输了。",
                "2_H21602": "既然已被召唤，并缔结了契约，我就必须守护秩序才行。",
                "2_H21603": "那么今后还请多关照。",
                "2_H21604": "……您那僵硬的表情是什么意思。",
                "2_H21605": "难道是害怕我？"
            }
        },
        "2_H21800": {
            "name": "絆Lv.5",
            "text": {
                "2_H21800": "正如你们向往奇迹、向往神明一样，我们也对人类怀有梦想。",
                "2_H21801": "那正是我的愿望。",
                "2_H21802": "希望你们也对我怀有梦想。"
            }
        },
        "2_H21810": {
            "name": "絆Lv.5 (奏章Ⅳクリア以降)",
            "text": {
                "2_H21810": "坐端正，坐端正。",
                "2_H21811": "您似乎过于警惕我了。",
                "2_H21812": "确实，如果有必要，我确实会为了维持秩序而彻底扫荡迦勒底。",
                "2_H21813": "不过，我已经具备了在实际执行时，会提前五秒警告你们的体贴。",
                "2_H21814": "可以说，这也是积累的牵绊力量吧，嗯哼。"
            }
        },
        "2_H250": {
            "name": "会話 4",
            "text": {
                "2_H250": "啊，天草四郎也曾在吗。",
                "2_H251": "他是个让人想再和他谈谈的人类。",
                "2_H252": "真可惜，太可惜了。",
                "2_H253": "或许这话不该由我来说。"
            }
        },
        "2_H260": {
            "name": "会話 5",
            "text": {
                "2_H260": "嚯嚯，詹姆斯·莫里亚蒂也曾在这里啊。",
                "2_H261": "虽然似乎并不是那位勇敢的律师……",
                "2_H262": "但您的眼中仍寄宿着他的勇气与他的力量。",
                "2_H263": "即便他不在了，也没有改变。",
                "2_H264": "您并非只是失去了。",
                "2_H265": "这点，您自己也明白吧？"
            }
        },
        "2_H270": {
            "name": "会話 6",
            "text": {
                "2_H270": "但丁·阿利吉耶里？",
                "2_H271": "唔，那我可得重新好好教训他才行。",
                "2_H272": "……为了心上人创造特异点。",
                "2_H273": "这种爱值得送上敬意……",
                "2_H274": "不过，一码归一码。"
            }
        },
        "2_H280": {
            "name": "会話 7",
            "text": {
                "2_H280": "嗯，莉莉丝也在啊。",
                "2_H281": "那么，宝具准备。",
                "2_H282": "哎呀，怎么了？",
                "2_H283": "既然曾被她从背后攻击，做好临战态势也是很正常的吧？",
                "2_H284": "不，当然没有生气。没有哦？",
                "2_H285": "若真能惹怒我，那是非常了不起的哦。",
                "2_H286": "那么，宝具准备！"
            }
        }
    },
    "ChrVoice_ids": [
        "901900"
    ]
}