{
    "id": 9947990,
    "name": "Enemy 9947990",
    "voices": {
        "0_B010": {
            "name": "0_B010",
            "text": {
                "0_B010": "呼地一下冲过去！头好晕！"
            },
            "raw_text": {
                "0_B010": "ブーンっていくよ！目が回る！"
            }
        },
        "0_B020": {
            "name": "0_B020",
            "text": {
                "0_B020": "既然如此就用这个！"
            },
            "raw_text": {
                "0_B020": "だったらこいつだ！"
            }
        },
        "0_B030": {
            "name": "0_B030",
            "text": {
                "0_B030": "村正老爷！嘿咻！"
            },
            "raw_text": {
                "0_B030": "村正のところで!ほいさ!"
            }
        },
        "0_B040": {
            "name": "0_B040",
            "text": {
                "0_B040": "没用的！"
            },
            "raw_text": {
                "0_B040": "ただめだ！"
            }
        },
        "0_B041": {
            "name": "0_B041",
            "text": {
                "0_B041": "真是慷慨大方啊。"
            },
            "raw_text": {
                "0_B041": "大盤振る舞いだぜ。"
            }
        },
        "0_B050": {
            "name": "0_B050",
            "text": {
                "0_B050": "在此编织的是梦之气息。"
            },
            "raw_text": {
                "0_B050": "ここに紡ぐは夢の息吹。"
            }
        },
        "0_B051": {
            "name": "0_B051",
            "text": {
                "0_B051": "连宿命也能斩断的年轻生命之奔流。"
            },
            "raw_text": {
                "0_B051": "宿命すら断ち切る若き命の奔流。"
            }
        },
        "0_B052": {
            "name": "0_B052",
            "text": {
                "0_B052": "第二阶段，应急限定解除。"
            },
            "raw_text": {
                "0_B052": "第二段階応用限定解除。"
            }
        },
        "0_B053": {
            "name": "0_B053",
            "text": {
                "0_B053": "誓约胜利之剑·拉加斯。"
            },
            "raw_text": {
                "0_B053": "エクスカリバー ラガス。"
            }
        },
        "0_B080": {
            "name": "0_B080",
            "text": {
                "0_B080": "要全功率上了哦。"
            },
            "raw_text": {
                "0_B080": "パワー全開でいくぞ。"
            }
        },
        "0_B100": {
            "name": "0_B100",
            "text": {
                "0_B100": "要来喽。嘻嘻嘻，可别闹得太凶自己倒下啊。"
            },
            "raw_text": {
                "0_B100": "いくよー。いひひひ、暴れすぎて倒れんなよ。"
            }
        },
        "0_B110": {
            "name": "0_B110",
            "text": {
                "0_B110": "我会努力的，看着我哦，御主。"
            },
            "raw_text": {
                "0_B110": "頑張るから見ててね、マスター。"
            }
        },
        "0_B120": {
            "name": "0_B120",
            "text": {
                "0_B120": "太好了！真舒服！嘛，胜利的感觉也不赖嘛。"
            },
            "raw_text": {
                "0_B120": "やったー！気持ちいいね！まあ勝利ってのは悪くないな。"
            }
        },
        "0_B130": {
            "name": "0_B130",
            "text": {
                "0_B130": "好耶，胜利！这样的话御主和师匠也会认可的吧！"
            },
            "raw_text": {
                "0_B130": "ようした勝利！これならマスターも師匠も納得でしょう！"
            }
        },
        "0_B140": {
            "name": "0_B140",
            "text": {
                "0_B140": "唔！"
            },
            "raw_text": {
                "0_B140": "くうっ。"
            }
        },
        "0_B150": {
            "name": "0_B150",
            "text": {
                "0_B150": "快停下！这家伙太难对付了！"
            },
            "raw_text": {
                "0_B150": "止めて！こいつはきつい！"
            }
        },
        "0_B160": {
            "name": "0_B160",
            "text": {
                "0_B160": "对不起，御主，师匠。"
            },
            "raw_text": {
                "0_B160": "ごめんマスター、師匠。"
            }
        },
        "0_B170": {
            "name": "0_B170",
            "text": {
                "0_B170": "好像有点勉强了。抱歉啦，我先暂时撤退了。"
            },
            "raw_text": {
                "0_B170": "ちょっと無理したかも。悪いな、一時退避するぜ。"
            }
        },
        "0_B180": {
            "name": "0_B180",
            "text": {
                "0_B180": "就用那个吧。"
            },
            "raw_text": {
                "0_B180": "それでいくんだね。"
            }
        },
        "0_B190": {
            "name": "0_B190",
            "text": {
                "0_B190": "交给我吧。"
            },
            "raw_text": {
                "0_B190": "任せて。"
            }
        },
        "0_B200": {
            "name": "0_B200",
            "text": {
                "0_B200": "OK。"
            },
            "raw_text": {
                "0_B200": "オッケー。"
            }
        },
        "0_B2010": {
            "name": "0_B2010",
            "text": {
                "0_B2010": "要发射了哦！"
            },
            "raw_text": {
                "0_B2010": "ぶっ放すから！"
            }
        },
        "0_B2020": {
            "name": "0_B2020",
            "text": {
                "0_B2020": "要犀利地上了。既然如此，那就这样！"
            },
            "raw_text": {
                "0_B2020": "鋭く行くぞ。だったらこうだ。"
            }
        },
        "0_B2030": {
            "name": "0_B2030",
            "text": {
                "0_B2030": "这是组合连击！"
            },
            "raw_text": {
                "0_B2030": "コンビネーションだ！"
            }
        },
        "0_B210": {
            "name": "0_B210",
            "text": {
                "0_B210": "封印礼装，解除。"
            },
            "raw_text": {
                "0_B210": "封印礼装解除。"
            }
        },
        "0_B220": {
            "name": "0_B220",
            "text": {
                "0_B220": "亚德？好嘞，该我出场了！"
            },
            "raw_text": {
                "0_B220": "あった？よっしゃ、出番だな！"
            }
        },
        "0_B2410": {
            "name": "0_B2410",
            "text": {
                "0_B2410": "要刷刷刷地上了，看起来真开心啊。"
            },
            "raw_text": {
                "0_B2410": "ズバババっていくよ楽しそうだな。"
            }
        },
        "0_B2420": {
            "name": "0_B2420",
            "text": {
                "0_B2420": "用这个切裂吧。"
            },
            "raw_text": {
                "0_B2420": "こいつで切り裂け。"
            }
        },
        "0_B410": {
            "name": "0_B410",
            "text": {
                "0_B410": "刀还真是帅气呢！"
            },
            "raw_text": {
                "0_B410": "刀ってかっこいいよね！"
            }
        },
        "0_B420": {
            "name": "0_B420",
            "text": {
                "0_B420": "要咚地来一下了！交给我吧！"
            },
            "raw_text": {
                "0_B420": "ドンってやるから！任せろ！"
            }
        },
        "0_B430": {
            "name": "0_B430",
            "text": {
                "0_B430": "尽情地来吧！"
            },
            "raw_text": {
                "0_B430": "あー まいっきりだー。"
            }
        },
        "0_B440": {
            "name": "0_B440",
            "text": {
                "0_B440": "使出全力吧！"
            },
            "raw_text": {
                "0_B440": "全部出し切れ！"
            }
        },
        "0_B441": {
            "name": "0_B441",
            "text": {
                "0_B441": "干了！"
            },
            "raw_text": {
                "0_B441": "やってやるぜい。"
            }
        },
        "0_B480": {
            "name": "0_B480",
            "text": {
                "0_B480": "要干了，亚德！嘿嘿嘿，真没办法啊。"
            },
            "raw_text": {
                "0_B480": "やるぞアット！えへへへへ、仕方ねえな。"
            }
        },
        "0_B490": {
            "name": "0_B490",
            "text": {
                "0_B490": "亚德要大显身手了。"
            },
            "raw_text": {
                "0_B490": "セツがやっちゃうから。"
            }
        },
        "0_B500": {
            "name": "0_B500",
            "text": {
                "0_B500": "要尽情享受个够啦——"
            },
            "raw_text": {
                "0_B500": "思いっきり楽しんじゃうぞー。"
            }
        },
        "0_B510": {
            "name": "0_B510",
            "text": {
                "0_B510": "好，要上了，亚德！哎呀，这家伙可得加把劲了！"
            },
            "raw_text": {
                "0_B510": "さあ行くぞアッパッ！おっと、こいつは気張らねえとな！"
            }
        },
        "0_B520": {
            "name": "0_B520",
            "text": {
                "0_B520": "手感超群！啊，不过，不疼吗？——现在是担心别人的时候吗！"
            },
            "raw_text": {
                "0_B520": "抜群の手応え！あ、でも痛くなかった？他人の心配してる場合かっての！"
            }
        },
        "0_B540": {
            "name": "0_B540",
            "text": {
                "0_B540": "啊！"
            },
            "raw_text": {
                "0_B540": "ああ！"
            }
        },
        "0_B550": {
            "name": "0_B550",
            "text": {
                "0_B550": "喂，加油啊，格蕾。"
            },
            "raw_text": {
                "0_B550": "こんなの頑張れグレイ。"
            }
        },
        "0_B800": {
            "name": "0_B800",
            "text": {
                "0_B800": "此等灯火乃是未来的光辉。"
            },
            "raw_text": {
                "0_B800": "この灯火は未来の輝き。"
            }
        },
        "0_B801": {
            "name": "0_B801",
            "text": {
                "0_B801": "终将抵达星辰的宿命之战。"
            },
            "raw_text": {
                "0_B801": "いずれ星に至る宿命の一戦。"
            }
        },
        "0_B802": {
            "name": "0_B802",
            "text": {
                "0_B802": "第二阶段，应急限定解除。"
            },
            "raw_text": {
                "0_B802": "第二段階応用限定解除。"
            }
        },
        "0_B803": {
            "name": "0_B803",
            "text": {
                "0_B803": "誓约胜利之剑·拉加斯！"
            },
            "raw_text": {
                "0_B803": "エクスカリバー ラガス！"
            }
        },
        "0_B810": {
            "name": "0_B810",
            "text": {
                "0_B810": "疑似人格停止。"
            },
            "raw_text": {
                "0_B810": "擬似人格停止。"
            }
        },
        "0_B811": {
            "name": "0_B811",
            "text": {
                "0_B811": "魔力收集率突破规定值。"
            },
            "raw_text": {
                "0_B811": "魔力の収集率規定値を突破。"
            }
        },
        "0_B812": {
            "name": "0_B812",
            "text": {
                "0_B812": "释放复合礼装·逻辑反应复制品的功能。"
            },
            "raw_text": {
                "0_B812": "複合冷蔵ロゴスリヤクトレプリカの機能を解放。"
            }
        },
        "0_B813": {
            "name": "0_B813",
            "text": {
                "0_B813": "圣剑，拔刀！"
            },
            "raw_text": {
                "0_B813": "政権、バット！"
            }
        },
        "0_B814": {
            "name": "0_B814",
            "text": {
                "0_B814": "誓约胜利之剑·拉加斯！"
            },
            "raw_text": {
                "0_B814": "エクスカリバー ラガス！"
            }
        },
        "0_B840": {
            "name": "0_B840",
            "text": {
                "0_B840": "一口气解决吧！"
            },
            "raw_text": {
                "0_B840": "一気にやるぞー。"
            }
        },
        "0_B841": {
            "name": "0_B841",
            "text": {
                "0_B841": "好嘞！"
            },
            "raw_text": {
                "0_B841": "おっしゃあ！"
            }
        },
        "0_B910": {
            "name": "0_B910",
            "text": {
                "0_B910": "要斩断你哦——来大干一场吧——"
            },
            "raw_text": {
                "0_B910": "ぶった切ってやるぞー一丁やるかー。"
            }
        },
        "0_B920": {
            "name": "0_B920",
            "text": {
                "0_B920": "用个大家伙。"
            },
            "raw_text": {
                "0_B920": "でっかいやつで。"
            }
        },
        "0_B930": {
            "name": "0_B930",
            "text": {
                "0_B930": "要轰地来一下了！就是这个吧！"
            },
            "raw_text": {
                "0_B930": "ドカンってやるぞ！こいつだな！"
            }
        }
    }
}