{
    "id": 9947820,
    "name": "Enemy 9947820",
    "voices": {
        "0_B010": {
            "name": "0_B010",
            "text": {
                "0_B010": "丑陋。"
            },
            "raw_text": {
                "0_B010": "無様。"
            }
        },
        "0_B020": {
            "name": "0_B020",
            "text": {
                "0_B020": "生长。"
            },
            "raw_text": {
                "0_B020": "グロー。"
            }
        },
        "0_B030": {
            "name": "0_B030",
            "text": {
                "0_B030": "不逊。"
            },
            "raw_text": {
                "0_B030": "不遜。"
            }
        },
        "0_B050": {
            "name": "0_B050",
            "text": {
                "0_B050": "迦勒底，汝等的命运到此为止。"
            },
            "raw_text": {
                "0_B050": "カルデア汝らの運命はここまで。"
            }
        },
        "0_B051": {
            "name": "0_B051",
            "text": {
                "0_B051": "一切皆已破灭，一切皆已消亡。"
            },
            "raw_text": {
                "0_B051": "全て破れ去り全て滅び去った。"
            }
        },
        "0_B052": {
            "name": "0_B052",
            "text": {
                "0_B052": "乌尔德·斯鲁德·福尔恩。"
            },
            "raw_text": {
                "0_B052": "ウルザルスラズルフォルン。"
            }
        },
        "0_B053": {
            "name": "0_B053",
            "text": {
                "0_B053": "那正是被注定的汝之过去。"
            },
            "raw_text": {
                "0_B053": "それこそが決定付けられた汝の過去である。"
            }
        },
        "0_B080": {
            "name": "0_B080",
            "text": {
                "0_B080": "肃然起敬吧。"
            },
            "raw_text": {
                "0_B080": "敬え。"
            }
        },
        "0_B090": {
            "name": "0_B090",
            "text": {
                "0_B090": "跪拜吧。"
            },
            "raw_text": {
                "0_B090": "平伏せよ。"
            }
        },
        "0_B140": {
            "name": "0_B140",
            "text": {
                "0_B140": "动摇吧。"
            },
            "raw_text": {
                "0_B140": "ブレ。"
            }
        },
        "0_B150": {
            "name": "0_B150",
            "text": {
                "0_B150": "绝不姑息。"
            },
            "raw_text": {
                "0_B150": "許さぬ。"
            }
        },
        "0_B2010": {
            "name": "0_B2010",
            "text": {
                "0_B2010": "你已身死。"
            },
            "raw_text": {
                "0_B2010": "死んだな。"
            }
        },
        "0_B2020": {
            "name": "0_B2020",
            "text": {
                "0_B2020": "此乃极言。"
            },
            "raw_text": {
                "0_B2020": "極言だ。"
            }
        },
        "0_B2030": {
            "name": "0_B2030",
            "text": {
                "0_B2030": "古老的白骨啊。"
            },
            "raw_text": {
                "0_B2030": "古き骨よ。"
            }
        },
        "0_B2410": {
            "name": "0_B2410",
            "text": {
                "0_B2410": "雨。"
            },
            "raw_text": {
                "0_B2410": "雨。"
            }
        },
        "0_B2420": {
            "name": "0_B2420",
            "text": {
                "0_B2420": "收敛。"
            },
            "raw_text": {
                "0_B2420": "収束。"
            }
        },
        "0_B2430": {
            "name": "0_B2430",
            "text": {
                "0_B2430": "贯穿了。"
            },
            "raw_text": {
                "0_B2430": "貫いたぞ。"
            }
        },
        "0_B2810": {
            "name": "0_B2810",
            "text": {
                "0_B2810": "毫无意义。"
            },
            "raw_text": {
                "0_B2810": "無意味。"
            }
        },
        "0_B2820": {
            "name": "0_B2820",
            "text": {
                "0_B2820": "你败北了。"
            },
            "raw_text": {
                "0_B2820": "敗北したな。"
            }
        },
        "0_B2830": {
            "name": "0_B2830",
            "text": {
                "0_B2830": "毫无转圜余地。"
            },
            "raw_text": {
                "0_B2830": "精の余地なし。"
            }
        },
        "0_B300": {
            "name": "0_B300",
            "text": {
                "0_B300": "那么，开始宣告终结吧。与悲伤的过去决别，重新开启新的过去吧。吾名为乌尔德。命运三女神，诺恩之一柱，在此参上。"
            },
            "raw_text": {
                "0_B300": "では終わりを始めましょう。悲しき過去との決別、新しい過去をやり直すがいい。我が名はウルズ。運命の三女神。ノルニルの一柱参ります。"
            }
        },
        "0_B3010": {
            "name": "0_B3010",
            "text": {
                "0_B3010": "卷涌吧。"
            },
            "raw_text": {
                "0_B3010": "逆巻。"
            }
        },
        "0_B410": {
            "name": "0_B410",
            "text": {
                "0_B410": "大地崩裂。"
            },
            "raw_text": {
                "0_B410": "地は崩れた。"
            }
        },
        "0_B420": {
            "name": "0_B420",
            "text": {
                "0_B420": "碎裂也无妨。"
            },
            "raw_text": {
                "0_B420": "砕けてよし。"
            }
        },
        "0_B430": {
            "name": "0_B430",
            "text": {
                "0_B430": "恶化吧。"
            },
            "raw_text": {
                "0_B430": "悪化えせよ。"
            }
        },
        "0_B480": {
            "name": "0_B480",
            "text": {
                "0_B480": "困倦了。"
            },
            "raw_text": {
                "0_B480": "眠いな。"
            }
        },
        "0_B490": {
            "name": "0_B490",
            "text": {
                "0_B490": "汝之命运已定。"
            },
            "raw_text": {
                "0_B490": "汝の運命は定まった。"
            }
        },
        "0_B540": {
            "name": "0_B540",
            "text": {
                "0_B540": "啧。"
            },
            "raw_text": {
                "0_B540": "ち。"
            }
        },
        "0_B550": {
            "name": "0_B550",
            "text": {
                "0_B550": "呜呜呜呜呜呜呜呜呜呜呜呜呜呜呜呜呜呜呜呜呜"
            },
            "raw_text": {
                "0_B550": "ううううううううううううううううううううう"
            }
        },
        "0_B880": {
            "name": "0_B880",
            "text": {
                "0_B880": "当知未来已不存在。"
            },
            "raw_text": {
                "0_B880": "未来などないと知れ。"
            }
        },
        "0_B910": {
            "name": "0_B910",
            "text": {
                "0_B910": "践踏殆尽。"
            },
            "raw_text": {
                "0_B910": "踏みにじった。"
            }
        },
        "0_B920": {
            "name": "0_B920",
            "text": {
                "0_B920": "如此警惕。"
            },
            "raw_text": {
                "0_B920": "こう注意。"
            }
        },
        "0_B930": {
            "name": "0_B930",
            "text": {
                "0_B930": "想必是场好雨吧。"
            },
            "raw_text": {
                "0_B930": "良き雨であろう。"
            }
        }
    }
}