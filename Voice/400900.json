        "0_G010": {
            "name": "升级",
            "text": {
                "0_G010": "……嗯，变强了。"
            }
        },
        "0_G020": {
            "name": "灵基再临 2",
            "text": {
                "0_G020": "好像变得更厉害了呢。"
            }
        },
        "0_G030": {
            "name": "灵基再临 1",
            "text": {
                "0_G030": "对对，就是这种感觉啦。"
            }
        },
        "0_G040": {
            "name": "灵基再临 3",
            "text": {
                "0_G040": "几乎可以算是完美了呢，感觉真不错。"
            }
        },
        "0_G050": {
            "name": "灵基再临 4",
            "text": {
                "0_G050": "嗯，现在的我们甚至能支配七大洋。",
                "0_G051": "真是雄心大志呢，但我表示同意，呵呵呵。"
            }
        },
        "0_G110": {
            "name": "レベルアップ 2",
            "text": {
                "0_G110": ""
            },
            "raw_text": {
                "0_G110": ""
            }
        },
        "0_G120": {
            "name": "レベルアップ 3",
            "text": {
                "0_G120": ""
            },
            "raw_text": {
                "0_G120": ""
            }
        },
        "0_H010": {
            "name": "生日",
            "text": {
                "0_H010": "生日吗？　祝你生日快乐。",
                "0_H011": "如果不介意的话，需要我给你一个吻吗？"
            }
        },
        "0_H020": {
            "name": "活动举行中",
            "text": {
                "0_H020": "是财宝的味道呢，我们走吧。"
            }
        },
        "0_H030": {
            "name": "对话 1",
            "text": {
                "0_H030": "冒险似乎在等待着我们呢……"
            }
        },
        "0_H040": {
            "name": "对话 2",
            "text": {
                "0_H040": "我们可是热爱自由的海盗嘛。不过御主是很重要的。"
            }
        },
        "0_H050": {
            "name": "对话 3",
            "text": {
                "0_H050": "哎呀讨厌。 能不能别因为你是御主，就做一些奇怪的事啊。"
            }
        },
        "0_H060": {
            "name": "喜欢的东西",
            "text": {
                "0_H060": "每天都很快乐吧…… 海盗就是这样的存在。"
            }
        },
        "0_H070": {
            "name": "讨厌的东西",
            "text": {
                "0_H070": "我讨厌拘束。 御主会拘束我吗？"
            }
        },
        "0_H080": {
            "name": "关于圣杯",
            "text": {
                "0_H080": "圣杯，真好啊。 只要有藏宝图就会想要得到手。 这是不是一种任性呢？"
            }
        },
        "0_H090": {
            "name": "牵绊Lv.1",
            "text": {
                "0_H090": "怎么了？　找我有事吗？"
            }
        },
        "0_H100": {
            "name": "牵绊Lv.2",
            "text": {
                "0_H100": "我可不会不理睬你哦，呵呵呵。"
            }
        },
        "0_H110": {
            "name": "牵绊Lv.3",
            "text": {
                "0_H110": "真是的，不要调侃我啦，御主。 ……真是的！"
            }
        },
        "0_H120": {
            "name": "牵绊Lv.4",
            "text": {
                "0_H120": "想要触碰我吗？ 真是位让人困扰的人呢……"
            }
        },
        "0_H130": {
            "name": "牵绊Lv.5",
            "text": {
                "0_H130": "……可以哦？",
                "0_H131": "真没办法。我会一起抱着你们。 今晚就这样睡吧。"
            }
        },
        "0_H1400": {
            "name": "絆Lv.3 (3章クリア以降)",
            "text": {
                "0_H1400": "",
                "0_H1401": ""
            },
            "raw_text": {
                "0_H1400": "",
                "0_H1401": ""
            }
        },
        "0_H1600": {
            "name": "絆Lv.4 (3章クリア以降)",
            "text": {
                "0_H1600": "",
                "0_H1601": ""
            },
            "raw_text": {
                "0_H1600": "",
                "0_H1601": ""
            }
        },
        "0_H170": {
            "name": "会話 4",
            "text": {
                "0_H170": "啊，是黑胡子。还是老样子呢。感觉不管是过了十年还是百年都不会变。嘛，也就是说一直都不能大意呢。",
                "0_H171": "",
                "0_H172": "",
                "0_H173": ""
            },
            "raw_text": {
                "0_H170": "あ、黒ひげだ。相変わらずですわね。十年経っても百年経っても変わらない感じです。まあ、つまりずっと油断ならないってことなんだけどね。",
                "0_H171": "",
                "0_H172": "",
                "0_H173": ""
            }
        },
        "0_H180": {
            "name": "会話 5",
            "text": {
                "0_H180": "呀，是巴索罗缪。这个男人，连看都不看我一眼，真是让人有些莫名地生气呢。",
                "0_H181": ""
            },
            "raw_text": {
                "0_H180": "やあ、バーソロミューだ。この男、私には目もくれないのが地味に腹立ちますわ。",
                "0_H181": ""
            }
        },
        "0_H1800": {
            "name": "絆Lv.5 (3章クリア以降)",
            "text": {
                "0_H1800": "",
                "0_H1801": ""
            },
            "raw_text": {
                "0_H1800": "",
                "0_H1801": ""
            }
        },
        "0_H190": {
            "name": "会話 6",
            "text": {
                "0_H190": "哎呀，这不是德雷克船长吗。嘿嘿嘿，同为海盗，要好好相处哦。",
                "0_H191": ""
            },
            "raw_text": {
                "0_H190": "あらまあ、ドレーク船長では、へへへ、海賊同士仲良くしようね。",
                "0_H191": ""
            }
        },
        "0_H200": {
            "name": "会話 7",
            "text": {
                "0_H200": "哎呀，是清姬小姐。就是所谓的“真爱势”对吧。我们这边也是真爱呢。",
                "0_H201": "",
                "0_H202": ""
            },
            "raw_text": {
                "0_H200": "あら、きよひめさん。ガチ恋せ、というやつですわね。こっちだってガチ恋だもんね。",
                "0_H201": "",
                "0_H202": ""
            }
        },
        "0_H210": {
            "name": "会話 8",
            "text": {
                "0_H210": "您应该见过换上泳装的我们吧。泳装和便服，你喜欢哪一个？啊，要不两个都试试吧。在您面前换衣服什么的，听起来真不错呢。糟了，刚才的话引起风纪委员的反应了。快逃吧。",
                "0_H211": "",
                "0_H212": "",
                "0_H213": "",
                "0_H214": ""
            },
            "raw_text": {
                "0_H210": "水着に着替えた私たちをご覧になったことはありますわね。水着と普段着、どっちがいい？あ、両方やってみようか。目の前で着替えるとか、いいですわね。まずい、今の言葉に風紀委員が反応した。逃げよう。",
                "0_H211": "",
                "0_H212": "",
                "0_H213": "",
                "0_H214": ""
            }
        },
        "0_H3060": {
            "name": "好きなこと (絆Lv.5以上+3章クリア以降)",
            "text": {
                "0_H3060": "",
                "0_H3061": "",
                "0_H3062": "",
                "0_H3063": ""
            },
            "raw_text": {
                "0_H3060": "",
                "0_H3061": "",
                "0_H3062": "",
                "0_H3063": ""
            }
        },
        "0_S010": {
            "name": "召唤",
            "text": {
                "0_S010": "吓了一跳吗？　我们俩是二人一组的从者。",
                "0_S011": "她是玛莉·瑞德。我是安妮·伯妮。 请多多指教哦。"
            }
        }
    },
