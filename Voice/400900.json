        "0_B030": {
            "name": "攻击 3",
            "text": {
                "0_B030": "好！"
            }
        },
        "0_B040": {
            "name": "额外攻击",
            "text": {
                "0_B040": "别小看我们海盗！"
            }
        },
        "0_B050": {
            "name": "宝具",
            "text": {
                "0_B050": "由我先开始吧，",
                "0_B051": "看招看招看招！",
                "0_B052": "安妮，接下来就交给你了！",
                "0_B053": "好嘞，那我要瞄准了哟，",
                "0_B054": "射击！！"
            }
        },
        "0_B080": {
            "name": "技能 1",
            "text": {
                "0_B080": "就让我使用这个吧。"
            }
        },
        "0_B090": {
            "name": "技能 2",
            "text": {
                "0_B090": "嗯，就这个吧。嗯嗯。"
            }
        },
        "0_B100": {
            "name": "开始 1",
            "text": {
                "0_B100": "我会用全力上哦！ 行啊，玛莉，掩护就交给我吧。"
            }
        },
        "0_B110": {
            "name": "开始 2",
            "text": {
                "0_B110": "好了，开始掠夺吧。 呵呵呵，一较高下吧。"
            }
        },
        "0_B120": {
            "name": "胜利 1",
            "text": {
                "0_B120": "差不多就这样吧。 呵呵，这才配称得上海盗呢。"
            }
        },
        "0_B130": {
            "name": "胜利 2",
            "text": {
                "0_B130": "呼，真是千钧一发。 没事吧？ 没受伤吧？"
            }
        },
        "0_B140": {
            "name": "ダメージ 2",
            "text": {
