        },
        "0_G040": {
            "name": "灵基再临 3",
            "text": {
                "0_G040": "【安妮】几乎可以算是完美了呢，感觉真不错。"
            }
        },
        "0_G050": {
            "name": "灵基再临 4",
            "text": {
                "0_G050": "【玛莉】嗯，现在的我们甚至能支配七大洋。",
                "0_G051": "【安妮】真是雄心大志呢，但我表示同意，呵呵呵。"
            }
        },
        "0_G110": {
            "name": "レベルアップ 2",
            "text": {
                "0_G110": "【安妮】肚子上应该不会长肉吧？"
            },
            "raw_text": {
                "0_G110": ""
            }
        },
        "0_G120": {
            "name": "レベルアップ 3",
            "text": {
                "0_G120": "太棒啦～！"
            },
            "raw_text": {
                "0_G120": ""
            }
        },
        "0_H010": {
            "name": "生日",
            "text": {
                "0_H010": "【玛莉】生日吗？　祝你生日快乐。",
                "0_H011": "【安妮】如果不介意的话，需要我给你一个吻吗？"
            }
        },
        "0_H020": {
            "name": "活动举行中",
            "text": {
                "0_H020": "【安妮】是财宝的味道呢，我们走吧。"
            }
        },
        "0_H030": {
            "name": "对话 1",
            "text": {
                "0_H030": "【玛莉】冒险似乎在等待着我们呢……"
            }
        },
        "0_H040": {
            "name": "对话 2",
            "text": {
                "0_H040": "【玛莉】我们可是热爱自由的海盗嘛。 【玛莉】不过御主是很重要的。"
            }
        },
        "0_H050": {
            "name": "对话 3",
            "text": {
                "0_H050": "【安妮】哎呀讨厌。能不能别因为你是御主，就做一些奇怪的事啊。"
            }
        },
        "0_H060": {
            "name": "喜欢的东西",
            "text": {
                "0_H060": "【玛莉】每天都很快乐吧…… 【玛莉】海盗就是这样的存在。"
            }
        },
        "0_H070": {
            "name": "讨厌的东西",
            "text": {
                "0_H070": "【玛莉】我讨厌拘束。 【玛莉】御主会拘束我吗？"
            }
        },
        "0_H080": {
            "name": "关于圣杯",
            "text": {
                "0_H080": "【安妮】圣杯，真好啊。 【安妮】只要有藏宝图就会想要得到手。这是不是一种任性呢？"
            }
        },
        "0_H090": {
            "name": "牵绊Lv.1",
            "text": {
                "0_H090": "【玛莉】怎么了？　找我有事吗？"
            }
        },
        "0_H100": {
            "name": "牵绊Lv.2",
            "text": {
                "0_H100": "【安妮】我可不会不理睬你哦，呵呵呵。"
            }
        },
        "0_H110": {
            "name": "牵绊Lv.3",
            "text": {
                "0_H110": "【玛莉】真是的，不要调侃我啦，御主。 【玛莉】……真是的！"
            }
        },
        "0_H120": {
            "name": "牵绊Lv.4",
            "text": {
                "0_H120": "【安妮】想碰我吗？　真是位让人困扰的人呢……"
            }
        },
        "0_H130": {
            "name": "牵绊Lv.5",
            "text": {
                "0_H130": "【玛莉】……可以哦？",
                "0_H131": "【安妮】真没办法。我会一起抱着你们。今晚就这样睡吧。"
            }
        },
        "0_H1400": {
            "name": "絆Lv.3 (3章クリア以降)",
            "text": {
                "0_H1400": "【玛莉】被干掉了呢～。",
                "0_H1401": "【安妮】被狠狠揍了一顿呢～。"
            },
            "raw_text": {
                "0_H1400": "",
                "0_H1401": ""
            }
        },
        "0_H1600": {
            "name": "絆Lv.4 (3章クリア以降)",
            "text": {
                "0_H1600": "【玛莉】没问题没问题～，尽管触碰吧～。",
                "0_H1601": "【安妮】玛莉，是不是有点过度失去理智了？"
            },
            "raw_text": {
                "0_H1600": "",
                "0_H1601": ""
            }
        },
        "0_H170": {
            "name": "会話 4",
            "text": {
                "0_H170": "【玛莉】啊，是黑胡子～。",
                "0_H171": "【安妮】他还是老样子呢。",
                "0_H172": "【安妮】感觉不管经历十年还是百年，他都不会变呢。",
                "0_H173": "【玛莉】也就是说，始终不容大意呢。"
            },
            "raw_text": {
                "0_H170": "あ、黒ひげだ。相変わらずですわね。十年経っても百年経っても変わらない感じです。まあ、つまりずっと油断ならないってことなんだけどね。",
                "0_H171": "",
                "0_H172": "",
                "0_H173": ""
            }
        },
        "0_H180": {
            "name": "会話 5",
            "text": {
                "0_H180": "【玛莉】呀啊，是巴沙洛缪！",
                "0_H181": "【安妮】这男人看都不看我一眼，总是有些令人火大。"
            },
            "raw_text": {
                "0_H180": "やあ、バーソロミューだ。この男、私には目もくれないのが地味に腹立ちますわ。",
                "0_H181": ""
            }
        },
        "0_H1800": {
            "name": "絆Lv.5 (3章クリア以降)",
            "text": {
                "0_H1800": "【安妮】来吧，Go to bed吧！",
                "0_H1801": "【玛莉】毕竟是海盗，没啥伦理意识啦！　哎嘿嘿～。"
            },
            "raw_text": {
                "0_H1800": "",
                "0_H1801": ""
            }
        },
        "0_H190": {
            "name": "会話 6",
            "text": {
                "0_H190": "【安妮】哎呀，这不是德雷克船长嘛。",
                "0_H191": "【玛莉】哎嘿嘿～，都是海盗，让我们和睦相处吧。"
            },
            "raw_text": {
                "0_H190": "あらまあ、ドレーク船長では、へへへ、海賊同士仲良くしようね。",
                "0_H191": ""
            }
        },
        "0_H200": {
            "name": "会話 7",
            "text": {
                "0_H200": "【安妮】哎呀，清姬小姐。",
                "0_H201": "【安妮】您应该算认真恋爱群体吧。",
                "0_H202": "【玛莉】我们的恋爱也是认真的啦！"
            },
            "raw_text": {
                "0_H200": "あら、きよひめさん。ガチ恋せ、というやつですわね。こっちだってガチ恋だもんね。",
                "0_H201": "",
                "0_H202": ""
            }
        },
        "0_H210": {
            "name": "会話 8",
            "text": {
                "0_H210": "【安妮】您应该见过换上泳装的我们吧？",
                "0_H211": "【玛莉】泳装和平时的打扮哪种比较好？",
                "0_H212": "【玛莉】啊，两种都试试吧！",
                "0_H213": "【安妮】当着您的面更衣或许也不错哦～。",
                "0_H214": "【玛莉】糟了，风纪委员对刚才那句话有反应了。快逃！"
            },
            "raw_text": {
                "0_H210": "水着に着替えた私たちをご覧になったことはありますわね。水着と普段着、どっちがいい？あ、両方やってみようか。目の前で着替えるとか、いいですわね。まずい、今の言葉に風紀委員が反応した。逃げよう。",
                "0_H211": "",
                "0_H212": "",
                "0_H213": "",
                "0_H214": ""
            }
        },
        "0_H3060": {
            "name": "好きなこと (絆Lv.5以上+3章クリア以降)",
            "text": {
                "0_H3060": "【玛莉】喜欢的东西？",
                "0_H3061": "【玛莉】是御主！",
                "0_H3062": "【安妮】我也一样！",
                "0_H3063": "【安妮】御主当然也喜欢我们吧？"
            },
            "raw_text": {
                "0_H3060": "",
                "0_H3061": "",
                "0_H3062": "",
                "0_H3063": ""
            }
        },
        "0_S010": {
            "name": "召唤",
            "text": {
                "0_S010": "【玛莉】吓了一跳吗？　我们俩是二人一组的从者。",
                "0_S011": "【安妮】她是玛莉·瑞德。我是安妮·伯妮。 请多多指教哦。"
            }
