            "text": {
                "0_B150": "不要啊，玛莉！"
            }
        },
        "0_B160": {
            "name": "无法战斗 1",
            "text": {
                "0_B160": "对不起，安妮。 不行，不要死……"
            }
        },
        "0_B170": {
            "name": "无法战斗 2",
            "text": {
                "0_B170": "到此为止了吗……呜！ 我们……努力……过了吧……"
            }
        },
