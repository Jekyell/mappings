{
    "id": 109836020,
    "name": "",
    "voices": {
        "0_I010": {
            "name": "ショップついて 1",
            "text": {
                "0_I010": "交易现在开始。这些是在安条克发掘出的众多宝物。我打算将其变现以充实军费，还请迦勒底务必以合理的价格收购。",
                "0_I011": "",
                "0_I012": ""
            }
        },
        "0_I020": {
            "name": "ショップついて 2",
            "text": {
                "0_I020": "你来了啊，御主。看看这些绝妙的珍品。攻陷这家店，就等同于得到了全世界。要试着打倒看店的我，将其收入囊中吗？没错，就是这世界。",
                "0_I021": "",
                "0_I022": "",
                "0_I023": ""
            }
        },
        "0_I030": {
            "name": "ショップついて 3",
            "text": {
                "0_I030": "这可是件了不得的宝贝。能送给我吗？……开玩笑的。",
                "0_I031": "",
                "0_I032": ""
            }
        },
        "0_I040": {
            "name": "ショップついて 4",
            "text": {
                "0_I040": "明白了，要好好珍惜使用啊。"
            }
        },
        "0_I050": {
            "name": "ショップついて 5",
            "text": {
                "0_I050": "我很好奇你会如何利用这个。如果不介意的话，下次让我看看你的用法吧。",
                "0_I051": ""
            }
        },
        "0_I060": {
            "name": "ショップついて 6",
            "text": {
                "0_I060": "这个和我的发色很像呢。是什么动物的毛？要是手头紧的话，我也试着剪掉自己的头发拿去卖吧。",
                "0_I061": ""
            }
        }
    },
    "ChrVoice_ids": [
        "109836020"
    ]
}