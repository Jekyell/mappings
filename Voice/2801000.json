    "name": "ダンテ・アリギエーリ",
    "voices": {
        "0_B010": {
            "name": "アタック 1",
            "text": {
                "0_B010": "哈！"
            }
        },
        "0_B020": {
            "name": "アタック 2",
            "text": {
                "0_B020": "是那边吧！"
            }
        },
        "0_B030": {
            "name": "アタック 3",
            "text": {
                "0_B030": "呵呵……！"
            }
        },
        "0_B040": {
            "name": "エクストラアタック 1",
            "text": {
                "0_B040": "呵呵……要打起精神来吗！"
            }
        },
        "0_B050": {
            "name": "宝具 1",
            "text": {
                "0_B050": "痛苦，痛苦痛苦！",
                "0_B051": "我的黑暗啊！　此刻将满溢此世！",
                "0_B052": "来吧，凡入此门者，必当捐弃希望！！",
                "0_B053": "汝此刻，已身在地狱！"
            }
        },
        "0_B080": {
            "name": "スキル 1",
            "text": {
                "0_B080": "太美妙了。"
            }
        },
        "0_B090": {
            "name": "スキル 2",
            "text": {
                "0_B090": "来吧。"
            }
        },
        "0_B100": {
            "name": "開始 1",
            "text": {
                "0_B100": "呵呵……那就开始吧……"
            }
        },
        "0_B110": {
            "name": "開始 2",
            "text": {
                "0_B110": "咯咯咯……飨宴开始了……干杯……"
            }
        },
        "0_B120": {
            "name": "勝利 1",
            "text": {
                "0_B120": "呵呵……赢了呢…… 也就是说……赢了啊……"
            }
        },
        "0_B130": {
            "name": "勝利 2",
            "text": {
                "0_B130": "胜利吗……真是空虚…… 但也不能败北……"
            }
        },
        "0_B140": {
            "name": "ダメージ 2",
            "text": {
                "0_B140": "不算什么！"
            }
        },
        "0_B150": {
            "name": "ダメージ 1",
            "text": {
                "0_B150": "呜哇——！"
            }
        },
        "0_B160": {
            "name": "戦闘不能 1",
            "text": {
                "0_B160": "不要……我不想……我不想去地狱……！"
            }
        },
        "0_B170": {
            "name": "戦闘不能 2",
            "text": {
                "0_B170": "但愿……能抵达……天堂……"
            }
        },
        "0_B180": {
            "name": "コマンドカード 1",
            "text": {
                "0_B180": "好吧。"
            }
        },
        "0_B190": {
            "name": "コマンドカード 2",
            "text": {
                "0_B190": "交给我吧～。"
            }
        },
        "0_B200": {
            "name": "コマンドカード 3",
            "text": {
                "0_B200": "当然能做。"
            }
        },
        "0_B2010": {
            "name": "アタック 10",
            "text": {
                "0_B2010": "别妨碍人恋爱！"
            }
        },
        "0_B2020": {
            "name": "アタック 11",
            "text": {
                "0_B2020": "连爱都不懂吗！"
            }
        },
        "0_B2030": {
            "name": "アタック 12",
            "text": {
                "0_B2030": "呵呵……呵呵呵！"
            }
        },
        "0_B210": {
            "name": "宝具カード 1",
            "text": {
                "0_B210": "宝具……虽然印象不太好……"
            }
        },
        "0_B220": {
            "name": "宝具カード 2",
            "text": {
                "0_B220": "呵呵……撒手锏……鬼牌……"
            }
        },
        "0_B2410": {
            "name": "アタック 13",
            "text": {
                "0_B2410": "虽然不够优雅！"
            }
        },
        "0_B2420": {
            "name": "アタック 14",
            "text": {
                "0_B2420": "是宿醉！"
            }
        },
        "0_B2430": {
            "name": "アタック 15",
            "text": {
                "0_B2430": "犹如风暴！"
            }
        },
        "0_B2810": {
            "name": "アタック 16",
            "text": {
                "0_B2810": "超常现象！"
            }
        },
        "0_B2820": {
            "name": "アタック 17",
            "text": {
                "0_B2820": "谢谢再见！"
            }
        },
        "0_B410": {
            "name": "アタック 4",
            "text": {
                "0_B410": "地狱之风啊！"
            }
        },
        "0_B420": {
            "name": "アタック 5",
            "text": {
                "0_B420": "马拉勃朗卡！"
            }
        },
        "0_B430": {
            "name": "アタック 6",
            "text": {
                "0_B430": "刻耳柏洛斯！"
            }
        },
        "0_B440": {
            "name": "エクストラアタック 2",
            "text": {
                "0_B440": "好，就趁现在！"
            }
        },
        "0_B480": {
            "name": "スキル 3",
            "text": {
                "0_B480": "呵呵……"
            }
        },
        "0_B490": {
            "name": "スキル 4",
            "text": {
                "0_B490": "好乖好乖。"
            }
        },
        "0_B500": {
            "name": "開始 3",
            "text": {
                "0_B500": "呵……害怕战斗吗？ 我会害怕……"
            }
        },
        "0_B520": {
            "name": "勝利 3",
            "text": {
                "0_B520": "贝雅特丽齐……我似乎还在念着你……"
            }
        },
        "0_B540": {
            "name": "ダメージ 4",
            "text": {
                "0_B540": "可恶！"
            }
        },
        "0_B550": {
            "name": "ダメージ 3",
            "text": {
                "0_B550": "哦——！哦——！"
            }
        },
        "0_B560": {
            "name": "戦闘不能 3",
            "text": {
                "0_B560": "贝雅特丽齐……只有你……"
            }
        },
        "0_B800": {
            "name": "宝具 2",
            "text": {
                "0_B800": "啊啊，啊啊！",
                "0_B801": "若要开启这扇门，必当捐弃一切希望！",
                "0_B802": "绝望的魔兽啊，满溢吧！",
                "0_B803": "此乃地狱之门，猎奇之源！"
            }
        },
        "0_B840": {
            "name": "エクストラアタック 3",
            "text": {
                "0_B840": "觉得我卑鄙吗！？"
            }
        },
        "0_B880": {
            "name": "スキル 5",
            "text": {
                "0_B880": "伸手。"
            }
        },
        "0_B910": {
            "name": "アタック 7",
            "text": {
                "0_B910": "瘴气的吐息！"
            }
        },
        "0_B920": {
            "name": "アタック 8",
            "text": {
                "0_B920": "半人马！"
            }
        },
        "0_B930": {
            "name": "アタック 9",
            "text": {
                "0_B930": "烦死了！"
            }
        },
        "0_G010": {
            "name": "レベルアップ 1",
            "text": {
                "0_G010": "呵呵……变强了……"
            }
        },
        "0_G020": {
            "name": "霊基再臨 2",
            "text": {
                "0_G020": "呵呵……没有变化……",
                "0_G021": "也没有什么可评论的……"
            }
        },
        "0_G030": {
            "name": "霊基再臨 1",
            "text": {
                "0_G030": "嗯……因为有些害羞，所以一直遮住了嘴……但现在对自己有了一些自信，所以就露出来了……",
                "0_G031": "呵呵……",
                "0_G032": "因为变强了，你可以对这方面期待一下……",
                "0_G033": "还有……我之前穿的那件外套，就不能卖出去吗……？",
                "0_G034": "不，因为各种原因，开销有点大……"
            }
        },
        "0_G110": {
            "name": "レベルアップ 2",
            "text": {
                "0_G110": "呵呵……有些吃得太饱了……"
            }
        },
        "0_H010": {
            "name": "誕生日",
            "text": {
                "0_H010": "你的生日啊……",
                "0_H011": "呵呵……这不是挺好的嘛……",
                "0_H012": "即便诞生在这痛苦的世界里，你的幸福也是受到期待的……"
            }
        },
        "0_H020": {
            "name": "イベント開催中",
            "text": {
                "0_H020": "好像是活动哦，我的御主……",
                "0_H021": "呵呵……素材……"
            }
        },
        "0_H030": {
            "name": "会話 1",
            "text": {
                "0_H030": "收到出击的通知了……",
                "0_H031": "那就逃跑吧……",
                "0_H032": "呵呵……"
            }
        },
        "0_H040": {
            "name": "会話 2",
            "text": {
                "0_H040": "当然了……你是主人、是御主，也是这个世界的楔子……",
                "0_H041": "我当然会郑重相待……"
            }
        },
        "0_H050": {
            "name": "会話 3",
            "text": {
                "0_H050": "和御主的关系吗……",
                "0_H051": "呵呵……没有编辑的作家无法出书……没有作家的的编辑无法编书……",
                "0_H052": "就是那样的关系……",
                "0_H053": "也就是说……我本想说得巧妙一些的……结果我反而混乱了……"
            }
        },
        "0_H060": {
            "name": "好きなこと",
            "text": {
                "0_H060": "喜欢的事情吗……",
                "0_H061": "呵呵……当然……是编撰故事……",
                "0_H062": "还有吃意大利菜……",
                "0_H063": "呵呵……"
            }
        },
        "0_H070": {
            "name": "嫌いなこと",
            "text": {
                "0_H070": "讨厌的事情吗……",
                "0_H071": "呵呵……运动……战斗……和很多人一起聊天……不让我返回故乡的阴谋……放久变质的肉和蔬菜……",
                "0_H072": "讨厌的东西有很多……多到数不清……"
            }
        },
        "0_H080": {
            "name": "聖杯について",
            "text": {
                "0_H080": "最优先的是贝雅特丽齐……其次是返回意大利佛罗伦萨……",
                "0_H081": "另外……既然我不需要财富，也不用更多名声了……",
                "0_H082": "那就希望意大利在足球世界大赛上有精彩的表现……",
                "0_H083": "还有如果佛罗伦萨能变更好的话……"
            }
        },
        "0_H090": {
            "name": "絆Lv.1",
            "text": {
                "0_H090": "呵呵……你能看出来我今天心情不好吗……？"
            }
        },
        "0_H100": {
            "name": "絆Lv.2",
            "text": {
                "0_H100": "呵呵……你能看出来我今天心情不错吗……？"
            }
        },
        "0_H110": {
            "name": "絆Lv.3",
            "text": {
                "0_H110": "呵呵……",
                "0_H111": "你是不是已经发现我是作家从者中常见的有沟通问题的那类了呢……？"
            }
        },
        "0_H120": {
            "name": "絆Lv.4",
            "text": {
                "0_H120": "呵呵……",
                "0_H121": "今天心情特别好，就来聊聊贝雅特丽齐吧……",
                "0_H122": "她的外表，以及她的灵魂，究竟该从哪边开始说起呢……？",
                "0_H123": "另外自不用说，会说很久哦……"
            }
        },
        "0_H130": {
            "name": "絆Lv.5",
            "text": {
                "0_H130": "呵呵……",
                "0_H131": "非常感谢你愿意耐心陪我这个交流能力有点那个的从者……",
                "0_H132": "真的很了不起啊……",
                "0_H133": "和你在一起时，我也能放松地说话了……",
                "0_H134": "你该不会是贝雅特丽齐，或是圣人那类的存在……？",
                "0_H135": "……都不是？",
                "0_H136": "也就是说……你只是单纯很厉害吗……"
            }
        },
        "0_H1600": {
            "name": "絆Lv.4 (奏章Ⅳクリア以降)",
            "text": {
                "0_H1600": "没错。我就是那个特异点的犯人。哎呀……真的非常抱歉。只是一时鬼迷心窍…… 嘛，虽然是我做的，但之后基本就没再经手了。 活着真是抱歉。",
                "0_H1601": "",
                "0_H1602": "",
                "0_H1603": ""
            }
        },
        "0_H170": {
            "name": "会話 4",
            "text": {
                "0_H170": "……呵呵呵……没想到梅塔特隆·贞德也在啊……。那时真是给你们添了不少麻烦……。不过我们也相当困扰，所以算是扯平了……啊、是。关于特异点的事，我确实有在反省……不！是非常！非常深刻的反省……是的",
                "0_H171": "",
                "0_H172": "",
                "0_H173": "",
                "0_H174": "",
                "0_H175": ""
            }
        },
        "0_H180": {
            "name": "会話 5",
            "text": {
                "0_H180": "莫里亚蒂……不在吗。真遗憾。虽然我们相似之处不多，甚至可以说他是我最不擅长应付的类型，呵呵。但在那个特异点里，不知为何却格外合拍。无妨，迟早会再相逢的。即便不再相见，那段记忆也足够让我回味良久。呵呵。",
                "0_H181": "",
                "0_H182": "",
                "0_H183": "",
                "0_H184": "",
                "0_H185": "",
                "0_H186": ""
            }
        },
        "0_H1800": {
            "name": "絆Lv.5 (奏章Ⅳクリア以降)",
            "text": {
                "0_H1800": "对你而言，那得意之处如何？ 虽有悲伤之事，但也很快乐。 这样啊。 嗯，仅凭这一句话我便得救了。 啊，所以为了你能迎来幸福结局，我愿奉献一切。 呵呵。",
                "0_H1801": "",
                "0_H1802": "",
                "0_H1803": "",
                "0_H1804": ""
            }
        },
        "0_H190": {
            "name": "会話 6",
            "text": {
                "0_H190": "呵呵……没想到莉莉丝也在……这边大家都很和睦哦？咦？你说“自己跟谁都能处得来，是个现充”？唔……这个嘛，嗯，我倒是不否认啦……不过是不是有个天敌唯独对你例外呢？",
                "0_H191": "",
                "0_H192": "",
                "0_H193": "",
                "0_H194": ""
            }
        },
        "0_I010": {
            "name": "CBC2025 彼の名はダンテ \n～ホテル・デノヴォのコンシェルジュ～ 1",
            "text": {
                "0_I010": "呵呵……欢迎光临酒店的纪念品商店……",
                "0_I011": "这里还有本地特产，咖喱味种火哦……"
            }
        },
        "0_I020": {
            "name": "CBC2025 彼の名はダンテ \n～ホテル・デノヴォのコンシェルジュ～ 2",
            "text": {
                "0_I020": "呵呵……欢迎光临……",
                "0_I021": "我是就算浮现出意味深长的笑容，也没什么特别意义的但丁……"
            }
        },
        "0_I030": {
            "name": "CBC2025 彼の名はダンテ \n～ホテル・デノヴォのコンシェルジュ～ 3",
            "text": {
                "0_I030": "呵呵……是要交换吧。",
                "0_I031": "……那么，请收下用多余的圣杯之滴制作的圣杯眼药水作为赠品吧……",
                "0_I032": "抱歉，就是普通的眼药水……"
            }
        },
        "0_I040": {
            "name": "CBC2025 彼の名はダンテ \n～ホテル・デノヴォのコンシェルジュ～ 4",
            "text": {
                "0_I040": "呵呵……那请收下这个……",
                "0_I041": "呵呵……"
            }
        },
        "0_I050": {
            "name": "CBC2025 彼の名はダンテ \n～ホテル・デノヴォのコンシェルジュ～ 5",
            "text": {
                "0_I050": "好嘞，意面一份！",
                "0_I051": "……不，我只是心想如果突然大叫你会不会吓一跳……"
            }
        },
        "0_I060": {
            "name": "CBC2025 彼の名はダンテ \n～ホテル・デノヴォのコンシェルジュ～ 6",
            "text": {
                "0_I060": "呵呵……终于结束了呢……",
                "0_I061": "有没有忘记交换……？"
            }
        },
        "0_I070": {
            "name": "CBC2025 彼の名はダンテ \n～ホテル・デノヴォのコンシェルジュ～ 7",
            "text": {
                "0_I070": "忘东西了吗……？",
                "0_I071": "呵呵……慢慢找吧……",
                "0_I072": "反正酒店也要暂时停业了……"
            }
        },
        "0_I1010": {
            "name": "CBC2025 彼の名はダンテ \n～ホテル・デノヴォのコンシェルジュ～ 8",
            "text": {
                "0_I1010": "呵呵……这边是特殊的店……",
                "0_I1011": "不，并不会供应酒之类的……"
            }
        },
        "0_I1020": {
            "name": "CBC2025 彼の名はダンテ \n～ホテル・デノヴォのコンシェルジュ～ 9",
            "text": {
                "0_I1020": "欢迎光临～……"
            }
        },
        "0_I1030": {
            "name": "CBC2025 彼の名はダンテ \n～ホテル・デノヴォのコンシェルジュ～ 10",
            "text": {
                "0_I1030": "原来如此，是要交换吧……",
                "0_I1031": "那么，请慢慢挑……"
            }
        },
        "0_I1040": {
            "name": "CBC2025 彼の名はダンテ \n～ホテル・デノヴォのコンシェルジュ～ 11",
            "text": {
                "0_I1040": "呵呵……这边的商店也要关门了……",
                "0_I1041": "也就是说……我要成为无业游民了呢……"
            }
        },
        "0_I1050": {
            "name": "CBC2025 彼の名はダンテ \n～ホテル・デノヴォのコンシェルジュ～ 12",
            "text": {
                "0_I1050": "呵呵……一定要仔细做好最终检查哦……",
                "0_I1051": "一旦不小心忘记交换，可就惨不忍睹了哦……"
            }
        },
        "0_S010": {
            "name": "召喚",
            "text": {
                "0_S010": "召唤……召唤？",
                "0_S011": "呵呵……竟然召唤了我……",
                "0_S012": "我名为但丁·阿利吉耶里……",
                "0_S013": "不必多说，乃是神曲的作者……",
                "0_S014": "作为身披角色者，也是神曲的主角……",
                "0_S015": "呵呵……也就是说……",
                "0_S016": "今后还请多多关照……"
            }
        },
        "2_B010": {
            "name": "アタック 1",
            "text": {
                "2_B010": "嘿！"
            }
        },
        "2_B020": {
            "name": "アタック 2",
            "text": {
                "2_B020": "哦—！"
            }
        },
        "2_B030": {
            "name": "アタック 3",
            "text": {
                "2_B030": "吃这招！"
            }
        },
        "2_B040": {
            "name": "エクストラアタック 1",
            "text": {
                "2_B040": "这就是上天的惩罚！"
            }
        },
        "2_B050": {
            "name": "宝具 1",
            "text": {
                "2_B050": "被诅咒被诅咒被诅咒！",
                "2_B051": "我的魔性唤醒了这扇门！",
                "2_B052": "也就是地狱、地狱、地狱！　如果无法承受这种绝望，就看不到明天！",
                "2_B053": "来吧，让我们一同前往地狱吧！　走吧走吧走吧！"
            }
        },
        "2_B080": {
            "name": "スキル 1",
            "text": {
                "2_B080": "好吧！"
            }
        },
        "2_B090": {
            "name": "スキル 2",
            "text": {
                "2_B090": "可以！"
            }
        },
        "2_B100": {
            "name": "開始 1",
            "text": {
                "2_B100": "没问题，御主。是要出击了吧？"
            }
        },
        "2_B110": {
            "name": "開始 2",
            "text": {
                "2_B110": "好吧。由我但丁·阿利吉耶里当你的对手吧！"
            }
        },
        "2_B120": {
            "name": "勝利 1",
            "text": {
                "2_B120": "呵呵……这就是胜利的方程式！ ……好像不够帅气呢……准确地说和我的印象有些偏差……毕竟我是作家嘛……"
            }
        },
        "2_B130": {
            "name": "勝利 2",
            "text": {
                "2_B130": "没事，如果要去地狱的话，我可以给你配一本导览手册。 给，这是我的著作。"
            }
        },
        "2_B140": {
            "name": "ダメージ 2",
            "text": {
                "2_B140": "还没完！"
            }
        },
        "2_B150": {
            "name": "ダメージ 1",
            "text": {
                "2_B150": "咕——！"
            }
        },
        "2_B160": {
            "name": "戦闘不能 1",
            "text": {
                "2_B160": "不承认……我不承认……呵呵……我会无数次从地狱中……！"
            }
        },
        "2_B170": {
            "name": "戦闘不能 2",
            "text": {
                "2_B170": "呵呵……贝雅特丽齐……这次也能见到你吗……？"
            }
        },
        "2_B180": {
            "name": "コマンドカード 1",
            "text": {
                "2_B180": "交给我吧。"
            }
        },
        "2_B190": {
            "name": "コマンドカード 2",
            "text": {
                "2_B190": "这是你的选择。"
            }
        },
        "2_B200": {
            "name": "コマンドカード 3",
            "text": {
                "2_B200": "嗯。"
            }
        },
        "2_B2010": {
            "name": "アタック 10",
            "text": {
                "2_B2010": "降下弹雨吧！"
            }
        },
        "2_B2020": {
            "name": "アタック 11",
            "text": {
                "2_B2020": "真放肆！"
            }
        },
        "2_B2030": {
            "name": "アタック 12",
            "text": {
                "2_B2030": "真有干劲呢！"
            }
        },
        "2_B210": {
            "name": "宝具カード 1",
            "text": {
                "2_B210": "宝具吗，好！"
            }
        },
        "2_B220": {
            "name": "宝具カード 2",
            "text": {
                "2_B220": "要开启大门了！"
            }
        },
        "2_B2410": {
            "name": "アタック 13",
            "text": {
                "2_B2410": "大突击！"
            }
        },
        "2_B2420": {
            "name": "アタック 14",
            "text": {
                "2_B2420": "原稿还没写完！"
            }
        },
        "2_B2430": {
            "name": "アタック 15",
            "text": {
                "2_B2430": "上面！"
            }
        },
        "2_B2810": {
            "name": "アタック 16",
            "text": {
                "2_B2810": "更上一层！"
            }
        },
        "2_B2820": {
            "name": "アタック 17",
            "text": {
                "2_B2820": "你还不明白吗！？"
            }
        },
        "2_B410": {
            "name": "アタック 4",
            "text": {
                "2_B410": "遁入雾中。"
            }
        },
        "2_B420": {
            "name": "アタック 5",
            "text": {
                "2_B420": "1(uno)、2(due)、3（tre）！"
            }
        },
        "2_B430": {
            "name": "アタック 6",
            "text": {
                "2_B430": "奔牛节！"
            }
        },
        "2_B440": {
            "name": "エクストラアタック 2",
            "text": {
                "2_B440": "没完没完没完没完没完！"
            }
        },
        "2_B480": {
            "name": "スキル 3",
            "text": {
                "2_B480": "出来吧，摆渡人。"
            }
        },
        "2_B490": {
            "name": "スキル 4",
            "text": {
                "2_B490": "地狱的居民啊！"
            }
        },
        "2_B500": {
            "name": "開始 3",
            "text": {
                "2_B500": "呵呵……你说我有点亢奋？　那当然！"
            }
        },
        "2_B520": {
            "name": "勝利 3",
            "text": {
                "2_B520": "呵呵……要升上天堂吗。 既然如此，记得向贝雅特丽齐打个招呼…… 不，还是不用了。"
            }
        },
        "2_B540": {
            "name": "ダメージ 4",
            "text": {
                "2_B540": "好痛啊。"
            }
        },
        "2_B550": {
            "name": "ダメージ 3",
            "text": {
                "2_B550": "可恶……这是……！"
            }
        },
        "2_B560": {
            "name": "戦闘不能 3",
            "text": {
                "2_B560": "御主……我……已经，不行了吗……？"
            }
        },
        "2_B800": {
            "name": "宝具 2",
            "text": {
                "2_B800": "啊啊，至高天消失，剩下的唯有地狱门！",
                "2_B801": "不要看！　不要看！　虫子涌入脑中，地狱的游行即将开始！",
                "2_B802": "凡入此门者，必当捐弃一切希望！"
            }
        },
        "2_B810": {
            "name": "宝具 3",
            "text": {
                "2_B810": "呜呜，头好痛……偏头痛……！",
                "2_B811": "不好，还被付与了眩晕、作呕、寒战！　大家快跑！　地狱将满溢此世！",
                "2_B812": "这是宿醉与睡眠不足……！",
                "2_B813": "没有希望！"
            }
        },
        "2_B820": {
            "name": "宝具 4",
            "text": {
                "2_B820": "呜呜，头好痛……偏头痛……！",
                "2_B821": "不好，还被付与了眩晕、作呕、寒战！　大家快跑！　地狱将满溢此世！",
                "2_B822": "这是宿醉与睡眠不足……！",
                "2_B823": "没有希望！"
            }
        },
        "2_B840": {
            "name": "エクストラアタック 3",
            "text": {
                "2_B840": "至高天，Empireo！"
            }
        },
        "2_B880": {
            "name": "スキル 5",
            "text": {
                "2_B880": "高唱凯歌吧。"
            }
        },
        "2_B910": {
            "name": "アタック 7",
            "text": {
                "2_B910": "断割吧！"
            }
        },
        "2_B920": {
            "name": "アタック 8",
            "text": {
                "2_B920": "妖鸟怪异！"
            }
        },
        "2_B930": {
            "name": "アタック 9",
            "text": {
                "2_B930": "当然是飨宴！"
            }
        },
        "2_G010": {
            "name": "レベルアップ 1",
            "text": {
                "2_G010": "呵呵……美妙的升级。"
            }
        },
        "2_G040": {
            "name": "霊基再臨 1",
            "text": {
                "2_G040": "呵呵……而这，就是我的最终形态。",
                "2_G041": "我曾经穿着这身服装穿过了地狱、炼狱，以及天堂！",
                "2_G042": "……当然并非如此，只是觉得如果有第二次巡游地狱的机会，大概会穿成这样去吧，这身打扮就是建立在这种念头上的……",
                "2_G043": "总之请多关照。",
                "2_G044": "愿主的庇佑与贝雅特丽齐的祝福伴你左右。"
            }
        },
        "2_G050": {
            "name": "霊基再臨 2",
            "text": {
                "2_G050": "呵呵……我是来迎接你的啊！　没错，前往天堂！",
                "2_G051": "呵呵……天堂是个相当不错的地方哦……",
                "2_G052": "虽然你似乎收到了好几份邀请，但这次就去最经典的那个地方吧……",
                "2_G053": "没有痛苦的安宁。你难道不想去一趟吗？",
                "2_G054": "……你觉得现在决定有些为时尚早？",
                "2_G055": "原来如此，确实……",
                "2_G056": "那就留待下次机会吧……于是我再度折返……",
                "2_G057": "呼哇～……"
            }
        },
        "2_G110": {
            "name": "レベルアップ 2",
            "text": {
                "2_G110": "御主，何不偶尔换个口味呢？"
            }
        },
        "2_H010": {
            "name": "誕生日",
            "text": {
                "2_H010": "生日吗……",
                "2_H011": "好，趁此难得的机会送你点什么吧。",
                "2_H012": "比方说，通往天堂的车票作为纪念如何？",
                "2_H013": "只不过，应该要过很久……才能用上吧，呵呵。"
            }
        },
        "2_H020": {
            "name": "イベント開催中",
            "text": {
                "2_H020": "活动……",
                "2_H021": "来吧，把最顶级的素材献给你！"
            }
        },
        "2_H030": {
            "name": "会話 1",
            "text": {
                "2_H030": "呵呵……全军出击。",
                "2_H031": "去外面吧……！"
            }
        },
        "2_H040": {
            "name": "会話 2",
            "text": {
                "2_H040": "主从吗……",
                "2_H041": "呵呵，我可是像云彩一样自由的男人……不属于任何人的侍从……！",
                "2_H042": "……毕竟我不是那种类型的从者，所以就是普通的主从吧，嗯。"
            }
        },
        "2_H050": {
            "name": "会話 3",
            "text": {
                "2_H050": "和御主的关系吗……",
                "2_H051": "真是复杂的关系呢……",
                "2_H052": "要不要为此新写一本书呢？"
            }
        },
        "2_H060": {
            "name": "好きなこと",
            "text": {
                "2_H060": "喜欢的事情……",
                "2_H061": "呵呵，思索（sisaku）……！",
                "2_H062": "不是诗作（sisaku），而是思考的那个思索（sisaku）……！",
                "2_H063": "……我可不是没有兴趣爱好的哦？"
            }
        },
        "2_H070": {
            "name": "嫌いなこと",
            "text": {
                "2_H070": "讨厌的事情吗……",
                "2_H071": "大概是回不了故乡吧？",
                "2_H072": "啊，说得有点太认真了。",
                "2_H073": "下次我会准备个更调皮的答案！"
            }
        },
        "2_H080": {
            "name": "聖杯について",
            "text": {
                "2_H080": "圣杯吗……",
                "2_H081": "当然想要了。毕竟……",
                "2_H082": "哎哟，不行不行。"
            }
        },
        "2_H200": {
            "name": "会話 4",
            "text": {
                "2_H200": "噢噢，佛罗伦萨的至宝，莱昂纳多·达·芬奇！",
                "2_H201": "我家乡的大天才！",
                "2_H202": "作为前辈，我倍感自豪。",
                "2_H203": "……不知道他对合作有没有兴趣？"
            }
        },
        "2_H20090": {
            "name": "絆Lv.1",
            "text": {
                "2_H20090": "哎呀，是御主啊。",
                "2_H20091": "竟然优先再临，而没有和我建立牵绊，太不像话了吧？"
            }
        },
        "2_H20100": {
            "name": "絆Lv.2",
            "text": {
                "2_H20100": "呵呵……你找我但丁·阿利吉耶里有什么事吗？"
            }
        },
        "2_H20110": {
            "name": "絆Lv.3",
            "text": {
                "2_H20110": "作为战力的我应该算马马虎虎吧。",
                "2_H20111": "不过严格说来，我应该算召唤型的从者。",
                "2_H20112": "我会把在地狱里遇到的那些家伙全都叫出来。"
            }
        },
        "2_H20120": {
            "name": "絆Lv.4",
            "text": {
                "2_H20120": "呵呵……御主，要我的签名吗？",
                "2_H20121": "不需要？",
                "2_H20122": "那真是太遗憾了。",
                "2_H20123": "那么……需要我的著作吗？",
                "2_H20124": "噢噢，想要啊，那太好了。",
                "2_H20125": "……不过我手头只有意大利语版的，可以吗？"
            }
        },
        "2_H20130": {
            "name": "絆Lv.5",
            "text": {
                "2_H20130": "御主，你的故事就快迎来终结了。",
                "2_H20131": "届时，你会为了逝去的时光而哀叹吗？　会不知所措吗？　还是会向着明天继续迈步呢？",
                "2_H20132": "没事，哪种都可以。",
                "2_H20133": "因为，没有任何一个是正确的，或是错误的。"
            }
        },
        "2_H210": {
            "name": "会話 5",
            "text": {
                "2_H210": "安徒生？　作家的那位吗？",
                "2_H211": "……原来如此，只要变成小孩子，就不用被截稿日压迫了。",
                "2_H212": "真是跨时代的点子啊……！",
                "2_H213": "哎，即便如此还会被截稿日压迫？　太过分了吧？"
            }
        },
        "2_H220": {
            "name": "会話 6",
            "text": {
                "2_H220": "什么，威廉·莎士比亚……",
                "2_H221": "好开朗……好开朗……",
                "2_H222": "明明写了麦克白和罗朱之类的作品，却好开朗……",
                "2_H223": "在我的印象里，他应该是更阴郁一点的文豪……",
                "2_H224": "哎，截稿日快到时基本都会变得阴郁？",
                "2_H225": "呵呵，那就好！",
                "2_H226": "……不，也不好呢……"
            }
        },
        "2_H230": {
            "name": "会話 7",
            "text": {
                "2_H230": "梵高……",
                "2_H231": "降临者中与外神相关的从者吗……",
                "2_H232": "呵呵……或许能请她描绘全新而前所未见的地狱呢。",
                "2_H233": "她能不能画十二幅左右的连作呢？",
                "2_H234": "哎，感觉会把人画到精神崩溃所以不行？",
                "2_H235": "……好像的确没法保证……不让人崩溃呢……"
            }
        },
        "2_H240": {
            "name": "会話 8",
            "text": {
                "2_H240": "北斋……职业是降临者吗。",
                "2_H241": "但更重要的是她出身远东。",
                "2_H242": "如果从她的视角出发，说不定能描绘出全新的贝雅特丽齐……！",
                "2_H243": "哎，插画经常不按要求的来？　比方说能把这位老师换成为朝吗？",
                "2_H244": "呵呵……不行……！",
                "2_H245": "巡游地狱时有一台机器人跟着未免有些……！",
                "2_H246": "不过反过来想想好像也可以……？"
            }
        }
    },
    "ChrVoice_ids": [
        "2801000"
    ]
}