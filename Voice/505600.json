{
    "id": 505600,
    "name": "",
    "voices": {
        "0_M010": {
            "name": "Fate/strange Fakeコラボイベント 6",
            "text": {
                "0_M010": "不错嘛，给你个礼物吧。"
            }
        },
        "0_M020": {
            "name": "Fate/strange Fakeコラボイベント 7",
            "text": {
                "0_M020": "我有准备过这么好的东西吗？虽然亏本了，不过算啦。",
                "0_M021": ""
            }
        },
        "0_M030": {
            "name": "Fate/strange Fakeコラボイベント 8",
            "text": {
                "0_M030": "干得漂亮。作为回礼，送你一些新任务吧。",
                "0_M031": ""
            }
        },
        "0_M040": {
            "name": "Fate/strange Fakeコラボイベント 9",
            "text": {
                "0_M040": "那么，让黑暗计划再向前推进一个阶段吧。"
            }
        },
        "0_N010": {
            "name": "Fate/strange Fakeコラボイベント 1",
            "text": {
                "0_N010": "圣诞快乐。来吧来吧，惯例的无限池。不是吗？也不是圣诞节？真是的。",
                "0_N011": "",
                "0_N012": "",
                "0_N013": ""
            }
        },
        "0_N020": {
            "name": "Fate/strange Fakeコラボイベント 2",
            "text": {
                "0_N020": "完成任务的时候，考虑一下效率会比较轻松哦。比如按什么顺序去哪些地方转转最省事。偷懒可是很重要的。放轻松去干吧。",
                "0_N021": "",
                "0_N022": "",
                "0_N023": ""
            }
        },
        "0_N030": {
            "name": "Fate/strange Fakeコラボイベント 3",
            "text": {
                "0_N030": "我最喜欢看人类在欲望中起舞的瞬间了。嘛，所以只要你肯起舞，我就会给你相应的谢礼。比如QP或是素材之类的。这种双赢的关系很不错吧？",
                "0_N031": "",
                "0_N032": ""
            }
        },
        "0_N040": {
            "name": "Fate/strange Fakeコラボイベント 4",
            "text": {
                "0_N040": "哦，怎么了怎么了，完成了什么吗？来，让我看看，让我看看。",
                "0_N041": ""
            }
        },
        "0_N050": {
            "name": "Fate/strange Fakeコラボイベント 5",
            "text": {
                "0_N050": "信息播报。唯有世界的真理，即便是我的现实也无法欺骗。所以要好好确认清楚哦。毕竟这个世界上到处都是无法挽回的事情呢。",
                "0_N051": "",
                "0_N052": ""
            }
        }
    },
