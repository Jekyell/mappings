{
    "id": 9947700,
    "name": "Enemy 9947700",
    "voices": {
        "0_B010": {
            "name": "0_B010",
            "text": {
                "0_B010": "重税，能让身子变轻盈真是太好了呢。"
            },
            "raw_text": {
                "0_B010": "十世、身軽になって良かったな。"
            }
        },
        "0_B020": {
            "name": "0_B020",
            "text": {
                "0_B020": "这就是金钱，是税收的力量。"
            },
            "raw_text": {
                "0_B020": "これが金、税金の力だ。"
            }
        },
        "0_B030": {
            "name": "0_B030",
            "text": {
                "0_B030": "区区投石，余根本不在意。"
            },
            "raw_text": {
                "0_B030": "透析など気にもならん。"
            }
        },
        "0_B040": {
            "name": "0_B040",
            "text": {
                "0_B040": "愚蠢之辈，余连大地都不会施舍给你们。"
            },
            "raw_text": {
                "0_B040": "愚者どもめ、貴様らには大地すら与えん。"
            }
        },
        "0_B050": {
            "name": "0_B050",
            "text": {
                "0_B050": "为何能够相信？"
            },
            "raw_text": {
                "0_B050": "なぜ信じられる。"
            }
        },
        "0_B051": {
            "name": "0_B051",
            "text": {
                "0_B051": "相信今日所踏足的大地，明日依然会存在。"
            },
            "raw_text": {
                "0_B051": "今日踏みしめている大地が明日もそこにあると。"
            }
        },
        "0_B052": {
            "name": "0_B052",
            "text": {
                "0_B052": "相信什么光芒会包容你们之类的。"
            },
            "raw_text": {
                "0_B052": "光がお前たちを包み込むなどと。"
            }
        },
        "0_B053": {
            "name": "0_B053",
            "text": {
                "0_B053": "根本不存在什么安宁的明天。"
            },
            "raw_text": {
                "0_B053": "あんねえの明日などない。"
            }
        },
        "0_B054": {
            "name": "0_B054",
            "text": {
                "0_B054": "无论是身为平民的你们，还是身为王的余，甚至是神明。"
            },
            "raw_text": {
                "0_B054": "平民の貴様らにも大たる俺にも神々にさえもだ。"
            }
        },
        "0_B080": {
            "name": "0_B080",
            "text": {
                "0_B080": "民众皆为蝼蚁。"
            },
            "raw_text": {
                "0_B080": "民衆は虫けらだ。"
            }
        },
        "0_B090": {
            "name": "0_B090",
            "text": {
                "0_B090": "贵族也是蝼蚁。"
            },
            "raw_text": {
                "0_B090": "貴族も虫けらだ。"
            }
        },
        "0_B100": {
            "name": "0_B100",
            "text": {
                "0_B100": "真是群血气方刚的家伙。就那么喜欢互相残杀吗？"
            },
            "raw_text": {
                "0_B100": "血の気の多い奴らめ。そんなに殺し合いが好きか。"
            }
        },
        "0_B110": {
            "name": "0_B110",
            "text": {
                "0_B110": "随你们便。余也会随兴报复回去。"
            },
            "raw_text": {
                "0_B110": "好きにしろ。よも好きにやり返す。"
            }
        },
        "0_B120": {
            "name": "0_B120",
            "text": {
                "0_B120": "喂喂喂喂，我可是一步都没离开过王座啊。"
            },
            "raw_text": {
                "0_B120": "おいおいおいおい俺は玉座から動いてすらいないんだぞ。"
            }
        },
        "0_B130": {
            "name": "0_B130",
            "text": {
                "0_B130": "告诉我吧。输给被称作最低最恶之王的家伙，现在是什么心情？"
            },
            "raw_text": {
                "0_B130": "教えてくれよ。最低最悪と呼ばれた王に負けて、今どんな気分だ。"
            }
        },
        "0_B140": {
            "name": "0_B140",
            "text": {
                "0_B140": "啊啊。"
            },
            "raw_text": {
                "0_B140": "ああ。"
            }
        },
        "0_B150": {
            "name": "0_B150",
            "text": {
                "0_B150": "搞什么，那种乱七八糟的攻击。"
            },
            "raw_text": {
                "0_B150": "なんだよ、そのでたらめな攻撃は。"
            }
        },
        "0_B160": {
            "name": "0_B160",
            "text": {
                "0_B160": "哈哈，真是凄惨的临终吧。笑啊。"
            },
            "raw_text": {
                "0_B160": "ははっ惨めな最後だろう。笑えよ。"
            }
        },
        "0_B170": {
            "name": "0_B170",
            "text": {
                "0_B170": "这份痛苦我记住了。定要复仇。绝对要复仇。"
            },
            "raw_text": {
                "0_B170": "この痛みは覚えた。必ず復讐する。必ずだ。"
            }
        },
        "0_B180": {
            "name": "0_B180",
            "text": {
                "0_B180": "哼。"
            },
            "raw_text": {
                "0_B180": "ふん。"
            }
        },
        "0_B190": {
            "name": "0_B190",
            "text": {
                "0_B190": "还算凑合吧。"
            },
            "raw_text": {
                "0_B190": "まあまあか。"
            }
        },
        "0_B200": {
            "name": "0_B200",
            "text": {
                "0_B200": "知道了知道了。"
            },
            "raw_text": {
                "0_B200": "分かった分かった。"
            }
        },
        "0_B2010": {
            "name": "0_B2010",
            "text": {
                "0_B2010": "真是无礼。"
            },
            "raw_text": {
                "0_B2010": "無礼だな。"
            }
        },
        "0_B2020": {
            "name": "0_B2020",
            "text": {
                "0_B2020": "断头台？不需要呢。"
            },
            "raw_text": {
                "0_B2020": "ギロチン？いらないね。"
            }
        },
        "0_B2030": {
            "name": "0_B2030",
            "text": {
                "0_B2030": "不需要处刑人呢。"
            },
            "raw_text": {
                "0_B2030": "処刑人いらないね。"
            }
        },
        "0_B210": {
            "name": "0_B210",
            "text": {
                "0_B210": "好吧。余兴致上来了。"
            },
            "raw_text": {
                "0_B210": "いいだろう。今日が乗った。"
            }
        },
        "0_B2410": {
            "name": "0_B2410",
            "text": {
                "0_B2410": "哈哈，起舞吧，起舞吧。"
            },
            "raw_text": {
                "0_B2410": "ハハ、踊れ踊れ。"
            }
        },
        "0_B2420": {
            "name": "0_B2420",
            "text": {
                "0_B2420": "这是赏赐，收下吧。"
            },
            "raw_text": {
                "0_B2420": "褒美だ受け取れ。"
            }
        },
        "0_B410": {
            "name": "0_B410",
            "text": {
                "0_B410": "在那儿会被卷进来的哦。"
            },
            "raw_text": {
                "0_B410": "そこ巻き込まれるぞ。"
            }
        },
        "0_B420": {
            "name": "0_B420",
            "text": {
                "0_B420": "贯穿吧，哈德洛。"
            },
            "raw_text": {
                "0_B420": "貫け、ハーゼロ。"
            }
        },
        "0_B430": {
            "name": "0_B430",
            "text": {
                "0_B430": "哼，相当痛啊。"
            },
            "raw_text": {
                "0_B430": "ふん、かなり痛いぞ。"
            }
        },
        "0_B440": {
            "name": "0_B440",
            "text": {
                "0_B440": "征税了。你们的土地归余了。"
            },
            "raw_text": {
                "0_B440": "徴税だ。貴様らの土地をもらう。"
            }
        },
        "0_B480": {
            "name": "0_B480",
            "text": {
                "0_B480": "我吗？我是无始无终的诱饵。"
            },
            "raw_text": {
                "0_B480": "俺か。無始無終の餌さだ。"
            }
        },
        "0_B490": {
            "name": "0_B490",
            "text": {
                "0_B490": "让你见识见识诱饵的享受。"
            },
            "raw_text": {
                "0_B490": "餌の教授を見せてやる。"
            }
        },
        "0_B500": {
            "name": "0_B500",
            "text": {
                "0_B500": "真是群血气方刚的家伙。就那么喜欢互相残杀吗？"
            },
            "raw_text": {
                "0_B500": "血の気の多い奴らめ。そんなに殺し合いが好きか。"
            }
        },
        "0_B510": {
            "name": "0_B510",
            "text": {
                "0_B510": "随你们便。余也会随兴报复回去。"
            },
            "raw_text": {
                "0_B510": "好きにしろ。よも好きにやり返す。"
            }
        },
        "0_B530": {
            "name": "0_B530",
            "text": {
                "0_B530": "兄长能做到的事，余没有做不到的。"
            },
            "raw_text": {
                "0_B530": "兄上にできて世にできぬことなどない。"
            }
        },
        "0_B540": {
            "name": "0_B540",
            "text": {
                "0_B540": "住手。"
            },
            "raw_text": {
                "0_B540": "やめろ。"
            }
        },
        "0_B550": {
            "name": "0_B550",
            "text": {
                "0_B550": "骗人的吧，不该是这样的……"
            },
            "raw_text": {
                "0_B550": "嘘だ、こんなはずじゃ。"
            }
        },
        "0_B570": {
            "name": "0_B570",
            "text": {
                "0_B570": "无论如何都无法触及兄长吗……"
            },
            "raw_text": {
                "0_B570": "どうしても兄上に届かないのか。"
            }
        },
        "0_B840": {
            "name": "0_B840",
            "text": {
                "0_B840": "这是土地的污秽，尽情品味吧。"
            },
            "raw_text": {
                "0_B840": "土地の汚れだ存分に味わえ。"
            }
        },
        "0_B880": {
            "name": "0_B880",
            "text": {
                "0_B880": "想受伤吗？滚开。"
            },
            "raw_text": {
                "0_B880": "怪我したいのか離れろ。"
            }
        },
        "0_B890": {
            "name": "0_B890",
            "text": {
                "0_B890": "好啦，你们到底想干什么？"
            },
            "raw_text": {
                "0_B890": "はい、何がしたいんだお前ら。"
            }
        },
        "0_B910": {
            "name": "0_B910",
            "text": {
                "0_B910": "哈，跟得上吗？"
            },
            "raw_text": {
                "0_B910": "はっ、ついてこれるか。"
            }
        },
        "0_B920": {
            "name": "0_B920",
            "text": {
                "0_B920": "就陪你玩玩。由‘那家伙’来当你的对手。"
            },
            "raw_text": {
                "0_B920": "相手してやる。そいつがな。"
            }
        },
        "0_B930": {
            "name": "0_B930",
            "text": {
                "0_B930": "堂堂正正地，进行暗杀。"
            },
            "raw_text": {
                "0_B930": "正々堂々、闇討ちだ。"
            }
        }
    }
}