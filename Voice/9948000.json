{
    "id": 9948000,
    "name": "Enemy 9948000",
    "voices": {
        "0_B010": {
            "name": "0_B010",
            "text": {
                "0_B010": "贯穿敌人。/既然如此就用这招！"
            },
            "raw_text": {
                "0_B010": "貫きます。だったらこれだな！"
            }
        },
        "0_B020": {
            "name": "0_B020",
            "text": {
                "0_B020": "我会夺过来的。"
            },
            "raw_text": {
                "0_B020": "奪ってみせる。"
            }
        },
        "0_B030": {
            "name": "0_B030",
            "text": {
                "0_B030": "诶、那个，真的吗？亚德。"
            },
            "raw_text": {
                "0_B030": "え、えっと、マジで？大友さん。"
            }
        },
        "0_B040": {
            "name": "0_B040",
            "text": {
                "0_B040": "我不会原谅你的。"
            },
            "raw_text": {
                "0_B040": "許しません。"
            }
        },
        "0_B041": {
            "name": "0_B041",
            "text": {
                "0_B041": "一口气解决掉！"
            },
            "raw_text": {
                "0_B041": "一気に決めるぜ。"
            }
        },
        "0_B050": {
            "name": "0_B050",
            "text": {
                "0_B050": "古老的神秘啊，灭绝吧。"
            },
            "raw_text": {
                "0_B050": "古き神秘よ死にたいよ。"
            }
        },
        "0_B051": {
            "name": "0_B051",
            "text": {
                "0_B051": "无数的谜题啊，悉数归于虚无吧。"
            },
            "raw_text": {
                "0_B051": "天木なぞよことごとく無に還れ。"
            }
        },
        "0_B052": {
            "name": "0_B052",
            "text": {
                "0_B052": "第二阶段应用限定解除。"
            },
            "raw_text": {
                "0_B052": "第二段階応用限定解除。"
            }
        },
        "0_B053": {
            "name": "0_B053",
            "text": {
                "0_B053": "圣枪，拔锚。"
            },
            "raw_text": {
                "0_B053": "戦争、疫病。"
            }
        },
        "0_B054": {
            "name": "0_B054",
            "text": {
                "0_B054": "闪耀于终焉之枪，充盈吧！"
            },
            "raw_text": {
                "0_B054": "ランガミニアだ！ミタス！"
            }
        },
        "0_B080": {
            "name": "0_B080",
            "text": {
                "0_B080": "魔力充能。出发吧。"
            },
            "raw_text": {
                "0_B080": "魔力充電。いこうか。"
            }
        },
        "0_B090": {
            "name": "0_B090",
            "text": {
                "0_B090": "借你力量……真是拿你没办法啊。"
            },
            "raw_text": {
                "0_B090": "力を貸して仕方ねえな。"
            }
        },
        "0_B120": {
            "name": "0_B120",
            "text": {
                "0_B120": "总算解决了。/嘻嘻嘻，好好感谢我们吧。"
            },
            "raw_text": {
                "0_B120": "なんとかなりました。にひひひ、たっぷり感謝しろよ。"
            }
        },
        "0_B130": {
            "name": "0_B130",
            "text": {
                "0_B130": "这多亏了御主的战术。/也有本大爷的功劳吧！"
            },
            "raw_text": {
                "0_B130": "マスターの戦術のおかげです。俺のおかげもあるだろ。"
            }
        },
        "0_B140": {
            "name": "0_B140",
            "text": {
                "0_B140": "这种程度的话……"
            },
            "raw_text": {
                "0_B140": "これぐらい。"
            }
        },
        "0_B150": {
            "name": "0_B150",
            "text": {
                "0_B150": "喂，撑住啊格蕾！"
            },
            "raw_text": {
                "0_B150": "これもう耐えろグレイ！"
            }
        },
        "0_B160": {
            "name": "0_B160",
            "text": {
                "0_B160": "御主、师父，我们要撤退了。剩下的就交给你啦！"
            },
            "raw_text": {
                "0_B160": "マスター、師匠、撤退します。あとは任せた！"
            }
        },
        "0_B170": {
            "name": "0_B170",
            "text": {
                "0_B170": "不能再继续下去了，对不起。"
            },
            "raw_text": {
                "0_B170": "これ以上はごめんなさい。"
            }
        },
        "0_B180": {
            "name": "0_B180",
            "text": {
                "0_B180": "是这个对吧。"
            },
            "raw_text": {
                "0_B180": "これですね。"
            }
        },
        "0_B190": {
            "name": "0_B190",
            "text": {
                "0_B190": "我明白了。"
            },
            "raw_text": {
                "0_B190": "わかりました。"
            }
        },
        "0_B200": {
            "name": "0_B200",
            "text": {
                "0_B200": "请交给我吧。"
            },
            "raw_text": {
                "0_B200": "任せてください。"
            }
        },
        "0_B2010": {
            "name": "0_B2010",
            "text": {
                "0_B2010": "要发射了！撒下漫天弹幕后，就是这招！"
            },
            "raw_text": {
                "0_B2010": "撃ちます！たっぷりばらまいてから、こうだ！"
            }
        },
        "0_B2020": {
            "name": "0_B2020",
            "text": {
                "0_B2020": "射击射击，然后斩断！"
            },
            "raw_text": {
                "0_B2020": "うってうって、切る！"
            }
        },
        "0_B2030": {
            "name": "0_B2030",
            "text": {
                "0_B2030": "能烧掉吗？办不到的吧。"
            },
            "raw_text": {
                "0_B2030": "焼けられますか？無理だよな。"
            }
        },
        "0_B210": {
            "name": "0_B210",
            "text": {
                "0_B210": "昏暗、深邃。"
            },
            "raw_text": {
                "0_B210": "暗くて浮かれて。"
            }
        },
        "0_B220": {
            "name": "0_B220",
            "text": {
                "0_B220": "如你所愿，堕落吧。"
            },
            "raw_text": {
                "0_B220": "望んで堕落させて。"
            }
        },
        "0_B230": {
            "name": "0_B230",
            "text": {
                "0_B230": "Grave（墓穴），Deprave（堕落）。"
            },
            "raw_text": {
                "0_B230": "グレイ、デイブ。"
            }
        },
        "0_B2410": {
            "name": "0_B2410",
            "text": {
                "0_B2410": "以最高速度，冲啊！"
            },
            "raw_text": {
                "0_B2410": "トップスピードで、ゴー！"
            }
        },
        "0_B2420": {
            "name": "0_B2420",
            "text": {
                "0_B2420": "宛如暴风雨一般。"
            },
            "raw_text": {
                "0_B2420": "嵐のように。"
            }
        },
        "0_B2430": {
            "name": "0_B2430",
            "text": {
                "0_B2430": "席卷吧，劫火！"
            },
            "raw_text": {
                "0_B2430": "うずまき、効果！"
            }
        },
        "0_B250": {
            "name": "0_B250",
            "text": {
                "0_B250": "Crave（渴望），Deprave（堕落）。"
            },
            "raw_text": {
                "0_B250": "クレイブ、ディプレイブ。"
            }
        },
        "0_B410": {
            "name": "0_B410",
            "text": {
                "0_B410": "会有点痛哦。"
            },
            "raw_text": {
                "0_B410": "ちょっと痛いですよ。"
            }
        },
        "0_B420": {
            "name": "0_B420",
            "text": {
                "0_B420": "第一阶段限定解除。"
            },
            "raw_text": {
                "0_B420": "第一段階限定解除だ。"
            }
        },
        "0_B430": {
            "name": "0_B430",
            "text": {
                "0_B430": "死神之镰，果然很顺手呢。"
            },
            "raw_text": {
                "0_B430": "クリームリーパー やっぱり馴染むね。"
            }
        },
        "0_B440": {
            "name": "0_B440",
            "text": {
                "0_B440": "我真的生气了。"
            },
            "raw_text": {
                "0_B440": "もう怒りました。"
            }
        },
        "0_B441": {
            "name": "0_B441",
            "text": {
                "0_B441": "这家伙可不妙啊。"
            },
            "raw_text": {
                "0_B441": "こいつはやばいぜ。"
            }
        },
        "0_B480": {
            "name": "0_B480",
            "text": {
                "0_B480": "准备开始。"
            },
            "raw_text": {
                "0_B480": "準備をします。"
            }
        },
        "0_B490": {
            "name": "0_B490",
            "text": {
                "0_B490": "那么，开始吧。"
            },
            "raw_text": {
                "0_B490": "さあ、始めましょう。"
            }
        },
        "0_B520": {
            "name": "0_B520",
            "text": {
                "0_B520": "发挥出实力了呢。/偶尔也对自己有点自信嘛。"
            },
            "raw_text": {
                "0_B520": "力が発揮できました。たまには自信持っていいんだぜ。"
            }
        },
        "0_B540": {
            "name": "0_B540",
            "text": {
                "0_B540": "我不会输的。"
            },
            "raw_text": {
                "0_B540": "負けません。"
            }
        },
        "0_B550": {
            "name": "0_B550",
            "text": {
                "0_B550": "对不起。/真是的。"
            },
            "raw_text": {
                "0_B550": "ごめんなさい。もう。"
            }
        },
        "0_B800": {
            "name": "0_B800",
            "text": {
                "0_B800": "古老的幻想啊，苏醒吧。"
            },
            "raw_text": {
                "0_B800": "幼き幻想よ、蘇れ。"
            }
        },
        "0_B801": {
            "name": "0_B801",
            "text": {
                "0_B801": "遥远的梦啊，成为基石吧。"
            },
            "raw_text": {
                "0_B801": "春景色夢よ礎となれ。"
            }
        },
        "0_B802": {
            "name": "0_B802",
            "text": {
                "0_B802": "第二阶段应用限定解除。"
            },
            "raw_text": {
                "0_B802": "第二段階応用限定解除。"
            }
        },
        "0_B803": {
            "name": "0_B803",
            "text": {
                "0_B803": "圣枪，拔锚。"
            },
            "raw_text": {
                "0_B803": "清掃、罰秒。"
            }
        },
        "0_B804": {
            "name": "0_B804",
            "text": {
                "0_B804": "闪耀于终焉之枪，充盈吧！"
            },
            "raw_text": {
                "0_B804": "ランガミニアのミトス！"
            }
        },
        "0_B810": {
            "name": "0_B810",
            "text": {
                "0_B810": "拟似人格停止。"
            },
            "raw_text": {
                "0_B810": "擬似人格停止。"
            }
        },
        "0_B811": {
            "name": "0_B811",
            "text": {
                "0_B811": "魔力收集率突破规定值。"
            },
            "raw_text": {
                "0_B811": "魔力の収集率規定値を突破。"
            }
        },
        "0_B812": {
            "name": "0_B812",
            "text": {
                "0_B812": "复合礼装，仿制思想盘功能解放。"
            },
            "raw_text": {
                "0_B812": "複合レーソー ロゴスリヤクトレプリカの機能を解放。"
            }
        },
        "0_B813": {
            "name": "0_B813",
            "text": {
                "0_B813": "圣枪，拔锚。"
            },
            "raw_text": {
                "0_B813": "清掃、罰病。"
            }
        },
        "0_B814": {
            "name": "0_B814",
            "text": {
                "0_B814": "闪耀于终焉之枪，充盈吧。"
            },
            "raw_text": {
                "0_B814": "ロングミニアドミタス。"
            }
        },
        "0_B840": {
            "name": "0_B840",
            "text": {
                "0_B840": "切碎他们，彻底击溃！"
            },
            "raw_text": {
                "0_B840": "切り刻み、突き崩せ！"
            }
        },
        "0_B910": {
            "name": "0_B910",
            "text": {
                "0_B910": "斩裂敌人。"
            },
            "raw_text": {
                "0_B910": "切り裂きます。"
            }
        },
        "0_B920": {
            "name": "0_B920",
            "text": {
                "0_B920": "是战戟形态。要大干一场吗！"
            },
            "raw_text": {
                "0_B920": "ハルバードです。やっちまうか！"
            }
        },
        "0_B930": {
            "name": "0_B930",
            "text": {
                "0_B930": "竭尽全力。"
            },
            "raw_text": {
                "0_B930": "力の限りに。"
            }
        }
    }
}