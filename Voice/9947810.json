{
    "id": 9947810,
    "name": "Enemy 9947810",
    "voices": {
        "0_B010": {
            "name": "0_B010",
            "text": {
                "0_B010": "哈。"
            },
            "raw_text": {
                "0_B010": "はっ。"
            }
        },
        "0_B020": {
            "name": "0_B020",
            "text": {
                "0_B020": "喝。"
            },
            "raw_text": {
                "0_B020": "せっ。"
            }
        },
        "0_B030": {
            "name": "0_B030",
            "text": {
                "0_B030": "真是的。"
            },
            "raw_text": {
                "0_B030": "まったく。"
            }
        },
        "0_B050": {
            "name": "0_B050",
            "text": {
                "0_B050": "过去并非不可动摇，而是由吾之权能所支配之物。"
            },
            "raw_text": {
                "0_B050": "過去は不動にあらず我が権能によって支配するもの。"
            }
        },
        "0_B051": {
            "name": "0_B051",
            "text": {
                "0_B051": "汝已败北，坠落于地。"
            },
            "raw_text": {
                "0_B051": "汝は敗北し地に堕ちた。"
            }
        },
        "0_B052": {
            "name": "0_B052",
            "text": {
                "0_B052": "乌尔扎·斯拉扎·佛恩。"
            },
            "raw_text": {
                "0_B052": "ウルザルスラズルフォルン。"
            }
        },
        "0_B053": {
            "name": "0_B053",
            "text": {
                "0_B053": "那正是汝之命运。"
            },
            "raw_text": {
                "0_B053": "それこそが汝の運命であったのです。"
            }
        },
        "0_B080": {
            "name": "0_B080",
            "text": {
                "0_B080": "不知您是否享用了呢。"
            },
            "raw_text": {
                "0_B080": "召し上がったかしら。"
            }
        },
        "0_B090": {
            "name": "0_B090",
            "text": {
                "0_B090": "汝之过去已定。"
            },
            "raw_text": {
                "0_B090": "汝の過去が決まりました。"
            }
        },
        "0_B140": {
            "name": "0_B140",
            "text": {
                "0_B140": "徒劳。"
            },
            "raw_text": {
                "0_B140": "無駄。"
            }
        },
        "0_B150": {
            "name": "0_B150",
            "text": {
                "0_B150": "这是……"
            },
            "raw_text": {
                "0_B150": "これは。"
            }
        },
        "0_B160": {
            "name": "0_B160",
            "text": {
                "0_B160": "时间不会倒流，不会倒流的哦。"
            },
            "raw_text": {
                "0_B160": "時間が戻らない戻らないの。"
            }
        },
        "0_B170": {
            "name": "0_B170",
            "text": {
                "0_B170": "这也是注定好的呢。"
            },
            "raw_text": {
                "0_B170": "これも決まっていたことね。"
            }
        },
        "0_B2010": {
            "name": "0_B2010",
            "text": {
                "0_B2010": "贯穿了。"
            },
            "raw_text": {
                "0_B2010": "貫きました。"
            }
        },
        "0_B2020": {
            "name": "0_B2020",
            "text": {
                "0_B2020": "迪里扬光束。"
            },
            "raw_text": {
                "0_B2020": "ディリヤンビーム。"
            }
        },
        "0_B2030": {
            "name": "0_B2030",
            "text": {
                "0_B2030": "如波涛般。"
            },
            "raw_text": {
                "0_B2030": "波涛のように。"
            }
        },
        "0_B2410": {
            "name": "0_B2410",
            "text": {
                "0_B2410": "我可是把您揍飞了哦。"
            },
            "raw_text": {
                "0_B2410": "殴り飛ばしましたわ。"
            }
        },
        "0_B2420": {
            "name": "0_B2420",
            "text": {
                "0_B2420": "退下。"
            },
            "raw_text": {
                "0_B2420": "控えよ。"
            }
        },
        "0_B2430": {
            "name": "0_B2430",
            "text": {
                "0_B2430": "这是命运。"
            },
            "raw_text": {
                "0_B2430": "運命でした。"
            }
        },
        "0_B2810": {
            "name": "0_B2810",
            "text": {
                "0_B2810": "解体。"
            },
            "raw_text": {
                "0_B2810": "解体。"
            }
        },
        "0_B2820": {
            "name": "0_B2820",
            "text": {
                "0_B2820": "分离作业。"
            },
            "raw_text": {
                "0_B2820": "分離作業。"
            }
        },
        "0_B2830": {
            "name": "0_B2830",
            "text": {
                "0_B2830": "真是悲哀的事。"
            },
            "raw_text": {
                "0_B2830": "悲しきことです。"
            }
        },
        "0_B3010": {
            "name": "0_B3010",
            "text": {
                "0_B3010": "原来是在那里。"
            },
            "raw_text": {
                "0_B3010": "そこでした。"
            }
        },
        "0_B410": {
            "name": "0_B410",
            "text": {
                "0_B410": "被贯穿吧。"
            },
            "raw_text": {
                "0_B410": "うがたれよ。"
            }
        },
        "0_B420": {
            "name": "0_B420",
            "text": {
                "0_B420": "愚者之雨。"
            },
            "raw_text": {
                "0_B420": "愚者の雨。"
            }
        },
        "0_B430": {
            "name": "0_B430",
            "text": {
                "0_B430": "开始运转了呢。"
            },
            "raw_text": {
                "0_B430": "回りましたね。"
            }
        },
        "0_B480": {
            "name": "0_B480",
            "text": {
                "0_B480": "真是有趣呢。"
            },
            "raw_text": {
                "0_B480": "おかしかったわ。"
            }
        },
        "0_B490": {
            "name": "0_B490",
            "text": {
                "0_B490": "你很有趣呢。"
            },
            "raw_text": {
                "0_B490": "面白かったわね、あなた。"
            }
        },
        "0_B540": {
            "name": "0_B540",
            "text": {
                "0_B540": "唔。"
            },
            "raw_text": {
                "0_B540": "くっ。"
            }
        },
        "0_B550": {
            "name": "0_B550",
            "text": {
                "0_B550": "住手。"
            },
            "raw_text": {
                "0_B550": "やめなさい。"
            }
        },
        "0_B570": {
            "name": "0_B570",
            "text": {
                "0_B570": "这可不算败北哦。"
            },
            "raw_text": {
                "0_B570": "敗北ではありませんでしたよ。"
            }
        },
        "0_B800": {
            "name": "0_B800",
            "text": {
                "0_B800": "终焉已然开始。线头散开，过去动摇。"
            },
            "raw_text": {
                "0_B800": "終焉を開始しました糸はほつれ過去は揺らぐ。"
            }
        },
        "0_B801": {
            "name": "0_B801",
            "text": {
                "0_B801": "时间倒流吧，汝曾是如此美丽。"
            },
            "raw_text": {
                "0_B801": "時を巻き戻れ汝はかつて美しかった。"
            }
        },
        "0_B802": {
            "name": "0_B802",
            "text": {
                "0_B802": "乌尔扎·斯拉茨·佛恩。"
            },
            "raw_text": {
                "0_B802": "ウルザルスラツルフォルン。"
            }
        },
        "0_B803": {
            "name": "0_B803",
            "text": {
                "0_B803": "肃然接受这命运吧。"
            },
            "raw_text": {
                "0_B803": "この運命を粛々と受け入れよ。"
            }
        },
        "0_B910": {
            "name": "0_B910",
            "text": {
                "0_B910": "历代。"
            },
            "raw_text": {
                "0_B910": "歴代。"
            }
        },
        "0_B920": {
            "name": "0_B920",
            "text": {
                "0_B920": "倾泻而下了哦。"
            },
            "raw_text": {
                "0_B920": "降り注ぎましたよ。"
            }
        },
        "0_B930": {
            "name": "0_B930",
            "text": {
                "0_B930": "是温柔的雨。"
            },
            "raw_text": {
                "0_B930": "優しい雨です。"
            }
        }
    }
}