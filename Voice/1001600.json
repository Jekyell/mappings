        "2_H160": {
            "name": "会話 4",
            "text": {
                "2_H160": "你们，也是，兽……？"
            },
            "raw_text": {
                "2_H160": "あなたたちも獣？"
            }
        },
        "2_H180": {
            "name": "会話 5",
            "text": {
                "2_H180": "呜呜……",
                "2_H181": "老人……",
                "2_H182": "害怕……"
            },
            "raw_text": {
                "2_H180": "ああ、おっきな、怖い。",
                "2_H181": "",
                "2_H182": ""
            }
        },
        "2_H190": {
            "name": "会話 6",
            "text": {
                "2_H190": "恩奇都……？",
                "2_H191": "是，这样……",
                "2_H192": "你，是，恩奇都……"
            },
            "raw_text": {
                "2_H190": "エルキドゥ。そう、なの。あなたはエルキドゥ。",
                "2_H191": "",
                "2_H192": ""
            }
        }
