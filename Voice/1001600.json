            "raw_text": {
                "0_I030": "",
                "0_I031": "",
                "0_I032": ""
            }
        },
        "0_I040": {
            "name": "螺旋証明世界 リリムハーロット \n～喝采なき薔薇～ 4",
            "text": {
                "0_I040": "给，请收下。",
                "0_I041": "……不要紧吧？　零花钱还够吗？",
                "0_I042": "需要妈妈帮你买吗？"
