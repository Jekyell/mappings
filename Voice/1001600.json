        "2_H030": {
            "name": "会話 1",
            "text": {
                "2_H030": "……请带上，我吧。"
            },
            "raw_text": {
                "2_H030": "連れて行ってください。"
            }
        },
        "2_H040": {
            "name": "会話 2",
            "text": {
                "2_H040": "因为，我是，母亲。",
                "2_H041": "什么话，都可以说哦？"
            },
            "raw_text": {
                "2_H040": "私お母さんなのです。なんでも言ってね。",
                "2_H041": ""
            }
        },
        "2_H050": {
            "name": "会話 3",
            "text": {
                "2_H050": "依赖我，我会，很高兴。"
            },
            "raw_text": {
                "2_H050": "頼ってくれて嬉しいです。"
            }
        },
