        "0_H030": {
            "name": "会話 1",
            "text": {
                "0_H030": "去散步吗？",
                "0_H031": "母亲也会一起去，牵着手吧。"
            },
            "raw_text": {
                "0_H030": "お散歩だな。母も行くので手を繋ぎなさい。",
                "0_H031": ""
            }
        },
        "0_H040": {
            "name": "会話 2",
            "text": {
                "0_H040": "我是母亲，人类啊。",
                "0_H041": "好乖好乖。"
            },
            "raw_text": {
                "0_H040": "私は母だ。人類よ、よしよし。",
                "0_H041": ""
            }
        },
        "0_H050": {
            "name": "会話 3",
            "text": {
                "0_H050": "照顾御主还真费神。",
                "0_H051": "……呵呵。"
            },
            "raw_text": {
                "0_H050": "マスターの世話は手が焼ける。うふん。",
                "0_H051": ""
            }
        },
