            "name": "絆Lv.1",
            "text": {
                "2_H10090": "呵呵……",
                "2_H10091": "每天都在茁壮成长……",
                "2_H10092": "光这样，就足以令人高兴了。"
            },
            "raw_text": {
                "2_H10090": "",
                "2_H10091": "",
                "2_H10092": ""
            }
        },
        "2_H10100": {
            "name": "絆Lv.2",
            "text": {
                "2_H10100": "尽量，不要走得，太远哦？",
                "2_H10101": "一旦迷路……我会，去接你的。"
            },
            "raw_text": {
                "2_H10100": "",
                "2_H10101": ""
            }
        },
        "2_H10110": {
            "name": "絆Lv.3",
            "text": {
                "2_H10110": "我想，试试，那个叫，约会（？）……的。",
                "2_H10111": "虽然我，是母亲，可以吗？"
            },
            "raw_text": {
                "2_H10110": "",
                "2_H10111": ""
            }
        },
        "2_H10120": {
            "name": "絆Lv.4",
            "text": {
                "2_H10120": "交到，很多朋友了呢……",
                "2_H10121": "呵呵。",
                "2_H10122": "友爱，友爱。",
                "2_H10123": "但愿你能，保持笑容。"
            },
            "raw_text": {
                "2_H10120": "",
                "2_H10121": "",
                "2_H10122": "",
                "2_H10123": ""
            }
        },
        "2_H10130": {
            "name": "絆Lv.5",
            "text": {
                "2_H10130": "哪怕，就这样，变得越来越大……",
                "2_H10131": "哪怕，人类的语言，逐渐淡漠……",
                "2_H10132": "哪怕，无法恢复，原本的样子……",
                "2_H10133": "我也会继续守护你……",
                "2_H10134": "……想要，继续守护你……"
            },
            "raw_text": {
                "2_H10130": "",
                "2_H10131": "",
                "2_H10132": "",
                "2_H10133": "",
                "2_H10134": ""
            }
        },
        "2_H160": {
            "name": "会話 4",
            "text": {
                "2_H160": "你们，也是，兽……？"
            },
            "raw_text": {
                "2_H160": "あなたたちも獣？"
            }
        },
        "2_H180": {
            "name": "会話 5",
            "text": {
                "2_H180": "呜呜……",
                "2_H181": "老人……",
                "2_H182": "害怕……"
            },
            "raw_text": {
                "2_H180": "ああ、おっきな、怖い。",
                "2_H181": "",
                "2_H182": ""
            }
        },
        "2_H190": {
            "name": "会話 6",
            "text": {
                "2_H190": "恩奇都……？",
                "2_H191": "是，这样……",
                "2_H192": "你，是，恩奇都……"
            },
            "raw_text": {
                "2_H190": "エルキドゥ。そう、なの。あなたはエルキドゥ。",
                "2_H191": "",
                "2_H192": ""
            }
        }
    },
