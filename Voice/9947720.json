{
    "id": 9947720,
    "name": "Enemy 9947720",
    "voices": {
        "0_B010": {
            "name": "0_B010",
            "text": {
                "0_B010": "那么，今天的天气是……"
            },
            "raw_text": {
                "0_B010": "さて今日の天気は。"
            }
        },
        "0_B020": {
            "name": "0_B020",
            "text": {
                "0_B020": "Ame-dam-fure-fui."
            },
            "raw_text": {
                "0_B020": "アメダムフーレフーイ。"
            }
        },
        "0_B030": {
            "name": "0_B030",
            "text": {
                "0_B030": "来赏花吧。"
            },
            "raw_text": {
                "0_B030": "お花見しよう。"
            }
        },
        "0_B040": {
            "name": "0_B040",
            "text": {
                "0_B040": "加油加油，卡里奥斯特罗先生。"
            },
            "raw_text": {
                "0_B040": "がんばれがんばれケイルメロさん。"
            }
        },
        "0_B050": {
            "name": "0_B050",
            "text": {
                "0_B050": "名门与欺瞒共舞，将真理的整合践踏混杂。"
            },
            "raw_text": {
                "0_B050": "名門は欺瞞と踊り、理の正吾を踏みまぜる。"
            }
        },
        "0_B051": {
            "name": "0_B051",
            "text": {
                "0_B051": "我乃名号晦暗者。"
            },
            "raw_text": {
                "0_B051": "我は眠くら。"
            }
        },
        "0_B052": {
            "name": "0_B052",
            "text": {
                "0_B052": "沉溺吧，于心灵的狼狈之中。"
            },
            "raw_text": {
                "0_B052": "たぶれ心の狼狽を。"
            }
        },
        "0_B053": {
            "name": "0_B053",
            "text": {
                "0_B053": "Holostis, Stis, Strellas."
            },
            "raw_text": {
                "0_B053": "ホロスティスティストレラス。"
            }
        },
        "0_B080": {
            "name": "0_B080",
            "text": {
                "0_B080": "来，继续，继续。"
            },
            "raw_text": {
                "0_B080": "さあ、続き続き。"
            }
        },
        "0_B090": {
            "name": "0_B090",
            "text": {
                "0_B090": "变得有意思起来了呢。"
            },
            "raw_text": {
                "0_B090": "面白くなってきたね。"
            }
        },
        "0_B100": {
            "name": "0_B100",
            "text": {
                "0_B100": "诶——要战斗吗？太野蛮了。还是算了吧。"
            },
            "raw_text": {
                "0_B100": "えー、戦うの？やばんだよ。やめようよ。"
            }
        },
        "0_B110": {
            "name": "0_B110",
            "text": {
                "0_B110": "买爆米花了吗？精彩的演出要开始了哦。"
            },
            "raw_text": {
                "0_B110": "ポップコーン買った？素敵なショーが始まるよ。"
            }
        },
        "0_B120": {
            "name": "0_B120",
            "text": {
                "0_B120": "唯独性命我会饶你一命的。骗你的啦。"
            },
            "raw_text": {
                "0_B120": "命だけは助けてあげるよ。嘘だけどね。"
            }
        },
        "0_B130": {
            "name": "0_B130",
            "text": {
                "0_B130": "诶，这就结束了？笑点呢？没有反转吗？"
            },
            "raw_text": {
                "0_B130": "ええ、もう終わり？おちは？どんでん返しはないの？"
            }
        },
        "0_B140": {
            "name": "0_B140",
            "text": {
                "0_B140": "上吧。"
            },
            "raw_text": {
                "0_B140": "やる。"
            }
        },
        "0_B150": {
            "name": "0_B150",
            "text": {
                "0_B150": "要坏掉了，要坏掉了。"
            },
            "raw_text": {
                "0_B150": "壊れちゃう壊れちゃう。"
            }
        },
        "0_B160": {
            "name": "0_B160",
            "text": {
                "0_B160": "演出已经要结束了吗。"
            },
            "raw_text": {
                "0_B160": "もう上演もおしまいか。"
            }
        },
        "0_B170": {
            "name": "0_B170",
            "text": {
                "0_B170": "啊呀，派对才刚刚要开始呢。真遗憾。"
            },
            "raw_text": {
                "0_B170": "ああ、まだパーティーはこれからなのに。残念。"
            }
        },
        "0_B180": {
            "name": "0_B180",
            "text": {
                "0_B180": "可以吗？"
            },
            "raw_text": {
                "0_B180": "いいの？"
            }
        },
        "0_B190": {
            "name": "0_B190",
            "text": {
                "0_B190": "攻势很猛嘛。"
            },
            "raw_text": {
                "0_B190": "攻めるね。"
            }
        },
        "0_B200": {
            "name": "0_B200",
            "text": {
                "0_B200": "似乎会变得有趣起来。"
            },
            "raw_text": {
                "0_B200": "楽しくなりそう。"
            }
        },
        "0_B2010": {
            "name": "0_B2010",
            "text": {
                "0_B2010": "玩得开心吗？"
            },
            "raw_text": {
                "0_B2010": "楽しんでる。"
            }
        },
        "0_B2020": {
            "name": "0_B2020",
            "text": {
                "0_B2020": "请享用甜美的梦境吧。"
            },
            "raw_text": {
                "0_B2020": "甘い夢をどうぞった。"
            }
        },
        "0_B2030": {
            "name": "0_B2030",
            "text": {
                "0_B2030": "来吧来吧，跳起舞来吧。"
            },
            "raw_text": {
                "0_B2030": "レッツレッツダダダダダンシング。"
            }
        },
        "0_B210": {
            "name": "0_B210",
            "text": {
                "0_B210": "厉害，太棒了！"
            },
            "raw_text": {
                "0_B210": "すごい、最高！"
            }
        },
        "0_B220": {
            "name": "0_B220",
            "text": {
                "0_B220": "表演时间。"
            },
            "raw_text": {
                "0_B220": "ショータイム。"
            }
        },
        "0_B230": {
            "name": "0_B230",
            "text": {
                "0_B230": "啊，对了对了，真的没关系吗？"
            },
            "raw_text": {
                "0_B230": "あそうそう、本当にいいの？"
            }
        },
        "0_B2410": {
            "name": "0_B2410",
            "text": {
                "0_B2410": "猜谜时间：谁才是真货呢？"
            },
            "raw_text": {
                "0_B2410": "クイズ、本物は誰でしょう。"
            }
        },
        "0_B2420": {
            "name": "0_B2420",
            "text": {
                "0_B2420": "呐呐，现在是什么心情？什么心情呀？"
            },
            "raw_text": {
                "0_B2420": "ねえねえ、どんな気持ち？どんな気持ち？"
            }
        },
        "0_B2430": {
            "name": "0_B2430",
            "text": {
                "0_B2430": "这是美人计哦。咻——咻——"
            },
            "raw_text": {
                "0_B2430": "色仕掛けだよ。ひゅひゅう。"
            }
        },
        "0_B2440": {
            "name": "0_B2440",
            "text": {
                "0_B2440": "放心吧，不会咬你的。虽然会发射光炮就是了。"
            },
            "raw_text": {
                "0_B2440": "噛まないから大丈夫。ビームは打つけどね。"
            }
        },
        "0_B410": {
            "name": "0_B410",
            "text": {
                "0_B410": "让我们和平相处吧。"
            },
            "raw_text": {
                "0_B410": "平和に行こうよ。"
            }
        },
        "0_B420": {
            "name": "0_B420",
            "text": {
                "0_B420": "焦糖可是滚烫滚烫的哦。"
            },
            "raw_text": {
                "0_B420": "キャラメルはサビアチだよ。"
            }
        },
        "0_B430": {
            "name": "0_B430",
            "text": {
                "0_B430": "萨巴内罗盐味黄油，上菜了。"
            },
            "raw_text": {
                "0_B430": "サバネロ塩バター入ります。"
            }
        },
        "0_B440": {
            "name": "0_B440",
            "text": {
                "0_B440": "你知道吗，小猫们其实最喜欢吃曲奇了。"
            },
            "raw_text": {
                "0_B440": "金子たち、クッキーが大好物って知ってた？"
            }
        },
        "0_B480": {
            "name": "0_B480",
            "text": {
                "0_B480": "气氛热烈起来了。"
            },
            "raw_text": {
                "0_B480": "盛り上がってる。"
            }
        },
        "0_B490": {
            "name": "0_B490",
            "text": {
                "0_B490": "你们最棒了。"
            },
            "raw_text": {
                "0_B490": "最高だね、君たち。"
            }
        },
        "0_B500": {
            "name": "0_B500",
            "text": {
                "0_B500": "真没办法。至少帮你拖延一下时间吧。"
            },
            "raw_text": {
                "0_B500": "しょうがないな。足止めぐらいはしてあげるね。"
            }
        },
        "0_B510": {
            "name": "0_B510",
            "text": {
                "0_B510": "我来为你注入了哦。嘿咻，嘿呀。"
            },
            "raw_text": {
                "0_B510": "入れに来てあげたよ。やっこ、やっり。"
            }
        },
        "0_B520": {
            "name": "0_B520",
            "text": {
                "0_B520": "没关系。既然站不起来了，那接下来我就随心所欲了哦。"
            },
            "raw_text": {
                "0_B520": "いいの。立ち上がれないなら、あとは好きにしちゃうよ。"
            }
        },
        "0_B530": {
            "name": "0_B530",
            "text": {
                "0_B530": "呐，御主。我没有背叛你吧？可以夸奖我哦。"
            },
            "raw_text": {
                "0_B530": "ねえ、マスター。私、裏切らなかったでしょ？褒めていいんだよ。"
            }
        },
        "0_B540": {
            "name": "0_B540",
            "text": {
                "0_B540": "好痛。"
            },
            "raw_text": {
                "0_B540": "あいた。"
            }
        },
        "0_B550": {
            "name": "0_B550",
            "text": {
                "0_B550": "哎呀，真是不懂幽默呢。"
            },
            "raw_text": {
                "0_B550": "あら、冗談通じないなもう。"
            }
        },
        "0_B560": {
            "name": "0_B560",
            "text": {
                "0_B560": "是不是稍微让你有点太生气了呢。"
            },
            "raw_text": {
                "0_B560": "ちょっと怒らせすぎちゃったかな。"
            }
        },
        "0_B570": {
            "name": "0_B570",
            "text": {
                "0_B570": "谢谢啦，御主。玩得很开心哦。"
            },
            "raw_text": {
                "0_B570": "ありがとね、マスター。楽しかったよ。"
            }
        },
        "0_B800": {
            "name": "0_B800",
            "text": {
                "0_B800": "啊啊，再靠近一点，让我看得更清楚些吧。"
            },
            "raw_text": {
                "0_B800": "ああもっともっと近くで見せておくれ。"
            }
        },
        "0_B801": {
            "name": "0_B801",
            "text": {
                "0_B801": "在那清醒与疯狂交融的尽头，所抵达的人类之极致。"
            },
            "raw_text": {
                "0_B801": "正気と狂気が溶け合った果てにたどり着く人間の極致を。"
            }
        },
        "0_B802": {
            "name": "0_B802",
            "text": {
                "0_B802": "Holostis, Iastis, Strellas."
            },
            "raw_text": {
                "0_B802": "ホロスティシアスティストレラス。"
            }
        },
        "0_B803": {
            "name": "0_B803",
            "text": {
                "0_B803": "啊啊。"
            },
            "raw_text": {
                "0_B803": "ああ。"
            }
        },
        "0_B804": {
            "name": "0_B804",
            "text": {
                "0_B804": "再靠近一点，让我看得更清楚些吧。"
            },
            "raw_text": {
                "0_B804": "もっともっと近くで見せておくれ。"
            }
        },
        "0_B810": {
            "name": "0_B810",
            "text": {
                "0_B810": "啊——"
            },
            "raw_text": {
                "0_B810": "あー。"
            }
        },
        "0_B811": {
            "name": "0_B811",
            "text": {
                "0_B811": "偶尔展露一下本性也没关系吧。"
            },
            "raw_text": {
                "0_B811": "たまには素でいいかな。"
            }
        },
        "0_B812": {
            "name": "0_B812",
            "text": {
                "0_B812": "这只不过是虚有其表的空壳罢了。"
            },
            "raw_text": {
                "0_B812": "これはただのハリボテです。"
            }
        },
        "0_B813": {
            "name": "0_B813",
            "text": {
                "0_B813": "一点都不痛的，放心吧。"
            },
            "raw_text": {
                "0_B813": "痛くないから安心して。"
            }
        },
        "0_B814": {
            "name": "0_B814",
            "text": {
                "0_B814": "当然，是骗你的。"
            },
            "raw_text": {
                "0_B814": "もちろん嘘だけどね。"
            }
        },
        "0_B840": {
            "name": "0_B840",
            "text": {
                "0_B840": "首次公开，这孩子就是万圣节刻耳柏洛斯哦。"
            },
            "raw_text": {
                "0_B840": "初公開この子がハロウィンケルベロスだよ。"
            }
        },
        "0_B880": {
            "name": "0_B880",
            "text": {
                "0_B880": "不行不行，胆管和脾脏都要笑得扭成一团了。"
            },
            "raw_text": {
                "0_B880": "だめだめ、胆管と脾臓がよじれちゃう。"
            }
        },
        "0_B910": {
            "name": "0_B910",
            "text": {
                "0_B910": "MyMixi的好友过生日了。"
            },
            "raw_text": {
                "0_B910": "マイミクがバースデー。"
            }
        },
        "0_B920": {
            "name": "0_B920",
            "text": {
                "0_B920": "是交换礼物环节哦。"
            },
            "raw_text": {
                "0_B920": "プレゼント交換だよ。"
            }
        },
        "0_B930": {
            "name": "0_B930",
            "text": {
                "0_B930": "骗人的吧，不要，别杀我。你这混蛋……"
            },
            "raw_text": {
                "0_B930": "うそ、嫌だ、殺さないで。てめ。"
            }
        }
    }
}