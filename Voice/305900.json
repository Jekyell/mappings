{
    "id": 305900,
    "collectionNo": 442,
    "name": "インドラ",
    "voices": {
        "0_B010": {
            "name": "アタック 1",
            "text": {
                "0_B010": "准了。"
            }
        },
        "0_B020": {
            "name": "アタック 2",
            "text": {
                "0_B020": "就赏给你吧。"
            }
        },
        "0_B030": {
            "name": "アタック 3",
            "text": {
                "0_B030": "爱罗婆多，去吧。"
            }
        },
        "0_B040": {
            "name": "エクストラアタック 1",
            "text": {
                "0_B040": "来兴致了，这是赏赐。"
            }
        },
        "0_B050": {
            "name": "宝具 1",
            "text": {
                "0_B050": "神王领域填充，空间冻结。",
                "0_B051": "神罚执行权限永续，王威解放。",
                "0_B052": "狂妄之徒们啊，仰望吾之雷霆吧！",
                "0_B053": "神之雷！"
            }
        },
        "0_B080": {
            "name": "スキル 1",
            "text": {
                "0_B080": "接下来就由你们自己去干吧。"
            }
        },
        "0_B090": {
            "name": "スキル 2",
            "text": {
                "0_B090": "咕嘟、咕嘟……呼哈～。真好喝！"
            }
        },
        "0_B100": {
            "name": "開始 1",
            "text": {
                "0_B100": "你面对的是诸神之王。跪拜吧。"
            }
        },
        "0_B110": {
            "name": "開始 2",
            "text": {
                "0_B110": "让神从宝座上下去？　你以为自己是在对谁下令啊？"
            }
        },
        "0_B120": {
            "name": "勝利 1",
            "text": {
                "0_B120": "哼，真是场无趣的余兴。"
            }
        },
        "0_B130": {
            "name": "勝利 2",
            "text": {
                "0_B130": "既然赢了，就快拿酒来。"
            }
        },
        "0_B140": {
            "name": "ダメージ 2",
            "text": {
                "0_B140": "随你们的便吧。"
            }
        },
        "0_B150": {
            "name": "ダメージ 1",
            "text": {
                "0_B150": "哈哈哈，真可笑。"
            }
        },
        "0_B160": {
            "name": "戦闘不能 1",
            "text": {
                "0_B160": "如你所见，神还没拿出真本事哦。"
            }
        },
        "0_B170": {
            "name": "戦闘不能 2",
            "text": {
                "0_B170": "回去重新开喝吧。"
            }
        },
        "0_B180": {
            "name": "コマンドカード 1",
            "text": {
                "0_B180": "你说什么呢。"
            }
        },
        "0_B190": {
            "name": "コマンドカード 2",
            "text": {
                "0_B190": "神才不要。"
            }
        },
        "0_B200": {
            "name": "コマンドカード 3",
            "text": {
                "0_B200": "神拒绝。"
            }
        },
        "0_B2010": {
            "name": "アタック 10",
            "text": {
                "0_B2010": "想怎么前进都行。"
            }
        },
        "0_B2020": {
            "name": "アタック 11",
            "text": {
                "0_B2020": "头抬得太高了。"
            }
        },
        "0_B2030": {
            "name": "アタック 12",
            "text": {
                "0_B2030": "总不至于这点程度就死了吧。"
            }
        },
        "0_B210": {
            "name": "宝具カード 1",
            "text": {
                "0_B210": "你是认真的吗？"
            }
        },
        "0_B220": {
            "name": "宝具カード 2",
            "text": {
                "0_B220": "真是愚不可及。"
            }
        },
        "0_B230": {
            "name": "宝具カード 3",
            "text": {
                "0_B230": "你会后悔的哦。"
            }
        },
        "0_B2410": {
            "name": "アタック 13",
            "text": {
                "0_B2410": "伐折罗，陪他们玩玩。"
            }
        },
        "0_B2420": {
            "name": "アタック 14",
            "text": {
                "0_B2420": "你们不就渴望雨吗？"
            }
        },
        "0_B410": {
            "name": "アタック 4",
            "text": {
                "0_B410": "叩伏于地吧。"
            }
        },
        "0_B420": {
            "name": "アタック 5",
            "text": {
                "0_B420": "来，要试试看吗。"
            }
        },
        "0_B430": {
            "name": "アタック 6",
            "text": {
                "0_B430": "帮神收拾掉。神要睡了。"
            }
        },
        "0_B440": {
            "name": "エクストラアタック 2",
            "text": {
                "0_B440": "无聊，也只能喝酒了。"
            }
        },
        "0_B480": {
            "name": "スキル 3",
            "text": {
                "0_B480": "神的伐诃纳正在躁动。"
            }
        },
        "0_B490": {
            "name": "スキル 4",
            "text": {
                "0_B490": "至少让神小睡一会儿啦。"
            }
        },
        "0_B500": {
            "name": "開始 3",
            "text": {
                "0_B500": "余兴节目吗，可要好好取悦神哦。"
            }
        },
        "0_B520": {
            "name": "勝利 3",
            "text": {
                "0_B520": "你看吧，神根本不需要降临到地面上。"
            }
        },
        "0_B800": {
            "name": "宝具 2",
            "text": {
                "0_B800": "此乃斩断群山翅膀之刃。",
                "0_B801": "乃开拓、支撑苍天的救济之光。即为——",
                "0_B802": "【伐折罗们】神之雷！　Śakra Vajra！",
                "0_B803": "……必杀台词难道不该由神来说吗？"
            }
        },
        "0_B810": {
            "name": "宝具 3",
            "text": {
                "0_B810": "吾乃因陀罗，为天地两界所畏惧者。",
                "0_B811": "吾乃弗栗多罕，为诛灭邪恶之蛇者！",
                "0_B812": "神雷解放——神之雷！",
                "0_B813": "吾之敌啊，沉入漫长的黑暗吧。"
            }
        },
        "0_B820": {
            "name": "宝具 4",
            "text": {
                "0_B820": "好吧，这便是戏耍的极致。",
                "0_B821": "就让你们见识一下由圣仙之骨所铸的吾之金刚吧。",
                "0_B822": "降临吧，神雷！　神之雷！",
                "0_B823": "哈～哈哈哈哈！"
            }
        },
        "0_B840": {
            "name": "エクストラアタック 3",
            "text": {
                "0_B840": "就用你们的滑稽模样来下酒吧。"
            }
        },
        "0_B880": {
            "name": "スキル 5",
            "text": {
                "0_B880": "就算你表现得再怎么想要，神也不会给你哦。"
            }
        },
        "0_B890": {
            "name": "スキル 6",
            "text": {
                "0_B890": "看吧。就连承载神的东西都有如此威容。"
            }
        },
        "0_B910": {
            "name": "アタック 7",
            "text": {
                "0_B910": "这是王的赏赐，感恩戴德吧。"
            }
        },
        "0_B920": {
            "name": "アタック 8",
            "text": {
                "0_B920": "起舞吧。"
            }
        },
        "0_B930": {
            "name": "アタック 9",
            "text": {
                "0_B930": "这是水之恩惠。"
            }
        },
        "0_C010": {
            "name": "インドラの大試練 ～巡るブロークン・スカイ～ 8",
            "text": {
                "0_C010": "别犹豫。抽起来！"
            }
        },
        "0_C020": {
            "name": "インドラの大試練 ～巡るブロークン・スカイ～ 9",
            "text": {
                "0_C020": "嚯。速度快如雷霆。 当然，还远远不及我哦。",
                "0_C021": ""
            }
        },
        "0_C030": {
            "name": "インドラの大試練 ～巡るブロークン・スカイ～ 10",
            "text": {
                "0_C030": "这种程度都看不见吗？ 哼，人类还真是不方便呢。",
                "0_C031": ""
            }
        },
        "0_C040": {
            "name": "インドラの大試練 ～巡るブロークン・スカイ～ 11",
            "text": {
                "0_C040": "神就为你解放吧，就像以往的天空那样。"
            }
        },
        "0_C050": {
            "name": "インドラの大試練 ～巡るブロークン・スカイ～ 12",
            "text": {
                "0_C050": "嗯。快准备献给因陀罗的赞歌吧！"
            }
        },
        "0_C060": {
            "name": "インドラの大試練 ～巡るブロークン・スカイ～ 13",
            "text": {
                "0_C060": "在吾之天界帝释天界，宝物根本不会穷尽。 将这点铭记于心，然后继续抽吧！",
                "0_C061": ""
            }
        },
        "0_C110": {
            "name": "インドラの大試練 ～巡るブロークン・スカイ～ 14",
            "text": {
                "0_C110": "虽不知人类会如何使用这些东西，但不管怎么说， 总比被永远封在雪山深处要好吧。",
                "0_C111": ""
            }
        },
        "0_C120": {
            "name": "インドラの大試練 ～巡るブロークン・スカイ～ 15",
            "text": {
                "0_C120": "吾之宝物中没有所谓的鼓励奖。 记好了。",
                "0_C121": ""
            }
        },
        "0_C130": {
            "name": "インドラの大試練 ～巡るブロークン・スカイ～ 16",
            "text": {
                "0_C130": "以你那瘦弱的手臂恐怕都抱不动这等财富吧。 可别被压垮了哦。",
                "0_C131": ""
            }
        },
        "0_C150": {
            "name": "インドラの大試練 ～巡るブロークン・スカイ～ 18",
            "text": {
                "0_C150": "呼哈哈哈哈！　对你们来说，这可谓极致的奖品吧？ 神准了，感到欢喜吧！",
                "0_C151": ""
            }
        },
        "0_C160": {
            "name": "インドラの大試練 ～巡るブロークン・スカイ～ 19",
            "text": {
                "0_C160": "呼哈哈，睁大眼睛看清楚！这便是诸神之王因陀罗此次带来的解放！"
            }
        },
        "0_C700": {
            "name": "インドラの大試練 ～巡るブロークン・スカイ～ 17",
            "text": {
                "0_C700": "慢着，那种莫名的酒对你们来说还太早了。交给神。 别担心，神会特别为你们准备别的宝物。",
                "0_C701": ""
            }
        },
        "0_G010": {
            "name": "レベルアップ 1",
            "text": {
                "0_G010": "神明无法成长。",
                "0_G011": "这是自然现象。"
            }
        },
        "0_G110": {
            "name": "レベルアップ 2",
            "text": {
                "0_G110": "唔。",
                "0_G111": "或许正好用来……当下酒菜呢……"
            }
        },
        "0_G120": {
            "name": "レベルアップ 3",
            "text": {
                "0_G120": "不要慌，只是灵基开始适应了而已。"
            }
        },
        "0_H010": {
            "name": "誕生日",
            "text": {
                "0_H010": "嚯，今天是你的生日吗。",
                "0_H011": "可不能让人觉得诸神之王吝啬。",
                "0_H012": "想要什么尽管说。",
                "0_H013": "……但甘露和苏摩酒除外。"
            }
        },
        "0_H020": {
            "name": "イベント開催中",
            "text": {
                "0_H020": "似乎正在举行祭典。",
                "0_H021": "当然是为了赞颂吾这诸神之王吧？",
                "0_H022": "很好，为神带路吧。"
            }
        },
        "0_H030": {
            "name": "会話 1",
            "text": {
                "0_H030": "神已经开始厌倦在这里举杯畅饮了。",
                "0_H031": "应该还有其他足以取悦诸神之王双眼的地方吧。",
                "0_H032": "带路吧。"
            }
        },
        "0_H040": {
            "name": "会話 2",
            "text": {
                "0_H040": "【红伐折罗】因陀罗大人不会侍奉任何人。他会在这里，只是因为他本人如此希望而已。",
                "0_H041": "【绿伐折罗】可别误会了哦～？",
                "0_H042": "哼。神可没让你们连神要说的话都代劳，不过，大体就是这样。"
            }
        },
        "0_H050": {
            "name": "会話 3",
            "text": {
                "0_H050": "御主吗。",
                "0_H051": "为了对让神显现于此的奇迹表以敬意，神倒是不介意称你一句御主——",
                "0_H052": "但归根结底，你不过是犹如无数雨滴的人类之一罢了。",
                "0_H053": "别以为自己能随意命令诸神之王哦，人类。"
            }
        },
        "0_H060": {
            "name": "好きなこと",
            "text": {
                "0_H060": "甘露，苏摩……",
                "0_H061": "这些本就是为了被神喝下而存在的。",
                "0_H062": "如果人界也有能与之匹敌的酒，",
                "0_H063": "就尽管拿来吧。",
                "0_H064": "诸神之王会把它们全部喝干。",
                "0_H065": "这是莫大的荣耀吧？"
            }
        },
        "0_H070": {
            "name": "嫌いなこと",
            "text": {
                "0_H070": "哎哎，别苦修啦！　别让神看见！",
                "0_H071": "太可怕……不，会令人不适啦！"
            }
        },
        "0_H080": {
            "name": "聖杯について",
            "text": {
                "0_H080": "你说圣杯？",
                "0_H081": "无聊。",
                "0_H082": "诸神之王不会向其他东西许愿。",
                "0_H083": "不过，只要是神饮酒时使用的酒杯，应该可以全部称作圣杯吧。",
                "0_H084": "毕竟是神之口触碰过的器皿，你们应该好好崇拜！"
            }
        },
        "0_H090": {
            "name": "絆Lv.1",
            "text": {
                "0_H090": "这些家伙？是金刚杵。王需要几个跑腿的嘛。我把自己灵基的一部分切下来，以金刚杵为核心，使其寄宿微小的神性。说到底，就连我这身体，也不过是自己制作的容器，是神的依代。外形这种东西，根本没什么好在意的。",
                "0_H091": "你说这两个？　是伐折罗。",
                "0_H092": "因为王总需要仆从嘛。",
                "0_H093": "神将自身灵基的一部分切分出来，以伐折罗为核心，寄宿了小小的神性。",
                "0_H095": "况且神的这身体也不过是神自己制造的容器，神的凭依之躯罢了。",
                "0_H096": "外形这种东西根本没什么好在意的。"
            }
        },
        "0_H100": {
            "name": "絆Lv.2",
            "text": {
                "0_H100": "既然你在意，那就告诉你吧，这两个家伙也算神明之一。",
                "0_H101": "因此并不存在所谓的性别。",
                "0_H102": "【绿伐折罗】没错没错，所以我们只是变成了自己觉得合适的样子而已～。",
                "0_H103": "【红伐折罗】我觉得只要能做出最基本的区分，怎么都行啦。"
            }
        },
        "0_H110": {
            "name": "絆Lv.3",
            "text": {
                "0_H110": "你似乎与不少神明都有交情。",
                "0_H111": "那神随便问你一句，你觉得在他们中，最为强大、最为耀眼的神明是哪一位？",
                "0_H112": "【红伐折罗】感觉答案只有一个呢。凝视～。",
                "0_H113": "【绿伐折罗】答错的话可是很惨的哦～♪咿嘻嘻！"
            }
        },
        "0_H120": {
            "name": "絆Lv.4",
            "text": {
                "0_H120": "喂。你那些胡说八道拿来下酒倒是不错。",
                "0_H121": "神可以允许你参加神之酒宴。",
                "0_H122": "不过，你喝的酒得自己准备哦。",
                "0_H123": "神的酒可不会赏给你。"
            }
        },
        "0_H130": {
            "name": "絆Lv.5",
            "text": {
                "0_H130": "作为对你信仰的奖赏，神就告诉你一件重要的事吧。",
                "0_H131": "听好了。",
                "0_H132": "真正强大的神明，不会挥汗如雨地劳动，也不会靠努力去成就什么。",
                "0_H133": "会做那种事的神明，都是弱小、丢人的家伙。",
                "0_H134": "也就是说，神不是那种神明。",
                "0_H135": "好好记住。"
            }
        },
        "0_H170": {
            "name": "会話 4",
            "text": {
                "0_H170": "湿婆神不在，取而代之的是你吗，帕尔瓦蒂。",
                "0_H171": "神再怎么说也不会对你出手啦。",
                "0_H172": "这么办吧，神保证不对你出手，相反，你也要保证无论神对哪个女人出手都不会来碍事……",
                "0_H173": "……不保证？",
                "0_H174": "嘁。"
            }
        },
        "0_H180": {
            "name": "会話 5",
            "text": {
                "0_H180": "杜尔伽。虽然你相当于我们所有神明的女儿……",
                "0_H181": "但你现在的最高优先级命令是如何定义的？",
                "0_H182": "……服从身为传达者的御主吗。",
                "0_H183": "好吧，反正也没什么差别。",
                "0_H184": "既然隶属于同一阵营，作为歼灭女神的你应该也会偶尔替神完成工作吧。",
                "0_H185": "要好好干哦。"
            }
        },
        "0_H190": {
            "name": "会話 6",
            "text": {
                "0_H190": "喂，你这家伙到底什么意思。",
                "0_H191": "既成了女人，又用了和帕尔瓦蒂相同的凭依之躯，似乎还强化了魔之要素……",
                "0_H192": "那把伐折罗也在恶心神吗？",
                "0_H193": "别用那种眼神看神啦。",
                "0_H194": "虽说的确是神让你去找湿婆的，但神也没想到湿婆会那么干脆地把你烧了。",
                "0_H195": "所以那不是神的错！",
                "0_H196": "要恨就去恨湿婆和帕尔瓦蒂吧！"
            }
        },
        "0_H200": {
            "name": "会話 7",
            "text": {
                "0_H200": "哦哦，那家伙是谁。",
                "0_H201": "像女神吉祥天女、又像狄罗德玛，还像兰跋……真是个好女人啊……！",
                "0_H202": "……",
                "0_H203": "…………？",
                "0_H204": "这不是弗栗多吗————！"
            }
        },
        "0_H210": {
            "name": "会話 8",
            "text": {
                "0_H210": "嚯，苏利耶的儿子，日轮之子啊。没想到你也在这里。",
                "0_H211": "你最终有没有使用神给你的那柄枪？",
                "0_H212": "……罢了。或许连使用过的事实都被消失了吧。",
                "0_H213": "总之，神都听说了。你输给了吾的儿子吧。",
                "0_H214": "倒也正常。",
                "0_H215": "因为太阳自然比不过能遮天蔽日的雷雨嘛。",
                "0_H216": "哈哈哈哈！"
            }
        },
        "0_H220": {
            "name": "会話 9",
            "text": {
                "0_H220": "吾的儿子啊，你可安好？",
                "0_H221": "需要像以前那样，由神再陪你锻炼锻炼吗？",
                "0_H222": "【红伐折罗】他说「当初陪我锻炼的好像基本是湿婆神吧……」",
                "0_H223": "不，那个，其实……怎么说呢……因为你当时还没达到那个境界……",
                "0_H224": "【绿伐折罗】因陀罗大人只是不好意思啦～♪咿嘻嘻！",
                "0_H225": "……闭嘴。"
            }
        },
        "0_H230": {
            "name": "会話 10",
            "text": {
                "0_H230": "喂，那边那个迦利的化身。",
                "0_H231": "你那身铠甲以前应该是神的东西吧？",
                "0_H232": "德罗纳给你的？　唔……感觉已经在无数人手里转过了呢。",
                "0_H233": "不过，这本来就是湿婆的东西。",
                "0_H234": "神也没什么资格说三道四。"
            }
        },
        "0_H240": {
            "name": "会話 11",
            "text": {
                "0_H240": "关于那是不是伽内什的问题……虽然尚无定论。",
                "0_H241": "但对于神明不该勤勤恳恳劳动的说法，神表示同意。",
                "0_H242": "不过既然诸神之王的神在此，那家伙肯定应该比神先行动吧？",
                "0_H243": "综上所述，那边的被炉归神了。快让开。"
            }
        },
        "0_H250": {
            "name": "会話 12",
            "text": {
                "0_H250": "很久以前，有一位圣仙。",
                "0_H251": "神实在忍受不了他那难看的苦行模样，于是派去了阿卜娑罗。",
                "0_H252": "之后在经历了很多事之后诞生的孩子，就是克里帕（慈悯）与克里毗（慈悯）。",
                "0_H253": "没错，马嘶，就是你的母亲。",
                "0_H254": "也就是说，如果没有神，你根本不会出生。",
                "0_H255": "你要好好感谢神哦。"
            }
        },
        "0_N010": {
            "name": "インドラの大試練 ～巡るブロークン・スカイ～ 1",
            "text": {
                "0_N010": "无需过于勉强哦。",
                "0_N011": "苦修这种事本来就不该去做。"
            }
        },
        "0_N020": {
            "name": "インドラの大試練 ～巡るブロークン・スカイ～ 2",
            "text": {
                "0_N020": "来了么。",
                "0_N021": "没什么，不必为自己的贪心感到羞耻。",
                "0_N022": "面对令人崇拜的因陀罗之宝，会这样也是理所当然的。",
                "0_N023": "好好品味自己的幸运吧。"
            }
        },
        "0_N030": {
            "name": "インドラの大試練 ～巡るブロークン・スカイ～ 3",
            "text": {
                "0_N030": "你们收集而来的这些，既是开启这宝物库的钥匙，也是献给诸神之王的供品。",
                "0_N031": "尽情品味这种能亲手献上的法悦吧。"
            }
        },
        "0_N040": {
            "name": "インドラの大試練 ～巡るブロークン・スカイ～ 4",
            "text": {
                "0_N040": "神曾无数次解放天空。",
                "0_N041": "与之相比，解放这种程度的宝物等同于儿戏。",
                "0_N042": "也就是说，无论神喝下多少酒，手上也不会失误。",
                "0_N043": "明白了的话，就别再用那种担心的眼神看着神了。"
            }
        },
        "0_N050": {
            "name": "インドラの大試練 ～巡るブロークン・スカイ～ 5",
            "text": {
                "0_N050": "你还没有无礼到需要诸神之王亲自为你说明什么吧？",
                "0_N051": "如果有想知道的事，就自己去查。"
            }
        },
        "0_N060": {
            "name": "インドラの大試練 ～巡るブロークン・スカイ～ 6",
            "text": {
                "0_N060": "哼，事到如今又来了啊。",
                "0_N061": "真是迟钝到与神之雷霆截然相反呢。",
                "0_N062": "不过，人类本就是如此吧。",
                "0_N063": "神愿意奉陪，要好好感谢诸神之王的慈悲哦。"
            }
        },
        "0_N070": {
            "name": "インドラの大試練 ～巡るブロークン・スカイ～ 7",
            "text": {
                "0_N070": "…………",
                "0_N071": "……唔。……喂，别误会了。",
                "0_N072": "刚才神只是在闭目思考而已。",
                "0_N073": "就算完成了职责，神明也不会因喝酒过度而打瞌睡。记住了。"
            }
        },
        "0_S010": {
            "name": "召喚",
            "text": {
                "0_S010": "神乃诸神之王，因陀罗。",
                "0_S011": "虽然没有什么战斗是必须劳神出马的，但神还是怀着游山玩水的心情来了。",
                "0_S012": "来吧，将这世界上极致的美酒献给神品尝吧！",
                "0_S013": "哈哈哈哈哈！"
            }
        },
        "1_B010": {
            "name": "アタック 1",
            "text": {
                "1_B010": "动手。 【伐折罗们】好！"
            }
        },
        "1_B020": {
            "name": "アタック 2",
            "text": {
                "1_B020": "动手。 【红伐折罗】像这样吗。 【绿伐折罗】嘿咻～！"
            }
        },
        "1_B030": {
            "name": "アタック 3",
            "text": {
                "1_B030": "动手。 【红伐折罗】伐折罗拳！ 【绿伐折罗】伐折罗踢！"
            }
        },
        "1_B040": {
            "name": "エクストラアタック 1",
            "text": {
                "1_B040": "让他们见识一下。 【伐折罗们】这就是伐折罗的力量～！"
            }
        },
        "1_B050": {
            "name": "宝具 1",
            "text": {
                "1_B050": "神王领域填充，空间冻结。",
                "1_B051": "神罚执行权限永续，王威解放。",
                "1_B052": "狂妄之徒们啊，仰望吾之雷霆吧！",
                "1_B053": "神之雷！"
            }
        },
        "1_B080": {
            "name": "スキル 1",
            "text": {
                "1_B080": "【红伐折罗】可以喝酒， 【绿伐折罗】但别喝倒～♪"
            }
        },
        "1_B090": {
            "name": "スキル 2",
            "text": {
                "1_B090": "你是在懊悔吗？"
            }
        },
        "1_B100": {
            "name": "開始 1",
            "text": {
                "1_B100": "竟敢让王降临地面。"
            }
        },
        "1_B110": {
            "name": "開始 2",
            "text": {
                "1_B110": "能够看见神的背影，你应该感到荣幸哦。"
            }
        },
        "1_B120": {
            "name": "勝利 1",
            "text": {
                "1_B120": "记得打扫干净哦。否则太碍眼了。"
            }
        },
        "1_B130": {
            "name": "勝利 2",
            "text": {
                "1_B130": "【绿伐折罗】因陀罗大人，胜利的姿势呢？ 不做！ 【绿伐折罗】那就由我替您做好吧。V！"
            }
        },
        "1_B140": {
            "name": "ダメージ 2",
            "text": {
                "1_B140": "不过如此吗。"
            }
        },
        "1_B150": {
            "name": "ダメージ 1",
            "text": {
                "1_B150": "真有精神。"
            }
        },
        "1_B160": {
            "name": "戦闘不能 1",
            "text": {
                "1_B160": "嚯……有意思……"
            }
        },
        "1_B170": {
            "name": "戦闘不能 2",
            "text": {
                "1_B170": "呵呵，真可笑……"
            }
        },
        "1_B180": {
            "name": "コマンドカード 1",
            "text": {
                "1_B180": "别命令神明。"
            }
        },
        "1_B190": {
            "name": "コマンドカード 2",
            "text": {
                "1_B190": "只是刚好一致而已。"
            }
        },
        "1_B200": {
            "name": "コマンドカード 3",
            "text": {
                "1_B200": "嚯……"
            }
        },
        "1_B2010": {
            "name": "アタック 10",
            "text": {
                "1_B2010": "卑贱的劳动—— 【伐折罗们】是我们的职责～！"
            }
        },
        "1_B2020": {
            "name": "アタック 11",
            "text": {
                "1_B2020": "感激涕零吧。 【伐折罗们】这是礼物～！"
            }
        },
        "1_B2030": {
            "name": "アタック 12",
            "text": {
                "1_B2030": "【红伐折罗】这里。 【红伐折罗】……什么？ 【红伐折罗】没注意前面……"
            }
        },
        "1_B210": {
            "name": "宝具カード 1",
            "text": {
                "1_B210": "神也会有心血来潮的时候。"
            }
        },
        "1_B220": {
            "name": "宝具カード 2",
            "text": {
                "1_B220": "【绿伐折罗】因陀罗大人是说偶尔也会这样啦！"
            }
        },
        "1_B230": {
            "name": "宝具カード 3",
            "text": {
                "1_B230": "【红伐折罗】因陀罗大人是说因为闲着没事，所以才会出手。"
            }
        },
        "1_B2410": {
            "name": "アタック 13",
            "text": {
                "1_B2410": "偶尔也让他们见识一下本事吧。 【绿伐折罗】能看见吗～？"
            }
        },
        "1_B2420": {
            "name": "アタック 14",
            "text": {
                "1_B2420": "准了。 为神华丽地解决掉。 【红伐折罗】谨遵命令！"
            }
        },
        "1_B410": {
            "name": "アタック 4",
            "text": {
                "1_B410": "动手。 【伐折罗们】预备～，降下吧～！"
            }
        },
        "1_B420": {
            "name": "アタック 5",
            "text": {
                "1_B420": "【绿伐折罗】就是现在～♪ 【绿伐折罗】哇哇哇！？ 【绿伐折罗】真是的，你倒是好好看路啦～。"
            }
        },
        "1_B430": {
            "name": "アタック 6",
            "text": {
                "1_B430": "动手。 【绿伐折罗】比比谁更快～？ 【红伐折罗】无关紧要啦。"
            }
        },
        "1_B440": {
            "name": "エクストラアタック 2",
            "text": {
                "1_B440": "【红伐折罗】制裁指令·接收完毕。 【绿伐折罗】也就是说，该惩罚啦～！"
            }
        },
        "1_B480": {
            "name": "スキル 3",
            "text": {
                "1_B480": "神并不讨厌引人注目！"
            }
        },
        "1_B490": {
            "name": "スキル 4",
            "text": {
                "1_B490": "渗透到了灵基的每一个角落。"
            }
        },
        "1_B500": {
            "name": "開始 3",
            "text": {
                "1_B500": "掂量清楚自己的斤两。"
            }
        },
        "1_B520": {
            "name": "勝利 3",
            "text": {
                "1_B520": "【红伐折罗】您辛苦了。要喝点…… ……您已经在喝了呢。"
            }
        },
        "1_B800": {
            "name": "宝具 2",
            "text": {
                "1_B800": "此乃斩断群山翅膀之刃。",
                "1_B801": "乃开拓、支撑苍天的救济之光。即为——",
                "1_B802": "【伐折罗们】神之雷！　Śakra Vajra！",
                "1_B803": "……必杀台词难道不该由神来说吗？"
            }
        },
        "1_B810": {
            "name": "宝具 3",
            "text": {
                "1_B810": "吾乃因陀罗，为天地两界所畏惧者。",
                "1_B811": "吾乃弗栗多罕，为诛灭邪恶之蛇者！",
                "1_B812": "神雷解放——神之雷！",
                "1_B813": "吾之敌啊，沉入漫长的黑暗吧。"
            }
        },
        "1_B820": {
            "name": "宝具 4",
            "text": {
                "1_B820": "好吧，这便是戏耍的极致。",
                "1_B821": "就让你们见识一下由圣仙之骨所铸的吾之金刚吧。",
                "1_B822": "降临吧，神雷！　神之雷！",
                "1_B823": "哈～哈哈哈哈！"
            }
        },
        "1_B840": {
            "name": "エクストラアタック 3",
            "text": {
                "1_B840": "陀湿多打造之物啊，轰鸣吧！"
            }
        },
        "1_B880": {
            "name": "スキル 5",
            "text": {
                "1_B880": "只要这样做，你就会死。"
            }
        },
        "1_B890": {
            "name": "スキル 6",
            "text": {
                "1_B890": "【红伐折罗】因陀罗之夜—— 【绿伐折罗】狂热时间！"
            }
        },
        "1_B910": {
            "name": "アタック 7",
            "text": {
                "1_B910": "就用这个。 【伐折罗们】明白了！ 【伐折罗们】伐折罗·螺旋击！"
            }
        },
        "1_B920": {
            "name": "アタック 8",
            "text": {
                "1_B920": "让他们领教一下。 【伐折罗们】遵命！"
            }
        },
        "1_B930": {
            "name": "アタック 9",
            "text": {
                "1_B930": "动手。 【红伐折罗】来自侧面的伐折罗。 【绿伐折罗】来自上方的伐折罗～♪"
            }
        },
        "1_G010": {
            "name": "レベルアップ 1",
            "text": {
                "1_G010": "神明无法成长。",
                "1_G011": "这是自然现象。"
            }
        },
        "1_G020": {
            "name": "霊基再臨 2",
            "text": {
                "1_G020": "可别太得意忘形哦，人类。",
                "1_G021": "神还没允许你站到神的面前。",
                "1_G022": "因为如果正面与神相对，没准会被神过于耀眼的光辉灼瞎双眼哦。",
                "1_G023": "哈哈哈哈哈！",
                "1_G024": "现在就暂且望着神的背影，慢慢习惯吧。"
            }
        },
        "1_G030": {
            "name": "霊基再臨 1",
            "text": {
                "1_G030": "这是对于你送上的那些可爱供品的奖励。",
                "1_G031": "就允许你与神身处同一视角高度好了。",
                "1_G032": "【红伐折罗】明明只是自己走了下来，这理由听上去可能有些奇怪。",
                "1_G033": "……你烦死了，伐折罗。"
            }
        },
        "1_G110": {
            "name": "レベルアップ 2",
            "text": {
                "1_G110": "唔。",
                "1_G111": "或许正好用来……当下酒菜呢……"
            }
        },
        "1_G120": {
            "name": "レベルアップ 3",
            "text": {
                "1_G120": "不要慌，只是灵基开始适应了而已。"
            }
        },
        "1_H010": {
            "name": "誕生日",
            "text": {
                "1_H010": "嚯，今天是你的生日吗。",
                "1_H011": "可不能让人觉得诸神之王吝啬。",
                "1_H012": "想要什么尽管说。",
                "1_H013": "……但甘露和苏摩酒除外。"
            }
        },
        "1_H020": {
            "name": "イベント開催中",
            "text": {
                "1_H020": "似乎正在举行祭典。",
                "1_H021": "当然是为了赞颂吾这诸神之王吧？",
                "1_H022": "很好，为神带路吧。"
            }
        },
        "1_H030": {
            "name": "会話 1",
            "text": {
                "1_H030": "神已经开始厌倦在这里举杯畅饮了。",
                "1_H031": "应该还有其他足以取悦诸神之王双眼的地方吧。",
                "1_H032": "带路吧。"
            }
        },
        "1_H040": {
            "name": "会話 2",
            "text": {
                "1_H040": "【红伐折罗】因陀罗大人不会侍奉任何人。他会在这里，只是因为他本人如此希望而已。",
                "1_H041": "【绿伐折罗】可别误会了哦～？",
                "1_H042": "哼。神可没让你们连神要说的话都代劳，不过，大体就是这样。"
            }
        },
        "1_H050": {
            "name": "会話 3",
            "text": {
                "1_H050": "御主吗。",
                "1_H051": "为了对让神显现于此的奇迹表以敬意，神倒是不介意称你一句御主——",
                "1_H052": "但归根结底，你不过是犹如无数雨滴的人类之一罢了。",
                "1_H053": "别以为自己能随意命令诸神之王哦，人类。"
            }
        },
        "1_H060": {
            "name": "好きなこと",
            "text": {
                "1_H060": "甘露，苏摩……",
                "1_H061": "这些本就是为了被神喝下而存在的。",
                "1_H062": "如果人界也有能与之匹敌的酒，",
                "1_H063": "就尽管拿来吧。",
                "1_H064": "诸神之王会把它们全部喝干。",
                "1_H065": "这是莫大的荣耀吧？"
            }
        },
        "1_H070": {
            "name": "嫌いなこと",
            "text": {
                "1_H070": "哎哎，别苦修啦！　别让神看见！",
                "1_H071": "太可怕……不，会令人不适啦！"
            }
        },
        "1_H080": {
            "name": "聖杯について",
            "text": {
                "1_H080": "你说圣杯？",
                "1_H081": "无聊。",
                "1_H082": "诸神之王不会向其他东西许愿。",
                "1_H083": "不过，只要是神饮酒时使用的酒杯，应该可以全部称作圣杯吧。",
                "1_H084": "毕竟是神之口触碰过的器皿，你们应该好好崇拜！"
            }
        },
        "1_H090": {
            "name": "絆Lv.1",
            "text": {
                "1_H090": "这些家伙吗？是金刚杵。王需要棋子来操控。我将自己的一部分灵气分割出来，以巴休拉为核心，注入了微小的神性。原本我的这具躯体也不过是自己打造的容器，是神的凭依之物罢了。外形如何，我毫不在意。",
                "1_H091": "你说这两个？　是伐折罗。",
                "1_H092": "因为王总需要仆从嘛。",
                "1_H093": "神将自身灵基的一部分切分出来，以伐折罗为核心，寄宿了小小的神性。",
                "1_H095": "况且神的这身体也不过是神自己制造的容器，神的凭依之躯罢了。",
                "1_H096": "外形这种东西根本没什么好在意的。"
            }
        },
        "1_H100": {
            "name": "絆Lv.2",
            "text": {
                "1_H100": "既然你在意，那就告诉你吧，这两个家伙也算神明之一。",
                "1_H101": "因此并不存在所谓的性别。",
                "1_H102": "【绿伐折罗】没错没错，所以我们只是变成了自己觉得合适的样子而已～。",
                "1_H103": "【红伐折罗】我觉得只要能做出最基本的区分，怎么都行啦。"
            }
        },
        "1_H110": {
            "name": "絆Lv.3",
            "text": {
                "1_H110": "你似乎与不少神明都有交情。",
                "1_H111": "那神随便问你一句，你觉得在他们中，最为强大、最为耀眼的神明是哪一位？",
                "1_H112": "【红伐折罗】感觉答案只有一个呢。凝视～。",
                "1_H113": "【绿伐折罗】答错的话可是很惨的哦～♪咿嘻嘻！"
            }
        },
        "1_H120": {
            "name": "絆Lv.4",
            "text": {
                "1_H120": "喂。你那些胡说八道拿来下酒倒是不错。",
                "1_H121": "神可以允许你参加神之酒宴。",
                "1_H122": "不过，你喝的酒得自己准备哦。",
                "1_H123": "神的酒可不会赏给你。"
            }
        },
        "1_H130": {
            "name": "絆Lv.5",
            "text": {
                "1_H130": "作为对你信仰的奖赏，神就告诉你一件重要的事吧。",
                "1_H131": "听好了。",
                "1_H132": "真正强大的神明，不会挥汗如雨地劳动，也不会靠努力去成就什么。",
                "1_H133": "会做那种事的神明，都是弱小、丢人的家伙。",
                "1_H134": "也就是说，神不是那种神明。",
                "1_H135": "好好记住。"
            }
        },
        "1_H170": {
            "name": "会話 4",
            "text": {
                "1_H170": "湿婆神不在，取而代之的是你吗，帕尔瓦蒂。",
                "1_H171": "神再怎么说也不会对你出手啦。",
                "1_H172": "这么办吧，神保证不对你出手，相反，你也要保证无论神对哪个女人出手都不会来碍事……",
                "1_H173": "……不保证？",
                "1_H174": "嘁。"
            }
        },
        "1_H180": {
            "name": "会話 5",
            "text": {
                "1_H180": "杜尔伽。虽然你相当于我们所有神明的女儿……",
                "1_H181": "但你现在的最高优先级命令是如何定义的？",
                "1_H182": "……服从身为传达者的御主吗。",
                "1_H183": "好吧，反正也没什么差别。",
                "1_H184": "既然隶属于同一阵营，作为歼灭女神的你应该也会偶尔替神完成工作吧。",
                "1_H185": "要好好干哦。"
            }
        },
        "1_H190": {
            "name": "会話 6",
            "text": {
                "1_H190": "喂，你这家伙到底什么意思。",
                "1_H191": "既成了女人，又用了和帕尔瓦蒂相同的凭依之躯，似乎还强化了魔之要素……",
                "1_H192": "那把伐折罗也在恶心神吗？",
                "1_H193": "别用那种眼神看神啦。",
                "1_H194": "虽说的确是神让你去找湿婆的，但神也没想到湿婆会那么干脆地把你烧了。",
                "1_H195": "所以那不是神的错！",
                "1_H196": "要恨就去恨湿婆和帕尔瓦蒂吧！"
            }
        },
        "1_H200": {
            "name": "会話 7",
            "text": {
                "1_H200": "哦哦，那家伙是谁。",
                "1_H201": "像女神吉祥天女、又像狄罗德玛，还像兰跋……真是个好女人啊……！",
                "1_H202": "……",
                "1_H203": "…………？",
                "1_H204": "这不是弗栗多吗————！"
            }
        },
        "1_H210": {
            "name": "会話 8",
            "text": {
                "1_H210": "嚯，苏利耶的儿子，日轮之子啊。没想到你也在这里。",
                "1_H211": "你最终有没有使用神给你的那柄枪？",
                "1_H212": "……罢了。或许连使用过的事实都被消失了吧。",
                "1_H213": "总之，神都听说了。你输给了吾的儿子吧。",
                "1_H214": "倒也正常。",
                "1_H215": "因为太阳自然比不过能遮天蔽日的雷雨嘛。",
                "1_H216": "哈哈哈哈！"
            }
        },
        "1_H220": {
            "name": "会話 9",
            "text": {
                "1_H220": "吾的儿子啊，你可安好？",
                "1_H221": "需要像以前那样，由神再陪你锻炼锻炼吗？",
                "1_H222": "【红伐折罗】他说「当初陪我锻炼的好像基本是湿婆神吧……」",
                "1_H223": "不，那个，其实……怎么说呢……因为你当时还没达到那个境界……",
                "1_H224": "【绿伐折罗】因陀罗大人只是不好意思啦～♪咿嘻嘻！",
                "1_H225": "……闭嘴。"
            }
        },
        "1_H230": {
            "name": "会話 10",
            "text": {
                "1_H230": "喂，那边那个迦利的化身。",
                "1_H231": "你那身铠甲以前应该是神的东西吧？",
                "1_H232": "德罗纳给你的？　唔……感觉已经在无数人手里转过了呢。",
                "1_H233": "不过，这本来就是湿婆的东西。",
                "1_H234": "神也没什么资格说三道四。"
            }
        },
        "1_H240": {
            "name": "会話 11",
            "text": {
                "1_H240": "关于那是不是伽内什的问题……虽然尚无定论。",
                "1_H241": "但对于神明不该勤勤恳恳劳动的说法，神表示同意。",
                "1_H242": "不过既然诸神之王的神在此，那家伙肯定应该比神先行动吧？",
                "1_H243": "综上所述，那边的被炉归神了。快让开。"
            }
        },
        "1_H250": {
            "name": "会話 12",
            "text": {
                "1_H250": "很久以前，有一位圣仙。",
                "1_H251": "神实在忍受不了他那难看的苦行模样，于是派去了阿卜娑罗。",
                "1_H252": "之后在经历了很多事之后诞生的孩子，就是克里帕（慈悯）与克里毗（慈悯）。",
                "1_H253": "没错，马嘶，就是你的母亲。",
                "1_H254": "也就是说，如果没有神，你根本不会出生。",
                "1_H255": "你要好好感谢神哦。"
            }
        },
        "2_B010": {
            "name": "アタック 1",
            "text": {
                "2_B010": "神比任何事物都更快。"
            }
        },
        "2_B020": {
            "name": "アタック 2",
            "text": {
                "2_B020": "如暴雨般降下的雷霆如何？"
            }
        },
        "2_B030": {
            "name": "アタック 3",
            "text": {
                "2_B030": "回想起来吧。这片天空正是由神所开辟的！"
            }
        },
        "2_B040": {
            "name": "エクストラアタック 1",
            "text": {
                "2_B040": "嘁……有些火大了！"
            }
        },
        "2_B050": {
            "name": "宝具 1",
            "text": {
                "2_B050": "神王领域填充，空间冻结。",
                "2_B051": "神罚执行权限永续，王威解放。",
                "2_B052": "狂妄之徒们啊，仰望吾之雷霆吧！",
                "2_B053": "神之雷！"
            }
        },
        "2_B080": {
            "name": "スキル 1",
            "text": {
                "2_B080": "自帝释天界降临吧！"
            }
        },
        "2_B090": {
            "name": "スキル 2",
            "text": {
                "2_B090": "冷静点……要从容地上。"
            }
        },
        "2_B100": {
            "name": "開始 1",
            "text": {
                "2_B100": "感到荣幸吧，神会亲手杀了你。"
            }
        },
        "2_B110": {
            "name": "開始 2",
            "text": {
                "2_B110": "真本事？　哼，你难道以为神会拿出全力吗？"
            }
        },
        "2_B120": {
            "name": "勝利 1",
            "text": {
                "2_B120": "蠢货。竟敢让神费这么大劲……咳咳。 很符合神的风格，赢得很从容吧？"
            }
        },
        "2_B130": {
            "name": "勝利 2",
            "text": {
                "2_B130": "呼哈哈哈哈！　真是极致的美味！"
            }
        },
        "2_B140": {
            "name": "ダメージ 2",
            "text": {
                "2_B140": "杀了你。"
            }
        },
        "2_B150": {
            "name": "ダメージ 1",
            "text": {
                "2_B150": "绝对要杀了你。"
            }
        },
        "2_B160": {
            "name": "戦闘不能 1",
            "text": {
                "2_B160": "可恶，也太烂了吧……"
            }
        },
        "2_B170": {
            "name": "戦闘不能 2",
            "text": {
                "2_B170": "神记住你的脸了……！"
            }
        },
        "2_B180": {
            "name": "コマンドカード 1",
            "text": {
                "2_B180": "无关紧要。"
            }
        },
        "2_B190": {
            "name": "コマンドカード 2",
            "text": {
                "2_B190": "神会按自己的方式来。"
            }
        },
        "2_B200": {
            "name": "コマンドカード 3",
            "text": {
                "2_B200": "那又怎样？"
            }
        },
        "2_B2010": {
            "name": "アタック 10",
            "text": {
                "2_B2010": "吾命令天，将其轰灭吧！"
            }
        },
        "2_B2020": {
            "name": "アタック 11",
            "text": {
                "2_B2020": "竟让王亲自踢你之罪！"
            }
        },
        "2_B2030": {
            "name": "アタック 12",
            "text": {
                "2_B2030": "不必担心。神是不会放跑你的。"
            }
        },
        "2_B210": {
            "name": "宝具カード 1",
            "text": {
                "2_B210": "这情况岂能不喝啊。"
            }
        },
        "2_B220": {
            "name": "宝具カード 2",
            "text": {
                "2_B220": "神明才不会拼命。"
            }
        },
        "2_B230": {
            "name": "宝具カード 3",
            "text": {
                "2_B230": "既然你说到这份上了，那就给你吧。"
            }
        },
        "2_B2410": {
            "name": "アタック 13",
            "text": {
                "2_B2410": "不需要什么小把戏！"
            }
        },
        "2_B2420": {
            "name": "アタック 14",
            "text": {
                "2_B2420": "给你们上场的机会。 【红伐折罗】其实并不需要。 【绿伐折罗】我倒是超开心♪"
            }
        },
        "2_B410": {
            "name": "アタック 4",
            "text": {
                "2_B410": "这是神明的一踹，这是你的荣幸。"
            }
        },
        "2_B420": {
            "name": "アタック 5",
            "text": {
                "2_B420": "这酒可不是你能喝的，消失吧。"
            }
        },
        "2_B430": {
            "name": "アタック 6",
            "text": {
                "2_B430": "犹如迦楼罗的飞翔！"
            }
        },
        "2_B440": {
            "name": "エクストラアタック 2",
            "text": {
                "2_B440": "可恶，这是王的动作吗！？"
            }
        },
        "2_B480": {
            "name": "スキル 3",
            "text": {
                "2_B480": "这就是吾之威能！"
            }
        },
        "2_B490": {
            "name": "スキル 4",
            "text": {
                "2_B490": "这就是杀死你的天则。"
            }
        },
        "2_B500": {
            "name": "開始 3",
            "text": {
                "2_B500": "好久没有这么火大了。"
            }
        },
        "2_B520": {
            "name": "勝利 3",
            "text": {
                "2_B520": "别让神太热血了……"
            }
        },
        "2_B800": {
            "name": "宝具 2",
            "text": {
                "2_B800": "此乃斩断群山翅膀之刃。",
                "2_B801": "乃开拓、支撑苍天的救济之光。即为——",
                "2_B802": "【伐折罗们】神之雷！　Śakra Vajra！",
                "2_B803": "……必杀台词难道不该由神来说吗？"
            }
        },
        "2_B810": {
            "name": "宝具 3",
            "text": {
                "2_B810": "吾乃因陀罗，为天地两界所畏惧者。",
                "2_B811": "吾乃弗栗多罕，为诛灭邪恶之蛇者！",
                "2_B812": "神雷解放——神之雷！",
                "2_B813": "吾之敌啊，沉入漫长的黑暗吧。"
            }
        },
        "2_B820": {
            "name": "宝具 4",
            "text": {
                "2_B820": "好吧，这便是戏耍的极致。",
                "2_B821": "就让你们见识一下由圣仙之骨所铸的吾之金刚吧。",
                "2_B822": "降临吧，神雷！　神之雷！",
                "2_B823": "哈～哈哈哈哈！"
            }
        },
        "2_B840": {
            "name": "エクストラアタック 3",
            "text": {
                "2_B840": "啊啊啊啊，烦死了——！"
            }
        },
        "2_B880": {
            "name": "スキル 5",
            "text": {
                "2_B880": "不用慌，结果并不会改变。"
            }
        },
        "2_B890": {
            "name": "スキル 6",
            "text": {
                "2_B890": "呼哈哈哈！　叩拜吧！"
            }
        },
        "2_B910": {
            "name": "アタック 7",
            "text": {
                "2_B910": "让神休息一会儿。 【红伐折罗】请交给我们吧。 【绿伐折罗】我们来收拾干净♪"
            }
        },
        "2_B920": {
            "name": "アタック 8",
            "text": {
                "2_B920": "陀提遮之骨啊，疾驰吧！"
            }
        },
        "2_B930": {
            "name": "アタック 9",
            "text": {
                "2_B930": "包围一切万物！"
            }
        },
        "2_G010": {
            "name": "レベルアップ 1",
            "text": {
                "2_G010": "神明无法成长。",
                "2_G011": "这是自然现象。"
            }
        },
        "2_G040": {
            "name": "霊基再臨 1",
            "text": {
                "2_G040": "原本并不想让你看见这种形态……",
                "2_G041": "但有时候也无可奈何。",
                "2_G042": "啊？　你问这是什么形态？",
                "2_G043": "【绿伐折罗】是因陀罗大人最帅气的形象～♪",
                "2_G044": "【红伐折罗】在我看来也只能这么说了。",
                "2_G045": "哎哎，你们两个给神闭嘴。",
                "2_G046": "总之，神没兴趣解释。",
                "2_G047": "等完事之后就立刻把这样的神忘掉。明白了吗。"
            }
        },
        "2_G050": {
            "name": "霊基再臨 2",
            "text": {
                "2_G050": "神乃是诸神之王。理应悠然自得、从容不迫地面对一切才对。",
                "2_G051": "然而——可恶。",
                "2_G052": "不知为何，有时总会狼狈不堪、像弱小人类那样拼死挣扎。而这个形象就是那种状态的象征。",
                "2_G053": "你想必也对这诸神之王的形态——",
                "2_G054": "什么？　正如伐折罗他们所言，这是神看起来最耀眼的时候？",
                "2_G055": "……哼，别说胡话了。",
                "2_G056": "按照约定，不准把神究竟如何战斗过的样子写进什么叙事诗或赞歌里哦。",
                "2_G057": "不过嘛……如果只是留存在记忆之中，倒是可以允许。",
                "2_G058": "就将神这道最为鲜烈的雷光烙印在脑海中——",
                "2_G059": "人类啊，去活完你那短暂的一生吧。"
            }
        },
        "2_G110": {
            "name": "レベルアップ 2",
            "text": {
                "2_G110": "唔。",
                "2_G111": "或许正好用来……当下酒菜呢……"
            }
        },
        "2_G120": {
            "name": "レベルアップ 3",
            "text": {
                "2_G120": "不要慌，只是灵基开始适应了而已。"
            }
        },
        "2_H010": {
            "name": "誕生日",
            "text": {
                "2_H010": "嚯，今天是你的生日吗。",
                "2_H011": "可不能让人觉得诸神之王吝啬。",
                "2_H012": "想要什么尽管说。",
                "2_H013": "……但甘露和苏摩酒除外。"
            }
        },
        "2_H020": {
            "name": "イベント開催中",
            "text": {
                "2_H020": "似乎正在举行祭典。",
                "2_H021": "当然是为了赞颂吾这诸神之王吧？",
                "2_H022": "很好，为神带路吧。"
            }
        },
        "2_H030": {
            "name": "会話 1",
            "text": {
                "2_H030": "神已经开始厌倦在这里举杯畅饮了。",
                "2_H031": "应该还有其他足以取悦诸神之王双眼的地方吧。",
                "2_H032": "带路吧。"
            }
        },
        "2_H040": {
            "name": "会話 2",
            "text": {
                "2_H040": "【红伐折罗】因陀罗大人不会侍奉任何人。他会在这里，只是因为他本人如此希望而已。",
                "2_H041": "【绿伐折罗】可别误会了哦～？",
                "2_H042": "哼。神可没让你们连神要说的话都代劳，不过，大体就是这样。"
            }
        },
        "2_H050": {
            "name": "会話 3",
            "text": {
                "2_H050": "御主吗。",
                "2_H051": "为了对让神显现于此的奇迹表以敬意，神倒是不介意称你一句御主——",
                "2_H052": "但归根结底，你不过是犹如无数雨滴的人类之一罢了。",
                "2_H053": "别以为自己能随意命令诸神之王哦，人类。"
            }
        },
        "2_H060": {
            "name": "好きなこと",
            "text": {
                "2_H060": "甘露，苏摩……",
                "2_H061": "这些本就是为了被神喝下而存在的。",
                "2_H062": "如果人界也有能与之匹敌的酒，",
                "2_H063": "就尽管拿来吧。",
                "2_H064": "诸神之王会把它们全部喝干。",
                "2_H065": "这是莫大的荣耀吧？"
            }
        },
        "2_H070": {
            "name": "嫌いなこと",
            "text": {
                "2_H070": "哎哎，别苦修啦！　别让神看见！",
                "2_H071": "太可怕……不，会令人不适啦！"
            }
        },
        "2_H080": {
            "name": "聖杯について",
            "text": {
                "2_H080": "你说圣杯？",
                "2_H081": "无聊。",
                "2_H082": "诸神之王不会向其他东西许愿。",
                "2_H083": "不过，只要是神饮酒时使用的酒杯，应该可以全部称作圣杯吧。",
                "2_H084": "毕竟是神之口触碰过的器皿，你们应该好好崇拜！"
            }
        },
        "2_H090": {
            "name": "絆Lv.1",
            "text": {
                "2_H090": "这些家伙吗？是金刚杵。王需要使唤的棋子。  我分出一部分灵气，以伐折罗为核心，注入了些许神圣。  说到底，我这副身体也不过是自制的容器，是神明的凭依罢了。  姿态、形体这些，我根本不在意。",
                "2_H091": "你说这两个？　是伐折罗。",
                "2_H092": "因为王总需要仆从嘛。",
                "2_H093": "神将自身灵基的一部分切分出来，以伐折罗为核心，寄宿了小小的神性。",
                "2_H095": "况且神的这身体也不过是神自己制造的容器，神的凭依之躯罢了。",
                "2_H096": "外形这种东西根本没什么好在意的。"
            }
        },
        "2_H100": {
            "name": "絆Lv.2",
            "text": {
                "2_H100": "既然你在意，那就告诉你吧，这两个家伙也算神明之一。",
                "2_H101": "因此并不存在所谓的性别。",
                "2_H102": "【绿伐折罗】没错没错，所以我们只是变成了自己觉得合适的样子而已～。",
                "2_H103": "【红伐折罗】我觉得只要能做出最基本的区分，怎么都行啦。"
            }
        },
        "2_H110": {
            "name": "絆Lv.3",
            "text": {
                "2_H110": "你似乎与不少神明都有交情。",
                "2_H111": "那神随便问你一句，你觉得在他们中，最为强大、最为耀眼的神明是哪一位？",
                "2_H112": "【红伐折罗】感觉答案只有一个呢。凝视～。",
                "2_H113": "【绿伐折罗】答错的话可是很惨的哦～♪咿嘻嘻！"
            }
        },
        "2_H120": {
            "name": "絆Lv.4",
            "text": {
                "2_H120": "喂。你那些胡说八道拿来下酒倒是不错。",
                "2_H121": "神可以允许你参加神之酒宴。",
                "2_H122": "不过，你喝的酒得自己准备哦。",
                "2_H123": "神的酒可不会赏给你。"
            }
        },
        "2_H130": {
            "name": "絆Lv.5",
            "text": {
                "2_H130": "作为对你信仰的奖赏，神就告诉你一件重要的事吧。",
                "2_H131": "听好了。",
                "2_H132": "真正强大的神明，不会挥汗如雨地劳动，也不会靠努力去成就什么。",
                "2_H133": "会做那种事的神明，都是弱小、丢人的家伙。",
                "2_H134": "也就是说，神不是那种神明。",
                "2_H135": "好好记住。"
            }
        },
        "2_H170": {
            "name": "会話 4",
            "text": {
                "2_H170": "湿婆神不在，取而代之的是你吗，帕尔瓦蒂。",
                "2_H171": "神再怎么说也不会对你出手啦。",
                "2_H172": "这么办吧，神保证不对你出手，相反，你也要保证无论神对哪个女人出手都不会来碍事……",
                "2_H173": "……不保证？",
                "2_H174": "嘁。"
            }
        },
        "2_H180": {
            "name": "会話 5",
            "text": {
                "2_H180": "杜尔伽。虽然你相当于我们所有神明的女儿……",
                "2_H181": "但你现在的最高优先级命令是如何定义的？",
                "2_H182": "……服从身为传达者的御主吗。",
                "2_H183": "好吧，反正也没什么差别。",
                "2_H184": "既然隶属于同一阵营，作为歼灭女神的你应该也会偶尔替神完成工作吧。",
                "2_H185": "要好好干哦。"
            }
        },
        "2_H190": {
            "name": "会話 6",
            "text": {
                "2_H190": "喂，你这家伙到底什么意思。",
                "2_H191": "既成了女人，又用了和帕尔瓦蒂相同的凭依之躯，似乎还强化了魔之要素……",
                "2_H192": "那把伐折罗也在恶心神吗？",
                "2_H193": "别用那种眼神看神啦。",
                "2_H194": "虽说的确是神让你去找湿婆的，但神也没想到湿婆会那么干脆地把你烧了。",
                "2_H195": "所以那不是神的错！",
                "2_H196": "要恨就去恨湿婆和帕尔瓦蒂吧！"
            }
        },
        "2_H200": {
            "name": "会話 7",
            "text": {
                "2_H200": "哦哦，那家伙是谁。",
                "2_H201": "像女神吉祥天女、又像狄罗德玛，还像兰跋……真是个好女人啊……！",
                "2_H202": "……",
                "2_H203": "…………？",
                "2_H204": "这不是弗栗多吗————！"
            }
        },
        "2_H210": {
            "name": "会話 8",
            "text": {
                "2_H210": "嚯，苏利耶的儿子，日轮之子啊。没想到你也在这里。",
                "2_H211": "你最终有没有使用神给你的那柄枪？",
                "2_H212": "……罢了。或许连使用过的事实都被消失了吧。",
                "2_H213": "总之，神都听说了。你输给了吾的儿子吧。",
                "2_H214": "倒也正常。",
                "2_H215": "因为太阳自然比不过能遮天蔽日的雷雨嘛。",
                "2_H216": "哈哈哈哈！"
            }
        },
        "2_H220": {
            "name": "会話 9",
            "text": {
                "2_H220": "吾的儿子啊，你可安好？",
                "2_H221": "需要像以前那样，由神再陪你锻炼锻炼吗？",
                "2_H222": "【红伐折罗】他说「当初陪我锻炼的好像基本是湿婆神吧……」",
                "2_H223": "不，那个，其实……怎么说呢……因为你当时还没达到那个境界……",
                "2_H224": "【绿伐折罗】因陀罗大人只是不好意思啦～♪咿嘻嘻！",
                "2_H225": "……闭嘴。"
            }
        },
        "2_H230": {
            "name": "会話 10",
            "text": {
                "2_H230": "喂，那边那个迦利的化身。",
                "2_H231": "你那身铠甲以前应该是神的东西吧？",
                "2_H232": "德罗纳给你的？　唔……感觉已经在无数人手里转过了呢。",
                "2_H233": "不过，这本来就是湿婆的东西。",
                "2_H234": "神也没什么资格说三道四。"
            }
        },
        "2_H240": {
            "name": "会話 11",
            "text": {
                "2_H240": "关于那是不是伽内什的问题……虽然尚无定论。",
                "2_H241": "但对于神明不该勤勤恳恳劳动的说法，神表示同意。",
                "2_H242": "不过既然诸神之王的神在此，那家伙肯定应该比神先行动吧？",
                "2_H243": "综上所述，那边的被炉归神了。快让开。"
            }
        },
        "2_H250": {
            "name": "会話 12",
            "text": {
                "2_H250": "很久以前，有一位圣仙。",
                "2_H251": "神实在忍受不了他那难看的苦行模样，于是派去了阿卜娑罗。",
                "2_H252": "之后在经历了很多事之后诞生的孩子，就是克里帕（慈悯）与克里毗（慈悯）。",
                "2_H253": "没错，马嘶，就是你的母亲。",
                "2_H254": "也就是说，如果没有神，你根本不会出生。",
                "2_H255": "你要好好感谢神哦。"
            }
        }
    },
    "ChrVoice_ids": [
        "305900"
    ]
}