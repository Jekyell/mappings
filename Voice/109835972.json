{
    "id": 109835972,
    "name": "",
    "voices": {
        "0_M010": {
            "name": "ミッションについて 1",
            "text": {
                "0_M010": "做得很好。给你一点奖励吧。",
                "0_M011": ""
            }
        },
        "0_M020": {
            "name": "ミッションについて 2",
            "text": {
                "0_M020": "这是我的珍藏。要对弗朗索瓦保密哦。",
                "0_M021": ""
            }
        },
        "0_M030": {
            "name": "ミッションについて 3",
            "text": {
                "0_M030": "你以为到此为止了吗？真遗憾。是下一个任务。",
                "0_M031": ""
            }
        },
        "0_M040": {
            "name": "ミッションについて 4",
            "text": {
                "0_M040": "哎呀呀？感觉情况有点不对劲，去确认一下看看吧。"
            }
        },
        "0_M050": {
            "name": "Fate/strange Fakeコラボイベント 16",
            "text": {
                "0_M050": "是新的约会地点吗？不去看看吗？"
            }
        },
        "0_M060": {
            "name": "Fate/strange Fakeコラボイベント 17",
            "text": {
                "0_M060": "增加这么多希波吕忒酱，是打算把迦勒底变成亚马逊人的国度吗？",
                "0_M061": ""
            }
        },
        "0_N010": {
            "name": "Fate/strange Fakeコラボイベント 12",
            "text": {
                "0_N010": "为了不让人生就此终结，大家绝对不可以做会被逮捕的事情哦。这是和弗兰切斯卡姐姐的约定。",
                "0_N011": ""
            }
        },
        "0_N020": {
            "name": "Fate/strange Fakeコラボイベント 13",
            "text": {
                "0_N020": "你问我不是应该已经消失了吗？现在的我是弗朗索瓦的现实哦。虽然因为用力过猛，弗朗索瓦可能没有留下关于现在的我的记忆就是了。",
                "0_N021": "",
                "0_N022": ""
            }
        },
        "0_N030": {
            "name": "イベントについて 3",
            "text": {
                "0_N030": "呐呐，弗朗索瓦和我，你更喜欢哪一个？啊，抱歉抱歉，我问法不对。是哪一个更讨厌？如果只能让一个人消失的话，你会选谁？",
                "0_N031": "",
                "0_N032": "",
                "0_N033": ""
            }
        },
        "0_N040": {
            "name": "イベントについて 4",
            "text": {
                "0_N040": "快乐的任务，愉快的任务。完成了就有惊喜。我会给你一份特别的奖励哦。",
                "0_N041": "",
                "0_N042": ""
            }
        },
        "0_N050": {
            "name": "イベントについて 5",
            "text": {
                "0_N050": "信息公告。不想看的话也可以无视哦。毕竟看着你因为错过了重要的事情，事后在那悔恨哭泣的样子，感觉也挺有趣的呢。",
                "0_N051": "",
                "0_N052": ""
            }
        }
    },
