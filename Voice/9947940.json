{
    "id": 9947940,
    "name": "Enemy 9947940",
    "voices": {
        "0_B010": {
            "name": "0_B010",
            "text": {
                "0_B010": "看得到吗？"
            },
            "raw_text": {
                "0_B010": "見えるか。"
            }
        },
        "0_B020": {
            "name": "0_B020",
            "text": {
                "0_B020": "沉入河底吧。"
            },
            "raw_text": {
                "0_B020": "川の底へ。"
            }
        },
        "0_B030": {
            "name": "0_B030",
            "text": {
                "0_B030": "引向冥府之路吧。"
            },
            "raw_text": {
                "0_B030": "読みじへ誘え。"
            }
        },
        "0_B040": {
            "name": "0_B040",
            "text": {
                "0_B040": "黑暗、黑暗、黑暗、黑暗。"
            },
            "raw_text": {
                "0_B040": "暗く暗く暗く暗く。"
            }
        },
        "0_B050": {
            "name": "0_B050",
            "text": {
                "0_B050": "吾身为河，吾身为冥府。"
            },
            "raw_text": {
                "0_B050": "我が身は皮、我が身は冥府。"
            }
        },
        "0_B051": {
            "name": "0_B051",
            "text": {
                "0_B051": "包容并吞噬一切，引向深邃的黑暗。"
            },
            "raw_text": {
                "0_B051": "すべてを包み飲み込み暗き闇へと誘わん。"
            }
        },
        "0_B052": {
            "name": "0_B052",
            "text": {
                "0_B052": "冥界之河。"
            },
            "raw_text": {
                "0_B052": "ポタモス中カトコズム。"
            }
        },
        "0_B053": {
            "name": "0_B053",
            "text": {
                "0_B053": "包容一切。"
            },
            "raw_text": {
                "0_B053": "すべてを包み。"
            }
        },
        "0_B054": {
            "name": "0_B054",
            "text": {
                "0_B054": "引向深邃的黑暗。"
            },
            "raw_text": {
                "0_B054": "暗き闇へと誘は。"
            }
        },
        "0_B080": {
            "name": "0_B080",
            "text": {
                "0_B080": "燃烧吧，吾之河川。"
            },
            "raw_text": {
                "0_B080": "燃え上がる我が川よ。"
            }
        },
        "0_B090": {
            "name": "0_B090",
            "text": {
                "0_B090": "降临吧，我的冥府。"
            },
            "raw_text": {
                "0_B090": "来たり、我が冥府。"
            }
        },
        "0_B100": {
            "name": "0_B100",
            "text": {
                "0_B100": "好吧。由我来结束这场战斗。"
            },
            "raw_text": {
                "0_B100": "いいだろう。僕が戦いを終わらせる。"
            }
        },
        "0_B110": {
            "name": "0_B110",
            "text": {
                "0_B110": "你竟敢踏入我的领域。"
            },
            "raw_text": {
                "0_B110": "われの領域に足を踏み入れたな。"
            }
        },
        "0_B120": {
            "name": "0_B120",
            "text": {
                "0_B120": "似乎结束了。御主怎么样？若平安无事便好。"
            },
            "raw_text": {
                "0_B120": "終わったようだ。マスターはどうだ。無事ならばよい。"
            }
        },
        "0_B130": {
            "name": "0_B130",
            "text": {
                "0_B130": "虽然很抱歉借用了父亲的力量，但这样的话绝不可能输。"
            },
            "raw_text": {
                "0_B130": "父の力を借りて申し訳ないですがこれなら負けるはずもありません。"
            }
        },
        "0_B140": {
            "name": "0_B140",
            "text": {
                "0_B140": "喂。"
            },
            "raw_text": {
                "0_B140": "ねえ。"
            }
        },
        "0_B150": {
            "name": "0_B150",
            "text": {
                "0_B150": "仅凭这种程度吗。"
            },
            "raw_text": {
                "0_B150": "この程度で。"
            }
        },
        "0_B160": {
            "name": "0_B160",
            "text": {
                "0_B160": "对不起，我的儿子。"
            },
            "raw_text": {
                "0_B160": "すまない息子よ。"
            }
        },
        "0_B170": {
            "name": "0_B170",
            "text": {
                "0_B170": "让我稍微休息一下吧。"
            },
            "raw_text": {
                "0_B170": "少し休ませてもらいます。"
            }
        },
        "0_B180": {
            "name": "0_B180",
            "text": {
                "0_B180": "好吧。"
            },
            "raw_text": {
                "0_B180": "よかろう。"
            }
        },
        "0_B190": {
            "name": "0_B190",
            "text": {
                "0_B190": "如您所愿。"
            },
            "raw_text": {
                "0_B190": "そのように。"
            }
        },
        "0_B200": {
            "name": "0_B200",
            "text": {
                "0_B200": "试一试吧。"
            },
            "raw_text": {
                "0_B200": "やってみよう。"
            }
        },
        "0_B2010": {
            "name": "0_B2010",
            "text": {
                "0_B2010": "啊。"
            },
            "raw_text": {
                "0_B2010": "ああ。"
            }
        },
        "0_B2020": {
            "name": "0_B2020",
            "text": {
                "0_B2020": "吞噬殆尽吧。"
            },
            "raw_text": {
                "0_B2020": "喰らい尽くせ。"
            }
        },
        "0_B2030": {
            "name": "0_B2030",
            "text": {
                "0_B2030": "随流逝去吧。"
            },
            "raw_text": {
                "0_B2030": "流れて果てよ。"
            }
        },
        "0_B210": {
            "name": "0_B210",
            "text": {
                "0_B210": "是吗，在呼唤我的河川吗。"
            },
            "raw_text": {
                "0_B210": "そうか我が川を呼ぶか。"
            }
        },
        "0_B220": {
            "name": "0_B220",
            "text": {
                "0_B220": "既然如此，便将一切粉碎并吞噬殆尽。"
            },
            "raw_text": {
                "0_B220": "ならば全てを砕き飲み干さん。"
            }
        },
        "0_B2410": {
            "name": "0_B2410",
            "text": {
                "0_B2410": "吾之刃啊。"
            },
            "raw_text": {
                "0_B2410": "我が刃よ。"
            }
        },
        "0_B2420": {
            "name": "0_B2420",
            "text": {
                "0_B2420": "在此一战中。"
            },
            "raw_text": {
                "0_B2420": "この一戦で。"
            }
        },
        "0_B2430": {
            "name": "0_B2430",
            "text": {
                "0_B2430": "光是碎尸万段还不够吗？"
            },
            "raw_text": {
                "0_B2430": "八つ裂きでは足りぬか。"
            }
        },
        "0_B2810": {
            "name": "0_B2810",
            "text": {
                "0_B2810": "撕裂吧。"
            },
            "raw_text": {
                "0_B2810": "見だれ酒。"
            }
        },
        "0_B410": {
            "name": "0_B410",
            "text": {
                "0_B410": "浑身是窟窿也不坏呢。"
            },
            "raw_text": {
                "0_B410": "穴だらけも悪くないさ。"
            }
        },
        "0_B420": {
            "name": "0_B420",
            "text": {
                "0_B420": "吞噬吧。"
            },
            "raw_text": {
                "0_B420": "クラウンがいい。"
            }
        },
        "0_B430": {
            "name": "0_B430",
            "text": {
                "0_B430": "奔流吧！"
            },
            "raw_text": {
                "0_B430": "ほとばしれ。"
            }
        },
        "0_B440": {
            "name": "0_B440",
            "text": {
                "0_B440": "我的河川将把你吞噬。"
            },
            "raw_text": {
                "0_B440": "我が川がお前を飲み込め。"
            }
        },
        "0_B480": {
            "name": "0_B480",
            "text": {
                "0_B480": "要来品尝一下吗？"
            },
            "raw_text": {
                "0_B480": "一つ賞味してみるかい。"
            }
        },
        "0_B800": {
            "name": "0_B800",
            "text": {
                "0_B800": "带你走不需要摆渡人。"
            },
            "raw_text": {
                "0_B800": "お前を連れて行くのに私森はいらぬ。"
            }
        },
        "0_B801": {
            "name": "0_B801",
            "text": {
                "0_B801": "与虚幻的梦境一同流逝吧。"
            },
            "raw_text": {
                "0_B801": "儚き夢と共に流れゆけ。"
            }
        },
        "0_B802": {
            "name": "0_B802",
            "text": {
                "0_B802": "冥界之河。"
            },
            "raw_text": {
                "0_B802": "ポタモスチューカトコズム。"
            }
        },
        "0_B810": {
            "name": "0_B810",
            "text": {
                "0_B810": "你听到那流水声了吗？"
            },
            "raw_text": {
                "0_B810": "その流れを聞いたか。"
            }
        },
        "0_B811": {
            "name": "0_B811",
            "text": {
                "0_B811": "你触碰到那股冰冷了吗？"
            },
            "raw_text": {
                "0_B811": "その冷たさに触れたか。"
            }
        },
        "0_B812": {
            "name": "0_B812",
            "text": {
                "0_B812": "死之河来迎接你了。"
            },
            "raw_text": {
                "0_B812": "死の川がお前を迎えに来たぞ。"
            }
        },
        "0_B813": {
            "name": "0_B813",
            "text": {
                "0_B813": "冥界之河。"
            },
            "raw_text": {
                "0_B813": "ポタモスティーカトカズム。"
            }
        },
        "0_B910": {
            "name": "0_B910",
            "text": {
                "0_B910": "贯穿。"
            },
            "raw_text": {
                "0_B910": "突き抜ける。"
            }
        },
        "0_B920": {
            "name": "0_B920",
            "text": {
                "0_B920": "力量啊，化作漩涡吧。"
            },
            "raw_text": {
                "0_B920": "力よ、渦巻。"
            }
        },
        "0_B930": {
            "name": "0_B930",
            "text": {
                "0_B930": "深渊啊，降临吧。"
            },
            "raw_text": {
                "0_B930": "深淵よ来たり。"
            }
        }
    }
}