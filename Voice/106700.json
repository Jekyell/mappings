{
    "id": 106700,
    "collectionNo": 472,
    "name": "グレイ・リリィ",
    "voices": {
        "0_B010": {
            "name": "アタック 1",
            "text": {
                "0_B010": "嗖地一下冲过去喽！头好晕！"
            },
            "raw_text": {
                "0_B010": "ブーンっていくよ！目が回る！"
            }
        },
        "0_B020": {
            "name": "アタック 2",
            "text": {
                "0_B020": "既然这样，那就看这招！"
            },
            "raw_text": {
                "0_B020": "だったらこいつだ！"
            }
        },
        "0_B030": {
            "name": "アタック 3",
            "text": {
                "0_B030": "在村正那儿学到的——嘿咻！"
            },
            "raw_text": {
                "0_B030": "村正のところで ほいさ。"
            }
        },
        "0_B040": {
            "name": "エクストラアタック 1",
            "text": {
                "0_B040": "免费的！大酬宾啦！",
                "0_B041": ""
            },
            "raw_text": {
                "0_B040": "ただめだ！オーバン振る舞いだぜ！",
                "0_B041": ""
            }
        },
        "0_B050": {
            "name": "宝具 1",
            "text": {
                "0_B050": "于此编织的是梦之气息。",
                "0_B051": "连宿命也能斩断的年轻生命之奔流。",
                "0_B052": "第二阶段，封印限定解除。",
                "0_B053": "誓约胜利之剑·罗格斯！"
            },
            "raw_text": {
                "0_B050": "ここに紡ぐは夢のいい武器。宿命すら断ち切る、若き命の本流。第二段階、応用限定解除。エクスカリバー ラガス！",
                "0_B051": "",
                "0_B052": "",
                "0_B053": ""
            }
        },
        "0_B080": {
            "name": "スキル 1",
            "text": {
                "0_B080": "要全开马力上喽——"
            },
            "raw_text": {
                "0_B080": "パワー全開でいくぞー。"
            }
        },
        "0_B100": {
            "name": "開始 1",
            "text": {
                "0_B100": "「要出发啰～」「嘿嘿嘿，可别闹得太凶结果自己倒下啦！」"
            },
            "raw_text": {
                "0_B100": "いくよーんふふふ暴れすぎて倒れんなよ。"
            }
        },
        "0_B110": {
            "name": "開始 2",
            "text": {
                "0_B110": "我会努力的，看着我哦，御主。"
            },
            "raw_text": {
                "0_B110": "頑張るから見ててね、マスター。"
            }
        },
        "0_B120": {
            "name": "勝利 1",
            "text": {
                "0_B120": "太好了！感觉真棒呢。嘛，胜利的感觉确实不坏啊。"
            },
            "raw_text": {
                "0_B120": "やったー！気持ちいいね。まあ勝利ってのは悪くないな。"
            }
        },
        "0_B130": {
            "name": "勝利 2",
            "text": {
                "0_B130": "哟吼——！大胜利！这样的话，御主和师匠也会认可我们的吧！"
            },
            "raw_text": {
                "0_B130": "よおおおっ大勝利！これならマスターも師匠も納得でしょう！"
            }
        },
        "0_B140": {
            "name": "ダメージ 2",
            "text": {
                "0_B140": "唔……！"
            },
            "raw_text": {
                "0_B140": "くうっ。"
            }
        },
        "0_B150": {
            "name": "ダメージ 1",
            "text": {
                "0_B150": "快住手！这家伙太棘手了！"
            },
            "raw_text": {
                "0_B150": "止めて！こいつはきつい！"
            }
        },
        "0_B160": {
            "name": "戦闘不能 1",
            "text": {
                "0_B160": "对不起，御主、师匠。"
            },
            "raw_text": {
                "0_B160": "ごめんマスター、師匠。"
            }
        },
        "0_B170": {
            "name": "戦闘不能 2",
            "text": {
                "0_B170": "可能有点勉强了。抱歉啦，我们先暂时撤退了！"
            },
            "raw_text": {
                "0_B170": "ちょっと無理したかも。悪いな、一時退避するぜ。"
            }
        },
        "0_B180": {
            "name": "コマンドカード 1",
            "text": {
                "0_B180": "要用那个是吧。"
            },
            "raw_text": {
                "0_B180": "それで行くんだね。"
            }
        },
        "0_B190": {
            "name": "コマンドカード 2",
            "text": {
                "0_B190": "交给我吧。"
            },
            "raw_text": {
                "0_B190": "任せて。"
            }
        },
        "0_B200": {
            "name": "コマンドカード 3",
            "text": {
                "0_B200": "好嘞！"
            },
            "raw_text": {
                "0_B200": "オッケー。"
            }
        },
        "0_B2010": {
            "name": "アタック 10",
            "text": {
                "0_B2010": "要轰飞你啦！"
            },
            "raw_text": {
                "0_B2010": "ぶっ放すから！"
            }
        },
        "0_B2020": {
            "name": "アタック 11",
            "text": {
                "0_B2020": "锐利地攻过去。既然这样的话，那就这样！"
            },
            "raw_text": {
                "0_B2020": "鋭く行くぞ。だったらこうだ。"
            }
        },
        "0_B2030": {
            "name": "アタック 12",
            "text": {
                "0_B2030": "连携攻击！"
            },
            "raw_text": {
                "0_B2030": "コンビネーションだ！"
            }
        },
        "0_B210": {
            "name": "宝具カード 1",
            "text": {
                "0_B210": "封印礼装，解除！"
            },
            "raw_text": {
                "0_B210": "封印礼装解除。"
            }
        },
        "0_B220": {
            "name": "宝具カード 2",
            "text": {
                "0_B220": "找到了？好嘞，该我出场啦！"
            },
            "raw_text": {
                "0_B220": "あった？よっしゃ、出番だな！"
            }
        },
        "0_B2410": {
            "name": "アタック 13",
            "text": {
                "0_B2410": "唰唰唰地攻过去喽！看起来很有趣呢！"
            },
            "raw_text": {
                "0_B2410": "ズバババっていくよ！楽しそうだな！"
            }
        },
        "0_B2420": {
            "name": "アタック 14",
            "text": {
                "0_B2420": "用这个斩裂吧！"
            },
            "raw_text": {
                "0_B2420": "こいつで切り裂け。"
            }
        },
        "0_B410": {
            "name": "アタック 4",
            "text": {
                "0_B410": "刀真帅气啊！"
            },
            "raw_text": {
                "0_B410": "刀ってかっこいいよね！"
            }
        },
        "0_B420": {
            "name": "アタック 5",
            "text": {
                "0_B420": "我要狠狠地来一下了！交给我吧！"
            },
            "raw_text": {
                "0_B420": "ドンってやるから！任せる！"
            }
        },
        "0_B430": {
            "name": "アタック 6",
            "text": {
                "0_B430": "使出全力啦啊啊！"
            },
            "raw_text": {
                "0_B430": "ああ、まいっきりだああ。"
            }
        },
        "0_B440": {
            "name": "エクストラアタック 2",
            "text": {
                "0_B440": "全部使出来，大干一场啦！",
                "0_B441": ""
            },
            "raw_text": {
                "0_B440": "全部出してやるやってやるぜい。",
                "0_B441": ""
            }
        },
        "0_B480": {
            "name": "スキル 2",
            "text": {
                "0_B480": "要上喽，亚德！嘿嘿嘿，真拿你没办法啊。"
            },
            "raw_text": {
                "0_B480": "やるぞアット！えへへへへ、仕方ねえな。"
            }
        },
        "0_B490": {
            "name": "スキル 3",
            "text": {
                "0_B490": "拙要上喽。"
            },
            "raw_text": {
                "0_B490": "せつがやっちゃうから。"
            }
        },
        "0_B500": {
            "name": "開始 3",
            "text": {
                "0_B500": "要尽情享受个够啦——"
            },
            "raw_text": {
                "0_B500": "思いっきり楽しんじゃうぞー。"
            }
        },
        "0_B510": {
            "name": "開始 4",
            "text": {
                "0_B510": "好，要上喽，亚德！噢，这家伙可得打起精神来啊！"
            },
            "raw_text": {
                "0_B510": "さあ行くぞ、アッパ！おっと、こいつは気ばらねえとな！"
            }
        },
        "0_B520": {
            "name": "勝利 3",
            "text": {
                "0_B520": "手感棒极了！啊，那个，不疼吧？现在是担心别人的时候吗！"
            },
            "raw_text": {
                "0_B520": "抜群の手応え。あ、でも痛くなかった？他人の心配してる場合かっての！"
            }
        },
        "0_B540": {
            "name": "ダメージ 4",
            "text": {
                "0_B540": "啊啊！"
            },
            "raw_text": {
                "0_B540": "ああ！"
            }
        },
        "0_B550": {
            "name": "ダメージ 3",
            "text": {
                "0_B550": "这种程度……！加油啊，格蕾！"
            },
            "raw_text": {
                "0_B550": "こんなの！頑張れグレイ！"
            }
        },
        "0_B800": {
            "name": "宝具 2",
            "text": {
                "0_B800": "这盏灯火是未来的光辉，",
                "0_B801": "终将抵达星辰的宿命之一闪。",
                "0_B802": "第二阶段，封印限定解除。",
                "0_B803": "誓约胜利之剑·罗格斯！"
            },
            "raw_text": {
                "0_B800": "この灯火は未来の輝き、いずれ星に至る宿命の一戦。第二段階、応用限定解除。エクスカリバー・ラゴス！",
                "0_B801": "",
                "0_B802": "",
                "0_B803": ""
            }
        },
        "0_B810": {
            "name": "宝具 3",
            "text": {
                "0_B810": "拟似人格停止，",
                "0_B811": "魔力收集率突破规定值。",
                "0_B812": "复合礼装·理法活性复刻（Logos React Replica）功能解放。",
                "0_B813": "圣剑，拔刀！",
                "0_B814": "誓约胜利之剑·罗格斯！"
            },
            "raw_text": {
                "0_B810": "擬似人格停止、魔力の収集率、規定値を突破。複合霊装、ロゴスリアクトレプリカの機能を解放。聖剣バットエクスカリバー、ロゴス！",
                "0_B811": "",
                "0_B812": "",
                "0_B813": "",
                "0_B814": ""
            }
        },
        "0_B840": {
            "name": "エクストラアタック 3",
            "text": {
                "0_B840": "一口气解决！好嘞！",
                "0_B841": ""
            },
            "raw_text": {
                "0_B840": "一気にやるぞーおっしゃあ。",
                "0_B841": ""
            }
        },
        "0_B910": {
            "name": "アタック 7",
            "text": {
                "0_B910": "我要把你斩成两半！来大干一场吧！"
            },
            "raw_text": {
                "0_B910": "ぶった切ってやるぞー いっちょやるかー。"
            }
        },
        "0_B920": {
            "name": "アタック 8",
            "text": {
                "0_B920": "来个大的！"
            },
            "raw_text": {
                "0_B920": "でっかいやつで。"
            }
        },
        "0_B930": {
            "name": "アタック 9",
            "text": {
                "0_B930": "要轰地来一下喽！就是这家伙吧！"
            },
            "raw_text": {
                "0_B930": "ドカンってやるぞ！こいつだな！"
            }
        },
        "0_G010": {
            "name": "レベルアップ 1",
            "text": {
                "0_G010": "嗯，等级提升！魔力在源源不断地涌上来哦！",
                "0_G011": ""
            },
            "raw_text": {
                "0_G010": "うん、レベルアップ！魔力がぐんぐん湧いてくるよ！",
                "0_G011": ""
            }
        },
        "0_G020": {
            "name": "霊基再臨 2",
            "text": {
                "0_G020": "第二次灵基再临。虽然没有换衣服，但我很喜欢像这样和御主聊天。以前总是莱妮丝帮我挑选新衣服的。好想再去伦敦吃点心啊。",
                "0_G021": "",
                "0_G022": "",
                "0_G023": ""
            },
            "raw_text": {
                "0_G020": "礼儀最林二回目。着替えはないけど、マスターとこうして話すのは好き。昔はいつもライネスが新しい服を見繕ってくれたんだ。またロンドンでお菓子食べたいな。",
                "0_G021": "",
                "0_G022": "",
                "0_G023": ""
            }
        },
        "0_G030": {
            "name": "霊基再臨 1",
            "text": {
                "0_G030": "「灵基再临。虽然你可能已经知道了，但这个灵基好像是不会换衣服的。稍微有点遗憾呢。」「要是换衣服的话，连我可能都会跟着变好几次，所以这样反而更让人安心呢！」",
                "0_G031": "",
                "0_G032": "",
                "0_G033": ""
            },
            "raw_text": {
                "0_G030": "霊気再臨。知ってると思うけど、この霊気はお着替えしないんだって。ちょっとだけ残念。着替えがあったら俺まで何度も変わりそうだから、この方が安心だぜい。",
                "0_G031": "",
                "0_G032": "",
                "0_G033": ""
            }
        },
        "0_G040": {
            "name": "霊基再臨 3",
            "text": {
                "0_G040": "好，第三次灵基再临。感觉想要蹦蹦跳跳的。御主和大小姐在等级提升的时候，也会有这种感觉吗？",
                "0_G041": "",
                "0_G042": ""
            },
            "raw_text": {
                "0_G040": "はい、霊気再臨三回目。ぴょんぴょん飛び跳ねたい感じがする。マスター、やオルガちゃんもレベルが上がったらそんな感じがする？",
                "0_G041": "",
                "0_G042": ""
            }
        },
        "0_G050": {
            "name": "霊基再臨 4",
            "text": {
                "0_G050": "谢谢你。为我倾注了这么多。虽然不知道能一起度过多少时间，但无论是拙、弗拉特、莱妮丝还是奥尔加妹妹，到最后都会是御主的盟友。嘛，就是这么回事，请多指教啦。",
                "0_G051": "",
                "0_G052": ""
            },
            "raw_text": {
                "0_G050": "ありがとう。これだけ惜しみなく注いでくれて。一緒にいられる時間がどれくらいかわからないけれど、雪雪も紫苑もライネスもオルガちゃんも、最後までマスターの味方だからね。まあ、そういうわけだからよろしくな。",
                "0_G051": "",
                "0_G052": ""
            }
        },
        "0_G110": {
            "name": "レベルアップ 2",
            "text": {
                "0_G110": "感觉每次从御主那里得到种火，圣枪的光芒也会变强呢。"
            },
            "raw_text": {
                "0_G110": "マスターから種火をもらうたびに聖剣の光も強くなってる気がするんだ。"
            }
        },
        "0_G120": {
            "name": "レベルアップ 3",
            "text": {
                "0_G120": "「嗯，真美味！」「喂，亚德。不准抢先吃种火啦。」",
                "0_G121": ""
            },
            "raw_text": {
                "0_G120": "うん、デリシャス。こら、アット。先に種火を食べるなって。",
                "0_G121": ""
            }
        },
        "0_H010": {
            "name": "誕生日",
            "text": {
                "0_H010": "我听说了，今天是御主的生日。虽然师父可能会说一年的节点没有什么意义，但能为家人和朋友庆祝这件事本身就很令人高兴呢。祝你生日快乐。还有，真的很感谢你作为御主在迦勒底这么努力。",
                "0_H011": "",
                "0_H012": "",
                "0_H013": ""
            },
            "raw_text": {
                "0_H010": "聞いたよ、マスターの誕生日だって。師匠なら一年の区切りに意味なんかないって言いそうだけど、それでも家族や友達を祝えるってこと自体が嬉しいもんね。おめでとう。それに、カルデアでマスターを頑張ってくれて、本当にありがとう。",
                "0_H011": "",
                "0_H012": "",
                "0_H013": ""
            }
        },
        "0_H020": {
            "name": "イベント開催中",
            "text": {
                "0_H020": "哇，外面好像开始办什么活动了。太棒了，我们快去吧。一定要把师父也叫上哦。",
                "0_H021": "",
                "0_H022": ""
            },
            "raw_text": {
                "0_H020": "おお、なんか外で始まったみたい。最高、すぐ行こう。せつも絶対に呼んでね。",
                "0_H021": "",
                "0_H022": ""
            }
        },
        "0_H030": {
            "name": "会話 1",
            "text": {
                "0_H030": "身体都有些跃跃欲试了呢。呐，御主，差不多该去哪里出击了吧？",
                "0_H031": ""
            },
            "raw_text": {
                "0_H030": "体がうずうずしてきたなあ。ねえマスター、そろそろどこかに出撃しない？",
                "0_H031": ""
            }
        },
        "0_H040": {
            "name": "会話 2",
            "text": {
                "0_H040": "主从关系吗？嗯，当然御主是御主，师父是师父。两边的话我都会听的哦。",
                "0_H041": "",
                "0_H042": ""
            },
            "raw_text": {
                "0_H040": "主従か。うん、もちろんマスターはマスターだし、師匠は師匠だもんね。どっちも言うこと聞くよ。",
                "0_H041": "",
                "0_H042": ""
            }
        },
        "0_H050": {
            "name": "会話 3",
            "text": {
                "0_H050": "御主和我相处时，并不会太在意我是Saber还是Assassin的姿态呢。总觉得这种地方很有御主的资质呢。",
                "0_H051": ""
            },
            "raw_text": {
                "0_H050": "マスターはセイバーの説もアサシンの説もあまり関係なく付き合ってくれるよね。そういうのってなんだかマスターの資質って感じがするよ。",
                "0_H051": ""
            }
        },
        "0_H060": {
            "name": "好きなこと",
            "text": {
                "0_H060": "喜欢的东西吗？妈妈做的乳脂糖、和莱妮丝以及奥尔加妹妹一起的茶会，还有就是师父的雪茄香味吧。",
                "0_H061": "",
                "0_H062": ""
            },
            "raw_text": {
                "0_H060": "好きなもの、母さんの作ってくれたファッチに、ナイネスとオルガちゃんが一緒のお茶会、それに師匠の葉巻の香りかな。",
                "0_H061": "",
                "0_H062": ""
            }
        },
        "0_H070": {
            "name": "嫌いなこと",
            "text": {
                "0_H070": "其实我还是很不擅长应付幽灵之类的。明明很多地方都和以前不同了，这种地方却还是没变呢。",
                "0_H071": ""
            },
            "raw_text": {
                "0_H070": "実はまだ幽霊とか苦手なままなんだ。あれこれ前と違ってるのに、こういうのは変わらないんだね。",
                "0_H071": ""
            }
        },
        "0_H080": {
            "name": "聖杯について",
            "text": {
                "0_H080": "圣杯吗。那是在我的人生中多次出现的名词呢。师父和凛都多次提到过它。虽然我不觉得自己会想要它，但总觉得以后一定还会听到这个名字。我是这么想的。",
                "0_H081": "",
                "0_H082": "",
                "0_H083": ""
            },
            "raw_text": {
                "0_H080": "聖杯か。何度も雪の人生に出てくる名前だね。師匠もリンも何度も言ってたやつ。欲しいとは思えないけれど。きっとまたその名前を聞くことになるんだろうって。そう思ってる。",
                "0_H081": "",
                "0_H082": "",
                "0_H083": ""
            }
        },
        "0_H090": {
            "name": "絆Lv.1",
            "text": {
                "0_H090": "嘿嘿，虽然一直都在迦勒底，但这个姿态感觉很新鲜呢。请多指教，御主。请多指教啦。",
                "0_H091": "",
                "0_H092": ""
            },
            "raw_text": {
                "0_H090": "へへへ、ずっとカルデアにいるんだけど、この姿だと新鮮な感じがするね。よろしく、マスター。よろしくな。",
                "0_H091": "",
                "0_H092": ""
            }
        },
        "0_H170": {
            "name": "会話 4",
            "text": {
                "0_H170": "师父有些过劳了，请在那边喝杯特里姆玛乌泡的茶，好好休息一下吧。……比平时态度更强硬？我从以前开始就一直这么想了。",
                "0_H171": "",
                "0_H172": ""
            },
            "raw_text": {
                "0_H170": "師匠はちょっと過労気味なのでそこでトリムバーのお茶でも飲んでゆっくりしていてください。いつもより押しが強い？前からずっとそう思ってたんです。",
                "0_H171": "",
                "0_H172": ""
            }
        },
        "0_H180": {
            "name": "会話 5",
            "text": {
                "0_H180": "莱妮丝她啊，无论我是平时的格蕾，还是Saber的格蕾，态度都完全没有变。能像这样在迦勒底也在一起，我真的很开心。……不过，当面说的话她肯定会害羞的，所以这话只对御主你说哦。",
                "0_H181": "",
                "0_H182": ""
            },
            "raw_text": {
                "0_H180": "ないですわ。セツがいつものセツでも、セイバーのセツでも、全然変わらないんだ。カルデアでも一緒にいられて本当に嬉しい。って、目の前で言うと照れちゃうだろうから、これはマスターだけにね。",
                "0_H181": "",
                "0_H182": ""
            }
        },
        "0_H190": {
            "name": "会話 6",
            "text": {
                "0_H190": "虽然我知道她并不是露维亚小姐，但无论什么时候看，天秤的女神和那位大人都很帅气呢。如果我也能变成那样就好了，好想变成那样啊。",
                "0_H191": "",
                "0_H192": ""
            },
            "raw_text": {
                "0_H190": "ルビアさん、じゃないのは知ってるけれど、いつ見ても天秤の女神もあの人もかっこいいよね。あんな風になれたらなあ、なりたいなあ。",
                "0_H191": "",
                "0_H192": ""
            }
        },
        "0_H200": {
            "name": "会話 7",
            "text": {
                "0_H200": "赫费小姐，下次请再指导我训练吧。啊，如果可以的话，要是能把和师父吵架的次数减少个三成左右就太好了。",
                "0_H201": ""
            },
            "raw_text": {
                "0_H200": "陛下さん、また今度訓練つけてください。あ、できたら師匠との喧嘩は三割ぐらい減らしてもらえると。",
                "0_H201": ""
            }
        },
        "0_H210": {
            "name": "会話 8",
            "text": {
                "0_H210": "露维亚小姐来的时候真的吓了一跳呢。要是让领主那家伙看到，肯定会捧腹大笑的吧。",
                "0_H211": ""
            },
            "raw_text": {
                "0_H210": "デュフォーが来た時は本当にびっくりしたよね。ローロンの野郎が見たら腹が返って笑い出すぜ。",
                "0_H211": ""
            }
        },
        "0_H220": {
            "name": "会話 9",
            "text": {
                "0_H220": "书文先生，谢谢您借书给我。啊，作为回礼，希望我下次能和年轻时的您切磋一下？哈哈，这可是我求之不得的呢。",
                "0_H221": "",
                "0_H222": ""
            },
            "raw_text": {
                "0_H220": "二人前よっさん、本を貸してくれてありがとうございました。お、お礼に今度若い自分と手合わせしてほしい？ははは、そんなのこっちから申し込みたいぐらいです。",
                "0_H221": "",
                "0_H222": ""
            }
        },
        "0_H230": {
            "name": "会話 10",
            "text": {
                "0_H230": "美杜莎小姐有时会露出寂寞的表情呢。虽然这也是无可奈何的事，但至少在那种时候，我想陪在她身边。御主觉得这样会打扰到她吗？",
                "0_H231": "",
                "0_H232": ""
            },
            "raw_text": {
                "0_H230": "デメテルさん、時々寂しそうな顔をするよね。仕方ないことだけれど、そんな時ぐらい一緒にいてあげたいな。マスターは迷惑にならないと思う？",
                "0_H231": "",
                "0_H232": ""
            }
        },
        "0_H240": {
            "name": "会話 11",
            "text": {
                "0_H240": "我之前说过，我的身体是模仿阿尔托莉雅小姐的吧。嗯，虽然我已经想通了，但像这样实际见到她，还是会忍不住回想起来呢。",
                "0_H241": ""
            },
            "raw_text": {
                "0_H240": "雪の体がアルトリアさんを模したものだってのは前に話したよね。うん、それはもう整理できてるんだけれど、こうして実際に会うとちょっと思い出しちゃうかな。",
                "0_H241": ""
            }
        },
        "0_H250": {
            "name": "会話 12",
            "text": {
                "0_H250": "虽然有必须对师父说的话，但却一直没能说出口。他会不会担心自己死后孩子的事情呢……",
                "0_H251": "",
                "0_H252": ""
            },
            "raw_text": {
                "0_H250": "制服を言わなきゃいけないことがあるんだけれど、ずっと言えないままなんだ。自分が死んだ後の子供のこととか気になったりするのかな。",
                "0_H251": "",
                "0_H252": ""
            }
        },
        "0_H260": {
            "name": "会話 13",
            "text": {
                "0_H260": "简直像到令人吃惊，或者该说根本就是本人。伊什塔尔和凛。唔，以前是不是发生过什么事呢，又好像没有。",
                "0_H261": "",
                "0_H262": ""
            },
            "raw_text": {
                "0_H260": "びっくりするぐらいリンそっくりというかそのもの。イシュタルとリン。うーん、昔何かあったような、なかったような。",
                "0_H261": "",
                "0_H262": ""
            }
        },
        "0_H270": {
            "name": "会話 14",
            "text": {
                "0_H270": "阿斯克勒庇俄斯总是看起来很忙呢。工作完美无缺，也不失幽默感，如果有小孩子在哭，还会用杂耍之类的方法迅速安抚。不过，稍微放松一下紧绷的神经也挺好的吧。",
                "0_H271": "",
                "0_H272": ""
            },
            "raw_text": {
                "0_H270": "アスカラポスはいっつも忙しそうだよね。仕事は完璧、ユーモアは忘れず、子供が泣いてたらジャグリングなんかでさっとあやす。だけどもうちょっと肩の力を抜いてもいいんじゃないかな。",
                "0_H271": "",
                "0_H272": ""
            }
        },
        "0_H280": {
            "name": "会話 15",
            "text": {
                "0_H280": "虽然感觉有点不可思议，但如果是奥尔加玛丽的话，当个迦勒底所长还是绰绰有余的吧。毕竟她一直和莱妮丝针锋相对。我很清楚，她可不会输给一般的贵族。",
                "0_H281": "",
                "0_H282": ""
            },
            "raw_text": {
                "0_H280": "ちょっと不思議な気もするけれど、あれがマリーならカレデア社長ぐらいできるよね。ライネスとずっと張り合ってたんだもん。そこらの貴族なんかには負けないって、よく知ってるよ。",
                "0_H281": "",
                "0_H282": ""
            }
        },
        "0_H290": {
            "name": "会話 16",
            "text": {
                "0_H290": "每次和村正见面时，我都会不由自主地挺直腰板。虽然以前也见过那位先生的依代，但我觉得他是那种仅凭微小的接触就能彻底改变他人人生的人。那位君主也有这样的一面呢。",
                "0_H291": "",
                "0_H292": "",
                "0_H293": ""
            },
            "raw_text": {
                "0_H290": "村正はいつも会うときに背筋が伸びちゃうんだ。あの人の寄り白とも昔会ったことがあるんだけれど、ほんのわずかな触れ合いで人生を丸ごと変えてしまう。そういうタイプの人だと思う。あのロードもそういうとこあるけどね。",
                "0_H291": "",
                "0_H292": "",
                "0_H293": ""
            }
        },
        "0_H300": {
            "name": "会話 17",
            "text": {
                "0_H300": "亚瑟先生真的很厉害。能向那个人学习圣枪的使用方法，真是太好了。",
                "0_H301": ""
            },
            "raw_text": {
                "0_H300": "アーサーさんはすごいんだよ。あの人に整形の使い方を習えて本当に良かった。",
                "0_H301": ""
            }
        },
        "0_S020": {
            "name": "仮加入",
            "text": {
                "0_S020": "Saber，格蕾。重新向您问好。虽然一切都要从头开始，但只要有师父和御主在，我就放心了。",
                "0_S021": "",
                "0_S022": ""
            },
            "raw_text": {
                "0_S020": "セイバー、グレイ。改めてよろしく。一からやり直しになったけれど、師匠やマスターがいるなら安心だよね。",
                "0_S021": "",
                "0_S022": ""
            }
        }
    },
    "ChrVoice_ids": [
        "106700"
    ]
}