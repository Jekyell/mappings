{
    "id": 106600,
    "collectionNo": 466,
    "name": "ジャック・ド・モレー",
    "voices": {
        "0_B010": {
            "name": "アタック 1",
            "text": {
                "0_B010": "发生。"
            },
            "raw_text": {
                "0_B010": "発生。"
            }
        },
        "0_B020": {
            "name": "アタック 2",
            "text": {
                "0_B020": "展现我愤怒之时。"
            },
            "raw_text": {
                "0_B020": "我が怒りを示すとき。"
            }
        },
        "0_B030": {
            "name": "アタック 3",
            "text": {
                "0_B030": "嗯，嘿呀。"
            },
            "raw_text": {
                "0_B030": "うん、ゼア。"
            }
        },
        "0_B040": {
            "name": "エクストラアタック 1",
            "text": {
                "0_B040": "尝尝这个吧。"
            },
            "raw_text": {
                "0_B040": "食らうがいい。"
            }
        },
        "0_B050": {
            "name": "宝具 1",
            "text": {
                "0_B050": "作为骑士败北，作为修道士被破坏，作为总长被废除。",
                "0_B051": "在无所成就中化为怪人的我之遗恨，就在此昭雪吧。",
                "0_B052": "朝圣之剑，圣殿！"
            },
            "raw_text": {
                "0_B050": "騎士として敗北し、修道士として破壊し、総長として廃絶した。",
                "0_B051": "何も成せぬまま怪人に帰した我が無念今ここで晴らそう。",
                "0_B052": "ピレリナーズドテンプル。"
            }
        },
        "0_B080": {
            "name": "スキル 1",
            "text": {
                "0_B080": "这是必要经费。"
            },
            "raw_text": {
                "0_B080": "必要経費です。"
            }
        },
        "0_B090": {
            "name": "スキル 2",
            "text": {
                "0_B090": "主语是我的领域，所以……"
            },
            "raw_text": {
                "0_B090": "主語はわ私めの領分ですので。"
            }
        },
        "0_B100": {
            "name": "開始 1",
            "text": {
                "0_B100": "您生命的价值，究竟几何呢？"
            },
            "raw_text": {
                "0_B100": "いかほどでしょうあなたの命の価値は。"
            }
        },
        "0_B110": {
            "name": "開始 2",
            "text": {
                "0_B110": "神一直在注视着我们。"
            },
            "raw_text": {
                "0_B110": "神は常に我々を見ております。"
            }
        },
        "0_B120": {
            "name": "勝利 1",
            "text": {
                "0_B120": "这里的胜利，正是因为有神的加护。"
            },
            "raw_text": {
                "0_B120": "ここの勝利は神の加護があったからこそ。"
            }
        },
        "0_B130": {
            "name": "勝利 2",
            "text": {
                "0_B130": "神所带来的金钱力量果然伟大。"
            },
            "raw_text": {
                "0_B130": "やはり神にもたらされた金の力は偉大です。"
            }
        },
        "0_B140": {
            "name": "ダメージ 2",
            "text": {
                "0_B140": ""
            },
            "raw_text": {
                "0_B140": "ええっ。"
            }
        },
        "0_B150": {
            "name": "ダメージ 1",
            "text": {
                "0_B150": "还没完呢。"
            },
            "raw_text": {
                "0_B150": "まだです。"
            }
        },
        "0_B160": {
            "name": "戦闘不能 1",
            "text": {
                "0_B160": "什么都没能达成……"
            },
            "raw_text": {
                "0_B160": "何も成せなかった。"
            }
        },
        "0_B170": {
            "name": "戦闘不能 2",
            "text": {
                "0_B170": "御主，请您千万不要停下脚步。"
            },
            "raw_text": {
                "0_B170": "マスター、どうか立ち止まらぬよう。"
            }
        },
        "0_B180": {
            "name": "コマンドカード 1",
            "text": {
                "0_B180": "请、请交给我吧。"
            },
            "raw_text": {
                "0_B180": "お、お任せください。"
            }
        },
        "0_B190": {
            "name": "コマンドカード 2",
            "text": {
                "0_B190": "这是我们的工作。"
            },
            "raw_text": {
                "0_B190": "我らの仕事です。"
            }
        },
        "0_B200": {
            "name": "コマンドカード 3",
            "text": {
                "0_B200": ""
            },
            "raw_text": {
                "0_B200": "オーダー！"
            }
        },
        "0_B2010": {
            "name": "アタック 10",
            "text": {
                "0_B2010": "我的盾乃是主之盾。"
            },
            "raw_text": {
                "0_B2010": "我が盾は主ごの盾。"
            }
        },
        "0_B2020": {
            "name": "アタック 11",
            "text": {
                "0_B2020": ""
            },
            "raw_text": {
                "0_B2020": "だあああっ。"
            }
        },
        "0_B2030": {
            "name": "アタック 12",
            "text": {
                "0_B2030": "感情合不来。"
            },
            "raw_text": {
                "0_B2030": "感情が合いません。"
            }
        },
        "0_B210": {
            "name": "宝具カード 1",
            "text": {
                "0_B210": "让您看看我的生存方式吧。"
            },
            "raw_text": {
                "0_B210": "我が生き様お見せしましょう。"
            }
        },
        "0_B220": {
            "name": "宝具カード 2",
            "text": {
                "0_B220": "赌上我们圣殿骑士团的骄傲。"
            },
            "raw_text": {
                "0_B220": "我らテンプル騎士団の誇りにかけて。"
            }
        },
        "0_B230": {
            "name": "宝具カード 3",
            "text": {
                "0_B230": "准、准备就绪了。"
            },
            "raw_text": {
                "0_B230": "よ、用意が整いました。"
            }
        },
        "0_B2410": {
            "name": "アタック 13",
            "text": {
                "0_B2410": "呜哈呀。"
            },
            "raw_text": {
                "0_B2410": "うっはっじゃ。"
            }
        },
        "0_B2420": {
            "name": "アタック 14",
            "text": {
                "0_B2420": "您大意了呢。"
            },
            "raw_text": {
                "0_B2420": "油断されましたな。"
            }
        },
        "0_B2430": {
            "name": "アタック 15",
            "text": {
                "0_B2430": "吼吼吼，那么。"
            },
            "raw_text": {
                "0_B2430": "ほっほっほっ、じゃあ。"
            }
        },
        "0_B2440": {
            "name": "エクストラアタック 4",
            "text": {
                "0_B2440": "您、您能接下吗？"
            },
            "raw_text": {
                "0_B2440": "う受け止められますか。"
            }
        },
        "0_B250": {
            "name": "宝具カード 4",
            "text": {
                "0_B250": "愿我们获得祝福。"
            },
            "raw_text": {
                "0_B250": "我らに祝福あれ。"
            }
        },
        "0_B2810": {
            "name": "アタック 16",
            "text": {
                "0_B2810": "这正是拉普斯的心痛。"
            },
            "raw_text": {
                "0_B2810": "これこそルラプスの心の痛み。"
            }
        },
        "0_B410": {
            "name": "アタック 4",
            "text": {
                "0_B410": "我的剑乃是信念之剑。"
            },
            "raw_text": {
                "0_B410": "我が剣は信念の剣。"
            }
        },
        "0_B420": {
            "name": "アタック 5",
            "text": {
                "0_B420": ""
            },
            "raw_text": {
                "0_B420": "そりゃあ。"
            }
        },
        "0_B430": {
            "name": "アタック 6",
            "text": {
                "0_B430": "这就是被焚烧的痛苦。"
            },
            "raw_text": {
                "0_B430": "これが燃やされる苦しみ。"
            }
        },
        "0_B440": {
            "name": "エクストラアタック 2",
            "text": {
                "0_B440": "这是对所受屈辱的加倍奉还。"
            },
            "raw_text": {
                "0_B440": "受けし屈辱の倍返しです。"
            }
        },
        "0_B480": {
            "name": "スキル 3",
            "text": {
                "0_B480": "在此立誓。"
            },
            "raw_text": {
                "0_B480": "ここに誓いましょう。"
            }
        },
        "0_B490": {
            "name": "スキル 4",
            "text": {
                "0_B490": "这是神迹吗？"
            },
            "raw_text": {
                "0_B490": "神の御業か。"
            }
        },
        "0_B500": {
            "name": "開始 3",
            "text": {
                "0_B500": "宁死不屈。"
            },
            "raw_text": {
                "0_B500": "幸福よりは死を。"
            }
        },
        "0_B510": {
            "name": "開始 4",
            "text": {
                "0_B510": "就让您见识一下神明所赐予的财富之力吧。"
            },
            "raw_text": {
                "0_B510": "ご覧に入れましょう神より授かりし富の力を。"
            }
        },
        "0_B520": {
            "name": "勝利 3",
            "text": {
                "0_B520": "那么，这次的战果如何呢？"
            },
            "raw_text": {
                "0_B520": "さてこの度の戦果はいかほどでしょうか。"
            }
        },
        "0_B530": {
            "name": "勝利 4",
            "text": {
                "0_B530": "我莫莱对御主的指挥感到由衷的赞叹。"
            },
            "raw_text": {
                "0_B530": "このモレ、マスターの采配に感嘆いたしました。"
            }
        },
        "0_B540": {
            "name": "ダメージ 4",
            "text": {
                "0_B540": ""
            },
            "raw_text": {
                "0_B540": "ぎゃあっ。"
            }
        },
        "0_B550": {
            "name": "ダメージ 3",
            "text": {
                "0_B550": "不可能有什么幸福。"
            },
            "raw_text": {
                "0_B550": "幸福などありえない。"
            }
        },
        "0_B560": {
            "name": "戦闘不能 3",
            "text": {
                "0_B560": "这下可彻底焦了呢。"
            },
            "raw_text": {
                "0_B560": "これは焦げ付きましたな。"
            }
        },
        "0_B570": {
            "name": "戦闘不能 4",
            "text": {
                "0_B570": "单凭财富的力量，终究无济于事吗……"
            },
            "raw_text": {
                "0_B570": "富の力だけではどうにもならぬ。"
            }
        },
        "0_B800": {
            "name": "宝具 2",
            "text": {
                "0_B800": "白色的街灯化为烟雾，红色的十字化为火焰，闪耀的宝剑化为朽铁，",
                "0_B801": "被夺去一切之人的执念，在此显现吧！",
                "0_B802": "朝圣之剑，圣殿！"
            },
            "raw_text": {
                "0_B800": "白き街頭は煙に、赤き十字は炎に、輝ける剣は朽ちた鉄に。",
                "0_B801": "全て奪われし者の執念ここに顕現せん。",
                "0_B802": "ピレリのアチドー天ぷり。"
            }
        },
        "0_B840": {
            "name": "エクストラアタック 3",
            "text": {
                "0_B840": "希望能有所产出。"
            },
            "raw_text": {
                "0_B840": "生産を願います。"
            }
        },
        "0_B880": {
            "name": "スキル 5",
            "text": {
                "0_B880": "神与我们同在。"
            },
            "raw_text": {
                "0_B880": "神は我らに味方しています。"
            }
        },
        "0_B890": {
            "name": "スキル 6",
            "text": {
                "0_B890": "羊很可爱对吧。"
            },
            "raw_text": {
                "0_B890": "羊可愛いですよね。"
            }
        },
        "0_B910": {
            "name": "アタック 7",
            "text": {
                "0_B910": "请撑住。"
            },
            "raw_text": {
                "0_B910": "耐えてください。"
            }
        },
        "0_B920": {
            "name": "アタック 8",
            "text": {
                "0_B920": "这是对迫害的愤怒。"
            },
            "raw_text": {
                "0_B920": "これは迫害への憤り。"
            }
        },
        "0_B930": {
            "name": "アタック 9",
            "text": {
                "0_B930": "嘿哈。"
            },
            "raw_text": {
                "0_B930": "ヒッハッ。"
            }
        },
        "0_G010": {
            "name": "レベルアップ 1",
            "text": {
                "0_G010": "利滚利，我的剑将不断积累胜利。"
            },
            "raw_text": {
                "0_G010": "利子がまた利子を呼び、我が剣は勝利を蓄える。"
            }
        },
        "0_G040": {
            "name": "霊基再臨 1",
            "text": {
                "0_G040": "我的十字之盾乃是信仰之盾。我的誓言绝不会破灭。这坚固的岩盘是绝对不会开裂的……不过，嗯嗯，防、防范于未然还是有必要的吧。",
                "0_G041": "",
                "0_G042": ""
            },
            "raw_text": {
                "0_G040": "我が十字の盾は信仰の盾。断じて破れぬ我が誓い。この強固なる岩盤が割れることなど決して……まあ、うんうん、そ、備えはされるべきでしょう。",
                "0_G041": "",
                "0_G042": ""
            }
        },
        "0_G050": {
            "name": "霊基再臨 2",
            "text": {
                "0_G050": "与御主一同走过、同甘共苦的这段朝圣之旅，我、我胸中的金库实在有些装不下了。这份满溢的感激之情，就用我的一生来回报您吧。",
                "0_G051": "",
                "0_G052": ""
            },
            "raw_text": {
                "0_G050": "マスターと共に歩み、泣き笑ったこの巡礼の旅路は、わ、私の胸の金庫にはいささか収まりかねる。溢れし感謝を、我が生涯をもってお返ししましょう。",
                "0_G051": "",
                "0_G052": ""
            }
        },
        "0_G110": {
            "name": "レベルアップ 2",
            "text": {
                "0_G110": "御、御主总是能打破我的预算估算呢。"
            },
            "raw_text": {
                "0_G110": "まマスターは私めの見積もりをいつも狂わせるお方だ。"
            }
        },
        "0_G120": {
            "name": "レベルアップ 3",
            "text": {
                "0_G120": "强化我这个莫莱，您到底是抱着怎样的想法呢？",
                "0_G121": ""
            },
            "raw_text": {
                "0_G120": "このモレメを強化されるとえ一体どのようなお考えで。",
                "0_G121": ""
            }
        },
        "0_H010": {
            "name": "誕生日",
            "text": {
                "0_H010": "祝您生日快乐，御主。一年的朝圣之旅，您又踏破了一程。能够守护您的这段旅途，是我作为骑士最大的骄傲。来吧，踏上下一段朝圣之路，我莫莱将全身心地伴您同行。",
                "0_H011": "",
                "0_H012": "",
                "0_H013": "",
                "0_H014": ""
            },
            "raw_text": {
                "0_H010": "誕生日おめでとうございます、マスター。一年という巡礼の旅路を、また一つ踏破なされた。あなた様のその旅路を守れたことが、私めの騎士として最大の誇りです。さあ、次なる巡礼の道へ、このモレ、全身全霊をもってお供いたします。",
                "0_H011": "",
                "0_H012": "",
                "0_H013": "",
                "0_H014": ""
            }
        },
        "0_H020": {
            "name": "イベント開催中",
            "text": {
                "0_H020": "这是进攻的良机。来吧，让我们看清这场战斗的价值。",
                "0_H021": ""
            },
            "raw_text": {
                "0_H020": "攻める好機です。いざ、この戦いの価値、見定めましょう。",
                "0_H021": ""
            }
        },
        "0_H030": {
            "name": "会話 1",
            "text": {
                "0_H030": "朝圣之旅的准备已经就绪。"
            },
            "raw_text": {
                "0_H030": "巡礼の旅の用意は整っております。"
            }
        },
        "0_H040": {
            "name": "会話 2",
            "text": {
                "0_H040": "我莫莱虽自称圣殿骑士团总长，但如今只是侍奉御主的一骑从者。我的忠诚献给神与御主，根据其运用方式，我收获的惊奇可以化为百骑乃至千骑，驰骋于战场。请务必善加利用。",
                "0_H041": "",
                "0_H042": "",
                "0_H043": ""
            },
            "raw_text": {
                "0_H040": "このモレーは、テンプル騎士団総長を名乗れど、今はマスターに仕えし一騎のサーヴァント。我が忠誠はか神とマスターにあり、その運用いかんで、我が収穫の驚きは百機にも千機にもなり、戦場を駆け巡りましょう。どうかおお役立てください。",
                "0_H041": "",
                "0_H042": "",
                "0_H043": ""
            }
        },
        "0_H050": {
            "name": "会話 3",
            "text": {
                "0_H050": "我、我手中紧握的辉煌旗帜，绝不能落入敌手。御主，我说的就是您。",
                "0_H051": "",
                "0_H052": ""
            },
            "raw_text": {
                "0_H050": "わ我が手に握られた輝かしき登りを敵に渡すことはあってはならない。マスター、あなたのことです。",
                "0_H051": "",
                "0_H052": ""
            }
        },
        "0_H060": {
            "name": "好きなこと",
            "text": {
                "0_H060": "作为骑士侍奉在您的身旁，这本身就是奇迹，是神的恩宠。",
                "0_H061": "",
                "0_H062": ""
            },
            "raw_text": {
                "0_H060": "騎士としてあなたの傍らに立っているそれ自体が奇跡神の恩寵です。",
                "0_H061": "",
                "0_H062": ""
            }
        },
        "0_H070": {
            "name": "嫌いなこと",
            "text": {
                "0_H070": "宁死不屈。即便成为了从者，我的信念也不会改变。但是御主，您绝不能如此。",
                "0_H071": "",
                "0_H072": ""
            },
            "raw_text": {
                "0_H070": "幸福よりは死を。サーヴァントであれど、わが信念は変わりません。されどマスター、あなたはそうであってはならない。",
                "0_H071": "",
                "0_H072": ""
            }
        },
        "0_H080": {
            "name": "聖杯について",
            "text": {
                "0_H080": "我的愿望是复兴圣殿骑士团。这、这样一来，通往圣地的道路也会开启吧。",
                "0_H081": ""
            },
            "raw_text": {
                "0_H080": "我が望みはテンプル騎士団の再興。そ、さすれば聖地への道も開けましょう。",
                "0_H081": ""
            }
        },
        "0_H090": {
            "name": "絆Lv.1",
            "text": {
                "0_H090": "电信诈骗。那、那是什么？难道是某种异端的竞技？",
                "0_H091": "",
                "0_H092": ""
            },
            "raw_text": {
                "0_H090": "振り込めない詐欺。な、なんでしょうそれは。もしや異端の競技。",
                "0_H091": "",
                "0_H092": ""
            }
        },
        "0_H100": {
            "name": "絆Lv.2",
            "text": {
                "0_H100": "世上怎会有比生命更沉重的金钱。只要生命能化作无限的财富……我们圣殿骑士的誓言，便是守护朝圣者的光芒。话、话虽如此，借出去的东西还是得请您还回来的。",
                "0_H101": "",
                "0_H102": "",
                "0_H103": ""
            },
            "raw_text": {
                "0_H100": "命より重い金などあろうはずがない。命こそ無限なる富になれば。我らテンプル騎士の誓いこそ巡礼者を守る光。そ、それはそれとして貸したものはお返しいただきますが。",
                "0_H101": "",
                "0_H102": "",
                "0_H103": ""
            }
        },
        "0_H110": {
            "name": "絆Lv.3",
            "text": {
                "0_H110": "贫困者的谦逊，远胜于恶人夺取的财富。请您千万不要忘记这一点。",
                "0_H111": ""
            },
            "raw_text": {
                "0_H110": "ま貧しき者の慎ましさは悪しき者が奪う富にはるかに勝ります。それをどうかお忘れなきよう。",
                "0_H111": ""
            }
        },
        "0_H120": {
            "name": "絆Lv.4",
            "text": {
                "0_H120": "我会竭尽全力，守护御主的朝圣之旅。就让您见识一下吧——神明所托付的财富之力，金钱的力量。",
                "0_H121": "",
                "0_H122": "",
                "0_H123": ""
            },
            "raw_text": {
                "0_H120": "心の限り、マスターの巡礼の旅路をお守りする。ご覧に入れましょう。神より預かりし富の力、金の力を。",
                "0_H121": "",
                "0_H122": "",
                "0_H123": ""
            }
        },
        "0_H130": {
            "name": "絆Lv.5",
            "text": {
                "0_H130": "我对复仇之类的事情并没有兴趣。但、但是，累积的堕落，也就是拉普斯之火正在折磨着这具身体。如今作为从者立于世间，这股热量正是驱使我的动力。真是讽刺啊。",
                "0_H131": "",
                "0_H132": "",
                "0_H133": ""
            },
            "raw_text": {
                "0_H130": "復讐など興味はないのです。ざ、されど積み重ねられし堕落、ルラプスの炎がこの身を苛む。サーヴァントとして世に立つ今、この熱こそが私を駆り立てる。皮肉なものだ。",
                "0_H131": "",
                "0_H132": "",
                "0_H133": ""
            }
        },
        "0_H170": {
            "name": "会話 4",
            "text": {
                "0_H170": "狮子心王啊，投身于圣战的陛下，正是圣殿骑士应当侍奉的理想君主。信仰虔诚，勇猛而高洁。我、我所侍奉的国王，却充满了对黄金的渴望。他所追求的并非圣地，而是骑士团的金库。但、但是，现在我想要告诉您。陛下在阿卡流下的鲜血，在雅法挥舞的剑，绝没有白费。我们圣殿骑士直到最后，都坚守住了那份骄傲。",
                "0_H171": "",
                "0_H172": "",
                "0_H173": "",
                "0_H174": "",
                "0_H175": "",
                "0_H176": "",
                "0_H177": ""
            },
            "raw_text": {
                "0_H170": "獅子神王よ、聖戦に身を捧げられた陛下こそ、テンプル騎士の仕えるべき理想の君主でした。信仰厚く、勇猛にして高潔。わ、私の仕えた王は、黄金への渇望で満ちていた。求めたのは聖地ではなく、騎士団の金庫でした。さ、されど、今こそ申し上げたい。陛下がアッコンで流された血も、ヤッファで振るわれた剣も、決して無駄にはなっておりませぬ。我らテンプル騎士は最後まで、その誇りを守り通しました。",
                "0_H171": "",
                "0_H172": "",
                "0_H173": "",
                "0_H174": "",
                "0_H175": "",
                "0_H176": "",
                "0_H177": ""
            }
        },
        "0_H180": {
            "name": "会話 5",
            "text": {
                "0_H180": "哎呀，哥、哥伦布提督。您才是太阳的霸者。引导风暴与雷鸣，披着北上清风的天使。将神的旨意传播到新世界，乃至海洋尽头的彼方。这简直是足以与十字军匹敌的、灿烂的伟业，这样说也毫不夸张。请务必让我……敬爱的克里斯托瓦尔。不，克里斯。哪怕只在我的心里，可以这样称呼您吗？",
                "0_H181": "",
                "0_H182": "",
                "0_H183": "",
                "0_H184": "",
                "0_H185": "",
                "0_H186": "",
                "0_H187": ""
            },
            "raw_text": {
                "0_H180": "なんと、コ、コロンブス提督。あなたこそ太陽の覇者です。嵐と雷鳴の導きて、北上の清風をまといし天使。神の意向を新世界に、海はつるその彼方にまで知らしめた。それはまさに、十字軍にも匹敵する、燦然たる偉業と言っても過言ではありません。ぜひとも、敬愛なるクリストバル。いえ、クリス。我が心の内だけでも、そうお呼びしてもよ、よろしいでしょうか。",
                "0_H181": "",
                "0_H182": "",
                "0_H183": "",
                "0_H184": "",
                "0_H185": "",
                "0_H186": "",
                "0_H187": ""
            }
        },
        "0_H190": {
            "name": "会話 6",
            "text": {
                "0_H190": "呼。堕落的雅克·德·莫莱吗。属性为中立·恶的降临者。我、我绝不承认那家伙是我的半身。那是不同可能性的姿态。说什么无垢的英灵，简直是荒谬的诡辩。那确实是我自身的罪孽。因此绝不能移开视线。无论我的胃会因此绞痛到何种地步。唔、呜呜，也、也许撑不住。只、只能从能做到的地方开始重新管教了。",
                "0_H191": "",
                "0_H192": "",
                "0_H193": "",
                "0_H194": "",
                "0_H195": "",
                "0_H196": "",
                "0_H197": "",
                "0_H198": "",
                "0_H199": ""
            },
            "raw_text": {
                "0_H190": "ふう。堕落したジャック・ド・モレとはな。属性、中立悪のフォーリナー。あ、あの者が我が半身であるなどとは認めまい。異なる可能性の形。無垢の英霊だなどと、もってのほかの詭弁だ。あれは確かに我が罪そのもの。ゆえに決して目を背けてはならぬ。どれほどこの胃が締め付けられようとも。う、うう、む、無理かも。で、できるところから叩き直すしか。",
                "0_H191": "",
                "0_H192": "",
                "0_H193": "",
                "0_H194": "",
                "0_H195": "",
                "0_H196": "",
                "0_H197": "",
                "0_H198": "",
                "0_H199": ""
            }
        },
        "0_I1010": {
            "name": "CBC2026 マイ・カインド・オブ・アブダクション \n～ふたりのモレーと果てなき遺産～ 1",
            "text": {
                "0_I1010": "欢迎光临。欢迎来到白色情人节商店。",
                "0_I1011": ""
            },
            "raw_text": {
                "0_I1010": "よくぞ参られました。ホワイトデーショップへようようこそ。",
                "0_I1011": ""
            }
        },
        "0_I1020": {
            "name": "CBC2026 マイ・カインド・オブ・アブダクション \n～ふたりのモレーと果てなき遺産～ 2",
            "text": {
                "0_I1020": "欢、欢迎光临，客人。请随意放松。",
                "0_I1021": ""
            },
            "raw_text": {
                "0_I1020": "いっいらっしゃいませお客様。どうぞお寛ぎください。",
                "0_I1021": ""
            }
        },
        "0_I1030": {
            "name": "CBC2026 マイ・カインド・オブ・アブダクション \n～ふたりのモレーと果てなき遺産～ 3",
            "text": {
                "0_I1030": "您的好意我收下了。这会是一笔有价值的交易哦。愿神祝福您。",
                "0_I1031": "",
                "0_I1032": ""
            },
            "raw_text": {
                "0_I1030": "好感を受けたまわりました。これが価値ある取引となりますよ。あなたに神の祝福を。",
                "0_I1031": "",
                "0_I1032": ""
            }
        },
        "0_I1040": {
            "name": "CBC2026 マイ・カインド・オブ・アブダクション \n～ふたりのモレーと果てなき遺産～ 4",
            "text": {
                "0_I1040": "哎呀，已经快到闭店的时间了。您也要再次踏上旅程了呢。分、离别虽然令人寂寞，但出发也是一件值得高兴的事。我莫莱由衷祝愿您的旅途一路平安。",
                "0_I1041": "",
                "0_I1042": "",
                "0_I1043": ""
            },
            "raw_text": {
                "0_I1040": "なんと、もう閉店の時が間近に。あなたもまた旅立たれるのですね。わ別れは寂しきものですが、出発は喜ばしいことでもある。あなたの旅路の安全を、このモレ、心よりお祈りしております。",
                "0_I1041": "",
                "0_I1042": "",
                "0_I1043": ""
            }
        },
        "0_I1050": {
            "name": "CBC2026 マイ・カインド・オブ・アブダクション \n～ふたりのモレーと果てなき遺産～ 5",
            "text": {
                "0_I1050": "呼，不知何时，我才能称呼您为御、御主呢。如果有一天，伴随着命运的预感，我有幸获得守护您身体的荣光，那么作为剑与信仰的从者，作为十字的骑士，我一定会侍奉在您的身边。一定。",
                "0_I1051": "",
                "0_I1052": "",
                "0_I1053": ""
            },
            "raw_text": {
                "0_I1050": "ふう、いつしかあなたをマ、マスターとお呼びできる日がわ、私にも訪れるでしょうか。いつの日か運命の予感とともに、お、御身を守護する光栄にあずかれたのならば、剣と信仰のサーヴァントとして、十字の騎士として、あなた様のお側でお仕えいたしましょう。必ずや。",
                "0_I1051": "",
                "0_I1052": "",
                "0_I1053": ""
            }
        },
        "0_S010": {
            "name": "召喚",
            "text": {
                "0_S010": "剑士，雅克·德·莫莱，在此听候差遣。啊，您、您称呼我为莫莱即可。请多多关照。",
                "0_S011": "",
                "0_S012": "",
                "0_S013": "",
                "0_S014": ""
            },
            "raw_text": {
                "0_S010": "セイバー、ジャック・ド・モレ、ここにまかり越しました。ああ、わ、私めはモレとお呼び下されば。どうぞ、お見知りおきを。",
                "0_S011": "",
                "0_S012": "",
                "0_S013": "",
                "0_S014": ""
            }
        },
        "1_B010": {
            "name": "アタック 1",
            "text": {
                "1_B010": "嘿呀。"
            },
            "raw_text": {
                "1_B010": "へっせえ。"
            }
        },
        "1_B020": {
            "name": "アタック 2",
            "text": {
                "1_B020": "不错的健身房。"
            },
            "raw_text": {
                "1_B020": "良いジムです。"
            }
        },
        "1_B030": {
            "name": "アタック 3",
            "text": {
                "1_B030": "信仰，以及罪过。"
            },
            "raw_text": {
                "1_B030": "信仰そして罪過。"
            }
        },
        "1_B040": {
            "name": "エクストラアタック 1",
            "text": {
                "1_B040": "这就是信仰的力量。"
            },
            "raw_text": {
                "1_B040": "これが信仰の力です。"
            }
        },
        "1_B050": {
            "name": "宝具 1",
            "text": {
                "1_B050": "清贫被断定为贪婪，纯洁被断定为异端，服从被断定为反叛，",
                "1_B051": "因虚假的罪名而被焚烧的灵魂啊，现在化为真实之剑吧。",
                "1_B052": "朝圣之剑，圣殿！"
            },
            "raw_text": {
                "1_B050": "製品は貪欲と純潔は異端と従順は反逆と断じられた。",
                "1_B051": "偽りの罪に焼かれた魂よ今こそ真実の剣となれん！",
                "1_B052": "ピレリナージドテンプル。"
            }
        },
        "1_B080": {
            "name": "スキル 1",
            "text": {
                "1_B080": "神之眼不可欺瞒。"
            },
            "raw_text": {
                "1_B080": "神の御目は欺かぬ。"
            }
        },
        "1_B090": {
            "name": "スキル 2",
            "text": {
                "1_B090": "板刃非常锋利。"
            },
            "raw_text": {
                "1_B090": "エッジがさえ渡ります。"
            }
        },
        "1_B100": {
            "name": "開始 1",
            "text": {
                "1_B100": "让我见识一下御主的指挥吧。"
            },
            "raw_text": {
                "1_B100": "マスターのご采配拝見します。"
            }
        },
        "1_B110": {
            "name": "開始 2",
            "text": {
                "1_B110": "战斗的雪道在呼唤着我。"
            },
            "raw_text": {
                "1_B110": "戦いのゲレンデが呼んでいる。"
            }
        },
        "1_B120": {
            "name": "勝利 1",
            "text": {
                "1_B120": "很有意思的投资。"
            },
            "raw_text": {
                "1_B120": "興味深き投資でした。"
            }
        },
        "1_B130": {
            "name": "勝利 2",
            "text": {
                "1_B130": "要、要一起去享受滑雪后的娱乐吗？"
            },
            "raw_text": {
                "1_B130": "ごご一緒にアプレスキー などいかがでしょう。"
            }
        },
        "1_B140": {
            "name": "ダメージ 2",
            "text": {
                "1_B140": ""
            },
            "raw_text": {
                "1_B140": "うん。"
            }
        },
        "1_B150": {
            "name": "ダメージ 1",
            "text": {
                "1_B150": "还能继续滑。"
            },
            "raw_text": {
                "1_B150": "まだ滑れる。"
            }
        },
        "1_B160": {
            "name": "戦闘不能 1",
            "text": {
                "1_B160": "又没能达成……"
            },
            "raw_text": {
                "1_B160": "また成せなかった。"
            }
        },
        "1_B170": {
            "name": "戦闘不能 2",
            "text": {
                "1_B170": "御主，请您一定要……"
            },
            "raw_text": {
                "1_B170": "マスター、どうかあなたは。"
            }
        },
        "1_B180": {
            "name": "コマンドカード 1",
            "text": {
                "1_B180": "就、就那样。"
            },
            "raw_text": {
                "1_B180": "そそのように。"
            }
        },
        "1_B190": {
            "name": "コマンドカード 2",
            "text": {
                "1_B190": "打倒。"
            },
            "raw_text": {
                "1_B190": "ダーコウ。"
            }
        },
        "1_B200": {
            "name": "コマンドカード 3",
            "text": {
                "1_B200": "已经够了！"
            },
            "raw_text": {
                "1_B200": "もうだ！"
            }
        },
        "1_B2010": {
            "name": "アタック 10",
            "text": {
                "1_B2010": "空降。"
            },
            "raw_text": {
                "1_B2010": "ドロップ。"
            }
        },
        "1_B2020": {
            "name": "アタック 11",
            "text": {
                "1_B2020": "捏哈。"
            },
            "raw_text": {
                "1_B2020": "ねっはっ。"
            }
        },
        "1_B2030": {
            "name": "アタック 12",
            "text": {
                "1_B2030": "怎么会、臭呢。"
            },
            "raw_text": {
                "1_B2030": "くっせえ、ものか。"
            }
        },
        "1_B210": {
            "name": "宝具カード 1",
            "text": {
                "1_B210": "现在正是良机。"
            },
            "raw_text": {
                "1_B210": "今こそ好機。"
            }
        },
        "1_B220": {
            "name": "宝具カード 2",
            "text": {
                "1_B220": "您的小羊就在这里。"
            },
            "raw_text": {
                "1_B220": "あなたの小羊はここに。"
            }
        },
        "1_B230": {
            "name": "宝具カード 3",
            "text": {
                "1_B230": "赌上我们圣殿骑士团的滑行。"
            },
            "raw_text": {
                "1_B230": "我らテンプル騎士団の滑りに賭けて。"
            }
        },
        "1_B2410": {
            "name": "アタック 13",
            "text": {
                "1_B2410": "沙滩旋转！"
            },
            "raw_text": {
                "1_B2410": "ビーチェルスパン！"
            }
        },
        "1_B2420": {
            "name": "アタック 14",
            "text": {
                "1_B2420": "完美地决定了呢。"
            },
            "raw_text": {
                "1_B2420": "バチバチ決まりました。"
            }
        },
        "1_B2430": {
            "name": "アタック 15",
            "text": {
                "1_B2430": "我要把你变得毛茸茸的。"
            },
            "raw_text": {
                "1_B2430": "もっこもこにいたします。"
            }
        },
        "1_B2440": {
            "name": "エクストラアタック 4",
            "text": {
                "1_B2440": "小、小羊断钢剑。"
            },
            "raw_text": {
                "1_B2440": "ひ羊カリバーン。"
            }
        },
        "1_B250": {
            "name": "宝具カード 4",
            "text": {
                "1_B250": "这正是圣殿骑士的滑行姿态。"
            },
            "raw_text": {
                "1_B250": "これぞテンプル騎士のライディング。"
            }
        },
        "1_B2810": {
            "name": "アタック 16",
            "text": {
                "1_B2810": "这、您觉得如何？"
            },
            "raw_text": {
                "1_B2810": "い、いかがでしょう。"
            }
        },
        "1_B410": {
            "name": "アタック 4",
            "text": {
                "1_B410": "作为神与御主的骑士。"
            },
            "raw_text": {
                "1_B410": "神とマスターの騎士として。"
            }
        },
        "1_B420": {
            "name": "アタック 5",
            "text": {
                "1_B420": "我、我可不会让你为所欲为。"
            },
            "raw_text": {
                "1_B420": "す好きにはさせません。"
            }
        },
        "1_B430": {
            "name": "アタック 6",
            "text": {
                "1_B430": "见识一下羁绊的力量吧。"
            },
            "raw_text": {
                "1_B430": "見よ絆の力を。"
            }
        },
        "1_B440": {
            "name": "エクストラアタック 2",
            "text": {
                "1_B440": "借了的东西就要还回来。"
            },
            "raw_text": {
                "1_B440": "借りしものは返されよ。"
            }
        },
        "1_B480": {
            "name": "スキル 3",
            "text": {
                "1_B480": "今天也是毛茸茸的。"
            },
            "raw_text": {
                "1_B480": "今日もモコモコです。"
            }
        },
        "1_B490": {
            "name": "スキル 4",
            "text": {
                "1_B490": "咩咩咩咩咩。"
            },
            "raw_text": {
                "1_B490": "べべべべべ。"
            }
        },
        "1_B500": {
            "name": "開始 3",
            "text": {
                "1_B500": "那么，要开始滑行了吗？"
            },
            "raw_text": {
                "1_B500": "いざセッションと参りますか。"
            }
        },
        "1_B510": {
            "name": "開始 4",
            "text": {
                "1_B510": "纯白的毛毡，真是绝佳的软绵绵日和。"
            },
            "raw_text": {
                "1_B510": "真っ白なフェルト、見事なふわふわビヨリ。"
            }
        },
        "1_B520": {
            "name": "勝利 3",
            "text": {
                "1_B520": "太棒了，完美的着陆。"
            },
            "raw_text": {
                "1_B520": "すばらしい見事な着地です。"
            }
        },
        "1_B530": {
            "name": "勝利 4",
            "text": {
                "1_B530": "呼，请、请让我稍微平复一下胃部。"
            },
            "raw_text": {
                "1_B530": "ふう、ちょ少々胃を鎮めさせてください。"
            }
        },
        "1_B540": {
            "name": "ダメージ 4",
            "text": {
                "1_B540": ""
            },
            "raw_text": {
                "1_B540": "あい。"
            }
        },
        "1_B550": {
            "name": "ダメージ 3",
            "text": {
                "1_B550": "完全是卡刃摔倒了。"
            },
            "raw_text": {
                "1_B550": "完全に逆エッジでした。"
            }
        },
        "1_B560": {
            "name": "戦闘不能 3",
            "text": {
                "1_B560": "摔了个大跟头。"
            },
            "raw_text": {
                "1_B560": "鬼ごけをいたしました。"
            }
        },
        "1_B570": {
            "name": "戦闘不能 4",
            "text": {
                "1_B570": "太丢人了。如果有毛茸茸的话，我真想钻进去躲起来。"
            },
            "raw_text": {
                "1_B570": "恥ずかしい。もこもこがあればもう懲りたく存じます。"
            }
        },
        "1_B800": {
            "name": "宝具 2",
            "text": {
                "1_B800": "始于耶路撒冷，与耶路撒冷一同消逝的",
                "1_B801": "朝圣守护者的骄傲，永不腐朽，在此显现——",
                "1_B802": "朝圣之剑，圣殿！"
            },
            "raw_text": {
                "1_B800": "エルサレムより始まりエルサレムとともに散った。",
                "1_B801": "巡礼の守護者たる誇り朽ちることなく今ここに。",
                "1_B802": "ピレリの味とテンプル。"
            }
        },
        "1_B840": {
            "name": "エクストラアタック 3",
            "text": {
                "1_B840": "请被这毛茸茸包围吧。"
            },
            "raw_text": {
                "1_B840": "このもこもこに包まれるのです。"
            }
        },
        "1_B880": {
            "name": "スキル 5",
            "text": {
                "1_B880": "守护者的证明就在此处。"
            },
            "raw_text": {
                "1_B880": "守護者の証はここに。"
            }
        },
        "1_B890": {
            "name": "スキル 6",
            "text": {
                "1_B890": "此手之中存有信仰与团结。"
            },
            "raw_text": {
                "1_B890": "この手に信仰と結束あり。"
            }
        },
        "1_B910": {
            "name": "アタック 7",
            "text": {
                "1_B910": "这正是复利的奇迹。"
            },
            "raw_text": {
                "1_B910": "これぞ福利の奇跡。"
            }
        },
        "1_B920": {
            "name": "アタック 8",
            "text": {
                "1_B920": "粉雪滑行！"
            },
            "raw_text": {
                "1_B920": "パウダー ラン！"
            }
        },
        "1_B930": {
            "name": "アタック 9",
            "text": {
                "1_B930": "要上啦。"
            },
            "raw_text": {
                "1_B930": "いきます。"
            }
        },
        "1_G010": {
            "name": "レベルアップ 1",
            "text": {
                "1_G010": "饭桶。"
            },
            "raw_text": {
                "1_G010": "メッシ僕。"
            }
        },
        "1_G020": {
            "name": "霊基再臨 2",
            "text": {
                "1_G020": "宁死不屈，比起反叛的狼，我选择服从的羊。您所高举的真理，以及投入的资本，我一定会善加利用。是的，我一定会选择羊的。",
                "1_G021": "",
                "1_G022": ""
            },
            "raw_text": {
                "1_G020": "幸福よりは死を選び、反逆の狼よりは服従の羊を選びます。あなたが真を掲げ、投じられた資本、必ずや役立てましょう。ええ、必ずや羊を選びますとも。",
                "1_G021": "",
                "1_G022": ""
            }
        },
        "1_G030": {
            "name": "霊基再臨 1",
            "text": {
                "1_G030": "您觉得如何？无论是地中海的荒漠，还是粉雪的雪道，圣殿骑士都不会落后。作为守护御主的圣殿骑士，就用板刃切裂敌人吧。滑雪板的设计吗？这是以存折为原型设计的，应该也能为我们的银行做宣传。诶？",
                "1_G031": "",
                "1_G032": "",
                "1_G033": "",
                "1_G034": ""
            },
            "raw_text": {
                "1_G030": "いかがでしょう。たとえ地中海の砂漠でも、パウダースノーのゲレンデであっても、テンプル騎士は遅れを取りません。マスターの守護者たるテンプル騎士として、敵にエッジを切りつけましょう。ボードのデザインですか？これは預金通帳をイメージしており、我が銀行の宣伝にもなろうかと。え？",
                "1_G031": "",
                "1_G032": "",
                "1_G033": "",
                "1_G034": ""
            }
        },
        "1_G110": {
            "name": "レベルアップ 2",
            "text": {
                "1_G110": "一片雪花堆积，终成削平山峦的冰之海。"
            },
            "raw_text": {
                "1_G110": "ひとひらの雪ぞ積りて山を削る氷の海をなす。"
            }
        },
        "1_G120": {
            "name": "レベルアップ 3",
            "text": {
                "1_G120": "一数就是一数。"
            },
            "raw_text": {
                "1_G120": "一数は一数です。"
            }
        },
        "1_H010": {
            "name": "誕生日",
            "text": {
                "1_H010": "由衷祝您生日快乐，御主。祝福您向着更遥远的未来，向着纯白无瑕的雪道滑行出发。会描绘出怎样的轨迹，全凭御主您自己决定。我、我会牢牢扶住您不让您摔倒的。啊，不，哪怕摔倒了，那也是您的风格。让我们毫不畏惧地前进吧。",
                "1_H011": "",
                "1_H012": "",
                "1_H013": "",
                "1_H014": "",
                "1_H015": "",
                "1_H016": ""
            },
            "raw_text": {
                "1_H010": "お誕生日、心よりお祝い申し上げます、マスター。さらなる未来へと、真白き無垢なゲレンデへと滑り出すあなたを祝福いたします。どのような軌跡を描くかは、マスター、あなた次第です。わ、私が転ばぬようしっかりと支えますので。あ、いえ、たとえ転んだとしても、それがあなたのスタイルだ。恐れずに参りましょう。",
                "1_H011": "",
                "1_H012": "",
                "1_H013": "",
                "1_H014": "",
                "1_H015": "",
                "1_H016": ""
            }
        },
        "1_H020": {
            "name": "イベント開催中",
            "text": {
                "1_H020": "这、这是绝佳的滑雪天气，御主。"
            },
            "raw_text": {
                "1_H020": "ぜ絶好の滑走日和ですマスター。"
            }
        },
        "1_H030": {
            "name": "会話 1",
            "text": {
                "1_H030": "一路顺风，祝您旅途愉快，御主。",
                "1_H031": ""
            },
            "raw_text": {
                "1_H030": "ボンボヤージュ、良き旅路を、マスター。",
                "1_H031": ""
            }
        },
        "1_H040": {
            "name": "会話 2",
            "text": {
                "1_H040": "您知道“连带保证人”这种诅咒吗？"
            },
            "raw_text": {
                "1_H040": "連帯保証人という呪いをご存じでしょうか。"
            }
        },
        "1_H050": {
            "name": "会話 3",
            "text": {
                "1_H050": "您喜欢羊吗？其、其实我也很喜欢。",
                "1_H051": ""
            },
            "raw_text": {
                "1_H050": "羊お好きですか？じ実は私めも。",
                "1_H051": ""
            }
        },
        "1_H060": {
            "name": "好きなこと",
            "text": {
                "1_H060": "我、我并非喜欢金钱本身，而是喜欢通过金钱获得的信赖，以及能够让世界变得更好的那份力量。",
                "1_H061": "",
                "1_H062": ""
            },
            "raw_text": {
                "1_H060": "わ私はお金自体が好きなのではなくお金で得られる信頼をそして世界をより良く変えられるその強さを好んでいるのです。",
                "1_H061": "",
                "1_H062": ""
            }
        },
        "1_H070": {
            "name": "嫌いなこと",
            "text": {
                "1_H070": "果然只有谎言和携款潜逃是无法原谅的。"
            },
            "raw_text": {
                "1_H070": "やはり嘘と仮逃げだけは許しがたい。"
            }
        },
        "1_H080": {
            "name": "聖杯について",
            "text": {
                "1_H080": "只有羊的亲、亲密动物园……不，那不就只是个牧场吗？",
                "1_H081": ""
            },
            "raw_text": {
                "1_H080": "羊だけのふ触れ合い動物園いやそれはただの牧場では。",
                "1_H081": ""
            }
        },
        "1_H10090": {
            "name": "絆Lv.1",
            "text": {
                "1_H10090": "财富的力量是惊人的。简直就像在雪山上滚动的雪球一样。我觉得御主也不要只顾着消费，而是把力量倾注在能增加财产的“食材”上比较好。",
                "1_H10091": "",
                "1_H10092": ""
            },
            "raw_text": {
                "1_H10090": "富の力は凄まじいものです。まさに雪山を転がる雪玉のごとく。マスターも消費ではなく、財を増やす食材に力を注ぐとよろしいかと。",
                "1_H10091": "",
                "1_H10092": ""
            }
        },
        "1_H10100": {
            "name": "絆Lv.2",
            "text": {
                "1_H10100": "浪、浪费虽是恶德，但赎罪并不算罪过，也就是说全凭持有者而定。",
                "1_H10101": ""
            },
            "raw_text": {
                "1_H10100": "ろ浪費は悪徳なれど贖罪は罪には当たらずすなわち持ち主次第です。",
                "1_H10101": ""
            }
        },
        "1_H10110": {
            "name": "絆Lv.3",
            "text": {
                "1_H10110": "众筹。真是具有划时代意义。从多数人那里每人募集少许资金，以成就大志。这正是骑士团存款业务的原理。嗯？没有还款义务？那、那样的话别说利息了，连、连本金也……这、这到底是什么契约？订阅服务？",
                "1_H10111": "",
                "1_H10112": "",
                "1_H10113": "",
                "1_H10114": "",
                "1_H10115": "",
                "1_H10116": "",
                "1_H10117": ""
            },
            "raw_text": {
                "1_H10110": "クラウドファンディング。なんと画期的な。多くの者から少額ずつ集め、大志を成す。まさに騎士団の預金業務の原理。ん？返済義務がない？そ、それでは利子どころか、が、元本も。い、一体どういう契約なのです？サブスク？",
                "1_H10111": "",
                "1_H10112": "",
                "1_H10113": "",
                "1_H10114": "",
                "1_H10115": "",
                "1_H10116": "",
                "1_H10117": ""
            }
        },
        "1_H10120": {
            "name": "絆Lv.4",
            "text": {
                "1_H10120": "我的故乡莫莱并不是个积雪深厚的地方。即便如此，一旦积雪，我还是会像小孩子一样兴奋不已。在柔软的新雪上，没错，就像小、小羊一样蹦蹦跳跳呢。",
                "1_H10121": "",
                "1_H10122": ""
            },
            "raw_text": {
                "1_H10120": "我が故郷モレアは雪深い土地ではなかった。それでも雪が積もれば子供心に胸が躍りました。柔らかな新雪の上で、そう、こ小羊のように跳ね飛んでみたものです。",
                "1_H10121": "",
                "1_H10122": ""
            }
        },
        "1_H10130": {
            "name": "絆Lv.5",
            "text": {
                "1_H10130": "羊，很可爱对吧。请听我说，御主。那个生物真的是百分之百纯正的羊。啊，这是何等的奇迹。",
                "1_H10131": "",
                "1_H10132": "",
                "1_H10133": ""
            },
            "raw_text": {
                "1_H10130": "羊、かわいいですよね。お聞きください、マスター。あの生き物は実に百パーセント混じりけのない羊なのです。ああ、なんたる奇跡。",
                "1_H10131": "",
                "1_H10132": "",
                "1_H10133": ""
            }
        },
        "1_H200": {
            "name": "会話 4",
            "text": {
                "1_H200": "哦，这、这滑雪技术相当了得。看来您在迦勒底也是数一数二的滑雪好手。要一起去滑一趟吗？",
                "1_H201": "",
                "1_H202": "",
                "1_H203": ""
            },
            "raw_text": {
                "1_H200": "おお、ここれはなかなかの滑りっぷり。カルデアでも名手の滑り手とお見受けいたしました。ご一緒に一滑りいかがですか。",
                "1_H201": "",
                "1_H202": "",
                "1_H203": ""
            }
        },
        "1_H210": {
            "name": "会話 5",
            "text": {
                "1_H210": "杜姆兹。这、这正是我梦寐以求的神之羊。简、简直就像活生生的细雪一般，毛发极其美丽。而且不知为何，这股让人肚子饿的、充满包容力的声音，仿佛能温、温柔地包容我疲惫不堪的胃袋。",
                "1_H211": "",
                "1_H212": "",
                "1_H213": "",
                "1_H214": "",
                "1_H215": ""
            },
            "raw_text": {
                "1_H210": "ドゥムジ。こ、これはまさしく私の夢見た神の羊。ま、まるで生ける綿雪のごとき見事な毛並みです。しかもなぜでしょうか、この無性にお腹の減る包容力のあるお声は、疲れ切った私の意をや、優しく包み込んでくださるかのようだ。",
                "1_H211": "",
                "1_H212": "",
                "1_H213": "",
                "1_H214": "",
                "1_H215": ""
            }
        },
        "1_H220": {
            "name": "会話 6",
            "text": {
                "1_H220": "与无垢少年一同嬉戏的可爱小羊。这是何等充满平稳与满足的景象。我本是带着微笑这样看着的，但难道这其实是邪教，是迷惑少年的魔物吗？去、去吧！离他远点！快点离开！你这恶魔！",
                "1_H221": "",
                "1_H222": "",
                "1_H223": "",
                "1_H224": "",
                "1_H225": ""
            },
            "raw_text": {
                "1_H220": "無垢なる少年と共に戯れるあ愛らしき子羊。なんと平穏に満ち足りた光景。と微笑ましく眺めていたのですが、これはもしや邪教、少年を惑わす魔物。さ、去れ！離れよ！立ち去れがいい！悪魔め！",
                "1_H221": "",
                "1_H222": "",
                "1_H223": "",
                "1_H224": "",
                "1_H225": ""
            }
        },
        "1_H230": {
            "name": "会話 7",
            "text": {
                "1_H230": "科尔基斯的金羊毛。我并不是被“黄金”这个部分所吸引，但既然说是云之女神派遣来的，想必其毛发一定非同寻常。我本想去向相关人士询问实际情况，结果美狄亚殿下一句“去问那个男人伊阿宋”就把我打发了，而那位英雄伊阿宋殿下则是一直滔滔不绝地炫耀他心爱的船和阿尔戈英雄同伴们的事，真、真是累死我了。",
                "1_H231": "",
                "1_H232": "",
                "1_H233": "",
                "1_H234": "",
                "1_H235": "",
                "1_H236": ""
            },
            "raw_text": {
                "1_H230": "コルキスの黄金の羊。黄金という部分に惹かれたわけではありませんが、雲の女神が遣わしたというからには、その毛並たるやさぞかしと。その実際を関係各位に尋ねに参ったのですが、メディア殿にはあの男イアソンに聞きなさいと一蹴されてしまい、その英雄イアソン殿からはひたすらに延々と愛すべき船とアルゴナウタイの仲間の自慢話を語り尽くされ、つ疲れました。",
                "1_H231": "",
                "1_H232": "",
                "1_H233": "",
                "1_H234": "",
                "1_H235": "",
                "1_H236": ""
            }
        }
    },
    "ChrVoice_ids": [
        "106600"
    ]
}